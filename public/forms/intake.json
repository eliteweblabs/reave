{
  "title": "Client Intake Form",
  "description": "Example of a complex multi-field form - perfect for PDF conversions",
  "fields": [
    {
      "tag": "input",
      "type": "text",
      "name": "fullName",
      "required": true,
      "cf-questions": "Welcome! Let's get started with your intake form.&&What's your full name?"
    },
    {
      "tag": "input",
      "type": "email",
      "name": "email",
      "required": true,
      "cf-questions": "What's your email address?"
    },
    {
      "tag": "input",
      "type": "tel",
      "name": "phone",
      "required": true,
      "cf-questions": "And your phone number?"
    },
    {
      "tag": "input",
      "type": "text",
      "name": "company",
      "required": false,
      "cf-questions": "What company are you with? (optional)"
    },
    {
      "tag": "select",
      "name": "industry",
      "required": true,
      "cf-questions": "What industry are you in?",
      "options": [
        { "value": "tech", "label": "Technology" },
        { "value": "finance", "label": "Finance" },
        { "value": "healthcare", "label": "Healthcare" },
        { "value": "retail", "label": "Retail" },
        { "value": "other", "label": "Other" }
      ]
    },
    {
      "tag": "select",
      "name": "budget",
      "required": true,
      "cf-questions": "What's your estimated budget range?",
      "options": [
        { "value": "under5k", "label": "Under $5,000" },
        { "value": "5k-10k", "label": "$5,000 - $10,000" },
        { "value": "10k-25k", "label": "$10,000 - $25,000" },
        { "value": "25k-50k", "label": "$25,000 - $50,000" },
        { "value": "over50k", "label": "Over $50,000" }
      ]
    },
    {
      "tag": "select",
      "name": "timeline",
      "required": true,
      "cf-questions": "What's your desired timeline?",
      "options": [
        { "value": "asap", "label": "ASAP (< 1 month)" },
        { "value": "1-3months", "label": "1-3 months" },
        { "value": "3-6months", "label": "3-6 months" },
        { "value": "6plus", "label": "6+ months" },
        { "value": "flexible", "label": "Flexible" }
      ]
    },
    {
      "tag": "textarea",
      "name": "projectDescription",
      "required": true,
      "cf-questions": "Please describe your project in a few sentences."
    },
    {
      "tag": "textarea",
      "name": "goals",
      "required": true,
      "cf-questions": "What are your main goals for this project?"
    },
    {
      "tag": "select",
      "name": "referral",
      "required": false,
      "cf-questions": "How did you hear about us?",
      "options": [
        { "value": "google", "label": "Google Search" },
        { "value": "referral", "label": "Referral" },
        { "value": "social", "label": "Social Media" },
        { "value": "event", "label": "Event/Conference" },
        { "value": "other", "label": "Other" }
      ]
    }
  ],
  "submitEndpoint": "/api/forms/submit",
  "onComplete": {
    "message": "Thank you! We've received your intake form and will be in touch within 24 hours.",
    "redirect": null
  }
}
