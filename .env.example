# Telegram (optional) — Business OS rudimentary webhook
# Webhook URL: https://<your-host>/api/telegram/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Your numeric Telegram user id(s), comma-separated. Required in production.
TELEGRAM_ALLOWED_USER_IDS=

# Optional — freeform messages use Anthropic (Claude) tool calls into bundled knowledge.
# Also required for natural-language invoicing ("invoice Tony Vello for $100").
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Crater billing — custom API (eliteweblabs/crater-invoicing → routes/api-custom.php)
# Base URL is the Crater host. On Railway prefer a reference: https://${{ crater.RAILWAY_PUBLIC_DOMAIN }}
CRATER_API_BASE_URL=
# Must equal Crater's OPENCLAW_API_TOKEN; sent as the X-OpenClaw-Token header.
CRATER_API_TOKEN=

# eliteweblabs/contact-api (Reave App on Railway: contact-api + contact-postgres)
# Local: paste https://… from `railway domain --service contact-api --json`
# Railway (Astro service): use a variable REFERENCE, not a literal:
#   CONTACT_API_BASE_URL=https://${{ contact-api.RAILWAY_PUBLIC_DOMAIN }}
CONTACT_API_BASE_URL=
# Prefer shared var reference on Railway, e.g. CONTACT_API_KEY=${{ shared.CONTACT_API_CLIENT_KEY }}
CONTACT_API_KEY=

# Public origin used to build shareable client-portal links (/c/<uid>).
# Optional: falls back to https://${RAILWAY_PUBLIC_DOMAIN} then https://reave.app.
PUBLIC_SITE_URL=https://reave.app

# Gate for the master-contacts dashboard at /dev/contacts (sensitive PII).
# Visit /dev/contacts?key=<this> once; if unset, the dashboard stays locked.
DASHBOARD_KEY=

# Railway — Telegram /railway project … (GraphQL). Token from https://railway.com/account/tokens
RAILWAY_API_TOKEN=
# Optional: Cmd+K in Railway dashboard → Copy Active Workspace ID (if API rejects name-only create)
RAILWAY_WORKSPACE_ID=
# Set to 1 to test Telegram flow without creating a project
RAILWAY_DRY_RUN=
# Optional description prefix on new projects
# RAILWAY_PROJECT_DESCRIPTION_PREFIX=Reave

# Railway → Telegram deploy alerts (project webhook). Long random string; use same value in ?key=
RAILWAY_WEBHOOK_INGRESS_KEY=

# GitHub dev/status tools — lets the assistant verify commits/pushes/branches without a human.
# PAT with read-only access (fine-grained: Contents + Metadata) for eliteweblabs/reave.
# Public repos work without a token but are rate-limited; a token is recommended.
GITHUB_TOKEN=
# Optional: override the repo the status tools inspect (default: eliteweblabs/reave)
# GITHUB_REPO=eliteweblabs/reave
# Optional: explicit URL for check_deployment_status health ping (default: RAILWAY_PUBLIC_DOMAIN, else reave.app)
# DEPLOY_HEALTH_URL=https://reave.app/
# Note: RAILWAY_GIT_COMMIT_SHA / RAILWAY_PUBLIC_DOMAIN are auto-injected by Railway at deploy time.
# Your Telegram chat id (often same numeric id as your user DM) to receive deploy failure pings
TELEGRAM_DEPLOY_NOTIFY_CHAT_ID=

# Inbound email triage (Resend webhook → /api/email/inbound). Replaces the old
# openclaw-email-tools IMAP monitor. See src/knowledge/email-rules.md.
RESEND_API_KEY=
# Webhook signing secret (whsec_…) returned when you create the Resend webhook
RESEND_WEBHOOK_SECRET=
# Outbound email sender for send_client_portal (must be a Resend-verified domain).
RESEND_FROM=Reave <noreply@reave.app>

# ─── Telnyx — SMS + voice (replaces Twilio) ─────────────────────────────────
# API key from https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=
# Your Telnyx phone number in E.164 format, e.g. +12125551234
TELNYX_FROM_NUMBER=
# Webhook public key for signature validation (optional but recommended):
#   Portal → Messaging Profile → edit → Webhook URL, copy the Public Key shown.
# Same key works for both SMS (/api/sms) and voice (/api/voice/webhook).
TELNYX_WEBHOOK_PUBLIC_KEY=

# ── Voice agent ──────────────────────────────────────────────────────────────
# Set to 1 to enable the AI phone agent on inbound calls (default: off).
# You can also toggle at runtime with /voice on|off in Telegram.
VOICE_AGENT_ENABLED=
# Phone number to transfer calls to when /takeover is used (E.164).
TELNYX_OPERATOR_NUMBER=
# Call Control Application ID from the Telnyx portal (needed for outbound calls).
TELNYX_APP_ID=
# TTS voice name. Defaults to Polly.Joanna. Options: Polly.Matthew, Polly.Amy, etc.
TELNYX_VOICE=Polly.Joanna
TELNYX_VOICE_LANGUAGE=en-US
# Opening line spoken to callers (optional).
# VOICE_GREETING=Hi, you've reached our AI assistant. How can I help you?
# Telegram chat id for inbound call alerts; falls back to SMS/email notify ids.
VOICE_NOTIFY_CHAT_ID=

# ── Inbound SMS ──────────────────────────────────────────────────────────────
# Comma-separated E.164 numbers allowed to message in. If empty, all pass.
SMS_ALLOWED_SENDERS=
# Set to 1 to have Claude auto-reply to inbound SMS (needs ANTHROPIC_API_KEY).
SMS_AI_REPLY_ENABLED=
# Telegram chat id for SMS alerts; falls back to TELEGRAM_DEPLOY_NOTIFY_CHAT_ID.
SMS_NOTIFY_CHAT_ID=

# ── Inbound email ────────────────────────────────────────────────────────────
# Chat id for email alerts; falls back to TELEGRAM_DEPLOY_NOTIFY_CHAT_ID if unset
EMAIL_NOTIFY_CHAT_ID=
# Optional sender allowlists (comma-separated). If both empty, all senders are processed.
EMAIL_ALLOWED_SENDERS=
EMAIL_ALLOWED_DOMAINS=
