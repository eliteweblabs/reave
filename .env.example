# Optional — freeform messages in /admin Chats use Anthropic (Claude) tool calls.
# Also required for natural-language invoicing ("invoice Tony Vello for $100").
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional — show prepaid API credit balance in /admin model switcher (account-level).
# Live: org id from console.anthropic.com/settings/organization + sessionKey cookie
# from DevTools → Network → request to …/prepaid/credits (expires; refresh when stale).
# ANTHROPIC_ORG_ID=
# ANTHROPIC_SESSION_KEY=
# Manual fallback only (no live fetch): ANTHROPIC_CREDIT_BALANCE_USD=12.53

# ── App Postgres (Railway) ────────────────────────────────────────────────────
# Persistent storage for dashboard chats, knowledge, jobs/work, email inbox log,
# and agent model preference. On Railway, reference the Postgres service:
#   DATABASE_URL=${{ reave-postgres.DATABASE_URL }}
# Tables are created automatically on first use. Without DATABASE_URL, those
# features fall back to bundled markdown or local JSON files (dev only).
DATABASE_URL=

# Crater billing — custom API (eliteweblabs/crater-invoicing → routes/api-custom.php)
# Base URL is the Crater host. On Railway prefer a reference: https://${{ crater.RAILWAY_PUBLIC_DOMAIN }}
CRATER_API_BASE_URL=
# Must equal Crater's CRATER_API_TOKEN; sent as the X-Crater-Api-Token header.
CRATER_API_TOKEN=

# eliteweblabs/materials-api (Reave App on Railway: materials-api service)
# Live retail pricing — Home Depot and future retailers. Bootstrap source: bootstrap/materials-api/
# Railway (Astro service): use a variable REFERENCE, not a literal:
#   MATERIALS_API_BASE_URL=https://${{ materials-api.RAILWAY_PUBLIC_DOMAIN }}
MATERIALS_API_BASE_URL=
# Prefer shared var reference on Railway, e.g. MATERIALS_API_KEY=${{ shared.MATERIALS_API_CLIENT_KEY }}
MATERIALS_API_KEY=

# eliteweblabs/fleet-api (Reave App on Railway: fleet-api service + Postgres)
# Multi-vehicle GPS tracking — drivers report location when signed into Reave App.
# Bootstrap source: bootstrap/fleet-api/
# Railway (Astro service): use a variable REFERENCE, not a literal:
#   FLEET_API_BASE_URL=https://${{ fleet-api.RAILWAY_PUBLIC_DOMAIN }}
FLEET_API_BASE_URL=
# Prefer shared var reference on Railway, e.g. FLEET_API_KEY=${{ shared.FLEET_API_CLIENT_KEY }}
FLEET_API_KEY=

# eliteweblabs/paulino-wizard (Paulino Auto Group Railway project — separate from Reave App)
# Dealership inventory sync, lead/deal wizard, test drives.
# Railway (Astro service): paste public URL or custom domain:
#   PAULINO_WIZARD_API_BASE_URL=https://paulino-wizard-production.up.railway.app
PAULINO_WIZARD_API_BASE_URL=
# Optional when admin/sync routes require auth
# PAULINO_WIZARD_API_KEY=

# eliteweblabs/contact-api (Reave App on Railway: contact-api + contact-postgres)
# Local: paste https://… from `railway domain --service contact-api --json`
# Railway (Astro service): use a variable REFERENCE, not a literal:
#   CONTACT_API_BASE_URL=https://${{ contact-api.RAILWAY_PUBLIC_DOMAIN }}
CONTACT_API_BASE_URL=
# Prefer shared var reference on Railway, e.g. CONTACT_API_KEY=${{ shared.CONTACT_API_CLIENT_KEY }}
CONTACT_API_KEY=

# CardDAV — native iOS Contacts sync at /carddav (Settings → Contacts → Add Account → CardDAV)
# Requires CONTACT_API_BASE_URL. iOS uses HTTP Basic Auth (username + password below).
CARDDAV_USERNAME=
CARDDAV_PASSWORD=
# Optional: token auth via X-CardDAV-Token or Bearer (defaults to CONTACT_API_KEY if unset)
# CARDDAV_TOKEN=

# Gate for the master-contacts dashboard at /admin/contacts (sensitive PII).
# Visit /admin/contacts?key=<this> once; if unset, the dashboard stays locked.
DASHBOARD_KEY=

# Railway — agent list_railway_domains tool (GraphQL). Token from https://railway.com/account/tokens
RAILWAY_API_TOKEN=
# Optional default project for list_railway_domains (else "<company name> App")
# RAILWAY_PROJECT_ID=af65eb9a-b11c-4c1c-8030-66b4347dcf71
# Optional: Cmd+K in Railway dashboard → Copy Active Workspace ID (if API rejects name-only create)
RAILWAY_WORKSPACE_ID=
# Set to 1 to test Railway project create without calling the API
RAILWAY_DRY_RUN=
# Optional description prefix on new projects (defaults to company name from admin Profile)
# RAILWAY_PROJECT_DESCRIPTION_PREFIX=

# Railway → admin System alerts (project webhook). Long random string; use same value in ?key=
RAILWAY_WEBHOOK_INGRESS_KEY=

# Kinsta — admin agent WordPress hosting tools (list/create/delete sites, backups, cache clear)
# MyKinsta → username → Company settings → API keys
KINSTA_API_KEY=
# Company UUID from MyKinsta URL (?idCompany=…) or Billing details
KINSTA_COMPANY_ID=
# Set to 1 to test write tools (create/delete/backup/cache) without calling Kinsta
# KINSTA_DRY_RUN=

# GitHub dev/status + write tools — lets the assistant verify commits/pushes/branches and commit files / open PRs.
# PAT for eliteweblabs/reave: read = Contents + Metadata; write_github_file / create_pull_request also need Contents write + Pull requests write.
# Public repos work without a token but are rate-limited; a token is recommended.
GITHUB_TOKEN=
# Optional: override the repo the status tools inspect (default: eliteweblabs/reave)
# GITHUB_REPO=eliteweblabs/reave
# Optional: explicit URL for check_deployment_status health ping (default: RAILWAY_PUBLIC_DOMAIN, else reave.app)
# DEPLOY_HEALTH_URL=https://reave.app/
# Note: RAILWAY_GIT_COMMIT_SHA / RAILWAY_PUBLIC_DOMAIN are auto-injected by Railway at deploy time.
# Clerk user id — deploy failures, SMS, voice, and email alerts post to admin Chats → System alerts
AGENT_ALERT_USER_ID=
# Set to 0 to skip auto agent reply on alert threads (default: run agent)
# AGENT_ALERT_AUTO_RUN=0
# Optional: cap user+assistant turns sent to Claude per request (unset = full thread)
# AGENT_CHAT_HISTORY_TURNS=20

# Inbound email triage (Resend webhook → /api/email/inbound). Replaces the old
# openclaw-email-tools IMAP monitor. See src/knowledge/email-rules.md.
RESEND_API_KEY=
# Webhook signing secret (whsec_…) returned when you create the Resend webhook
RESEND_WEBHOOK_SECRET=
# Outbound email sender for send_client_portal (must be a Resend-verified domain).
RESEND_FROM=Your Company <noreply@example.com>

# ─── Newsletter & email automation (FEATURES: email_marketing) ───────────────
# Sends welcome, follow-up, project-complete, review-request emails + broadcasts.
# Scheduler poll interval in minutes (1–60, default 5).
# NEWSLETTER_POLL_MINUTES=5
# Shared secret for cron-triggering the send loop: /api/newsletter/poll?key=…
# NEWSLETTER_POLL_SECRET=
# Only send between these hours (server time, 0–24). Default 8–20.
# NEWSLETTER_SEND_WINDOW_START=8
# NEWSLETTER_SEND_WINDOW_END=20
# Allow sends on Saturday/Sunday (default false).
# NEWSLETTER_SEND_ON_WEEKENDS=false
# Public review link used by the "Leave us a review" automation.
# NEWSLETTER_REVIEW_URL=https://g.page/r/your-google-review-link
# Secret for signing unsubscribe tokens (falls back to RESEND_WEBHOOK_SECRET).
# NEWSLETTER_UNSUB_SECRET=

# Cloudflare DNS (Resend DKIM/SPF/MX on reave.app). Token on Railway reave service.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─── Telnyx — SMS + voice (replaces Twilio) ─────────────────────────────────
# API key from https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=
# Your Telnyx phone number in E.164 format, e.g. +12125551234
TELNYX_FROM_NUMBER=
# Webhook public key for signature validation (optional but recommended):
#   Portal → Messaging Profile → edit → Webhook URL, copy the Public Key shown.
# Same key works for both SMS (/api/sms) and voice (/api/voice/webhook).
TELNYX_WEBHOOK_PUBLIC_KEY=

# ── Voice agent ──────────────────────────────────────────────────────────────
# Set to 1 to enable the AI phone agent on inbound calls (default: off).
VOICE_AGENT_ENABLED=
# Phone number to transfer calls to when /takeover is used (E.164).
TELNYX_OPERATOR_NUMBER=
# Call Control Application ID from the Telnyx portal (needed for outbound calls).
TELNYX_APP_ID=
# TTS voice name. Defaults to Polly.Joanna. Options: Polly.Matthew, Polly.Amy, etc.
TELNYX_VOICE=Polly.Joanna
TELNYX_VOICE_LANGUAGE=en-US
# Opening line spoken to callers (optional).
# VOICE_GREETING=Hi, you've reached our AI assistant. How can I help you?

# ── Siri Shortcuts ───────────────────────────────────────────────────────────
# API key for /api/siri endpoint (Apple Shortcuts voice commands via "Hey Siri").
# Generate: openssl rand -base64 32
# Keep this private — grants full access to clients, work, SMS via iOS Shortcuts.
SIRI_API_KEY=

# ── Vapi — homepage voice widget ─────────────────────────────────────────────
# Public key + assistant id (client SDK — also injected at page render time).
# Assistant ID and prompts can also be set in Admin → Vapi (stored in company_config).
PUBLIC_VAPI_PUBLIC_KEY=
PUBLIC_VAPI_ASSISTANT_ID=
# Private API key (dashboard → API keys) — used by prebuild sync only; never expose to browser.
VAPI_API_KEY=
# Optional alias for sync script (defaults to PUBLIC_VAPI_ASSISTANT_ID).
# VAPI_ASSISTANT_ID=
# Set to 1 to skip `npm run sync:vapi` / prebuild assistant sync (local dev without Vapi).
# VAPI_SYNC_SKIP=1
# Set to 1 to fail the build when Vapi sync errors (production deploys).
# VAPI_SYNC_REQUIRED=1
# Optional overrides for synced assistant copy (defaults use {{companyName}} variables):
# VAPI_FIRST_MESSAGE=Hi! Thanks for reaching out to {{companyName}}. How can I help?
# VAPI_SYSTEM_PROMPT=You are the voice assistant for {{companyName}}. ...
# Installation homepage voice widget (separate from admin vapi plugin):
# PUBLIC_INSTALL_HOMEPAGE_VOICE=1
# PUBLIC_VAPI_ENABLE_VOICE_RECOGNITION=true
# PUBLIC_VAPI_VOICE_PROFILE_ID=

# ── Inbound SMS ──────────────────────────────────────────────────────────────
# Comma-separated E.164 numbers allowed to message in. If empty, all pass.
SMS_ALLOWED_SENDERS=
# Set to 1 to have Claude auto-reply to inbound SMS (needs ANTHROPIC_API_KEY).
SMS_AI_REPLY_ENABLED=

# ── Inbound email ────────────────────────────────────────────────────────────
# Optional sender allowlists (comma-separated). If both empty, all senders are processed.
EMAIL_ALLOWED_SENDERS=
EMAIL_ALLOWED_DOMAINS=
# Ignore mail sent before this ISO date (overrides stored cutoff). First webhook auto-sets cutoff to now().
# EMAIL_INBOUND_SINCE=2026-07-17T00:00:00.000Z
# Set to 0 to process all mail regardless of send date (legacy behavior).
# EMAIL_INBOUND_FILTER=0
# Set to 0 to skip Claude summarization/routing (keyword rules only)
EMAIL_AI_ENABLED=1
# Admin inbox PWA push — generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com
PUSH_ENABLED=1
# Clerk user id for automated alert → admin agent (System alerts chat thread)
# Find in Clerk dashboard or browser devtools on /api/chats (userId in session).
AGENT_ALERT_USER_ID=
# Set to 0 to queue alert text only (no auto agent reply). Default: auto-run agent.
AGENT_ALERT_AUTO_RUN=1

# ── Per-install JSON config (config/config-{slug}.json) ─────────────────────
# Slug: INSTALL_CONFIG env, else first label of COMPANY_DOMAIN (reave.app → reave).
# Override file path: INSTALL_CONFIG_FILE=/absolute/path/config.json
#
# INSTALL_CONFIG=reave
#
# config/config-default.json ships with footerNav + profileMenu matching the admin UI.
# Add "features": ["client_portal", "billing", ...] to enable optional modules.
# Legacy fallback when features is empty: FEATURES env JSON array below.

# ── Deployment feature modules (legacy env fallback) ──────────────────────────
# Prefer the "features" array in your install config JSON file.
FEATURES=

# ── ChangeDetection.io (self-hosted on Railway) — requires site_monitoring in FEATURES
# Deploy the changedetectionio/changedetection.io Docker image as a Railway service.
CHANGEDETECTION_BASE_URL=
CHANGEDETECTION_API_KEY=
# Same value used in watch notification URLs (?key=) — generate a long random string
CHANGEDETECTION_WEBHOOK_SECRET=
# CHANGEDETECTION_CHECK_HOURS=24
# CHANGEDETECTION_POST_DEPLOY_SUPPRESS_MINUTES=20

# ── UptimeRobot — requires uptime_monitoring in FEATURES
# Account API key from Integrations → API (read-only or main key).
UPTIMEROBOT_API_KEY=
# Webhook URL: https://reave.app/api/uptime/webhook?key=<this secret>
UPTIMEROBOT_WEBHOOK_SECRET=
# Optional cron poll auth (defaults to UPTIMEROBOT_WEBHOOK_SECRET): /api/uptime/poll?key=
# UPTIMEROBOT_POLL_SECRET=
# UPTIMEROBOT_POLL_MINUTES=5
# Manual monitor → client uid map when Site URL auto-link misses:
# UPTIMEROBOT_MONITOR_CLIENT_MAP='{"798092635":"<client-uid>","802724019":"<client-uid>"}'
# Suppress push/system alerts for noisy monitors (webhook + poll — not email rules):
# UPTIMEROBOT_ALERT_SUPPRESS_MONITORS=798092635
# UPTIMEROBOT_ALERT_SUPPRESS_URLS=allautofinancial.com
# Free plan can't create monitors via API — "Sync sites" shows one-click quick-start
# links instead. Set this to prefill the notification email so each is truly one click:
# UPTIMEROBOT_ALERT_EMAIL=uptime@reave.app
# Auto-discovery is OFF by default (creates fail on free plan). Only set on a paid plan:
# UPTIMEROBOT_DISCOVER_MINUTES=60

# ── Plausible Analytics (self-hosted on Railway) ─────────────────────────────
# Public URL of your Plausible CE instance (no trailing slash).
PLAUSIBLE_API_BASE_URL=
# Stats API key from Plausible → Settings → API Keys → Stats API
PLAUSIBLE_API_KEY=
# Site id as registered in Plausible (defaults to company domain)
# PLAUSIBLE_SITE_ID=reave.app

# ── Cal.com scheduling (calcom-booking-api + calcom-web-app on Railway) — requires scheduling in FEATURES
# Server-side: prefer private network on Railway:
#   BOOKING_API_URL=http://${{ calcom-booking-api.RAILWAY_PRIVATE_DOMAIN }}:8080
# Browser form (/form/schedule): public booking API URL:
#   PUBLIC_BOOKING_API_URL=https://${{ calcom-booking-api.RAILWAY_PUBLIC_DOMAIN }}
BOOKING_API_URL=
PUBLIC_BOOKING_API_URL=
# Optional when calcom-booking-api has API_KEY set
# BOOKING_API_KEY=
# Cal.com web app — must be a public URL (custom domain or Railway public domain).
# Do not use *.railway.internal here; that host is unreachable from email links and browsers.
CALCOM_WEBAPP_URL=https://cal.reave.app
# Optional explicit public URL when CALCOM_WEBAPP_URL is internal (server-side only).
# PUBLIC_CALCOM_WEBAPP_URL=https://cal.reave.app
CALCOM_USERNAME=reave
# CALCOM_EVENT_TYPE_ID=1
# BOOKING_TIMEZONE=America/New_York
# Fallback street address when callers omit one (required for booking API geocoding).
# Prefer setting this in Admin → Company; env is a fallback when company address is unset.
# BOOKING_DEFAULT_ADDRESS=123 Main St, Boston, MA 02108
# Address autocomplete in admin scheduling (same key as Capco / Mavsafe).
# Suggestions center on the Admin → Company address (this key also geocodes it
# when Mapbox is unset), then BOOKING_DEFAULT_ADDRESS, then Boston, MA.
# GOOGLE_MAPS_API_KEY=
# Mapbox — client address map + driving directions in admin Clients tab.
# MAPBOX_ACCESS_TOKEN=
# PUBLIC_MAPBOX_ACCESS_TOKEN=
