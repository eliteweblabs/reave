---
export interface Props {
  /** Logo silhouette mask (same asset as the quantum hero). */
  maskSrc: string;
  /** Background video clipped to the logo shape. */
  videoSrc?: string;
  /** Homepage full-viewport; centered keeps the logo in the middle; compact fits the header. */
  layout?: "homepage" | "centered" | "compact";
  /** Cursor pixels moved per 1% video shift (100 = subtle, 20 = stronger). */
  cursorPxPerPercent?: number;
  /** Slowest playback rate at slow cursor movement. */
  cursorSpeedMinRate?: number;
  /** Fastest playback rate at fast cursor movement. */
  cursorSpeedMaxRate?: number;
  /** Cursor speed (px/ms) that reaches cursorSpeedMaxRate. */
  cursorSpeedVelocity?: number;
  class?: string;
}

const {
  maskSrc,
  videoSrc = "/videos/logo-2.mp4",
  layout = "homepage",
  cursorPxPerPercent = 100,
  cursorSpeedMinRate = 0.4,
  cursorSpeedMaxRate = 2.25,
  cursorSpeedVelocity = 2.5,
  class: className,
} = Astro.props;

const isHomepage = layout === "homepage";
const isCompact = layout === "compact";
const cursorParallax = isHomepage;
---

<div
  class:list={[
    "logo-2-stack",
    isHomepage && "logo-2-stack--homepage",
    layout === "centered" && "logo-2-stack--centered",
    isCompact && "logo-2-stack--compact",
    className,
  ]}
  style={`--logo-2-mask: url("${maskSrc}")`}
  data-logo-2
  data-cursor-parallax={cursorParallax ? "true" : "false"}
  data-cursor-px-per-percent={String(cursorPxPerPercent)}
  data-cursor-speed-min-rate={String(cursorSpeedMinRate)}
  data-cursor-speed-max-rate={String(cursorSpeedMaxRate)}
  data-cursor-speed-velocity={String(cursorSpeedVelocity)}
  aria-hidden="true"
>
  <div class="logo-2-frame">
    <div class="logo-2-parallax">
      <video
        class="logo-2-video"
        src={videoSrc}
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="logo-2-fallback" aria-hidden="true"></div>
    </div>
  </div>
</div>

<style>
  .logo-2-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: visible;
  }

  .logo-2-stack--centered {
    position: absolute;
    inset: 0;
  }

  .logo-2-stack--compact {
    position: relative;
    inset: unset;
    width: 24px;
    height: 24px;
    flex: 0 0 24px;
  }

  .logo-2-frame {
    position: relative;
    width: min(80vmin, 800px);
    height: min(80vmin, 800px);
    overflow: hidden;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.2))
      drop-shadow(0 0 16px rgba(200, 80, 180, 0.14));
    -webkit-mask-image: var(--logo-2-mask);
    mask-image: var(--logo-2-mask);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-mode: alpha;
    mask-mode: alpha;
  }

  .logo-2-stack--compact .logo-2-frame {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.24))
      drop-shadow(0 0 7px rgba(200, 80, 180, 0.12));
  }

  .logo-2-parallax {
    position: absolute;
    inset: -8%;
    width: 116%;
    height: 116%;
    transform: translate3d(var(--logo-2-shift-x, 0%), var(--logo-2-shift-y, 0%), 0);
    will-change: transform;
  }

  .logo-2-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-width: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: center center;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .logo-2-video.is-ready {
    opacity: 1;
  }

  .logo-2-fallback {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 28% 34%, rgba(0, 243, 255, 0.55), transparent 42%),
      radial-gradient(circle at 72% 68%, rgba(188, 19, 254, 0.5), transparent 46%),
      radial-gradient(circle at 52% 52%, rgba(255, 0, 85, 0.28), transparent 58%),
      linear-gradient(145deg, #120818 0%, #050505 100%);
    background-size: 200% 200%;
    animation: logo-2-fallback-drift 12s ease-in-out infinite alternate;
  }

  .logo-2-frame:has(.logo-2-video.is-ready) .logo-2-fallback {
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  @keyframes logo-2-fallback-drift {
    0% {
      background-position: 0% 0%, 100% 100%, 50% 50%, 0% 0%;
    }
    100% {
      background-position: 100% 100%, 0% 0%, 60% 40%, 0% 0%;
    }
  }

  @media (max-width: 768px) {
    .logo-2-frame {
      width: min(70vmin, 640px);
      height: min(70vmin, 640px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-2-fallback {
      animation: none;
    }

    .logo-2-parallax {
      transform: none !important;
    }
  }
</style>

<script>
  function prefersReducedMotion() {
    return (
      typeof matchMedia !== "undefined" &&
      matchMedia("(prefers-reduced-motion: reduce)").matches
    );
  }

  function clamp(value: number, min: number, max: number) {
    return Math.min(max, Math.max(min, value));
  }

  function attachCursorParallax(
    stack: HTMLElement,
    video: HTMLVideoElement,
  ): () => void {
    if (stack.dataset.cursorParallax !== "true" || prefersReducedMotion()) {
      return () => {};
    }

    const pxPerPercent = Number(stack.dataset.cursorPxPerPercent) || 100;
    const minRate = clamp(Number(stack.dataset.cursorSpeedMinRate) || 0.4, 0.05, 1);
    const maxRate = clamp(Number(stack.dataset.cursorSpeedMaxRate) || 2.25, 1, 4);
    const refVelocity = Math.max(Number(stack.dataset.cursorSpeedVelocity) || 2.5, 0.1);
    const maxShift = 8;
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let targetRate = 1;
    let currentRate = 1;
    let lastX = 0;
    let lastY = 0;
    let lastMoveTime = 0;
    let hasPointerSample = false;
    let rafId = 0;

    const setShift = (x: number, y: number) => {
      stack.style.setProperty("--logo-2-shift-x", `${x}%`);
      stack.style.setProperty("--logo-2-shift-y", `${y}%`);
    };

    const tick = () => {
      const now = performance.now();
      if (hasPointerSample && now - lastMoveTime > 120) {
        targetRate = 1;
      }

      currentX += (targetX - currentX) * 0.14;
      currentY += (targetY - currentY) * 0.14;
      currentRate += (targetRate - currentRate) * 0.12;

      if (
        Math.abs(currentX - targetX) < 0.01 &&
        Math.abs(currentY - targetY) < 0.01
      ) {
        currentX = targetX;
        currentY = targetY;
      }

      if (!video.paused) {
        video.playbackRate = clamp(currentRate, minRate, maxRate);
      }

      setShift(currentX, currentY);
      rafId = requestAnimationFrame(tick);
    };

    const onPointerMove = (event: PointerEvent) => {
      const now = performance.now();
      const cx = window.innerWidth * 0.5;
      const cy = window.innerHeight * 0.5;
      targetX = clamp((event.clientX - cx) / pxPerPercent, -maxShift, maxShift);
      targetY = clamp((event.clientY - cy) / pxPerPercent, -maxShift, maxShift);

      if (hasPointerSample) {
        const dt = Math.max(now - lastMoveTime, 8);
        const speed = Math.hypot(event.clientX - lastX, event.clientY - lastY) / dt;
        const speedNorm = clamp(speed / refVelocity, 0, 1);
        targetRate = minRate + speedNorm * (maxRate - minRate);
      }

      lastX = event.clientX;
      lastY = event.clientY;
      lastMoveTime = now;
      hasPointerSample = true;
    };

    const onPointerLeave = () => {
      targetX = 0;
      targetY = 0;
      targetRate = 1;
    };

    rafId = requestAnimationFrame(tick);
    window.addEventListener("pointermove", onPointerMove, { passive: true });
    document.addEventListener("mouseleave", onPointerLeave);

    return () => {
      cancelAnimationFrame(rafId);
      window.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("mouseleave", onPointerLeave);
      stack.style.removeProperty("--logo-2-shift-x");
      stack.style.removeProperty("--logo-2-shift-y");
      video.playbackRate = 1;
    };
  }

  function initLogo2(stack: HTMLElement) {
    const video = stack.querySelector<HTMLVideoElement>(".logo-2-video");
    if (!video) return () => {};

    const markReady = () => video.classList.add("is-ready");

    video.addEventListener("canplay", markReady, { once: true });
    video.addEventListener("loadeddata", markReady, { once: true });

    const play = video.play();
    if (play && typeof play.catch === "function") {
      play.catch(() => {
        /* Placeholder video missing or autoplay blocked — keep gradient fallback. */
      });
    }

    const detachParallax = attachCursorParallax(stack, video);

    return () => {
      detachParallax();
      video.pause();
      video.removeAttribute("src");
      video.load();
    };
  }

  const cleanups = new Map<HTMLElement, () => void>();

  function boot() {
    document.querySelectorAll<HTMLElement>("[data-logo-2]").forEach((stack) => {
      cleanups.get(stack)?.();
      cleanups.set(stack, initLogo2(stack));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }

  window.addEventListener("pagehide", () => {
    cleanups.forEach((cleanup) => cleanup());
    cleanups.clear();
  });
</script>
