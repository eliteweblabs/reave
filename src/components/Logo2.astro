---
export interface Props {
  /** Logo silhouette mask (same asset as the quantum hero). */
  maskSrc: string;
  /** Background video clipped to the logo shape. */
  videoSrc?: string;
  /** Homepage full-viewport; centered keeps the logo in the middle; compact fits the header. */
  layout?: "homepage" | "centered" | "compact";
  /** Slowest playback rate at slow cursor movement. */
  cursorSpeedMinRate?: number;
  /** Fastest playback rate at fast cursor movement. */
  cursorSpeedMaxRate?: number;
  /** Cursor speed (px/ms) that reaches cursorSpeedMaxRate. */
  cursorSpeedVelocity?: number;
  /** Resting playback rate when idle (default half speed). */
  basePlaybackRate?: number;
  class?: string;
}

const {
  maskSrc,
  videoSrc = "/videos/logo-2.mp4",
  layout = "homepage",
  cursorSpeedMinRate = 0.4,
  cursorSpeedMaxRate = 2.25,
  cursorSpeedVelocity = 2.5,
  basePlaybackRate = 0.5,
  class: className,
} = Astro.props;

const isHomepage = layout === "homepage";
const isCompact = layout === "compact";
const cursorSpeed = isHomepage;
---

<div
  class:list={[
    "logo-2-stack",
    isHomepage && "logo-2-stack--homepage",
    layout === "centered" && "logo-2-stack--centered",
    isCompact && "logo-2-stack--compact",
    className,
  ]}
  style={`--logo-2-mask: url("${maskSrc}")`}
  data-logo-2
  data-cursor-speed={cursorSpeed ? "true" : "false"}
  data-cursor-speed-min-rate={String(cursorSpeedMinRate)}
  data-cursor-speed-max-rate={String(cursorSpeedMaxRate)}
  data-cursor-speed-velocity={String(cursorSpeedVelocity)}
  data-base-playback-rate={String(basePlaybackRate)}
  aria-hidden="true"
>
  <div class="logo-2-frame">
    <div class="logo-2-media">
      <video
        class="logo-2-video"
        src={videoSrc}
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="logo-2-tint" aria-hidden="true"></div>
      <div class="logo-2-glow" aria-hidden="true"></div>
    </div>
    <div class="logo-2-fallback" aria-hidden="true"></div>
  </div>
</div>

<style>
  .logo-2-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: visible;
  }

  .logo-2-stack--centered {
    position: absolute;
    inset: 0;
  }

  .logo-2-stack--compact {
    position: relative;
    inset: unset;
    width: 24px;
    height: 24px;
    flex: 0 0 24px;
  }

  .logo-2-frame {
    position: relative;
    width: min(80vmin, 800px);
    height: min(80vmin, 800px);
    overflow: hidden;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.2))
      drop-shadow(0 0 16px rgba(200, 80, 180, 0.14));
    -webkit-mask-image: var(--logo-2-mask);
    mask-image: var(--logo-2-mask);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-mode: alpha;
    mask-mode: alpha;
  }

  .logo-2-stack--compact .logo-2-frame {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.24))
      drop-shadow(0 0 7px rgba(200, 80, 180, 0.12));
  }

  .logo-2-media {
    position: absolute;
    inset: 0;
    isolation: isolate;
  }

  .logo-2-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-width: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: center center;
    opacity: 0;
    transition: opacity 0.35s ease;
    filter: saturate(1.28) contrast(1.06) brightness(0.94);
  }

  .logo-2-video.is-ready {
    opacity: 1;
  }

  /* Tint stack tuned to public/logo.png: lavender → purple → fuchsia → violet. */
  .logo-2-tint {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      #d8b4fe 0%,
      #bc13fe 20%,
      #ff0080 54%,
      #ff0055 78%,
      #9d00ff 100%
    );
    mix-blend-mode: color;
    opacity: 0.9;
  }

  .logo-2-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 34% 28%, rgba(188, 19, 254, 0.34), transparent 46%),
      radial-gradient(circle at 68% 72%, rgba(255, 0, 128, 0.36), transparent 48%);
    mix-blend-mode: soft-light;
    opacity: 0.82;
  }

  .logo-2-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      165deg,
      #d8b4fe 0%,
      #bc13fe 20%,
      #ff0080 54%,
      #ff0055 78%,
      #9d00ff 100%
    );
  }

  .logo-2-frame:has(.logo-2-video.is-ready) .logo-2-fallback {
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  @media (max-width: 768px) {
    .logo-2-frame {
      width: min(70vmin, 640px);
      height: min(70vmin, 640px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-2-tint,
    .logo-2-glow {
      opacity: 0.78;
    }
  }
</style>

<script>
  function prefersReducedMotion() {
    return (
      typeof matchMedia !== "undefined" &&
      matchMedia("(prefers-reduced-motion: reduce)").matches
    );
  }

  function clamp(value: number, min: number, max: number) {
    return Math.min(max, Math.max(min, value));
  }

  function attachCursorSpeed(
    stack: HTMLElement,
    video: HTMLVideoElement,
  ): () => void {
    const minRate = clamp(Number(stack.dataset.cursorSpeedMinRate) || 0.4, 0.05, 1);
    const maxRate = clamp(Number(stack.dataset.cursorSpeedMaxRate) || 2.25, 1, 4);
    const refVelocity = Math.max(Number(stack.dataset.cursorSpeedVelocity) || 2.5, 0.1);
    const baseRate = clamp(Number(stack.dataset.basePlaybackRate) || 0.5, 0.05, 1);
    const moveIdleMs = 100;
    const stopHoldMs = 1000;

    if (stack.dataset.cursorSpeed !== "true" || prefersReducedMotion()) {
      video.playbackRate = baseRate;
      return () => {
        video.playbackRate = 1;
      };
    }

    type Phase = "auto" | "drive" | "wind_down" | "stopped" | "ease_in";
    let phase: Phase = "auto";
    let pointerDown = false;
    let activePointerId: number | null = null;
    let targetRate = baseRate;
    let currentRate = baseRate;
    let stoppedAt = 0;
    let lastX = 0;
    let lastY = 0;
    let lastMoveTime = 0;
    let hasPointerSample = false;
    let rafId = 0;

    const pauseVideo = () => {
      currentRate = 0;
      video.playbackRate = 0;
      video.pause();
    };

    const applyRate = (rate: number) => {
      const next = clamp(rate, 0, maxRate);
      video.playbackRate = next;
      if (next <= 0.01) {
        pauseVideo();
        return;
      }
      if (video.paused) {
        void video.play();
      }
    };

    const beginWindDown = () => {
      if (phase === "wind_down" || phase === "stopped") return;
      phase = "wind_down";
      targetRate = 0;
    };

    const enterStopped = (now: number) => {
      phase = "stopped";
      pauseVideo();
      stoppedAt = now;
    };

    const tick = () => {
      const now = performance.now();
      const idleMs = now - lastMoveTime;

      switch (phase) {
        case "auto":
          currentRate = baseRate;
          applyRate(baseRate);
          break;
        case "drive":
          currentRate += (targetRate - currentRate) * 0.12;
          applyRate(currentRate);
          if (idleMs >= moveIdleMs) {
            beginWindDown();
          }
          break;
        case "wind_down":
          currentRate += (0 - currentRate) * 0.18;
          applyRate(currentRate);
          if (currentRate <= 0.02) {
            enterStopped(now);
          }
          break;
        case "stopped":
          pauseVideo();
          if (pointerDown) break;
          if (now - stoppedAt >= stopHoldMs) {
            phase = "ease_in";
            targetRate = baseRate;
          }
          break;
        case "ease_in":
          currentRate += (targetRate - currentRate) * 0.035;
          applyRate(currentRate);
          if (Math.abs(currentRate - baseRate) < 0.015) {
            currentRate = baseRate;
            phase = "auto";
          }
          break;
      }

      rafId = requestAnimationFrame(tick);
    };

    const onPointerDown = (event: PointerEvent) => {
      pointerDown = true;
      activePointerId = event.pointerId;
      lastX = event.clientX;
      lastY = event.clientY;
      lastMoveTime = performance.now();
      hasPointerSample = false;
    };

    const onPointerUp = (event: PointerEvent) => {
      if (activePointerId !== null && event.pointerId !== activePointerId) return;
      pointerDown = false;
      activePointerId = null;

      if (phase === "drive") {
        beginWindDown();
      } else if (phase === "stopped") {
        stoppedAt = performance.now();
      }
    };

    const onPointerCancel = (event: PointerEvent) => {
      onPointerUp(event);
    };

    const onPointerMove = (event: PointerEvent) => {
      if (pointerDown && activePointerId !== null && event.pointerId !== activePointerId) {
        return;
      }

      const now = performance.now();

      if (hasPointerSample) {
        const dt = Math.max(now - lastMoveTime, 8);
        const speed = Math.hypot(event.clientX - lastX, event.clientY - lastY) / dt;
        if (speed > 0.04) {
          phase = "drive";
          const speedNorm = clamp(speed / refVelocity, 0, 1);
          targetRate = minRate + speedNorm * (maxRate - minRate);
        }
      }

      lastX = event.clientX;
      lastY = event.clientY;
      lastMoveTime = now;
      hasPointerSample = true;
    };

    const onPointerLeave = () => {
      if (!pointerDown && phase === "drive") {
        beginWindDown();
      }
    };

    video.playbackRate = baseRate;
    rafId = requestAnimationFrame(tick);
    window.addEventListener("pointerdown", onPointerDown, { passive: true });
    window.addEventListener("pointerup", onPointerUp, { passive: true });
    window.addEventListener("pointercancel", onPointerCancel, { passive: true });
    window.addEventListener("pointermove", onPointerMove, { passive: true });
    document.addEventListener("mouseleave", onPointerLeave);

    return () => {
      cancelAnimationFrame(rafId);
      window.removeEventListener("pointerdown", onPointerDown);
      window.removeEventListener("pointerup", onPointerUp);
      window.removeEventListener("pointercancel", onPointerCancel);
      window.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("mouseleave", onPointerLeave);
      video.playbackRate = 1;
    };
  }

  function initLogo2(stack: HTMLElement) {
    const video = stack.querySelector<HTMLVideoElement>(".logo-2-video");
    if (!video) return () => {};

    const markReady = () => video.classList.add("is-ready");

    video.addEventListener("canplay", markReady, { once: true });
    video.addEventListener("loadeddata", markReady, { once: true });

    const play = video.play();
    if (play && typeof play.catch === "function") {
      play.catch(() => {
        /* Placeholder video missing or autoplay blocked — keep gradient fallback. */
      });
    }

    const detachCursorSpeed = attachCursorSpeed(stack, video);

    return () => {
      detachCursorSpeed();
      video.pause();
      video.removeAttribute("src");
      video.load();
    };
  }

  const cleanups = new Map<HTMLElement, () => void>();

  function boot() {
    document.querySelectorAll<HTMLElement>("[data-logo-2]").forEach((stack) => {
      cleanups.get(stack)?.();
      cleanups.set(stack, initLogo2(stack));
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }

  window.addEventListener("pagehide", () => {
    cleanups.forEach((cleanup) => cleanup());
    cleanups.clear();
  });
</script>
