---
/**
 * Universal favicon links — single source of truth for every page.
 * Raster-only (PNG + multi-res .ico) for maximum browser compatibility;
 * we intentionally avoid an SVG favicon because the brand mark is a raster
 * image and embedded-image SVG favicons render inconsistently across browsers.
 * Include inside any page's <head>.
 */
import { getCompanyConfig, companyFaviconUrls } from "../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
const favicons = companyFaviconUrls(company);
---

<link rel="icon" href={favicons.ico} sizes="48x48" />
<link rel="icon" type="image/png" sizes="32x32" href={favicons.png32} />
<link rel="icon" type="image/png" sizes="16x16" href={favicons.png16} />
<link rel="apple-touch-icon" sizes="180x180" href={favicons.appleTouchIcon} />
