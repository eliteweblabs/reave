---
import ConversationalForm from "../ConversationalForm.astro";
import { Contact, Mail, Phone } from "lucide-astro";
import { getCompanyConfig } from "../../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
const supportMail =
  company.supportEmail ||
  (company.domain ? `hello@${company.domain}` : "");
const phoneHref = company.supportPhone
  ? `tel:${company.supportPhone.replace(/[^\d+]/g, "")}`
  : null;
const vcardHref = "/contact.vcf";
const vcardLabel = company.name ? `Add ${company.name}` : "Add contact";
---

<section
  id="contact"
  class="home-section"
  data-home-section="contact"
  aria-labelledby="contact-title"
>
  <div class="home-section-inner">
    <header class="home-section-hero">
      <p class="marketing-label">Get in Touch</p>
      <h2 id="contact-title">Contact</h2>
      <p class="marketing-lead">
        Tell us what you need — email, call, or chat through the form below.
      </p>
    </header>

    <div class="contact-top">
      {
        supportMail ? (
          <a
            class="contact-icon"
            href={`mailto:${supportMail}`}
            aria-label={`Email ${supportMail}`}
            title={supportMail}
          >
            <Mail size={22} strokeWidth={1.75} />
          </a>
        ) : (
          <span class="contact-icon contact-icon--muted" aria-hidden="true">
            <Mail size={22} strokeWidth={1.75} />
          </span>
        )
      }
      {
        company.supportPhone && phoneHref ? (
          <a
            class="contact-icon"
            href={phoneHref}
            aria-label={`Phone ${company.supportPhone}`}
            title={company.supportPhone}
          >
            <Phone size={22} strokeWidth={1.75} />
          </a>
        ) : company.supportPhone ? (
          <span
            class="contact-icon contact-icon--muted"
            aria-label={`Phone ${company.supportPhone}`}
            title={company.supportPhone}
          >
            <Phone size={22} strokeWidth={1.75} />
          </span>
        ) : (
          <span class="contact-icon contact-icon--muted" aria-hidden="true">
            <Phone size={22} strokeWidth={1.75} />
          </span>
        )
      }
      <a
        class="contact-icon"
        href={vcardHref}
        download
        aria-label={vcardLabel}
        title={vcardLabel}
      >
        <Contact size={22} strokeWidth={1.75} />
      </a>
    </div>

    <ConversationalForm slug="contact" embedded recipientEmail={supportMail} />
  </div>
</section>

<style>
  .contact-top {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 28px;
    margin-bottom: 16px;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a855f7;
    text-decoration: none;
    transition:
      color 0.2s,
      transform 0.2s;
  }

  a.contact-icon:hover {
    color: #ec4899;
    transform: scale(1.08);
  }

  .contact-icon--muted {
    color: rgba(255, 255, 255, 0.25);
    cursor: default;
  }

  @media (max-width: 640px) {
    .contact-top {
      gap: 24px;
      margin-bottom: 12px;
    }
  }
</style>
