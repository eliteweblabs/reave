---
import { clerkClient } from "@clerk/astro/server";
import { getCompanyConfig } from "../lib/companyConfig";

interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;

const company = await getCompanyConfig(Astro.request);

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;
let avatarUrl: string | null = null;
let userInitials = "";

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = user.imageUrl ?? null;
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials = ((first + last).toUpperCase() || user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ?? "?";
  } catch {
    // silently skip avatar if Clerk is unreachable
  }
}
---

<header class="site-header">
  {!isIndex && (
    <a href="/" class="site-logo" aria-label={company.name || "Home"}>
      <img src={company.logoPath} alt={company.name} class="logo-img" />
    </a>
  )}

  {!userId && (
    <a href="/sign-in" class="login-btn" aria-label="Sign in" title="Sign in">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </a>
  )}

  {userId && (
    <div class="profile-dock">
      <div class="profile-menu-wrapper">
        <button class="profile-btn" id="profile-toggle" aria-label="Account menu" aria-expanded="false" aria-haspopup="true">
          {avatarUrl ? (
            <img src={avatarUrl} alt="Avatar" class="profile-avatar" />
          ) : (
            <span class="profile-initials">{userInitials}</span>
          )}
        </button>
        <div class="profile-dropdown" id="profile-dropdown" role="menu">
          <a href="/admin/profile" class="dropdown-item" role="menuitem">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Profile
          </a>
          <div class="dropdown-divider"></div>
          <a href="/sign-out" class="dropdown-item dropdown-item--danger" role="menuitem" id="sign-out-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </a>
        </div>
      </div>
    </div>
  )}
</header>

<style>
  /* ── Global header bar (transparent overlay, all pages) ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 64px;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: env(safe-area-inset-top) max(20px, env(safe-area-inset-right)) 0 max(20px, env(safe-area-inset-left));
    /* Let page content/canvas underneath stay interactive; children opt back in. */
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .site-header > * {
    pointer-events: auto;
  }

  /* Logo (left) — hidden on the index page via `isIndex`. */
  .site-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .site-logo .logo-img {
    height: 28px;
    width: auto;
    display: block;
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  /* Never print the site chrome. */
  @media print {
    .site-header {
      display: none !important;
    }
  }

  /* Profile dock / login button pinned right even when the logo is hidden (index). */
  .profile-dock,
  .login-btn {
    margin-left: auto;
  }

  /* Logged-out sign-in icon (matches the profile button shape). */
  .login-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 0.15s;
  }

  .login-btn svg {
    pointer-events: none;
  }

  .login-btn:hover {
    color: rgba(255, 255, 255, 0.4);
  }

  .profile-menu-wrapper {
    position: relative;
  }

  .profile-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(168, 85, 247, 0.5);
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .profile-btn:hover {
    border-color: rgba(168, 85, 247, 0.9);
    box-shadow: 0 0 14px rgba(168, 85, 247, 0.4);
  }

  .profile-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .profile-initials {
    font-size: 13px;
    font-weight: 700;
    color: #a855f7;
    font-family: 'Inter', -apple-system, sans-serif;
    letter-spacing: 0.02em;
  }

  .profile-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: rgba(14, 14, 16, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 6px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(20px);
  }

  .profile-dropdown.is-open {
    display: block;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'Inter', -apple-system, sans-serif;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
  }

  .dropdown-item--danger { color: rgba(248, 113, 113, 0.85); }
  .dropdown-item--danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .dropdown-item svg {
    pointer-events: none;
    flex-shrink: 0;
  }

  .dropdown-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 4px 0;
  }

  @media (max-width: 639px) {
    .site-header {
      padding:
        env(safe-area-inset-top)
        max(10px, env(safe-area-inset-right))
        0
        max(10px, env(safe-area-inset-left));
    }
  }
</style>

<script>
  const toggle = document.getElementById("profile-toggle");
  const dropdown = document.getElementById("profile-dropdown");

  if (toggle && dropdown) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = dropdown.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(open));
    });

    document.addEventListener("click", () => {
      dropdown.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        dropdown.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  // Handle sign-out
  const signOutLink = document.getElementById("sign-out-link");
  if (signOutLink) {
    signOutLink.addEventListener("click", async (e) => {
      e.preventDefault();
      // Clerk's session cookie is cleared via the Clerk JS SDK
      // Redirect to Clerk's sign-out endpoint
      const { Clerk } = window as any;
      if (Clerk) {
        await Clerk.signOut();
        window.location.href = "/";
      } else {
        window.location.href = "/sign-out";
      }
    });
  }
</script>
