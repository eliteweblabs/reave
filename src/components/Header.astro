---
import { clerkClient } from "@clerk/astro/server";
import { getCompanyConfig } from "../lib/companyConfig";

interface Props {
  /** Admin SPA shell — tools menu filled by os-map-loader.js */
  adminShell?: boolean;
  /** Hide logo link (homepage — logo lives in page content) */
  hideLogo?: boolean;
}

const { adminShell = false, hideLogo = false } = Astro.props;

const company = await getCompanyConfig(Astro.request);
const logoPath = company.logoPath || "/logo.png";

const adminSpaTabs = [
  { tab: "chats", label: "Chats", icon: "💬" },
  { tab: "knowledge", label: "Knowledge", icon: "📚" },
  { tab: "email", label: "Inbox", icon: "📬" },
  { tab: "work", label: "Work", icon: "💼" },
  { tab: "clients", label: "Clients", icon: "👥" },
  { tab: "todo", label: "To-do", icon: "✅" },
  { tab: "documents", label: "Documents", icon: "📄" },
  { tab: "rules", label: "Rules", icon: "⚡" },
  { tab: "system", label: "System", icon: "🖥️" },
  { tab: "tooling", label: "MCP & CLI", icon: "🔧" },
  { tab: "telegram", label: "Telegram", icon: "✈️" },
] as const;

const adminPages = [
  { href: "/admin/contacts", label: "Contacts DB", icon: "📊" },
  { href: "/admin/telegram", label: "Telegram help", icon: "📋" },
] as const;

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;
let avatarUrl: string | null = null;
let userInitials = "";

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = user.imageUrl ?? null;
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials =
      ((first + last).toUpperCase() || user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ??
      "?";
  } catch {
    // Clerk unreachable
  }
}
---

<header
  class:list={["app-header", { "app-header--admin": adminShell }]}
  id={adminShell ? "topbar" : undefined}
>
  {!hideLogo && (
    <a href="/" class="app-header-logo brand" aria-label={company.name || "Home"}>
      <img src={logoPath} alt={company.name} class="app-header-logo-img brand-img logo-img" />
    </a>
  )}

  {!userId && (
    <a href="/sign-in" class="app-header-signin" aria-label="Sign in" title="Sign in">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </a>
  )}

  {userId && (
    <div class="app-header-end topbar-end">
      {adminShell ? (
        <button
          type="button"
          id="push-enable-btn"
          class="app-header-icon-btn topbar-icon-btn topbar-push-btn"
          aria-label="Enable push notifications"
          title="Enable push notifications"
          hidden
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        </button>
      ) : (
        <>
          <div class="app-header-menu topbar-menu topbar-tools-menu">
            <button
              type="button"
              id="topbar-tools-toggle"
              class="app-header-icon-btn topbar-icon-btn topbar-tools-btn"
              aria-label="Tools"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </button>
            <div id="topbar-tools-menu" class="app-header-dropdown topbar-dropdown" role="menu" aria-label="Tools">
              <a href="/admin/" class="topbar-dropdown-item" role="menuitem">
                <span class="topbar-dropdown-icon" aria-hidden="true">🧑‍💻</span>
                <span>Administration</span>
              </a>
              <div class="topbar-dropdown-divider"></div>
              {adminSpaTabs.map(({ tab, label, icon }) => (
                <a href={`/admin/?tab=${tab}`} class="topbar-dropdown-item" role="menuitem">
                  <span class="topbar-dropdown-icon" aria-hidden="true">{icon}</span>
                  <span>{label}</span>
                </a>
              ))}
              {adminPages.map(({ href, label, icon }) => (
                <a href={href} class="topbar-dropdown-item" role="menuitem">
                  <span class="topbar-dropdown-icon" aria-hidden="true">{icon}</span>
                  <span>{label}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="app-header-menu topbar-menu topbar-profile-menu">
            <button
              type="button"
              id="topbar-profile-toggle"
              class="app-header-profile-btn topbar-profile-btn"
              aria-label="Account menu"
              aria-expanded="false"
              aria-haspopup="true"
            >
              {avatarUrl ? (
                <img src={avatarUrl} alt="" class="topbar-profile-avatar" />
              ) : (
                <span class="topbar-profile-initials">{userInitials || "?"}</span>
              )}
            </button>
            <div id="topbar-profile-menu" class="app-header-dropdown topbar-dropdown" role="menu">
              <a href="/admin/profile" class="topbar-dropdown-item" role="menuitem">Profile</a>
              <div class="topbar-dropdown-divider"></div>
              <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">
                Sign out
              </button>
            </div>
          </div>
        </>
      )}
    </div>
  )}
</header>

<style is:global>
  :root {
    --app-header-h: 4rem;
  }

  .app-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: var(--app-header-h);
    padding:
      env(safe-area-inset-top, 0px)
      max(0.75rem, env(safe-area-inset-right, 0px))
      0
      max(0.75rem, env(safe-area-inset-left, 0px));
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .app-header--admin {
    z-index: 20;
    min-height: calc(var(--app-header-h) + env(safe-area-inset-top, 0px));
    background: var(--bg, #0a0d14);
    border-bottom: 1px solid rgba(35, 44, 58, 0.45);
  }

  .app-header--admin::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(10, 13, 20, 0.45);
    backdrop-filter: blur(16px) saturate(1.1);
    -webkit-backdrop-filter: blur(16px) saturate(1.1);
    pointer-events: none;
  }

  .app-header--admin > * {
    position: relative;
    z-index: 1;
  }

  .app-header--admin .topbar-end {
    margin-left: auto;
  }

  .app-header > * {
    pointer-events: auto;
  }

  .app-header-logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
    text-decoration: none;
  }

  .app-header-logo-img {
    height: 28px;
    width: auto;
    display: block;
    pointer-events: none;
  }

  .app-header-end,
  .topbar-end {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-left: auto;
  }

  .app-header-signin {
    margin-left: auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 0.15s;
  }

  .app-header-signin:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  .app-header-signin svg {
    pointer-events: none;
  }

  .app-header-menu {
    position: relative;
  }

  .app-header-icon-btn,
  .topbar-icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    background: var(--panel, rgba(18, 23, 34, 0.9));
    color: var(--muted, rgba(255, 255, 255, 0.55));
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    line-height: 1;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .topbar-tools-btn {
    position: relative;
    border-color: rgba(148, 163, 184, 0.35);
    background: rgba(148, 163, 184, 0.08);
    color: rgba(148, 163, 184, 0.95);
  }

  .topbar-tools-btn.has-badge {
    border-color: rgba(251, 191, 36, 0.55);
    background: rgba(251, 191, 36, 0.08);
  }

  .topbar-push-btn {
    border-color: rgba(239, 68, 68, 0.85);
    background: rgba(239, 68, 68, 0.1);
    color: rgba(252, 165, 165, 0.98);
    box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.35);
  }

  .topbar-push-btn:hover {
    border-color: rgba(248, 113, 113, 1);
    color: #fecaca;
    box-shadow: 0 0 0 1px rgba(248, 113, 113, 0.5);
  }

  .topbar-push-btn[hidden] {
    display: none !important;
  }

  .app-header-icon-btn:hover,
  .topbar-icon-btn:hover {
    color: var(--fg, #e9eef6);
    border-color: #4b5563;
  }

  .app-header-profile-btn,
  .topbar-profile-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(168, 85, 247, 0.5);
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .app-header-profile-btn:hover,
  .topbar-profile-btn:hover {
    border-color: rgba(168, 85, 247, 0.9);
    box-shadow: 0 0 14px rgba(168, 85, 247, 0.4);
  }

  .topbar-profile-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    pointer-events: none;
  }

  .topbar-profile-initials {
    font-size: 13px;
    font-weight: 700;
    color: #a855f7;
    letter-spacing: 0.02em;
    pointer-events: none;
  }

  .topbar-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 0 0 2px var(--bg, #0a0d14);
  }

  .app-header-dropdown,
  .topbar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 188px;
    max-width: min(88vw, 260px);
    max-height: min(62vh, 420px);
    overflow-y: auto;
    background: rgba(14, 17, 24, 0.98);
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    border-radius: 10px;
    padding: 0.35rem;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
    z-index: 120;
  }

  .app-header-dropdown.open,
  .topbar-dropdown.open {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .topbar-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.5rem 0.55rem;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted, rgba(255, 255, 255, 0.62));
    background: transparent;
    border: 1px solid transparent;
    border-radius: 7px;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
  }

  .topbar-dropdown-item:hover {
    color: var(--fg, #e9eef6);
    background: rgba(255, 255, 255, 0.05);
  }

  .topbar-dropdown-item.active {
    color: var(--fg, #e9eef6);
    background: #11253d;
    border-color: #2d5a94;
  }

  .topbar-dropdown-item--danger {
    color: rgba(248, 113, 113, 0.9);
  }

  .topbar-dropdown-item--danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .topbar-dropdown-divider {
    height: 1px;
    background: var(--panel-border, rgba(255, 255, 255, 0.08));
    margin: 0.2rem 0;
  }

  .topbar-dropdown-icon {
    width: 1rem;
    flex-shrink: 0;
    text-align: center;
    font-size: 0.82rem;
    line-height: 1;
  }

  @media print {
    .app-header {
      display: none !important;
    }
  }
</style>

{!adminShell && (
  <script>
    function closeHeaderMenus(exceptMenu?: HTMLElement | null) {
      for (const menu of document.querySelectorAll(".topbar-dropdown")) {
        if (exceptMenu && menu === exceptMenu) continue;
        menu.classList.remove("open");
      }
      document.getElementById("topbar-tools-toggle")?.setAttribute("aria-expanded", "false");
      document.getElementById("topbar-profile-toggle")?.setAttribute("aria-expanded", "false");
    }

    function toggleHeaderMenu(menuEl: HTMLElement | null, toggleEl: HTMLElement | null) {
      if (!menuEl || !toggleEl) return;
      const willOpen = !menuEl.classList.contains("open");
      closeHeaderMenus(null);
      if (willOpen) {
        menuEl.classList.add("open");
        toggleEl.setAttribute("aria-expanded", "true");
      }
    }

    const toolsToggle = document.getElementById("topbar-tools-toggle");
    const toolsMenu = document.getElementById("topbar-tools-menu");
    toolsToggle?.addEventListener("click", (ev) => {
      ev.stopPropagation();
      toggleHeaderMenu(toolsMenu, toolsToggle);
    });

    const profileToggle = document.getElementById("topbar-profile-toggle");
    const profileMenu = document.getElementById("topbar-profile-menu");
    profileToggle?.addEventListener("click", (ev) => {
      ev.stopPropagation();
      toggleHeaderMenu(profileMenu, profileToggle);
    });

    document.getElementById("topbar-sign-out")?.addEventListener("click", async (ev) => {
      ev.preventDefault();
      closeHeaderMenus(null);
      const { Clerk } = window as Window & { Clerk?: { signOut: () => Promise<void> } };
      if (Clerk) {
        await Clerk.signOut();
        window.location.href = "/";
      } else {
        window.location.href = "/sign-out";
      }
    });

    if (!document.documentElement.dataset.headerMenuBound) {
      document.documentElement.dataset.headerMenuBound = "1";
      document.addEventListener("click", () => closeHeaderMenus(null));
      document.addEventListener("keydown", (ev) => {
        if (ev.key === "Escape") closeHeaderMenus(null);
      });
    }
  </script>
)}
