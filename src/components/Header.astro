---
import { clerkClient } from "@clerk/astro/server";

interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;
let avatarUrl: string | null = null;
let userInitials = "";

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = user.imageUrl ?? null;
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials = ((first + last).toUpperCase() || user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ?? "?";
  } catch {
    // silently skip avatar if Clerk is unreachable
  }
}
---

{
  isIndex ? (
    <header class="header">
      {/* <div class="header-logo-mask">
    <div class="header-gradient-layer"></div>
  </div> */}
    </header>
  ) : (
    <a href="/" class="small-logo">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="80 205 368 118"
        class="logo-svg"
      >
        <path
          d="M84.7,313.4h-.5v-99.3h47.6c10.1,0,18.3,2.7,24.3,8.2,6,5.5,9.2,13.3,9.2,22.9s-1.4,11.4-3.7,15.1-5.5,6.9-9.2,8.7-7.3,3.2-11,4.1l26.1,40.3h-82.9Z"
          fill="currentColor"
        />
        <path d="M241.2,313.4l42.1-99.3,42.6,99.3" fill="currentColor" />
        <path d="M298.5,214.1h79.7l-40.3,99.3" fill="currentColor" />
        <polygon
          points="251 258 175.9 258 175.9 224.7 264.7 224.7 251 258"
          fill="currentColor"
        />
        <polygon
          points="232.7 303.8 175.9 303.8 175.9 270.5 246.4 270.5 232.7 303.8"
          fill="currentColor"
        />
        <polygon
          points="368.2 270.5 443.3 270.5 443.3 303.8 354.4 303.8 368.2 270.5"
          fill="currentColor"
        />
        <polygon
          points="386.5 224.7 443.3 224.7 443.3 258 372.7 258 386.5 224.7"
          fill="currentColor"
        />
      </svg>
    </a>
  )
}

{userId && (
  <div class="profile-dock">
    <div class="profile-menu-wrapper">
      <button class="profile-btn" id="profile-toggle" aria-label="Account menu" aria-expanded="false" aria-haspopup="true">
        {avatarUrl ? (
          <img src={avatarUrl} alt="Avatar" class="profile-avatar" />
        ) : (
          <span class="profile-initials">{userInitials}</span>
        )}
      </button>
      <div class="profile-dropdown" id="profile-dropdown" role="menu">
        <a href="/admin/profile" class="dropdown-item" role="menuitem">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Profile
        </a>
        <div class="dropdown-divider"></div>
        <a href="/sign-out" class="dropdown-item dropdown-item--danger" role="menuitem" id="sign-out-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Sign Out
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
  }

  .header-logo-mask {
    position: relative;
    width: 800px;
    height: 320px;
    mask-image: url("/logo-mask.svg");
    -webkit-mask-image: url("/logo-mask.svg");
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center center;
    -webkit-mask-position: center center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.5))
      drop-shadow(0 0 20px rgba(255, 100, 200, 0.3));
    pointer-events: none;
  }

  .header-gradient-layer {
    position: absolute;
    width: 1200px;
    height: 480px;
    left: -200px;
    top: -80px;
    transform: translate3d(0, 0, 0);
    background:
      radial-gradient(circle at 30% 30%, #ff0000 0%, transparent 40%),
      radial-gradient(circle at 70% 30%, #ff00ff 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, #00ffff 0%, transparent 40%),
      radial-gradient(circle at 30% 70%, #00ff00 0%, transparent 40%),
      radial-gradient(circle at 70% 70%, #ffff00 0%, transparent 40%),
      radial-gradient(
        ellipse at center,
        #ff0000 0%,
        #ffff00 25%,
        #00ffff 50%,
        #ff00ff 75%,
        #ff0000 100%
      );
    background-size: 600px 240px;
    background-repeat: repeat;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    contain: layout style paint;
    animation: headerGradientMove 20s linear infinite;
  }

  @keyframes headerGradientMove {
    0% {
      background-position: 0% 0%;
    }
    50% {
      background-position: 100% 100%;
    }
    100% {
      background-position: 0% 0%;
    }
  }

  /* Logo for non-index pages */
  .small-logo {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    display: block;
    text-decoration: none;
  }

  .small-logo .logo-svg {
    width: max(50vw, 280px);
    height: auto;
    animation: none;
    filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.5));
  }

  .small-logo path,
  .small-logo polygon {
    animation: colorShift 5s ease infinite;
  }

  @keyframes colorShift {
    0%,
    100% {
      color: #a855f7;
    }
    33% {
      color: #ec4899;
    }
    66% {
      color: #06b6d4;
    }
  }

  /* @media screen and (min-width: 768px) {
    .header {
      height: 400px;
    }
    .header-logo-mask {
      width: 1000px;
      height: 400px;
    }
    .header-gradient-layer {
      width: 1600px;
      height: 640px;
      left: -300px;
      top: -120px;
      background-size: 800px 320px;
    }
    .small-logo .logo-svg {
      width: 56px;
      height: 56px;
    }
  } */

  @media screen and (min-width: 1024px) {
    .header {
      height: 480px;
    }
    .header-logo-mask {
      width: 1200px;
      height: 480px;
    }
    .header-gradient-layer {
      width: 2000px;
      height: 800px;
      left: -400px;
      top: -160px;
      background-size: 1000px 400px;
    }
  }

  /* ── Profile dock (top-right, all pages) ── */
  .profile-dock {
    position: fixed;
    top: 16px;
    right: 20px;
    z-index: 2000;
  }

  .profile-menu-wrapper {
    position: relative;
  }

  .profile-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(168, 85, 247, 0.5);
    background: rgba(168, 85, 247, 0.15);
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .profile-btn:hover {
    border-color: rgba(168, 85, 247, 0.9);
    box-shadow: 0 0 14px rgba(168, 85, 247, 0.4);
  }

  .profile-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .profile-initials {
    font-size: 13px;
    font-weight: 700;
    color: #a855f7;
    font-family: 'Inter', -apple-system, sans-serif;
    letter-spacing: 0.02em;
    user-select: none;
  }

  .profile-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: rgba(14, 14, 16, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 6px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(20px);
  }

  .profile-dropdown.is-open {
    display: block;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'Inter', -apple-system, sans-serif;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
  }

  .dropdown-item--danger { color: rgba(248, 113, 113, 0.85); }
  .dropdown-item--danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .dropdown-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 4px 0;
  }
</style>

<script>
  const toggle = document.getElementById("profile-toggle");
  const dropdown = document.getElementById("profile-dropdown");

  if (toggle && dropdown) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = dropdown.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(open));
    });

    document.addEventListener("click", () => {
      dropdown.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        dropdown.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  // Handle sign-out
  const signOutLink = document.getElementById("sign-out-link");
  if (signOutLink) {
    signOutLink.addEventListener("click", async (e) => {
      e.preventDefault();
      // Clerk's session cookie is cleared via the Clerk JS SDK
      // Redirect to Clerk's sign-out endpoint
      const { Clerk } = window as any;
      if (Clerk) {
        await Clerk.signOut();
        window.location.href = "/";
      } else {
        window.location.href = "/sign-out";
      }
    });
  }
</script>
