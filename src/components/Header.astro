---
import { getCompanyConfig } from "../lib/companyConfig";
import {
  MessageCircle,
  BookOpen,
  Mail,
  Briefcase,
  Users,
  CheckSquare,
  FileText,
  Zap,
  Monitor,
  Wrench,
  LayoutDashboard,
} from "lucide-astro";

interface Props {
  /** Admin SPA shell — tools menu filled by os-map-loader.js */
  adminShell?: boolean;
  /** Hide logo link (homepage — logo lives in page content) */
  hideLogo?: boolean;
  /** Homepage — single user icon links to admin instead of tools/profile menus */
  homeAdminEntry?: boolean;
}

const { adminShell = false, hideLogo = false, homeAdminEntry = false } = Astro.props;

const company = await getCompanyConfig(Astro.request);
const logoPath = company.logoPath || "/logo.png";

const adminSpaTabs = [
  { tab: "chats", label: "Chats", Icon: MessageCircle },
  { tab: "knowledge", label: "Knowledge", Icon: BookOpen },
  { tab: "email", label: "Inbox", Icon: Mail },
  { tab: "work", label: "Work", Icon: Briefcase },
  { tab: "clients", label: "Clients", Icon: Users },
  { tab: "todo", label: "To-do", Icon: CheckSquare },
  { tab: "documents", label: "Documents", Icon: FileText },
  { tab: "rules", label: "Rules", Icon: Zap },
  { tab: "system", label: "System", Icon: Monitor },
  { tab: "tooling", label: "MCP & CLI", Icon: Wrench },
] as const;

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;
---

<header
  class:list={["app-header", { "app-header--admin": adminShell }]}
  id={adminShell ? "topbar" : undefined}
>
  {!hideLogo && (
    <a href="/" class="app-header-logo brand" aria-label={company.name || "Home"}>
      <img src={logoPath} alt={company.name} class="app-header-logo-img brand-img logo-img" />
    </a>
  )}

  <div id="topbar-panel-context" class="topbar-panel-context" hidden></div>

  {!userId && (
    <a href="/sign-in" class="app-header-signin" aria-label="Sign in" title="Sign in">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </a>
  )}

  {userId && (
    <div class="app-header-end topbar-end">
      {adminShell ? (
        <>
          <button
            type="button"
            id="push-enable-btn"
            class="app-header-icon-btn topbar-icon-btn topbar-push-btn"
            aria-label="Enable push notifications"
            title="Enable push notifications"
            hidden
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          </button>
          <div class="app-header-menu topbar-menu topbar-profile-menu">
            <button
              type="button"
              id="topbar-profile-toggle"
              class="app-header-profile-btn topbar-profile-btn"
              aria-label="Account menu"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </button>
            <div id="topbar-profile-menu" class="app-header-dropdown topbar-dropdown" role="menu">
              <button type="button" id="topbar-profile-link" class="topbar-dropdown-item" role="menuitem">
                Profile
              </button>
              <div class="topbar-dropdown-divider"></div>
              <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">
                Sign out
              </button>
            </div>
          </div>
        </>
      ) : homeAdminEntry ? (
        <a
          href="/admin/"
          class="app-header-admin-entry"
          aria-label="Administration"
          title="Administration"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </a>
      ) : (
        <>
          <div class="app-header-menu topbar-menu topbar-tools-menu">
            <button
              type="button"
              id="topbar-tools-toggle"
              class="app-header-icon-btn topbar-icon-btn topbar-tools-btn"
              aria-label="Tools"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </button>
            <div id="topbar-tools-menu" class="app-header-dropdown topbar-dropdown" role="menu" aria-label="Tools">
              <a href="/admin/" class="topbar-dropdown-item" role="menuitem">
                <span class="topbar-dropdown-icon" aria-hidden="true"><LayoutDashboard size={16} strokeWidth={1.75} /></span>
                <span>Administration</span>
              </a>
              <div class="topbar-dropdown-divider"></div>
              {adminSpaTabs.map(({ tab, label, Icon }) => (
                <a href={`/admin/?tab=${tab}`} class="topbar-dropdown-item" role="menuitem">
                  <span class="topbar-dropdown-icon" aria-hidden="true"><Icon size={16} strokeWidth={1.75} /></span>
                  <span>{label}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="app-header-menu topbar-menu topbar-profile-menu">
            <button
              type="button"
              id="topbar-profile-toggle"
              class="app-header-profile-btn topbar-profile-btn"
              aria-label="Account menu"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </button>
            <div id="topbar-profile-menu" class="app-header-dropdown topbar-dropdown" role="menu">
              <a href="/admin/profile" class="topbar-dropdown-item" role="menuitem">Profile</a>
              <div class="topbar-dropdown-divider"></div>
              <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">
                Sign out
              </button>
            </div>
          </div>
        </>
      )}
    </div>
  )}

  {adminShell && (
    <time id="topbar-dash-date" class="topbar-dash-date" datetime="" hidden></time>
  )}
</header>

<style is:global>
  :root {
    --app-header-h: 4rem;
  }

  .app-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: var(--app-header-h);
    padding:
      env(safe-area-inset-top, 0px)
      max(0.75rem, env(safe-area-inset-right, 0px))
      0
      max(0.75rem, env(safe-area-inset-left, 0px));
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .app-header--admin {
    z-index: 20;
    min-height: calc(var(--app-header-h) + env(safe-area-inset-top, 0px));
    background: transparent;
    border-bottom: none;
  }

  .app-header--admin::before {
    content: none;
  }

  .app-header--admin > * {
    position: relative;
    z-index: 1;
  }

  .app-header--admin .topbar-end {
    margin-left: auto;
  }

  .topbar-panel-context {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
    margin-left: 0.15rem;
    overflow: hidden;
  }

  .topbar-panel-context[hidden] {
    display: none !important;
  }

  .topbar-panel-context .topbar-panel-title {
    flex: 1;
    min-width: 0;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .topbar-panel-context .ch-header-title-input {
    flex: 1;
    min-width: 0;
    max-width: 100%;
  }

  .topbar-panel-context .ch-model-badge,
  .topbar-panel-context .ch-model-switcher {
    margin-left: 0;
    flex-shrink: 0;
  }

  .topbar-panel-actions {
    display: flex;
    align-items: center;
    gap: 0.05rem;
    flex-shrink: 0;
    margin-left: 0.15rem;
  }

  .app-header--admin.topbar-has-panel-context .topbar-dash-date {
    display: none !important;
  }

  .app-header--admin.topbar-has-panel-context .topbar-end {
    margin-left: 0;
  }

  .app-header > * {
    pointer-events: auto;
  }

  .app-header-logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
    text-decoration: none;
  }

  .app-header-logo-img {
    height: 28px;
    width: auto;
    display: block;
    pointer-events: none;
  }

  .topbar-dash-date {
    flex-shrink: 0;
    margin-left: 0;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted, rgba(255, 255, 255, 0.55));
    letter-spacing: -0.01em;
    white-space: nowrap;
    text-align: right;
  }

  .app-header--admin:not(.topbar-has-panel-context):not(:has(.topbar-end .topbar-icon-btn:not([hidden]))) .topbar-dash-date:not([hidden]) {
    position: absolute;
    right: max(0.65rem, env(safe-area-inset-right, 0px));
    top: calc(env(safe-area-inset-top, 0px) + var(--app-header-h) / 2);
    transform: translateY(-50%);
  }

  .topbar-dash-date[hidden] {
    display: none !important;
  }

  .app-header-end,
  .topbar-end {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    margin-left: auto;
  }

  .app-header-signin {
    margin-left: auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 0.15s;
  }

  .app-header-signin:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  .app-header-signin svg {
    pointer-events: none;
  }

  .app-header-admin-entry {
    margin-left: auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    background: var(--panel, rgba(18, 23, 34, 0.9));
    color: var(--muted, rgba(255, 255, 255, 0.55));
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .app-header-admin-entry:hover {
    color: var(--fg, #e9eef6);
    border-color: #4b5563;
  }

  .app-header-admin-entry svg {
    pointer-events: none;
  }

  .app-header-menu {
    position: relative;
  }

  .app-header-icon-btn,
  .topbar-icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    background: var(--panel, rgba(18, 23, 34, 0.9));
    color: var(--muted, rgba(255, 255, 255, 0.55));
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    line-height: 1;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .topbar-tools-btn {
    position: relative;
    border-color: rgba(148, 163, 184, 0.35);
    background: rgba(148, 163, 184, 0.08);
    color: rgba(148, 163, 184, 0.95);
  }

  .topbar-tools-btn.has-badge {
    border-color: rgba(251, 191, 36, 0.55);
    background: rgba(251, 191, 36, 0.08);
  }

  .topbar-push-btn {
    border-color: rgba(239, 68, 68, 0.85);
    background: rgba(239, 68, 68, 0.1);
    color: rgba(252, 165, 165, 0.98);
    box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.35);
  }

  .topbar-push-btn:hover {
    border-color: rgba(248, 113, 113, 1);
    color: #fecaca;
    box-shadow: 0 0 0 1px rgba(248, 113, 113, 0.5);
  }

  .topbar-push-btn[hidden] {
    display: none !important;
  }

  .app-header-icon-btn:hover,
  .topbar-icon-btn:hover {
    color: var(--fg, #e9eef6);
    border-color: #4b5563;
  }

  .app-header-profile-btn,
  .topbar-profile-btn {
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--nav-icon, var(--muted, rgba(255, 255, 255, 0.55)));
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
  }

  .app-header-profile-btn:hover,
  .topbar-profile-btn:hover {
    color: var(--nav-icon-hover, var(--fg, #e9eef6));
  }

  .topbar-profile-btn svg {
    display: block;
    pointer-events: none;
  }

  .topbar-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 0 0 2px var(--bg, #0a0d14);
  }

  .app-header-dropdown,
  .topbar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 188px;
    max-width: min(88vw, 260px);
    max-height: min(62vh, 420px);
    overflow-y: auto;
    background: var(--dropdown-bg);
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    border-radius: 10px;
    padding: 0.35rem;
    box-shadow: var(--dropdown-shadow, 0 16px 40px rgba(0, 0, 0, 0.55));
    z-index: 120;
  }

  .app-header-dropdown.open,
  .topbar-dropdown.open {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .topbar-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.5rem 0.55rem;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted, rgba(255, 255, 255, 0.62));
    background: transparent;
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
  }

  .topbar-dropdown-item:hover {
    color: var(--fg, #e9eef6);
    background: var(--surface-hover, rgba(255, 255, 255, 0.05));
  }

  .topbar-dropdown-item.active {
    color: var(--fg, #e9eef6);
    background: var(--list-item-active-bg, #11253d);
    border-color: var(--list-item-active-border, #2d5a94);
  }

  .topbar-dropdown-item--danger {
    color: rgba(248, 113, 113, 0.9);
  }

  .topbar-dropdown-item--danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .topbar-dropdown-divider {
    height: 1px;
    background: var(--panel-border, rgba(255, 255, 255, 0.08));
    margin: 0.2rem 0;
  }

  .topbar-dropdown-icon {
    width: 1rem;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--icon-muted, rgba(255, 255, 255, 0.72));
  }

  .topbar-dropdown-icon svg {
    display: block;
  }

  @media print {
    .app-header {
      display: none !important;
    }
  }
</style>

{!adminShell && !homeAdminEntry && (
  <script>
    function closeHeaderMenus(exceptMenu?: HTMLElement | null) {
      for (const menu of document.querySelectorAll(".topbar-dropdown")) {
        if (exceptMenu && menu === exceptMenu) continue;
        menu.classList.remove("open");
      }
      document.getElementById("topbar-tools-toggle")?.setAttribute("aria-expanded", "false");
      document.getElementById("topbar-profile-toggle")?.setAttribute("aria-expanded", "false");
    }

    function toggleHeaderMenu(menuEl: HTMLElement | null, toggleEl: HTMLElement | null) {
      if (!menuEl || !toggleEl) return;
      const willOpen = !menuEl.classList.contains("open");
      closeHeaderMenus(null);
      if (willOpen) {
        menuEl.classList.add("open");
        toggleEl.setAttribute("aria-expanded", "true");
      }
    }

    const toolsToggle = document.getElementById("topbar-tools-toggle");
    const toolsMenu = document.getElementById("topbar-tools-menu");
    toolsToggle?.addEventListener("click", (ev) => {
      ev.stopPropagation();
      toggleHeaderMenu(toolsMenu, toolsToggle);
    });

    const profileToggle = document.getElementById("topbar-profile-toggle");
    const profileMenu = document.getElementById("topbar-profile-menu");
    profileToggle?.addEventListener("click", (ev) => {
      ev.stopPropagation();
      toggleHeaderMenu(profileMenu, profileToggle);
    });

    document.getElementById("topbar-sign-out")?.addEventListener("click", async (ev) => {
      ev.preventDefault();
      closeHeaderMenus(null);
      const { Clerk } = window as Window & { Clerk?: { signOut: () => Promise<void> } };
      if (Clerk) {
        await Clerk.signOut();
        window.location.href = "/";
      } else {
        window.location.href = "/sign-out";
      }
    });

    if (!document.documentElement.dataset.headerMenuBound) {
      document.documentElement.dataset.headerMenuBound = "1";
      document.addEventListener("click", () => closeHeaderMenus(null));
      document.addEventListener("keydown", (ev) => {
        if (ev.key === "Escape") closeHeaderMenus(null);
      });
    }
  </script>
)}
