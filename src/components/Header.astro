---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { getCompanyConfig, companyStaffAvatarUrl } from "../lib/companyConfig";
import { PROFILE_MENU_LABELS, type ProfileMenuKey } from "../lib/installConfig";
import SignInSheet from "./SignInSheet.astro";
import {
  Shield,
  LayoutDashboard,
} from "lucide-astro";

const headerLogoMarkup = readFileSync(
  join(process.cwd(), "public/reave-logo.svg"),
  "utf8",
)
  .replace(/<\?xml[\s\S]*?\?>\s*/i, "")
  .replace(
    /xlink:href="reave-logo-1\.png"/g,
    'href="/reave-logo-1.png" xlink:href="/reave-logo-1.png"',
  )
  .replace(
    /<svg\b/,
    '<svg class="app-header-logo-svg brand-img logo-img" aria-hidden="true" focusable="false"',
  );

interface Props {
  /** Admin SPA shell — profile menu; tab nav lives in footer */
  adminShell?: boolean;
  /** Hide logo link (homepage — logo lives in page content) */
  hideLogo?: boolean;
  /** Homepage — single user icon links to admin instead of tools/profile menus */
  homeAdminEntry?: boolean;
  /** Client portal (or similar) — signed-in staff see an obvious Admin indicator */
  staffPreview?: boolean;
  /** Settings links in the account dropdown (from install config). */
  profileMenu?: readonly ProfileMenuKey[];
  /** Open the sign-in bottom sheet on load (signed-out admin shell). */
  signInAutoOpen?: boolean;
}

const {
  adminShell = false,
  hideLogo = false,
  homeAdminEntry = false,
  staffPreview = false,
  profileMenu = [],
  signInAutoOpen: signInAutoOpenProp = false,
} = Astro.props;

const company = await getCompanyConfig(Astro.request);
const profileIconSrc = companyStaffAvatarUrl(company);

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const inAdminRoute = adminShell || path.startsWith("/admin");
const logoHref = inAdminRoute ? "/admin/?tab=home" : "/";
const logoAriaLabel = inAdminRoute ? "Dashboard" : company.name || "Home";
const returnTo = Astro.url.searchParams.get("returnTo");
const signInRedirect =
  returnTo && returnTo.startsWith("/") && !returnTo.startsWith("//")
    ? returnTo
    : path.startsWith("/admin")
      ? "/admin/"
      : path === "/sign-in" || path === "/sign-up"
        ? "/admin/"
        : Astro.url.pathname + Astro.url.search;
const signInAutoOpen = signInAutoOpenProp || Astro.url.searchParams.get("auth") === "sign-in" || path === "/sign-in";
---

<header
  class:list={["app-header", { "app-header--admin": adminShell }]}
  id={adminShell ? "topbar" : undefined}
>
  <div class:list={["app-header-row", { "app-header-row--admin": adminShell }]}>
  {!hideLogo ? (
    <a href={logoHref} class="app-header-logo brand" aria-label={logoAriaLabel}>
      <Fragment set:html={headerLogoMarkup} />
    </a>
  ) : null}

  <div id="topbar-panel-context" class="topbar-panel-context" hidden></div>

  {!userId && (
    <button
      type="button"
      class="app-header-signin"
      data-ios-sheet-open="sign-in-sheet"
      aria-label="Sign in"
      title="Sign in"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
    </button>
  )}

  {userId && (
    <div class="app-header-end topbar-end">
      {adminShell ? (
        <>
          <button
            type="button"
            id="push-enable-btn"
            class="app-header-icon-btn topbar-icon-btn topbar-push-btn"
            aria-label="Enable push notifications"
            title="Enable push notifications"
            hidden
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          </button>
          <div class="topbar-profile-cluster">
            <button
              type="button"
              id="topbar-deploy-dot"
              class="topbar-deploy-dot tt-left"
              hidden
              aria-label="Deploy status"
              data-tooltip=""
            ></button>
            <div class="app-header-menu topbar-menu topbar-profile-menu">
              <button
                type="button"
                id="topbar-profile-toggle"
                class="app-header-profile-btn topbar-profile-btn"
                aria-label="Account menu"
                aria-expanded="false"
                aria-haspopup="true"
              >
                <img
                  src={profileIconSrc}
                  alt=""
                  class="topbar-profile-icon-img"
                  aria-hidden="true"
                  loading="eager"
                  decoding="async"
                />
              </button>
              <span id="topbar-review-badge" class="topbar-badge" hidden>0</span>
              <div id="topbar-profile-menu" class="app-header-dropdown topbar-dropdown" role="menu">
              {profileMenu.map((key) => (
                <button
                  type="button"
                  id={`topbar-${key}-link`}
                  class="topbar-dropdown-item"
                  role="menuitem"
                >
                  {PROFILE_MENU_LABELS[key]}
                </button>
              ))}
              <div class="topbar-dropdown-divider"></div>
              <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">
                Sign out
              </button>
              </div>
            </div>
          </div>
        </>
      ) : homeAdminEntry ? (
        <div class="topbar-profile-hit">
          <a
            href="/admin/"
            class="app-header-admin-entry"
            aria-label="Administration"
            title="Administration"
          >
            <img
              src={profileIconSrc}
              alt=""
              class="topbar-profile-icon-img topbar-profile-icon-img--round"
              aria-hidden="true"
              loading="eager"
              decoding="async"
            />
          </a>
          <span id="topbar-review-badge" class="topbar-badge" hidden>0</span>
        </div>
      ) : (
        <div class="app-header-menu topbar-menu topbar-profile-menu">
          <button
            type="button"
            id="topbar-profile-toggle"
            class:list={[
              "app-header-profile-btn",
              "topbar-profile-btn",
              { "topbar-profile-btn--admin": staffPreview },
            ]}
            aria-label={staffPreview ? "Admin account (signed in)" : "Account menu"}
            title={staffPreview ? "Signed in as admin" : "Account menu"}
            aria-expanded="false"
            aria-haspopup="true"
          >
            {staffPreview ? (
              <>
                <Shield size={16} strokeWidth={2} aria-hidden="true" />
                <span class="topbar-admin-label">Admin</span>
              </>
            ) : (
              <img
                src={profileIconSrc}
                alt=""
                class="topbar-profile-icon-img"
                aria-hidden="true"
                loading="eager"
                decoding="async"
              />
            )}
          </button>
          <span id="topbar-review-badge" class="topbar-badge" hidden>0</span>
          <div id="topbar-profile-menu" class="app-header-dropdown topbar-dropdown" role="menu">
            {staffPreview && (
              <div class="topbar-dropdown-admin-note" role="presentation">
                Viewing as admin
              </div>
            )}
            <a href="/admin/profile" class="topbar-dropdown-item" role="menuitem">Profile</a>
            <a href="/admin/" class="topbar-dropdown-item" role="menuitem">
              <span class="topbar-dropdown-icon" aria-hidden="true"><LayoutDashboard size={16} strokeWidth={1.75} /></span>
              <span>Administration</span>
            </a>
            <div class="topbar-dropdown-divider"></div>
            <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">
              Sign out
            </button>
          </div>
        </div>
      )}
    </div>
  )}

  {adminShell && (
    <time id="topbar-dash-date" class="topbar-dash-date" datetime="" hidden></time>
  )}
  </div>

  {adminShell && (
    <div id="admin-setup-alerts" class="admin-setup-alerts" hidden aria-live="polite"></div>
  )}
</header>

{!userId && (
  <SignInSheet fallbackRedirectUrl={signInRedirect} autoOpen={signInAutoOpen} />
)}

{userId && (
  <script src="/review-badge.js?v=20260717a" defer></script>
)}

<style is:global>
  :root {
    --app-header-h: 3.25rem;
    --app-header-chrome-scale: 1.333;
    --app-header-logo-h: calc(24px * var(--app-header-chrome-scale));
    --app-header-profile-h: calc(24px * var(--app-header-chrome-scale));
    --app-header-profile-icon-h: calc(16px * var(--app-header-chrome-scale));
    --app-header-signin-h: calc(32px * var(--app-header-chrome-scale));
    --app-header-signin-icon-h: calc(18px * var(--app-header-chrome-scale));
    --app-header-icon-btn-h: calc(36px * var(--app-header-chrome-scale));
    --app-header-icon-btn-icon-h: calc(18px * var(--app-header-chrome-scale));
    --radius-input: 8px;
    --control-h: 2.5rem;
    --footer-nav-pill-h: var(--control-h);
    --footer-nav-glass-border: 1px solid rgba(0, 0, 0, 0.08);
    --footer-nav-glass-bg: transparent;
    --footer-nav-glass-blur: blur(18px) saturate(1.15);
    --nav-icon: rgba(0, 0, 0, 0.45);
    --nav-icon-hover: rgba(0, 0, 0, 0.72);
    --nav-icon-active: #0f172a;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --footer-nav-glass-border: 1px solid rgba(255, 255, 255, 0.08);
      --nav-icon: rgba(255, 255, 255, 0.58);
      --nav-icon-hover: rgba(255, 255, 255, 0.88);
      --nav-icon-active: #ffffff;
    }
  }

  .app-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: var(--app-header-h);
    padding:
      env(safe-area-inset-top, 0px)
      max(0.5rem, env(safe-area-inset-right, 0px))
      0
      max(0.5rem, env(safe-area-inset-left, 0px));
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .app-header--admin {
    z-index: 20;
    flex-direction: column;
    align-items: stretch;
    min-height: 0;
    padding: 0;
    background: transparent;
    border-bottom: none;
  }

  .app-header-row--admin {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    min-height: calc(var(--app-header-h) + env(safe-area-inset-top, 0px));
    padding:
      env(safe-area-inset-top, 0px)
      max(0.5rem, env(safe-area-inset-right, 0px))
      0
      max(0.5rem, env(safe-area-inset-left, 0px));
  }

  .app-header--admin::before {
    content: none;
  }

  .app-header--admin .app-header-row > * {
    position: relative;
    z-index: 1;
  }

  .app-header--admin .app-header-row .topbar-end {
    margin-left: auto;
  }

  .topbar-panel-context {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
    margin-left: 0.15rem;
    overflow: hidden;
  }

  .topbar-panel-context[hidden] {
    display: none !important;
  }

  .topbar-panel-context .topbar-panel-title {
    flex: 1;
    min-width: 0;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .topbar-panel-context .ch-model-badge,
  .topbar-panel-context .ch-model-switcher {
    margin-left: 0;
    flex-shrink: 0;
  }

  .topbar-panel-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    margin-left: 0.15rem;
  }
  .topbar-end .topbar-panel-actions {
    margin-left: 0;
  }
  /* Match panel action buttons to topbar icon-btn size (ios-icon-btn defaults to 44px). */
  .app-header--admin .topbar-end .topbar-panel-actions .ios-icon-btn {
    width: var(--app-header-icon-btn-h);
    height: var(--app-header-icon-btn-h);
  }
  .app-header--admin .topbar-end .topbar-panel-actions .ios-icon-btn svg {
    width: var(--app-header-icon-btn-icon-h);
    height: var(--app-header-icon-btn-icon-h);
  }

  .app-header--admin.topbar-has-panel-context .topbar-dash-date {
    display: none !important;
  }

  .app-header--admin.topbar-has-panel-context .topbar-end {
    margin-left: 0;
  }

  .app-header > *,
  .app-header-row > * {
    pointer-events: auto;
  }

  .app-header:not(.app-header--admin) .app-header-row {
    display: contents;
  }

  .app-header-logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
    text-decoration: none;
    mix-blend-mode: difference;
  }

  .app-header-logo-svg {
    display: block;
    height: var(--app-header-logo-h);
    width: calc(var(--app-header-logo-h) * (1014 / 329));
    max-width: none;
    pointer-events: none;
  }

  .topbar-dash-date {
    flex-shrink: 0;
    margin-left: 0;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted, rgba(255, 255, 255, 0.55));
    letter-spacing: -0.01em;
    white-space: nowrap;
    text-align: right;
  }

  .app-header--admin:not(.topbar-has-panel-context):not(:has(.app-header-row .topbar-end .topbar-icon-btn:not([hidden]))) .topbar-dash-date:not([hidden]) {
    position: absolute;
    right: max(0.65rem, env(safe-area-inset-right, 0px));
    top: calc(env(safe-area-inset-top, 0px) + var(--app-header-h) / 2);
    transform: translateY(-50%);
  }

  .app-header-row--admin {
    position: relative;
    overflow: visible;
  }

  .topbar-dash-date[hidden] {
    display: none !important;
  }

  .app-header-end,
  .topbar-end {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.35rem;
    flex-shrink: 0;
    margin-left: auto;
    overflow: visible;
  }

  .app-header-signin {
    margin-left: auto;
    width: var(--app-header-signin-h);
    height: var(--app-header-signin-h);
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    padding: 0;
    font: inherit;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
  }

  .app-header-signin:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  .app-header-signin svg {
    width: var(--app-header-signin-icon-h);
    height: var(--app-header-signin-icon-h);
    pointer-events: none;
  }

  .app-header-admin-entry {
    position: relative;
    margin-left: auto;
    width: var(--app-header-signin-h);
    height: var(--app-header-signin-h);
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .app-header-admin-entry:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  .app-header-admin-entry svg {
    width: var(--app-header-signin-icon-h);
    height: var(--app-header-signin-icon-h);
    pointer-events: none;
  }

  .app-header-menu {
    position: relative;
    overflow: visible;
  }

  .topbar-profile-hit {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    overflow: visible;
  }

  .topbar-profile-cluster {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
    overflow: visible;
  }

  .app-header-icon-btn,
  .topbar-icon-btn {
    width: var(--app-header-icon-btn-h);
    height: var(--app-header-icon-btn-h);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    background: var(--panel, rgba(18, 23, 34, 0.9));
    color: var(--muted, rgba(255, 255, 255, 0.55));
    cursor: pointer;
    padding: 0;
    font-size: 1rem;
    line-height: 1;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .app-header-icon-btn:hover,
  .topbar-icon-btn:hover {
    color: var(--fg, #e9eef6);
    border-color: #4b5563;
  }

  .app-header:not(.app-header--admin) .topbar-profile-btn {
    color: rgba(255, 255, 255, 0.58);
  }

  .app-header:not(.app-header--admin) .topbar-profile-btn:hover,
  .app-header:not(.app-header--admin) .topbar-profile-menu:has(.topbar-dropdown.open) .topbar-profile-btn {
    color: rgba(255, 255, 255, 0.88);
  }

  .topbar-push-btn {
    border-color: rgba(239, 68, 68, 0.85);
    background: rgba(239, 68, 68, 0.1);
    color: rgba(252, 165, 165, 0.98);
    box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.35);
  }

  .topbar-push-btn:hover {
    border-color: rgba(248, 113, 113, 1);
    color: #fecaca;
    box-shadow: 0 0 0 1px rgba(248, 113, 113, 0.5);
  }

  .topbar-push-btn[hidden] {
    display: none !important;
  }

  .app-header-icon-btn svg,
  .topbar-icon-btn svg {
    width: var(--app-header-icon-btn-icon-h);
    height: var(--app-header-icon-btn-icon-h);
    pointer-events: none;
  }

  .app-header-profile-btn,
  .topbar-profile-btn {
    position: relative;
    width: var(--app-header-profile-h);
    height: var(--app-header-profile-h);
    min-width: var(--app-header-profile-h);
    border: none;
    border-radius: var(--radius-input, 8px);
    background: var(--footer-nav-glass-bg, transparent);
    backdrop-filter: var(--footer-nav-glass-blur, blur(18px) saturate(1.15));
    -webkit-backdrop-filter: var(--footer-nav-glass-blur, blur(18px) saturate(1.15));
    color: var(--nav-icon, var(--muted, rgba(255, 255, 255, 0.55)));
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s, background 0.15s;
  }

  .app-header-profile-btn:hover,
  .topbar-profile-btn:hover {
    color: var(--nav-icon-hover, var(--fg, #e9eef6));
  }

  .topbar-profile-menu:has(.topbar-dropdown.open) .topbar-profile-btn {
    color: var(--nav-icon-active, var(--fg, #e9eef6));
  }

  .topbar-deploy-dot {
    position: relative;
    width: 9px;
    height: 9px;
    margin-right: 2px;
    padding: 0;
    border: none;
    border-radius: 50%;
    flex-shrink: 0;
    cursor: pointer;
    background: #6b7280;
    box-shadow: 0 0 3px 1px rgba(107, 114, 128, 0.35);
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.12s ease;
  }

  .topbar-deploy-dot:hover {
    transform: scale(1.08);
  }

  .topbar-deploy-dot[hidden] {
    display: none !important;
  }

  .topbar-deploy-dot--live {
    background: #22c55e;
    box-shadow:
      0 0 3px 1px rgba(34, 197, 94, 0.55),
      0 0 8px 2px rgba(34, 197, 94, 0.2);
    animation: topbar-deploy-bulb-pulse 5s ease-in-out infinite;
  }

  .topbar-deploy-dot--deploying {
    background: #eab308;
    box-shadow:
      0 0 3px 1px rgba(234, 179, 8, 0.55),
      0 0 8px 2px rgba(234, 179, 8, 0.22);
    animation: topbar-deploy-bulb-pulse 5s ease-in-out infinite;
  }

  .topbar-deploy-dot--alert {
    background: #ef4444;
    box-shadow:
      0 0 3px 1px rgba(239, 68, 68, 0.55),
      0 0 8px 2px rgba(239, 68, 68, 0.22);
    animation: topbar-deploy-bulb-pulse 5s ease-in-out infinite;
  }

  @keyframes topbar-deploy-bulb-pulse {
    0%, 100% {
      filter: brightness(1);
      opacity: 1;
    }
    50% {
      filter: brightness(1.08);
      opacity: 0.9;
    }
  }

  .topbar-profile-btn svg {
    display: block;
    width: var(--app-header-profile-icon-h);
    height: var(--app-header-profile-icon-h);
    pointer-events: none;
  }

  .topbar-profile-btn .topbar-profile-icon-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: var(--radius-input, 8px);
    pointer-events: none;
  }

  .topbar-profile-btn .topbar-profile-icon-img--round,
  .app-header-admin-entry .topbar-profile-icon-img {
    object-fit: cover;
  }

  .topbar-profile-btn .topbar-profile-icon-img--round {
    border-radius: 50%;
  }

  .topbar-profile-btn:has(.topbar-profile-icon-img:not(.topbar-profile-icon-img--round)) {
    padding: 2px;
    overflow: visible;
  }

  .app-header-admin-entry .topbar-profile-icon-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    pointer-events: none;
  }

  .app-header-admin-entry:has(.topbar-profile-icon-img) {
    padding: 0;
    overflow: visible;
  }

  .topbar-profile-btn--admin {
    width: auto;
    min-width: var(--app-header-profile-h);
    height: var(--app-header-profile-h);
    padding: 0 0.65rem 0 0.55rem;
    gap: 0.35rem;
    background: rgba(168, 85, 247, 0.14);
    color: #e9d5ff;
  }

  .topbar-profile-btn--admin:hover,
  .topbar-profile-menu:has(.topbar-dropdown.open) .topbar-profile-btn--admin {
    background: rgba(168, 85, 247, 0.22);
    color: #f3e8ff;
  }

  .topbar-admin-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
    pointer-events: none;
  }

  .topbar-dropdown-admin-note {
    padding: 0.35rem 0.55rem 0.25rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(192, 132, 252, 0.95);
  }

  .topbar-badge {
    position: absolute;
    top: calc(-4px * var(--app-header-chrome-scale));
    right: calc(-4px * var(--app-header-chrome-scale));
    min-width: calc(14px * var(--app-header-chrome-scale));
    height: calc(14px * var(--app-header-chrome-scale));
    padding: 0 calc(3px * var(--app-header-chrome-scale));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: calc(0.5rem * var(--app-header-chrome-scale));
    font-weight: 700;
    line-height: 1;
    text-align: center;
    pointer-events: none;
    z-index: 5;
  }

  .topbar-profile-menu > .topbar-badge,
  .topbar-profile-hit > .topbar-badge {
    z-index: 6;
  }

  .topbar-badge[hidden] {
    display: none !important;
  }

  .app-header-dropdown,
  .topbar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 188px;
    max-width: min(88vw, 260px);
    max-height: min(62vh, 420px);
    overflow-y: auto;
    background: var(--dropdown-bg);
    border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.12));
    border-radius: 10px;
    padding: 0.35rem;
    box-shadow: var(--dropdown-shadow, 0 16px 40px rgba(0, 0, 0, 0.55));
    z-index: 120;
  }

  .app-header-dropdown.open,
  .topbar-dropdown.open {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .topbar-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.5rem 0.55rem;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted, rgba(255, 255, 255, 0.62));
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-input, 8px);
    cursor: pointer;
    text-align: left;
    text-decoration: none;
  }

  .topbar-dropdown-item:hover {
    color: var(--fg, #e9eef6);
    background: var(--surface-hover, rgba(255, 255, 255, 0.05));
  }

  .topbar-dropdown-item.active {
    color: var(--fg, #e9eef6);
    background: var(--list-item-active-bg, #11253d);
    border-color: var(--list-item-active-border, #2d5a94);
  }

  .topbar-dropdown-item--danger {
    color: rgba(248, 113, 113, 0.9);
  }

  .topbar-dropdown-item--danger:hover {
    background: rgba(239, 68, 68, 0.12);
    color: #f87171;
  }

  .topbar-dropdown-divider {
    height: 1px;
    background: var(--panel-border, rgba(255, 255, 255, 0.08));
    margin: 0.2rem 0;
  }

  .topbar-dropdown-icon {
    width: 1rem;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--icon-muted, rgba(255, 255, 255, 0.72));
  }

  .topbar-dropdown-icon svg {
    display: block;
  }

  @media print {
    .app-header {
      display: none !important;
    }
  }
</style>

{!adminShell && !homeAdminEntry && (
  <script>
    function closeHeaderMenus(exceptMenu?: HTMLElement | null) {
      for (const menu of document.querySelectorAll(".topbar-dropdown")) {
        if (exceptMenu && menu === exceptMenu) continue;
        menu.classList.remove("open");
      }
      document.getElementById("topbar-profile-toggle")?.setAttribute("aria-expanded", "false");
    }

    function toggleHeaderMenu(menuEl: HTMLElement | null, toggleEl: HTMLElement | null) {
      if (!menuEl || !toggleEl) return;
      const willOpen = !menuEl.classList.contains("open");
      closeHeaderMenus(null);
      if (willOpen) {
        menuEl.classList.add("open");
        toggleEl.setAttribute("aria-expanded", "true");
      }
    }

    const profileToggle = document.getElementById("topbar-profile-toggle");
    const profileMenu = document.getElementById("topbar-profile-menu");
    profileToggle?.addEventListener("click", (ev) => {
      ev.stopPropagation();
      toggleHeaderMenu(profileMenu, profileToggle);
    });

    document.getElementById("topbar-sign-out")?.addEventListener("click", async (ev) => {
      ev.preventDefault();
      closeHeaderMenus(null);
      const { Clerk } = window as Window & { Clerk?: { signOut: () => Promise<void> } };
      if (Clerk) {
        await Clerk.signOut();
        window.location.href = "/";
      } else {
        window.location.href = "/sign-out";
      }
    });

    if (!document.documentElement.dataset.headerMenuBound) {
      document.documentElement.dataset.headerMenuBound = "1";
      document.addEventListener("click", () => closeHeaderMenus(null));
      document.addEventListener("keydown", (ev) => {
        if (ev.key === "Escape") closeHeaderMenus(null);
      });
    }
  </script>
)}
