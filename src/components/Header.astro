---
interface Props {
  isIndex?: boolean;
}

const { isIndex = false } = Astro.props;
---

{isIndex ? (
<header class="header">
  <div class="header-logo-mask">
    <div class="header-gradient-layer"></div>
  </div>
</header>
) : (
<a href="/" class="small-logo">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="logo-svg">
    <path d="M84.7,313.4h-.5v-99.3h47.6c10.1,0,18.3,2.7,24.3,8.2,6,5.5,9.2,13.3,9.2,22.9s-1.4,11.4-3.7,15.1-5.5,6.9-9.2,8.7-7.3,3.2-11,4.1l26.1,40.3h-82.9Z" fill="currentColor"/>
    <path d="M241.2,313.4l42.1-99.3,42.6,99.3" fill="currentColor"/>
    <path d="M298.5,214.1h79.7l-40.3,99.3" fill="currentColor"/>
    <polygon points="251 258 175.9 258 175.9 224.7 264.7 224.7 251 258" fill="currentColor"/>
    <polygon points="232.7 303.8 175.9 303.8 175.9 270.5 246.4 270.5 232.7 303.8" fill="currentColor"/>
    <polygon points="368.2 270.5 443.3 270.5 443.3 303.8 354.4 303.8 368.2 270.5" fill="currentColor"/>
    <polygon points="386.5 224.7 443.3 224.7 443.3 258 372.7 258 386.5 224.7" fill="currentColor"/>
  </svg>
</a>
)}

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
  }

  .header-logo-mask {
    position: relative;
    width: 800px;
    height: 320px;
    mask-image: url("/logo-mask.svg");
    -webkit-mask-image: url("/logo-mask.svg");
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center center;
    -webkit-mask-position: center center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.5))
      drop-shadow(0 0 20px rgba(255, 100, 200, 0.3));
    pointer-events: none;
  }

  .header-gradient-layer {
    position: absolute;
    width: 1200px;
    height: 480px;
    left: -200px;
    top: -80px;
    transform: translate3d(0, 0, 0);
    background:
      radial-gradient(circle at 30% 30%, #ff0000 0%, transparent 40%),
      radial-gradient(circle at 70% 30%, #ff00ff 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, #00ffff 0%, transparent 40%),
      radial-gradient(circle at 30% 70%, #00ff00 0%, transparent 40%),
      radial-gradient(circle at 70% 70%, #ffff00 0%, transparent 40%),
      radial-gradient(
        ellipse at center,
        #ff0000 0%,
        #ffff00 25%,
        #00ffff 50%,
        #ff00ff 75%,
        #ff0000 100%
      );
    background-size: 600px 240px;
    background-repeat: repeat;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    contain: layout style paint;
    animation: headerGradientMove 20s linear infinite;
  }

  @keyframes headerGradientMove {
    0% { background-position: 0% 0%; }
    50% { background-position: 100% 100%; }
    100% { background-position: 0% 0%; }
  }

  /* Small logo for non-index pages */
  .small-logo {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 1000;
    display: block;
    text-decoration: none;
  }

  .small-logo .logo-svg {
    width: 48px;
    height: 48px;
    animation: none;
    filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.5));
  }

  .small-logo path, .small-logo polygon {
    animation: colorShift 5s ease infinite;
  }

  @keyframes colorShift {
    0%, 100% { color: #a855f7; }
    33% { color: #ec4899; }
    66% { color: #06b6d4; }
  }

  @media screen and (min-width: 768px) {
    .header { height: 400px; }
    .header-logo-mask { width: 1000px; height: 400px; }
    .header-gradient-layer { width: 1600px; height: 640px; left: -300px; top: -120px; background-size: 800px 320px; }
    .small-logo .logo-svg { width: 56px; height: 56px; }
  }

  @media screen and (min-width: 1024px) {
    .header { height: 480px; }
    .header-logo-mask { width: 1200px; height: 480px; }
    .header-gradient-layer { width: 2000px; height: 800px; left: -400px; top: -160px; background-size: 1000px 400px; }
    .small-logo .logo-svg { width: 64px; height: 64px; }
  }
</style>