---
export interface Props {
  /** Mask image URL. When omitted, nothing is rendered. */
  heroMask: string;
  /** Full-color logo PNG the particles resolve into (default /logo.png). */
  logoSrc: string;
  /** Canvas host element id. */
  hostId?: string;
  /** Homepage mask slide-in; centered keeps the logo in the middle; compact fits the header. */
  layout?: 'homepage' | 'centered' | 'compact';
  /** Particles rush inward from outside the mask on load. */
  introRush?: boolean;
  /** Rush duration in seconds (default 2). */
  introDuration?: number;
  /** Delay before WebGL init (homepage only, ms). */
  initDelay?: number;
  class?: string;
}

const {
  heroMask,
  logoSrc,
  hostId = 'quantumCanvasHost',
  layout = 'homepage',
  introRush = true,
  introDuration = 4,
  initDelay,
  class: className,
} = Astro.props;

const isHomepage = layout === 'homepage';
const isCompact = layout === 'compact';
const resolvedInitDelay = initDelay ?? (isHomepage ? 400 : 0);
---

<div
  class:list={[
    'quantum-logo-stack',
    'quantum-logo-stack--logo',
    isHomepage && 'quantum-logo-stack--homepage',
    layout === 'centered' && 'quantum-logo-stack--centered',
    isCompact && 'quantum-logo-stack--compact',
    className,
  ]}
  style={`--hero-logo-mask: url("${heroMask}")`}
  data-quantum-logo
  data-layout={layout}
  data-host-id={hostId}
  data-logo-src={logoSrc}
  data-hero-mask={heroMask}
  data-intro-rush={introRush ? 'true' : 'false'}
  data-intro-duration={String(introDuration)}
  data-init-delay={String(resolvedInitDelay)}
  aria-hidden="true"
>
  <div id={hostId} class="quantum-host"></div>
</div>

<style>
  .quantum-logo-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: auto;
    cursor: default;
    touch-action: none;
    overflow: hidden;
    --quantum-hero-logo-size: min(72vmin, 76vw, 420px);
  }

  /* Logo silhouette — CSS mask is the sole visibility clip from the first frame. */
  .quantum-logo-stack--logo:not(.quantum-logo-stack--compact),
  .quantum-logo-stack--compact {
    mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    -webkit-mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    mask-size: var(--quantum-hero-logo-size);
    -webkit-mask-size: var(--quantum-hero-logo-size);
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
  }

  .quantum-logo-stack--homepage.quantum-logo-stack--logo {
    mask-position: 42% center;
    -webkit-mask-position: 42% center;
    animation: quantumLogoIntro 1.4s ease-out forwards;
  }

  .quantum-logo-stack--centered {
    mask-position: center center;
    -webkit-mask-position: center center;
  }

  .quantum-logo-stack--compact {
    position: relative;
    inset: unset;
    width: 24px;
    height: 24px;
    flex: 0 0 24px;
    pointer-events: none;
    --quantum-hero-logo-size: contain;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center center;
    -webkit-mask-position: center center;
  }

  .quantum-logo-stack--compact .quantum-host {
    position: absolute;
    inset: 0;
  }

  .quantum-host {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    touch-action: none;
    overflow: hidden;
  }

  .quantum-host :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
    max-width: none;
    object-fit: cover;
  }

  @keyframes quantumLogoIntro {
    0% {
      mask-position: 42% center;
      -webkit-mask-position: 42% center;
    }
    100% {
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  @media (hover: none) {
    .quantum-logo-stack--homepage.quantum-logo-stack--logo {
      animation: none;
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  @media screen and (min-width: 768px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(64vmin, 68vw, 400px);
    }
  }

  @media screen and (min-width: 1024px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(56vmin, 60vw, 380px);
    }
  }

  @media screen and (min-width: 1440px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(48vmin, 52vw, 360px);
    }
  }

  @media screen and (min-width: 1920px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(42vmin, 46vw, 340px);
    }
  }

  @media screen and (min-width: 2560px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(36vmin, 40vw, 320px);
    }
  }
</style>

<script>
  import { attachQuantumCoreOpticalEngine } from '../lib/quantumCoreOpticalEngine';

  function logMaskStep(step: string, data?: Record<string, unknown>) {
    console.log(`[quantum-mask] ${step}`, data ?? '');
  }

  function readMaskDiagnostics(stack: HTMLElement | null): Record<string, unknown> {
    if (!stack) return { error: 'no stack element' };
    const cs = getComputedStyle(stack);
    const csExt = cs as CSSStyleDeclaration & {
      webkitMaskImage?: string;
      webkitMaskSize?: string;
      webkitMaskPosition?: string;
      webkitMaskMode?: string;
      webkitMaskRepeat?: string;
    };
    return {
      layout: stack.dataset.layout,
      hostId: stack.dataset.hostId,
      heroMask: stack.dataset.heroMask,
      classes: stack.className,
      heroLogoMaskVar: cs.getPropertyValue('--hero-logo-mask').trim(),
      maskImage: cs.maskImage || csExt.webkitMaskImage || '(none)',
      maskSize: cs.maskSize || csExt.webkitMaskSize || '(none)',
      maskPosition: cs.maskPosition || csExt.webkitMaskPosition || '(none)',
      maskMode: cs.maskMode || csExt.webkitMaskMode || '(none)',
      maskRepeat: cs.maskRepeat || csExt.webkitMaskRepeat || '(none)',
      filter: cs.filter || '(none)',
      rect: stack.getBoundingClientRect(),
    };
  }

  function prefersReducedMotion() {
    logMaskStep('prefersReducedMotion');
    return (
      typeof matchMedia !== 'undefined' &&
      matchMedia('(prefers-reduced-motion: reduce)').matches
    );
  }

  function waitForPreloaderGone(): Promise<void> {
    logMaskStep('waitForPreloaderGone');
    return new Promise((resolve) => {
      const boot = document.getElementById('boot');
      if (!boot) {
        logMaskStep('waitForPreloaderGone:no-boot');
        resolve();
        return;
      }
      logMaskStep('waitForPreloaderGone:watching-boot');
      const finish = () => {
        logMaskStep('waitForPreloaderGone:finished');
        obs?.disconnect();
        resolve();
      };
      const obs = new MutationObserver(() => {
        if (!document.getElementById('boot')) finish();
      });
      obs.observe(document.body, { childList: true, subtree: true });
      window.setTimeout(finish, 6000);
    });
  }

  function initStack(stack: HTMLElement): () => void {
    logMaskStep('initStack', {
      mask: readMaskDiagnostics(stack),
    });

    const hostId = stack.dataset.hostId || 'quantumCanvasHost';
    const host = document.getElementById(hostId);
    if (!host) {
      logMaskStep('initStack:missing-host', { hostId });
      return () => {};
    }

    const layout = stack.dataset.layout || 'homepage';
    const introRush = stack.dataset.introRush === 'true';
    const introDuration = Number(stack.dataset.introDuration) || 4;
    const resolvedInitDelay = Number(stack.dataset.initDelay) || 0;

    logMaskStep('initStack:config', {
      hostId,
      layout,
      introRush,
      introDuration,
      resolvedInitDelay,
    });

    const maskUrl = stack.dataset.heroMask;
    if (maskUrl) {
      const probe = new Image();
      probe.onload = () => {
        logMaskStep('initStack:mask-image-loaded', {
          maskUrl,
          width: probe.naturalWidth,
          height: probe.naturalHeight,
        });
      };
      probe.onerror = () => {
        logMaskStep('initStack:mask-image-error', { maskUrl });
      };
      probe.src = maskUrl;
    }

    document.documentElement.classList.add('quantum-page-touch');
    document.body.classList.add('quantum-page-touch');

    let detach: (() => void) | undefined;
    let delayId = 0;
    let cancelled = false;

    const start = () => {
      logMaskStep('initStack:start-engine', {
        cancelled,
        mask: readMaskDiagnostics(stack),
      });
      if (cancelled) return;
      detach = attachQuantumCoreOpticalEngine(host, {
        introRush: introRush ? { durationSec: introDuration } : undefined,
      });
    };

    const delayMs =
      prefersReducedMotion() ? 0 : resolvedInitDelay;

    const scheduleStart = () => {
      logMaskStep('initStack:scheduleStart', { delayMs });
      delayId = window.setTimeout(start, delayMs);
    };

    if (layout === 'homepage' && document.getElementById('boot')) {
      logMaskStep('initStack:wait-for-preloader');
      void waitForPreloaderGone().then(scheduleStart);
    } else {
      logMaskStep('initStack:schedule-immediate');
      scheduleStart();
    }

    const parent = stack.parentElement;
    let obs: MutationObserver | undefined;
    if (parent) {
      obs = new MutationObserver(() => {
        if (!document.getElementById(hostId)) {
          window.clearTimeout(delayId);
          detach?.();
          detach = undefined;
          obs?.disconnect();
        }
      });
      obs.observe(parent, { childList: true, subtree: true });
    }

    return () => {
      logMaskStep('initStack:cleanup', { hostId });
      cancelled = true;
      window.clearTimeout(delayId);
      detach?.();
      obs?.disconnect();
      document.documentElement.classList.remove('quantum-page-touch');
      document.body.classList.remove('quantum-page-touch');
    };
  }

  const cleanups = new Map<HTMLElement, () => void>();

  function boot() {
    logMaskStep('boot');
    const stacks = document.querySelectorAll<HTMLElement>('[data-quantum-logo]');
    logMaskStep('boot:stacks-found', { count: stacks.length });
    stacks.forEach((stack) => {
      cleanups.get(stack)?.();
      cleanups.set(stack, initStack(stack));
    });
  }

  function bootWhenReady() {
    logMaskStep('bootWhenReady', { readyState: document.readyState });
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }
  }

  bootWhenReady();

  window.addEventListener('pagehide', () => {
    cleanups.forEach((cleanup) => cleanup());
    cleanups.clear();
  });
</script>
