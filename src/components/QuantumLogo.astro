---
export interface Props {
  /** Mask image URL. When omitted, nothing is rendered. */
  heroMask: string;
  /** Full-color logo PNG the particles resolve into (default /logo.png). */
  logoSrc: string;
  /** Canvas host element id. */
  hostId?: string;
  /** Homepage hero; centered for preloader; compact fits small hosts. */
  layout?: 'homepage' | 'centered' | 'compact';
  /** Reverse-explosion implosion on load (particles rush inward behind the fixed mask). */
  introRush?: boolean;
  /** Rush duration in seconds (default 2). */
  introDuration?: number;
  /** Delay before WebGL init (homepage only, ms). */
  initDelay?: number;
  class?: string;
}

const {
  heroMask,
  logoSrc,
  hostId = 'quantumCanvasHost',
  layout = 'homepage',
  introRush = true,
  introDuration = 4,
  initDelay,
  class: className,
} = Astro.props;

const isHomepage = layout === 'homepage';
const isCompact = layout === 'compact';
const resolvedInitDelay = initDelay ?? (isHomepage ? 400 : 0);
---

<div
  class:list={[
    'quantum-logo-stack',
    'quantum-logo-stack--logo',
    isHomepage && 'quantum-logo-stack--homepage',
    layout === 'centered' && 'quantum-logo-stack--centered',
    isCompact && 'quantum-logo-stack--compact',
    className,
  ]}
  style={`--hero-logo-mask: url("${heroMask}")`}
  data-quantum-logo
  data-layout={layout}
  data-host-id={hostId}
  data-logo-src={logoSrc}
  data-hero-mask={heroMask}
  data-intro-rush={introRush ? 'true' : 'false'}
  data-intro-duration={String(introDuration)}
  data-init-delay={String(resolvedInitDelay)}
  aria-hidden="true"
>
  <div id={hostId} class="quantum-host"></div>
</div>

<style>
  .quantum-logo-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: auto;
    cursor: default;
    touch-action: none;
    overflow: hidden;
    --quantum-hero-logo-size: min(72vmin, 76vw, 420px);
  }

  /* Fixed logo window — particles implode behind this mask; nothing on the stack moves. */
  .quantum-logo-stack--logo:not(.quantum-logo-stack--compact),
  .quantum-logo-stack--compact {
    mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    -webkit-mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    mask-size: var(--quantum-hero-logo-size);
    -webkit-mask-size: var(--quantum-hero-logo-size);
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
    mask-position: center center;
    -webkit-mask-position: center center;
  }

  .quantum-logo-stack--compact {
    position: relative;
    inset: unset;
    width: 24px;
    height: 24px;
    flex: 0 0 24px;
    pointer-events: none;
    --quantum-hero-logo-size: contain;
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: center center;
    -webkit-mask-position: center center;
  }

  .quantum-logo-stack--compact .quantum-host {
    position: absolute;
    inset: 0;
  }

  .quantum-host {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    touch-action: none;
    overflow: hidden;
  }

  .quantum-host :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
    max-width: none;
    object-fit: cover;
  }

  @media screen and (min-width: 768px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(64vmin, 68vw, 400px);
    }
  }

  @media screen and (min-width: 1024px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(56vmin, 60vw, 380px);
    }
  }

  @media screen and (min-width: 1440px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(48vmin, 52vw, 360px);
    }
  }

  @media screen and (min-width: 1920px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(42vmin, 46vw, 340px);
    }
  }

  @media screen and (min-width: 2560px) {
    .quantum-logo-stack:not(.quantum-logo-stack--compact) {
      --quantum-hero-logo-size: min(36vmin, 40vw, 320px);
    }
  }
</style>

<script>
  import { attachQuantumCoreOpticalEngine } from '../lib/quantumCoreOpticalEngine';

  function prefersReducedMotion() {
    return (
      typeof matchMedia !== 'undefined' &&
      matchMedia('(prefers-reduced-motion: reduce)').matches
    );
  }

  function waitForPreloaderGone(): Promise<void> {
    return new Promise((resolve) => {
      const boot = document.getElementById('boot');
      if (!boot) {
        resolve();
        return;
      }
      const finish = () => {
        obs?.disconnect();
        resolve();
      };
      const obs = new MutationObserver(() => {
        if (!document.getElementById('boot')) finish();
      });
      obs.observe(document.body, { childList: true, subtree: true });
      window.setTimeout(finish, 6000);
    });
  }

  function initStack(stack: HTMLElement): () => void {
    const hostId = stack.dataset.hostId || 'quantumCanvasHost';
    const host = document.getElementById(hostId);
    if (!host) return () => {};

    const layout = stack.dataset.layout || 'homepage';
    const introRush = stack.dataset.introRush === 'true';
    const introDuration = Number(stack.dataset.introDuration) || 4;
    const resolvedInitDelay = Number(stack.dataset.initDelay) || 0;

    document.documentElement.classList.add('quantum-page-touch');
    document.body.classList.add('quantum-page-touch');

    let detach: (() => void) | undefined;
    let delayId = 0;
    let cancelled = false;

    const start = () => {
      if (cancelled) return;
      detach = attachQuantumCoreOpticalEngine(host, {
        introRush: introRush ? { durationSec: introDuration } : undefined,
      });
    };

    const delayMs =
      prefersReducedMotion() ? 0 : resolvedInitDelay;

    const scheduleStart = () => {
      delayId = window.setTimeout(start, delayMs);
    };

    if (layout === 'homepage' && document.getElementById('boot')) {
      void waitForPreloaderGone().then(scheduleStart);
    } else {
      scheduleStart();
    }

    const parent = stack.parentElement;
    let obs: MutationObserver | undefined;
    if (parent) {
      obs = new MutationObserver(() => {
        if (!document.getElementById(hostId)) {
          window.clearTimeout(delayId);
          detach?.();
          detach = undefined;
          obs?.disconnect();
        }
      });
      obs.observe(parent, { childList: true, subtree: true });
    }

    return () => {
      cancelled = true;
      window.clearTimeout(delayId);
      detach?.();
      obs?.disconnect();
      document.documentElement.classList.remove('quantum-page-touch');
      document.body.classList.remove('quantum-page-touch');
    };
  }

  const cleanups = new Map<HTMLElement, () => void>();

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-quantum-logo]').forEach((stack) => {
      cleanups.get(stack)?.();
      cleanups.set(stack, initStack(stack));
    });
  }

  function bootWhenReady() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }
  }

  bootWhenReady();

  window.addEventListener('pagehide', () => {
    cleanups.forEach((cleanup) => cleanup());
    cleanups.clear();
  });
</script>
