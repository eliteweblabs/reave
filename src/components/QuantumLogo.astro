---
export interface Props {
  /** Mask image URL. When omitted, nothing is rendered. */
  heroMask: string;
  /** Canvas host element id. */
  hostId?: string;
  /** Homepage mask slide-in; centered keeps the logo in the middle. */
  layout?: 'homepage' | 'centered';
  /** Particles rush inward from outside the mask on load. */
  introRush?: boolean;
  /** Rush duration in seconds (default 2). */
  introDuration?: number;
  /** Delay before WebGL init (homepage only, ms). */
  initDelay?: number;
  class?: string;
}

const {
  heroMask,
  hostId = 'quantumCanvasHost',
  layout = 'homepage',
  introRush = true,
  introDuration = 2,
  initDelay,
  class: className,
} = Astro.props;

const isHomepage = layout === 'homepage';
const resolvedInitDelay = initDelay ?? (isHomepage ? 400 : 0);
---

<div
  class:list={[
    'quantum-logo-stack',
    isHomepage && 'quantum-logo-stack--homepage',
    !isHomepage && 'quantum-logo-stack--centered',
    className,
  ]}
  style={`--hero-logo-mask: url("${heroMask}")`}
  data-quantum-logo
  data-host-id={hostId}
  data-intro-rush={introRush ? 'true' : 'false'}
  data-intro-duration={String(introDuration)}
  data-init-delay={String(resolvedInitDelay)}
  aria-hidden="true"
>
  <div id={hostId} class="quantum-host"></div>
</div>

<style>
  .quantum-logo-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: auto;
    cursor: default;
    touch-action: none;
    overflow: hidden;
    mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    -webkit-mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
    mask-size: min(92vmin, 96vw, 820px);
    -webkit-mask-size: min(92vmin, 96vw, 820px);
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
    filter: drop-shadow(0 0 18px rgba(255, 255, 255, 0.45))
      drop-shadow(0 0 36px rgba(255, 100, 200, 0.28));
  }

  .quantum-logo-stack--homepage {
    mask-position: 42% center;
    -webkit-mask-position: 42% center;
    animation: quantumLogoIntro 1.4s ease-out forwards;
  }

  .quantum-logo-stack--centered {
    mask-position: center center;
    -webkit-mask-position: center center;
  }

  .quantum-host {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    touch-action: none;
    overflow: hidden;
  }

  .quantum-host :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
    max-width: none;
    object-fit: cover;
  }

  @keyframes quantumLogoIntro {
    0% {
      mask-position: 42% center;
      -webkit-mask-position: 42% center;
    }
    100% {
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  @media (hover: none) {
    .quantum-logo-stack--homepage {
      animation: none;
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  @media screen and (min-width: 1024px) {
    .quantum-logo-stack {
      mask-size: min(88vmin, 94vw, 880px);
      -webkit-mask-size: min(88vmin, 94vw, 880px);
    }
  }

  @media screen and (min-width: 1440px) {
    .quantum-logo-stack {
      mask-size: min(84vmin, 92vw, 960px);
      -webkit-mask-size: min(84vmin, 92vw, 960px);
    }
  }

  @media screen and (min-width: 1920px) {
    .quantum-logo-stack {
      mask-size: min(80vmin, 90vw, 1040px);
      -webkit-mask-size: min(80vmin, 90vw, 1040px);
    }
  }

  @media screen and (min-width: 2560px) {
    .quantum-logo-stack {
      mask-size: min(76vmin, 88vw, 1180px);
      -webkit-mask-size: min(76vmin, 88vw, 1180px);
    }
  }
</style>

<script>
  import { attachQuantumCoreOpticalEngine } from '../lib/quantumCoreOpticalEngine';

  function prefersReducedMotion() {
    return (
      typeof matchMedia !== 'undefined' &&
      matchMedia('(prefers-reduced-motion: reduce)').matches
    );
  }

  function initStack(stack: HTMLElement): () => void {
    const hostId = stack.dataset.hostId || 'quantumCanvasHost';
    const host = document.getElementById(hostId);
    if (!host) return () => {};

    const introRush = stack.dataset.introRush === 'true';
    const introDuration = Number(stack.dataset.introDuration) || 2;
    const resolvedInitDelay = Number(stack.dataset.initDelay) || 0;

    document.documentElement.classList.add('quantum-page-touch');
    document.body.classList.add('quantum-page-touch');

    let detach: (() => void) | undefined;

    const start = () => {
      detach = attachQuantumCoreOpticalEngine(host, {
        introRush: introRush ? { durationSec: introDuration } : undefined,
      });
    };

    const touchUi =
      typeof matchMedia !== 'undefined' &&
      (matchMedia('(pointer: coarse)').matches ||
        matchMedia('(hover: none)').matches);
    const delayMs =
      prefersReducedMotion() || touchUi ? 0 : resolvedInitDelay;
    const delayId = window.setTimeout(start, delayMs);

    const parent = stack.parentElement;
    let obs: MutationObserver | undefined;
    if (parent) {
      obs = new MutationObserver(() => {
        if (!document.getElementById(hostId)) {
          window.clearTimeout(delayId);
          detach?.();
          detach = undefined;
          obs?.disconnect();
        }
      });
      obs.observe(parent, { childList: true, subtree: true });
    }

    return () => {
      window.clearTimeout(delayId);
      detach?.();
      obs?.disconnect();
      document.documentElement.classList.remove('quantum-page-touch');
      document.body.classList.remove('quantum-page-touch');
    };
  }

  const cleanups = new Map<HTMLElement, () => void>();

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-quantum-logo]').forEach((stack) => {
      cleanups.get(stack)?.();
      cleanups.set(stack, initStack(stack));
    });
  }

  function bootWhenReady() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }
  }

  bootWhenReady();

  window.addEventListener('pagehide', () => {
    cleanups.forEach((cleanup) => cleanup());
    cleanups.clear();
  });
</script>
