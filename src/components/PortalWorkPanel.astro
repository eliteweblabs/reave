---
/**
 * Client portal Work tab — job list with expandable comment threads.
 */
import type { WorkJobComment } from '../lib/workComments';
import type { WorkStatus } from '../lib/workStore';

export interface PortalWorkJobItem {
  slug: string;
  title: string;
  status: WorkStatus;
  statusLabel: string;
  /** Rich HTML from the project description (admin body field). */
  bodyHtml: string;
  /** Formatted updated/created date for display under the title. */
  dateLabel: string;
  /** Shareable portal URL for this project. */
  portalUrl: string;
}

export interface PortalWorkFileItem {
  id: string;
  filename: string;
  mediaType: string;
  sizeBytes: number;
  url: string;
  source?: string;
}

interface Props {
  jobs: PortalWorkJobItem[];
  commentsBySlug: Record<string, WorkJobComment[]>;
  filesBySlug?: Record<string, PortalWorkFileItem[]>;
  contactUid: string;
  /** Client company logo for client-authored comments. */
  clientAvatarUrl?: string;
  /** Provider logo for staff-authored comments. */
  staffAvatarUrl?: string;
  active?: boolean;
  /** Auto-expand the first (or only) job on load. */
  autoExpand?: boolean;
  /** Deep-link slug from ?project= — expands that job on load. */
  expandSlug?: string;
}

const {
  jobs,
  commentsBySlug,
  filesBySlug = {},
  contactUid,
  clientAvatarUrl = '',
  staffAvatarUrl = '',
  active = false,
  autoExpand = false,
  expandSlug = '',
} = Astro.props;

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function fmtCommentTime(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function fmtFileSize(bytes: number): string {
  const n = Number(bytes) || 0;
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
  return `${(n / (1024 * 1024)).toFixed(1)} MB`;
}

function authorInitial(name: string): string {
  const ch = name.trim().charAt(0);
  return ch ? ch.toUpperCase() : '?';
}

function avatarUrlForAuthor(author: WorkJobComment['author']): string {
  return author === 'staff' ? staffAvatarUrl : clientAvatarUrl;
}

const panelJobs = jobs.map((job) => ({
  ...job,
  comments: (commentsBySlug[job.slug] ?? []).map((c) => ({
    id: c.id,
    author: c.author,
    authorName: c.authorName,
    text: c.text,
    createdLabel: fmtCommentTime(c.createdAt),
  })),
}));

const commentEndpointBase = `/api/c/${encodeURIComponent(contactUid)}/work`;
const filesEndpointBase = commentEndpointBase;
---

<section class={`panel portal-work ${active ? 'active' : ''}`} data-tab-panel="work">

  {jobs.length === 0 ? (
    <p class="muted">No active projects right now.</p>
  ) : (
    <ul class="work-list" id="portal-work-list">
      {jobs.map((job, index) => {
        const comments = commentsBySlug[job.slug] ?? [];
        const files = filesBySlug[job.slug] ?? [];
        const startOpen = (expandSlug && job.slug === expandSlug) || (autoExpand && index === 0);
        return (
          <li class="work-item" data-job-slug={job.slug}>
            <button class="work-item-head" type="button" aria-expanded={startOpen ? 'true' : 'false'}>
              <span class="work-main">
                <span class="work-title">{job.title}</span>
                {job.dateLabel && <span class="work-meta">Updated {job.dateLabel}</span>}
              </span>
              <span class={`work-status work-status-${job.status}`}>{job.statusLabel}</span>
              <span class="work-chevron" aria-hidden="true">›</span>
            </button>

            <div class="work-item-body" hidden={!startOpen || undefined}>
              {job.bodyHtml ? (
                <div class="work-description" set:html={job.bodyHtml} />
              ) : (
                <p class="work-description-empty">Project details will appear here as work progresses.</p>
              )}

              <div class="work-files" data-files-root>
                <span class="work-files-label">Files</span>
                {files.length === 0 ? (
                  <p class="work-files-empty">No files yet — upload images or PDFs below.</p>
                ) : (
                  <div class="work-files-grid">
                    {files.map((file) => {
                      const isImage = file.mediaType.startsWith('image/');
                      return (
                        <a
                          class="work-file-card"
                          href={file.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          data-file-id={file.id}
                        >
                          {isImage ? (
                            <img
                              class="work-file-thumb"
                              src={file.url}
                              alt={file.filename}
                              loading="lazy"
                            />
                          ) : (
                            <span class="work-file-doc" aria-hidden="true">PDF</span>
                          )}
                          <span class="work-file-name">{escapeHtml(file.filename)}</span>
                          <span class="work-file-size">{fmtFileSize(file.sizeBytes)}</span>
                        </a>
                      );
                    })}
                  </div>
                )}
                <div class="work-files-upload">
                  <input
                    class="work-files-input"
                    type="file"
                    accept="image/jpeg,image/png,image/gif,image/webp,application/pdf"
                    multiple
                  />
                  <button class="work-files-upload-btn" type="button">Upload files</button>
                  <p class="work-files-hint">Images and PDFs up to 10 MB. Shared with our team instantly.</p>
                </div>
              </div>

              <div class="work-comments" data-comments-root>
                <span class="work-comments-label">Comments</span>
                {comments.length === 0 ? (
                  <p class="work-comments-empty">No comments yet — say hello below.</p>
                ) : (
                  <ul class="work-comment-list">
                    {comments.map((c) => (
                      <li class={`work-comment work-comment-${c.author}`} data-comment-id={c.id}>
                        <article class="work-comment-inner">
                          <div class="work-comment-avatar" aria-hidden="true">
                            {avatarUrlForAuthor(c.author) ? (
                              <img src={avatarUrlForAuthor(c.author)} alt="" loading="lazy" />
                            ) : (
                              <span class="work-comment-avatar-fallback">{authorInitial(c.authorName)}</span>
                            )}
                          </div>
                          <div class="work-comment-main">
                            <header class="work-comment-head">
                              <span class="work-comment-author">{escapeHtml(c.authorName)}</span>
                              <time class="work-comment-time" datetime={c.createdAt}>{fmtCommentTime(c.createdAt)}</time>
                            </header>
                            <p class="work-comment-text">{escapeHtml(c.text)}</p>
                          </div>
                        </article>
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              <label class="work-comment-label">
                <span>Add a comment</span>
                <textarea
                  class="work-comment-input"
                  rows="3"
                  maxlength="4000"
                  placeholder="Ask a question or share an update…"
                />
              </label>
              <button class="work-comment-submit" type="button">Post comment</button>
            </div>
          </li>
        );
      })}
    </ul>
  )}
</section>

<script define:vars={{ commentEndpointBase, filesEndpointBase, clientAvatarUrl, staffAvatarUrl }}>
  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function fmtTime(iso) {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function fmtFileSize(bytes) {
    const n = Number(bytes) || 0;
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / (1024 * 1024)).toFixed(1)} MB`;
  }

  function renderFileCard(file) {
    const isImage = String(file.mediaType || '').startsWith('image/');
    const card = document.createElement('a');
    card.className = 'work-file-card';
    card.href = file.url;
    card.target = '_blank';
    card.rel = 'noopener noreferrer';
    card.dataset.fileId = file.id;
    card.innerHTML =
      (isImage
        ? `<img class="work-file-thumb" src="${escHtml(file.url)}" alt="${escHtml(file.filename || 'file')}" loading="lazy" />`
        : `<span class="work-file-doc" aria-hidden="true">PDF</span>`) +
      `<span class="work-file-name">${escHtml(file.filename || 'file')}</span>` +
      `<span class="work-file-size">${escHtml(fmtFileSize(file.sizeBytes))}</span>`;
    return card;
  }

  function renderFilesGrid(filesRoot, files) {
    const empty = filesRoot.querySelector('.work-files-empty');
    if (empty) empty.remove();

    let grid = filesRoot.querySelector('.work-files-grid');
    if (!files.length) {
      if (grid) grid.remove();
      if (!filesRoot.querySelector('.work-files-empty')) {
        const p = document.createElement('p');
        p.className = 'work-files-empty';
        p.textContent = 'No files yet — upload images or PDFs below.';
        const uploadWrap = filesRoot.querySelector('.work-files-upload');
        filesRoot.insertBefore(p, uploadWrap);
      }
      return;
    }

    if (!grid) {
      grid = document.createElement('div');
      grid.className = 'work-files-grid';
      const uploadWrap = filesRoot.querySelector('.work-files-upload');
      filesRoot.insertBefore(grid, uploadWrap);
    }
    grid.innerHTML = '';
    for (const file of files) {
      grid.appendChild(renderFileCard(file));
    }
  }

  function authorInitial(name) {
    const ch = String(name || '').trim().charAt(0);
    return ch ? ch.toUpperCase() : '?';
  }

  function avatarHtml(author, authorName) {
    const url = author === 'staff' ? staffAvatarUrl : clientAvatarUrl;
    if (url) {
      return (
        `<div class="work-comment-avatar" aria-hidden="true">` +
        `<img src="${escHtml(url)}" alt="" loading="lazy" />` +
        `</div>`
      );
    }
    return (
      `<div class="work-comment-avatar" aria-hidden="true">` +
      `<span class="work-comment-avatar-fallback">${escHtml(authorInitial(authorName))}</span>` +
      `</div>`
    );
  }

  function renderComment(c) {
    const li = document.createElement('li');
    li.className = `work-comment work-comment-${c.author}`;
    li.dataset.commentId = c.id;
    const when = escHtml(c.createdLabel || fmtTime(c.createdAt));
    const whenIso = escHtml(c.createdAt || '');
    li.innerHTML =
      `<article class="work-comment-inner">` +
      avatarHtml(c.author, c.authorName) +
      `<div class="work-comment-main">` +
      `<header class="work-comment-head">` +
      `<span class="work-comment-author">${escHtml(c.authorName)}</span>` +
      `<time class="work-comment-time" datetime="${whenIso}">${when}</time>` +
      `</header>` +
      `<p class="work-comment-text">${escHtml(c.text)}</p>` +
      `</div>` +
      `</article>`;
    return li;
  }

  document.querySelectorAll('.work-item').forEach((item) => {
    const head = item.querySelector('.work-item-head');
    const body = item.querySelector('.work-item-body');
    const slug = item.getAttribute('data-job-slug');
    const textarea = item.querySelector('.work-comment-input');
    const submitBtn = item.querySelector('.work-comment-submit');
    const commentsRoot = item.querySelector('[data-comments-root]');
    const filesRoot = item.querySelector('[data-files-root]');
    const fileInput = item.querySelector('.work-files-input');
    const uploadBtn = item.querySelector('.work-files-upload-btn');
    if (!head || !body || !slug || !textarea || !submitBtn || !commentsRoot) return;

    if (filesRoot && fileInput && uploadBtn) {
      uploadBtn.addEventListener('click', () => fileInput.click());

      fileInput.addEventListener('change', async () => {
        const picked = [...fileInput.files];
        fileInput.value = '';
        if (!picked.length) return;

        uploadBtn.disabled = true;
        const prev = uploadBtn.textContent;
        uploadBtn.textContent = 'Uploading…';

        try {
          for (const file of picked) {
            const form = new FormData();
            form.append('file', file);
            const res = await fetch(
              `${filesEndpointBase}/${encodeURIComponent(slug)}/files`,
              { method: 'POST', body: form },
            );
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.error || 'Upload failed');
          }

          const listRes = await fetch(
            `${filesEndpointBase}/${encodeURIComponent(slug)}/files`,
            { cache: 'no-store' },
          );
          const listData = await listRes.json();
          if (!listRes.ok || !listData.ok) throw new Error(listData.error || 'Could not refresh files');
          renderFilesGrid(filesRoot, listData.files || []);
        } catch (e) {
          alert(e instanceof Error ? e.message : 'Upload failed. Please try again.');
        } finally {
          uploadBtn.disabled = false;
          uploadBtn.textContent = prev;
        }
      });
    }

    head.addEventListener('click', () => {
      const open = body.hasAttribute('hidden');
      document.querySelectorAll('.work-item-body').forEach((el) => {
        if (el !== body) {
          el.setAttribute('hidden', '');
          el.previousElementSibling?.setAttribute('aria-expanded', 'false');
        }
      });
      if (open) {
        body.removeAttribute('hidden');
        head.setAttribute('aria-expanded', 'true');
        textarea.focus();
      } else {
        body.setAttribute('hidden', '');
        head.setAttribute('aria-expanded', 'false');
      }
    });

    submitBtn.addEventListener('click', async () => {
      const text = textarea.value.trim();
      if (!text) {
        textarea.focus();
        return;
      }

      submitBtn.disabled = true;
      const prev = submitBtn.textContent;
      submitBtn.textContent = 'Posting…';

      try {
        const res = await fetch(`${commentEndpointBase}/${encodeURIComponent(slug)}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text }),
        });
        const data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to post');

        const empty = commentsRoot.querySelector('.work-comments-empty');
        if (empty) empty.remove();

        let list = commentsRoot.querySelector('.work-comment-list');
        if (!list) {
          list = document.createElement('ul');
          list.className = 'work-comment-list';
          commentsRoot.appendChild(list);
        }

        const c = data.comment;
        list.appendChild(
          renderComment({
            ...c,
            createdLabel: fmtTime(c.createdAt),
          }),
        );

        textarea.value = '';
        body.removeAttribute('hidden');
        head.setAttribute('aria-expanded', 'true');
      } catch {
        alert('Could not post your comment. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = prev;
      }
    });
  });
</script>

<style>
  .portal-work .work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .work-item {
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  .work-item-head {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 14px 16px;
    border: none;
    background: transparent;
    color: #fff;
    text-align: left;
    cursor: pointer;
    font: inherit;
  }

  .work-item-head:active {
    background: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.08);
  }

  .work-main {
    flex: 1;
    min-width: 0;
  }

  .work-title {
    display: block;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .work-meta {
    display: block;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
  }

  .work-status {
    flex: none;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    padding: 5px 10px;
    border-radius: 999px;
  }

  .work-status-inquiry {
    color: #93c5fd;
    background: rgba(147, 197, 253, 0.12);
  }
  .work-status-active {
    color: #86efac;
    background: rgba(134, 239, 172, 0.12);
  }
  .work-status-done {
    color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.06);
  }

  .work-chevron {
    flex: none;
    font-size: 18px;
    color: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.75);
    transition: transform 0.2s;
  }

  .work-item-head[aria-expanded='true'] .work-chevron {
    transform: rotate(90deg);
  }

  .work-item-body {
    padding: 0 16px 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .work-description {
    margin: 14px 0 16px;
    padding: 14px 16px;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }

  .work-description :global(a) {
    color: var(--portal-accent, #d8b4fe);
  }

  .work-description :global(.work-body-img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 10px 0;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .work-description-empty {
    margin: 14px 0 16px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  .work-files-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 10px;
  }

  .work-files {
    margin: 0 0 16px;
  }

  .work-files-empty {
    margin: 0 0 12px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  .work-files-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 10px;
    margin-bottom: 12px;
  }

  .work-file-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: inherit;
    text-decoration: none;
    min-width: 0;
  }

  .work-file-card:active {
    border-color: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.45);
  }

  .work-file-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
  }

  .work-file-doc {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
    background: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.12);
    color: var(--portal-accent, #d8b4fe);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .work-file-name {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .work-file-size {
    display: block;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.42);
  }

  .work-files-upload {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .work-files-input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .work-files-upload-btn {
    width: 100%;
    padding: 11px 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px dashed rgba(var(--portal-primary-rgb, 168, 85, 247), 0.45);
    border-radius: 12px;
    color: var(--portal-accent, #d8b4fe);
    font: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }

  .work-files-upload-btn:disabled {
    opacity: 0.55;
    cursor: default;
  }

  .work-files-upload-btn:active:not(:disabled) {
    transform: scale(0.98);
  }

  .work-files-hint {
    margin: 0;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.4;
  }

  .work-comments-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 10px;
  }

  .work-comments {
    margin: 0 0 12px;
  }

  .work-comments-empty {
    margin: 0;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
  }

  .portal-work :global(.work-comment-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .portal-work :global(.work-comment) {
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .portal-work :global(.work-comment:last-child) {
    border-bottom: none;
    padding-bottom: 4px;
  }

  .portal-work :global(.work-comment-inner) {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .portal-work :global(.work-comment-avatar) {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .portal-work :global(.work-comment-avatar img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portal-work :global(.work-comment-avatar-fallback) {
    font-size: 15px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1;
  }

  .portal-work :global(.work-comment-staff .work-comment-avatar) {
    border-color: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.35);
    background: rgba(var(--portal-primary-rgb, 168, 85, 247), 0.12);
  }

  .portal-work :global(.work-comment-main) {
    flex: 1;
    min-width: 0;
  }

  .portal-work :global(.work-comment-head) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }

  .portal-work :global(.work-comment-author) {
    font-size: 14px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
