---
import { SignIn } from '@clerk/astro/components';
import IosBottomSheet from './IosBottomSheet.astro';

interface Props {
  /** Where to send the user after a successful sign-in. */
  fallbackRedirectUrl?: string;
  allowSignUp?: boolean;
  /** Open automatically once the page loads (e.g. signed-out /admin visit). */
  autoOpen?: boolean;
}

const {
  fallbackRedirectUrl = '/admin/',
  allowSignUp = import.meta.env.PUBLIC_CLERK_ALLOW_SIGN_UP === '1',
  autoOpen = false,
} = Astro.props;

/** Clerk in the bottom sheet — no nested card chrome; body padding comes from ios-sheet. */
const clerkAppearance = {
  options: {
    elevation: 'flush',
  },
  elements: {
    rootBox: {
      width: '100%',
      maxWidth: '100%',
    },
    cardBox: {
      width: '100%',
      maxWidth: '100%',
      margin: '0',
      padding: '0',
      boxShadow: 'none',
    },
    card: {
      width: '100%',
      maxWidth: '100%',
      margin: '0',
      padding: '0',
      boxShadow: 'none',
      border: 'none',
      borderRadius: '0',
      background: 'transparent',
    },
    scrollBox: {
      width: '100%',
      maxWidth: '100%',
    },
    main: {
      padding: '0',
    },
    footer: {
      padding: '0',
      background: 'transparent',
      boxShadow: 'none',
    },
    footerAction: {
      background: 'transparent',
    },
    header: { display: 'none' },
    headerTitle: { display: 'none' },
    headerSubtitle: { display: 'none' },
  },
};
---

<IosBottomSheet id="sign-in-sheet" title="Sign in" dismissible={true} class="sign-in-sheet">
  <SignIn
    routing="hash"
    signUpUrl={allowSignUp ? '/sign-up' : '/sign-in'}
    fallbackRedirectUrl={fallbackRedirectUrl}
    appearance={clerkAppearance}
  />
</IosBottomSheet>

<script src="/ios-sheet.js" defer></script>
<link rel="stylesheet" href="/ios-sheet.css" />

<style is:global>
  /* Match Clerk default theme to sheet light/dark (do not force theme: dark). */
  #sign-in-sheet {
    color-scheme: light dark;
  }

  #sign-in-sheet .ios-sheet-body {
    padding: 0.75rem 1.35rem 1.5rem;
  }

  #sign-in-sheet .cl-rootBox,
  #sign-in-sheet .cl-cardBox,
  #sign-in-sheet .cl-card,
  #sign-in-sheet .cl-scrollBox,
  #sign-in-sheet .cl-main {
    width: 100%;
    max-width: 100%;
  }

  #sign-in-sheet .cl-cardBox,
  #sign-in-sheet .cl-card {
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 0;
    box-shadow: none;
    background: transparent;
  }

  #sign-in-sheet .cl-footer,
  #sign-in-sheet .cl-footerAction {
    background: transparent;
    box-shadow: none;
  }
</style>

{autoOpen && (
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      window.IosSheet?.open('sign-in-sheet');
    });
  </script>
)}
