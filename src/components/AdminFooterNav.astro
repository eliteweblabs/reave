---
import { clerkClient } from "@clerk/astro/server";
import { Home, MessageCircle, Mail, Search } from "lucide-astro";

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;

let avatarUrl: string | null = null;
let userInitials = "";

function footerAvatarUrl(user: {
  imageUrl: string;
  hasImage: boolean;
  externalAccounts?: Array<{ provider: string; imageUrl?: string | null }>;
}): string | null {
  const sized = (url: string) => {
    const join = url.includes("?") ? "&" : "?";
    return `${url}${join}width=56&height=56&fit=crop`;
  };

  if (user.hasImage && user.imageUrl) return sized(user.imageUrl);

  const google = user.externalAccounts?.find(
    (account) => account.provider === "oauth_google" || account.provider === "google",
  );
  if (google?.imageUrl) return sized(google.imageUrl);
  if (google && user.imageUrl) return sized(user.imageUrl);

  return null;
}

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = footerAvatarUrl(user);
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials =
      ((first + last).toUpperCase() || user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ??
      "?";
  } catch {
    // Clerk unreachable
  }
}
---

<nav id="admin-footer-nav" class="admin-footer-nav" aria-label="Admin navigation">
  <div class="admin-footer-nav-pill">
    <button
      type="button"
      id="footer-nav-home"
      class="footer-nav-btn"
      data-nav="home"
      aria-label="Home"
    >
      <Home size={22} strokeWidth={1.75} />
      <span id="footer-home-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-chat"
      class="footer-nav-btn"
      data-nav="chat"
      aria-label="Chats"
    >
      <MessageCircle size={22} strokeWidth={1.75} />
      <span id="footer-chat-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-inbox"
      class="footer-nav-btn"
      data-nav="inbox"
      aria-label="Inbox"
    >
      <Mail size={22} strokeWidth={1.75} />
      <span id="footer-inbox-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-search"
      class="footer-nav-btn"
      data-nav="search"
      aria-label="Search"
      aria-expanded="false"
    >
      <Search size={22} strokeWidth={1.75} />
    </button>

    <button
      type="button"
      id="footer-nav-profile"
      class="footer-nav-btn footer-nav-profile"
      data-nav="profile"
      aria-label="Profile"
    >
      {avatarUrl ? (
        <img src={avatarUrl} alt="" class="footer-nav-avatar" />
      ) : (
        <span class="footer-nav-initials">{userInitials || "?"}</span>
      )}
    </button>
  </div>
</nav>

<style is:global>
  :root {
    --bg: #0a0d14;
    --footer-nav-pill-h: 3.4rem;
    --footer-nav-h: calc(var(--footer-nav-pill-h) + env(safe-area-inset-bottom, 0px));
  }

  .admin-footer-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2000;
    display: flex;
    justify-content: center;
    padding:
      0 max(0.75rem, env(safe-area-inset-right, 0px))
      env(safe-area-inset-bottom, 0px)
      max(0.75rem, env(safe-area-inset-left, 0px));
    background: transparent;
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    transition: justify-content 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .admin-footer-nav.footer-nav-collapsed {
    justify-content: flex-start;
  }

  .admin-footer-nav-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: rgba(18, 22, 30, 0.72);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    transition:
      gap 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .admin-footer-nav.footer-nav-collapsed .admin-footer-nav-pill {
    gap: 0;
    padding: 0.45rem;
  }

  .footer-nav-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    max-width: 2.5rem;
    padding: 0;
    border: none;
    border-radius: 12px;
    background: transparent;
    color: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    flex-shrink: 0;
    overflow: visible;
    transition:
      color 0.15s,
      background 0.15s,
      opacity 0.24s ease,
      max-width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      margin 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-tap-highlight-color: transparent;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home),
  .admin-footer-nav.footer-nav-collapsed #footer-nav-profile {
    width: 0;
    max-width: 0;
    opacity: 0;
    margin: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .footer-nav-btn:hover {
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-nav-btn.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
  }

  .admin-footer-nav.footer-nav-collapsed #footer-nav-home {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
  }

  .footer-nav-btn svg,
  .footer-nav-chat-icon svg {
    display: block;
    pointer-events: none;
  }

  .footer-nav-profile {
    width: 2.5rem;
    height: 2.5rem;
    max-width: 2.5rem;
    padding: 0;
    overflow: hidden;
    border: none;
    background: transparent;
  }

  .footer-nav-profile:hover {
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-nav-profile.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
  }

  .footer-nav-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    pointer-events: none;
    display: block;
  }

  .footer-nav-initials {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.72);
    pointer-events: none;
  }

  .footer-nav-badge {
    position: absolute;
    top: 0.15rem;
    right: 0.1rem;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    pointer-events: none;
    z-index: 2;
    box-shadow: 0 0 0 2px rgba(18, 22, 30, 0.95);
    transition: opacity 0.2s ease;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home) .footer-nav-badge,
  .admin-footer-nav.footer-nav-collapsed #footer-nav-profile .footer-nav-badge {
    display: none !important;
  }

  .footer-nav-badge[hidden] {
    display: none !important;
  }

  @media print {
    .admin-footer-nav {
      display: none !important;
    }
  }
</style>
