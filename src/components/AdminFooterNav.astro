---
import { clerkClient } from "@clerk/astro/server";
import { Home, MessageCircle, Mail, Search } from "lucide-astro";

const auth = Astro.locals.auth?.();
const userId = auth?.userId ?? null;

let avatarUrl: string | null = null;
let userInitials = "";

function footerAvatarUrl(user: {
  imageUrl: string;
  hasImage: boolean;
  externalAccounts?: Array<{ provider: string; imageUrl?: string | null }>;
}): string | null {
  const sized = (url: string) => {
    const join = url.includes("?") ? "&" : "?";
    return `${url}${join}width=56&height=56&fit=crop`;
  };

  if (user.hasImage && user.imageUrl) return sized(user.imageUrl);

  const google = user.externalAccounts?.find(
    (account) => account.provider === "oauth_google" || account.provider === "google",
  );
  if (google?.imageUrl) return sized(google.imageUrl);
  if (google && user.imageUrl) return sized(user.imageUrl);

  return null;
}

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = footerAvatarUrl(user);
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials =
      ((first + last).toUpperCase() || user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ??
      "?";
  } catch {
    // Clerk unreachable
  }
}
---

<nav id="admin-footer-nav" class="admin-footer-nav" aria-label="Admin navigation">
  <div class="admin-footer-nav-bar">
    <div class="admin-footer-nav-pill">
    <div id="footer-nav-indicator" class="footer-nav-indicator" hidden aria-hidden="true"></div>
    <button
      type="button"
      id="footer-nav-home"
      class="footer-nav-btn"
      data-nav="home"
      aria-label="Home"
    >
      <Home size={22} strokeWidth={1.75} />
      <span id="footer-home-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-chat"
      class="footer-nav-btn"
      data-nav="chat"
      aria-label="Chats"
    >
      <MessageCircle size={22} strokeWidth={1.75} />
      <span id="footer-chat-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-inbox"
      class="footer-nav-btn"
      data-nav="inbox"
      aria-label="Inbox"
    >
      <Mail size={22} strokeWidth={1.75} />
      <span id="footer-inbox-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-search"
      class="footer-nav-btn"
      data-nav="search"
      aria-label="Search"
      aria-expanded="false"
    >
      <Search size={22} strokeWidth={1.75} />
    </button>

    <button
      type="button"
      id="footer-nav-profile"
      class="footer-nav-btn footer-nav-profile"
      data-nav="profile"
      aria-label="Profile"
    >
      {avatarUrl ? (
        <img src={avatarUrl} alt="" class="footer-nav-avatar" />
      ) : (
        <span class="footer-nav-initials">{userInitials || "?"}</span>
      )}
    </button>
  </div>
    <div id="footer-chat-compose" class="footer-chat-compose" hidden></div>
  </div>
</nav>

<style is:global>
  :root {
    --bg: #0a0d14;
    --footer-nav-pill-h: 3.4rem;
    --footer-nav-h: calc(var(--footer-nav-pill-h) + env(safe-area-inset-bottom, 0px));
    --create-fab-bg: linear-gradient(145deg, #f472b6 0%, #c026d3 52%, #6366f1 100%);
    --create-fab-shadow: 0 2px 16px rgba(192, 38, 211, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.16);
    --footer-nav-glass-bg: transparent;
    --footer-nav-glass-blur: blur(18px) saturate(1.15);
    --footer-nav-glass-border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .admin-footer-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2000;
    display: flex;
    justify-content: center;
    padding:
      0 max(0.75rem, env(safe-area-inset-right, 0px))
      env(safe-area-inset-bottom, 0px)
      max(0.75rem, env(safe-area-inset-left, 0px));
    background: transparent;
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    transition: justify-content 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .admin-footer-nav.footer-nav-has-compose {
    justify-content: stretch;
  }

  .admin-footer-nav-bar {
    display: flex;
    align-items: stretch;
    gap: 0.45rem;
    width: auto;
    max-width: none;
    pointer-events: auto;
  }

  .admin-footer-nav.footer-nav-has-compose:not(.footer-nav-compose-open) .admin-footer-nav-bar {
    width: 100%;
    max-width: min(100%, 720px);
  }

  .footer-chat-compose {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .footer-chat-compose[hidden] {
    display: none !important;
  }

  /* Mobile: merge home + compose into one compact pill. */
  @media (max-width: 639px) {
    .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar {
      width: 100%;
      max-width: min(100%, 720px);
      gap: 0;
      border-radius: 999px;
      background: var(--footer-nav-glass-bg);
      backdrop-filter: var(--footer-nav-glass-blur);
      -webkit-backdrop-filter: var(--footer-nav-glass-blur);
      border: var(--footer-nav-glass-border);
      box-shadow: none;
      overflow: hidden;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-chat-compose {
      padding: 0 0.45rem 0 0.35rem;
      border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-pill {
      background: transparent;
      border: none;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      gap: 0;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-nav-btn:not(#footer-nav-home),
    .admin-footer-nav.footer-nav-compose-open #footer-nav-profile {
      width: 0;
      max-width: 0;
      opacity: 0;
      margin: 0;
      overflow: hidden;
      pointer-events: none;
    }
  }

  /* Wider than mobile: all nav icons stay left; compose centers in remaining space. */
  @media (min-width: 640px) {
    .admin-footer-nav.footer-nav-has-compose,
    .admin-footer-nav.footer-nav-compose-open {
      justify-content: flex-start;
    }

    .admin-footer-nav.footer-nav-has-compose .admin-footer-nav-bar,
    .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar {
      width: 100%;
      max-width: none;
      gap: 0.75rem;
      background: transparent;
      border: none;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      overflow: visible;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-chat-compose {
      flex: 1 1 auto;
      justify-content: center;
      padding: 0;
      border-left: none;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-chat-compose .ch-compose {
      width: 100%;
      max-width: min(36rem, calc(100vw - 22rem));
    }

    .admin-footer-nav.footer-nav-has-compose.footer-nav-collapsed,
    .admin-footer-nav.footer-nav-compose-nav-only {
      justify-content: flex-start;
    }
  }

  .admin-footer-nav.footer-nav-collapsed {
    justify-content: flex-start;
  }

  .admin-footer-nav.footer-nav-has-compose.footer-nav-collapsed {
    justify-content: stretch;
  }

  .admin-footer-nav.footer-nav-compose-nav-only {
    justify-content: center;
  }

  .admin-footer-nav.footer-nav-compose-nav-only .admin-footer-nav-bar {
    width: auto;
    max-width: none;
  }

  .admin-footer-nav-pill {
    position: relative;
    flex-shrink: 0;
    pointer-events: auto;
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    height: var(--footer-nav-pill-h);
    padding: 0;
    border-radius: 999px;
    background: var(--footer-nav-glass-bg);
    backdrop-filter: var(--footer-nav-glass-blur);
    -webkit-backdrop-filter: var(--footer-nav-glass-blur);
    border: var(--footer-nav-glass-border);
    box-shadow: none;
    transition: gap 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .admin-footer-nav.footer-nav-collapsed .admin-footer-nav-pill {
    gap: 0;
    overflow: visible;
  }

  .admin-footer-nav.footer-nav-collapsed .admin-footer-nav-bar {
    overflow: visible;
  }

  .footer-nav-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transform: translateX(0);
    transition:
      transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.18s ease;
  }

  .footer-nav-indicator.is-visible {
    opacity: 1;
  }

  .admin-footer-nav-pill.footer-nav-pill--dragging {
    touch-action: none;
  }

  .admin-footer-nav-pill.footer-nav-pill--dragging .footer-nav-btn {
    pointer-events: none;
  }

  .footer-nav-indicator.footer-nav-indicator--dragging {
    transition: none !important;
    z-index: 2;
    cursor: grabbing;
  }

  .admin-footer-nav-pill:not(.footer-nav-pill--dragging) .footer-nav-indicator.is-visible {
    cursor: grab;
  }

  .footer-nav-indicator[hidden] {
    display: none !important;
  }

  .footer-nav-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--footer-nav-pill-h);
    height: 100%;
    max-width: var(--footer-nav-pill-h);
    padding: 0;
    border: none;
    border-radius: 999px;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    flex-shrink: 0;
    overflow: visible;
    transition:
      color 0.15s,
      background 0.15s,
      opacity 0.24s ease,
      max-width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      margin 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-tap-highlight-color: transparent;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home),
  .admin-footer-nav.footer-nav-collapsed #footer-nav-profile {
    width: 0;
    max-width: 0;
    opacity: 0;
    margin: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .footer-nav-btn:hover {
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-nav-btn.active,
  .footer-nav-profile.active,
  .admin-footer-nav.footer-nav-collapsed #footer-nav-home,
  .footer-nav-btn.footer-nav-btn--create,
  .footer-nav-btn.footer-nav-btn--create.active {
    border-radius: 999px;
  }

  .footer-nav-btn.active {
    color: #fff;
    background: transparent;
  }

  .footer-nav-btn.footer-nav-btn--create,
  .footer-nav-btn.footer-nav-btn--create.active {
    color: #fff;
    background: var(--create-fab-bg);
    box-shadow: var(--create-fab-shadow);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .footer-nav-btn.footer-nav-btn--create:hover {
    color: #fff;
    filter: brightness(1.08);
    box-shadow: 0 4px 20px rgba(192, 38, 211, 0.58), 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .footer-nav-btn.footer-nav-btn--create svg {
    stroke-width: 2.25;
  }

  .admin-footer-nav.footer-nav-collapsed #footer-nav-home {
    color: #fff;
    background: transparent;
  }

  .footer-nav-btn svg,
  .footer-nav-chat-icon svg {
    display: block;
    pointer-events: none;
  }

  .footer-nav-profile {
    width: var(--footer-nav-pill-h);
    height: 100%;
    max-width: var(--footer-nav-pill-h);
    padding: 0;
    overflow: hidden;
    border: none;
    border-radius: 999px;
    background: transparent;
  }

  .footer-nav-profile:hover {
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-nav-profile.active {
    color: #fff;
    background: transparent;
  }

  .footer-nav-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    pointer-events: none;
    display: block;
  }

  .footer-nav-initials {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.72);
    pointer-events: none;
  }

  .footer-nav-badge {
    position: absolute;
    top: 0.15rem;
    right: 0.1rem;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    pointer-events: none;
    z-index: 5;
    box-shadow: 0 0 0 2px rgba(10, 13, 20, 0.55);
    transition: opacity 0.2s ease;
  }

  .admin-footer-nav.footer-nav-collapsed #footer-nav-home .footer-nav-badge {
    z-index: 10;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home) .footer-nav-badge,
  .admin-footer-nav.footer-nav-collapsed #footer-nav-profile .footer-nav-badge {
    display: none !important;
  }

  .footer-nav-badge[hidden] {
    display: none !important;
  }

  @media print {
    .admin-footer-nav {
      display: none !important;
    }
  }
</style>
