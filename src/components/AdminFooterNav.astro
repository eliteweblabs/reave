---
import { Home, MessageCircle, Mail, Search, Briefcase } from "lucide-astro";
---

<nav id="admin-footer-nav" class="admin-footer-nav" aria-label="Admin navigation">
  <div class="admin-footer-nav-bar">
    <div class="admin-footer-nav-pill">
    <div id="footer-nav-indicator" class="footer-nav-indicator" hidden aria-hidden="true"></div>
    <button
      type="button"
      id="footer-nav-home"
      class="footer-nav-btn"
      data-nav="home"
      aria-label="Home"
    >
      <Home size={20} strokeWidth={1.75} />
      <span id="footer-home-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-chat"
      class="footer-nav-btn"
      data-nav="chat"
      aria-label="Chats"
    >
      <MessageCircle size={20} strokeWidth={1.75} />
      <span id="footer-chat-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-inbox"
      class="footer-nav-btn"
      data-nav="inbox"
      aria-label="Inbox"
    >
      <Mail size={20} strokeWidth={1.75} />
      <span id="footer-inbox-badge" class="footer-nav-badge" hidden>0</span>
    </button>
    <button
      type="button"
      id="footer-nav-search"
      class="footer-nav-btn"
      data-nav="search"
      aria-label="Search"
      aria-expanded="false"
    >
      <Search size={20} strokeWidth={1.75} />
    </button>

    <button
      type="button"
      id="footer-nav-work"
      class="footer-nav-btn"
      data-nav="work"
      aria-label="Projects"
    >
      <Briefcase size={20} strokeWidth={1.75} />
    </button>
  </div>
    <div id="footer-chat-compose" class="footer-chat-compose" hidden></div>
  </div>
</nav>

<style is:global>
  .admin-footer-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2000;
    display: flex;
    justify-content: center;
    padding:
      0 max(0.5rem, env(safe-area-inset-right, 0px))
      env(safe-area-inset-bottom, 0px)
      max(0.5rem, env(safe-area-inset-left, 0px));
    background: transparent;
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
    transition:
      left 0.18s ease,
      justify-content 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Desktop split view: center footer in the main pane, not under the sidebar. */
  body.admin-split-view .admin-footer-nav {
    left: var(--sidebar-w);
  }

  .admin-footer-nav.footer-nav-has-compose {
    justify-content: stretch;
  }

  .admin-footer-nav-bar {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    width: auto;
    max-width: none;
    pointer-events: auto;
  }

  .admin-footer-nav.footer-nav-has-compose:not(.footer-nav-compose-open) .admin-footer-nav-bar {
    width: 100%;
    max-width: min(100%, 720px);
  }

  .footer-chat-compose {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .footer-chat-compose .ch-compose {
    width: 100%;
    min-width: 0;
  }

  .footer-chat-compose[hidden] {
    display: none !important;
  }

  /* Compose open: one control-field shell wraps home + message (matches sidebar search). */
  .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar {
    flex: 1;
    min-width: 0;
    gap: 0;
    padding: var(--control-inset);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-pill);
    background: var(--card);
    min-height: var(--control-h);
    box-sizing: border-box;
    transition: border-color 0.12s;
  }

  .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar:focus-within {
    border-color: #3b82f6;
  }

  .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-pill {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border: none;
    box-shadow: none;
    gap: 0;
    flex-shrink: 0;
    height: auto;
  }

  .admin-footer-nav.footer-nav-compose-open #footer-nav-home {
    width: calc(var(--control-h) - var(--control-inset) * 2);
    height: calc(var(--control-h) - var(--control-inset) * 2);
    max-width: calc(var(--control-h) - var(--control-inset) * 2);
  }

  .admin-footer-nav.footer-nav-compose-open .footer-chat-compose {
    padding: 0;
    border-left: none;
  }

  /* Mobile: merge home + compose into one compact pill. */
  @media (max-width: 639px) {
    .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar {
      width: 100%;
      max-width: min(100%, 720px);
      overflow: visible;
      align-items: center;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-nav-btn:not(#footer-nav-home),
    .admin-footer-nav.footer-nav-compose-open #footer-nav-work {
      width: 0;
      max-width: 0;
      opacity: 0;
      margin: 0;
      overflow: hidden;
      pointer-events: none;
    }
  }

  /* Wider than mobile: all nav icons stay left; compose centers in remaining space. */
  @media (min-width: 640px) {
    .admin-footer-nav.footer-nav-has-compose,
    .admin-footer-nav.footer-nav-compose-open {
      justify-content: flex-start;
    }

    .admin-footer-nav.footer-nav-has-compose:not(.footer-nav-compose-open) .admin-footer-nav-bar {
      width: 100%;
      max-width: none;
      gap: 0.35rem;
      background: transparent;
      border: none;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      overflow: visible;
    }

    .admin-footer-nav.footer-nav-compose-open .admin-footer-nav-bar {
      width: 100%;
      max-width: none;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-chat-compose {
      flex: 1 1 auto;
      justify-content: center;
    }

    .admin-footer-nav.footer-nav-compose-open .footer-chat-compose .ch-compose {
      width: 100%;
      max-width: none;
    }

    .admin-footer-nav.footer-nav-has-compose.footer-nav-collapsed,
    .admin-footer-nav.footer-nav-compose-nav-only {
      justify-content: flex-end;
    }
  }

  .admin-footer-nav.footer-nav-collapsed {
    justify-content: flex-end;
  }

  .admin-footer-nav.footer-nav-has-compose.footer-nav-collapsed {
    justify-content: stretch;
  }

  .admin-footer-nav.footer-nav-compose-nav-only {
    justify-content: center;
  }

  .admin-footer-nav.footer-nav-compose-nav-only .admin-footer-nav-bar {
    width: auto;
    max-width: none;
  }

  .admin-footer-nav-pill {
    position: relative;
    flex-shrink: 0;
    pointer-events: auto;
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    height: var(--footer-nav-pill-h);
    padding: 0;
    border-radius: 999px;
    background: var(--footer-nav-glass-bg);
    backdrop-filter: var(--footer-nav-glass-blur);
    -webkit-backdrop-filter: var(--footer-nav-glass-blur);
    border: var(--footer-nav-glass-border);
    box-shadow: none;
    transition: gap 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .admin-footer-nav.footer-nav-collapsed .admin-footer-nav-pill {
    gap: 0;
    overflow: visible;
  }

  .admin-footer-nav.footer-nav-collapsed .admin-footer-nav-bar {
    overflow: visible;
  }

  .footer-nav-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    border-radius: 999px;
    background: var(--nav-indicator-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transform: translateX(0);
    transition:
      transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.18s ease;
  }

  .footer-nav-indicator.is-visible {
    opacity: 1;
  }

  .admin-footer-nav-pill.footer-nav-pill--dragging {
    touch-action: none;
  }

  .admin-footer-nav-pill.footer-nav-pill--dragging .footer-nav-btn {
    pointer-events: none;
  }

  .footer-nav-indicator.footer-nav-indicator--dragging {
    transition: none !important;
    z-index: 2;
    cursor: grabbing;
  }

  .admin-footer-nav-pill:not(.footer-nav-pill--dragging) .footer-nav-indicator.is-visible {
    cursor: grab;
  }

  .footer-nav-indicator[hidden] {
    display: none !important;
  }

  .footer-nav-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--footer-nav-pill-h);
    height: 100%;
    max-width: var(--footer-nav-pill-h);
    padding: 0;
    border: none;
    border-radius: 999px;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    color: var(--nav-icon);
    cursor: pointer;
    flex-shrink: 0;
    overflow: visible;
    transition:
      color 0.15s,
      background 0.15s,
      opacity 0.24s ease,
      max-width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      margin 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    -webkit-tap-highlight-color: transparent;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home),
  .admin-footer-nav.footer-nav-collapsed #footer-nav-work {
    width: 0;
    max-width: 0;
    opacity: 0;
    margin: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .footer-nav-btn:hover {
    color: var(--nav-icon-hover);
  }

  .footer-nav-btn.active,
  .admin-footer-nav.footer-nav-collapsed #footer-nav-home,
  .footer-nav-btn.footer-nav-btn--create,
  .footer-nav-btn.footer-nav-btn--create.active {
    border-radius: 999px;
  }

  .footer-nav-btn.active {
    color: var(--nav-icon-active);
    background: transparent;
  }

  .footer-nav-btn.footer-nav-btn--create,
  .footer-nav-btn.footer-nav-btn--create.active {
    color: #fff;
    background: var(--create-fab-bg);
    box-shadow: var(--create-fab-shadow);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .footer-nav-btn.footer-nav-btn--create:hover {
    color: #fff;
    filter: brightness(1.08);
    box-shadow: 0 4px 20px rgba(192, 38, 211, 0.58), 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .footer-nav-btn.footer-nav-btn--create svg {
    stroke-width: 2.25;
  }

  .admin-footer-nav.footer-nav-collapsed #footer-nav-home {
    color: var(--nav-icon-active);
    background: transparent;
  }

  .footer-nav-btn svg,
  .footer-nav-chat-icon svg,
  .footer-nav-work-icon svg {
    display: block;
    pointer-events: none;
  }

  .footer-nav-badge {
    position: absolute;
    top: 0.15rem;
    right: 0.1rem;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    pointer-events: none;
    z-index: 5;
    box-shadow: 0 0 0 2px var(--badge-ring);
    transition: opacity 0.2s ease;
  }

  .admin-footer-nav.footer-nav-collapsed #footer-nav-home .footer-nav-badge {
    z-index: 10;
  }

  .admin-footer-nav.footer-nav-collapsed .footer-nav-btn:not(#footer-nav-home) .footer-nav-badge,
  .admin-footer-nav.footer-nav-collapsed #footer-nav-work .footer-nav-badge {
    display: none !important;
  }

  .footer-nav-badge[hidden] {
    display: none !important;
  }

  @media print {
    .admin-footer-nav {
      display: none !important;
    }
  }
</style>
