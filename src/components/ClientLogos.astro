---
// Desaturated "worked with" logo marquee.
// Assets live in /public/logos/clients — see that folder for sourcing notes.
interface ClientLogo {
  name: string;
  src: string;
}

const logos: ClientLogo[] = [
  { name: "Porsche", src: "/logos/clients/porsche.svg" },
  { name: "The New York Times", src: "/logos/clients/newyorktimes.svg" },
  { name: "Red Bull", src: "/logos/clients/redbull.svg" },
  { name: "Chase Bank", src: "/logos/clients/chase.svg" },
  { name: "Acura", src: "/logos/clients/acura.svg" },
  { name: "Bombay Sapphire", src: "/logos/clients/bombay-sapphire.png" },
  { name: "Live Nation", src: "/logos/clients/live-nation.svg" },
  { name: "Johnnie Walker", src: "/logos/clients/johnnie-walker.svg" },
  { name: "Worcester Polytechnic Institute", src: "/logos/clients/wpi.svg" },
  { name: "Kingdom Trails", src: "/logos/clients/kingdom-trails.svg" },
  { name: "UC Law San Francisco", src: "/logos/clients/uc-law-sf.svg" },
  { name: "Mohegan Sun", src: "/logos/clients/mohegan-sun.svg" },
  { name: "Sharpie", src: "/logos/clients/sharpie.svg" },
  { name: "The Overlook", src: "/logos/clients/overlook.svg" },
];

const LOOP_COPIES = 3;
const trackLogos = Array.from({ length: LOOP_COPIES }, () => logos).flat();
---

<div
  class="client-logos-viewport"
  data-client-logos
  data-loop-copies={LOOP_COPIES}
  style={`--loop-copies: ${LOOP_COPIES}`}
>
  <div class="client-logos-track">
    {
      trackLogos.map((logo, index) => (
        <div class="client-logo-item" aria-hidden={index >= logos.length ? "true" : undefined}>
          <img
            src={logo.src}
            alt={index < logos.length ? logo.name : ""}
            loading="lazy"
            decoding="async"
            draggable="false"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .client-logos-viewport {
    --visible-count: 3;
    --marquee-duration: 45s;
    position: relative;
    width: 100%;
    overflow: hidden;
    cursor: grab;
    touch-action: pan-y;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 8%,
      #000 92%,
      transparent 100%
    );
    mask-image: linear-gradient(90deg, transparent 0%, #000 8%, #000 92%, transparent 100%);
  }

  .client-logos-viewport.is-dragging {
    cursor: grabbing;
  }

  .client-logos-track {
    display: flex;
    will-change: transform;
    animation: client-logos-marquee var(--marquee-duration) linear infinite;
  }

  .client-logos-viewport.is-paused .client-logos-track {
    animation-play-state: paused;
  }

  @keyframes client-logos-marquee {
    to {
      transform: translate3d(calc(-100% / var(--loop-copies)), 0, 0);
    }
  }

  .client-logo-item {
    flex: 0 0 calc(100vw / var(--visible-count));
    width: calc(100vw / var(--visible-count));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 21px;
    box-sizing: border-box;
  }

  .client-logo-item img {
    max-width: 100%;
    max-height: 34px;
    width: auto;
    height: auto;
    pointer-events: none;
    user-select: none;
    /* Fully desaturate, then flip dark wordmarks light so every logo —
       regardless of its source colors — reads as a neutral gray/white
       mark against the dark background. */
    filter: grayscale(100%) invert(100%);
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .client-logos-viewport:hover .client-logo-item img {
    opacity: 0.75;
  }

  @media (min-width: 480px) {
    .client-logos-viewport {
      --visible-count: 4;
    }
  }

  @media (min-width: 640px) {
    .client-logos-viewport {
      --visible-count: 5;
    }
  }

  @media (min-width: 768px) {
    .client-logos-viewport {
      --visible-count: 6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-logos-track {
      animation: none;
    }
  }
</style>

<script>
  function initClientLogos(viewport: HTMLElement) {
    if (viewport.dataset.clientLogosInit === "true") return;
    viewport.dataset.clientLogosInit = "true";

    const trackEl = viewport.querySelector<HTMLElement>(".client-logos-track");
    if (!trackEl) return;
    const track = trackEl;

    const loopCopies = Number(viewport.dataset.loopCopies || "3");
    const velocity = 28;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canHover = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

    function getSetWidth() {
      return track.scrollWidth / loopCopies;
    }

    function updateMarqueeDuration() {
      if (prefersReducedMotion) return;

      const setWidth = getSetWidth() || viewport.clientWidth;
      if (setWidth > 0) {
        viewport.style.setProperty("--marquee-duration", `${setWidth / velocity}s`);
      }
    }

    let isDragging = false;
    let offscreen = false;
    let dragStartX = 0;
    let dragStartOffset = 0;
    let manualOffset = 0;

    function syncPausedClass() {
      viewport.classList.toggle("is-paused", offscreen || isDragging);
    }

    function normalizeOffset() {
      const setWidth = getSetWidth();
      if (!setWidth) return;

      while (manualOffset <= -setWidth) manualOffset += setWidth;
      while (manualOffset > 0) manualOffset -= setWidth;
    }

    function applyManualTransform() {
      track.style.transform = `translate3d(${manualOffset}px, 0, 0)`;
    }

    function clearManualTransform() {
      track.style.removeProperty("transform");
    }

    const visibilityObs =
      "IntersectionObserver" in window
        ? new IntersectionObserver(
            (entries) => {
              offscreen = !entries.some((entry) => entry.isIntersecting);
              if (!isDragging) syncPausedClass();
            },
            { root: null, threshold: 0.05 },
          )
        : null;
    visibilityObs?.observe(viewport);

    function onPointerDown(event: PointerEvent) {
      if (event.button !== 0 && event.pointerType === "mouse") return;

      isDragging = true;
      viewport.classList.add("is-dragging");
      syncPausedClass();
      dragStartX = event.clientX;

      const matrix = new DOMMatrix(getComputedStyle(track).transform);
      manualOffset = matrix.m41;
      dragStartOffset = manualOffset;

      viewport.setPointerCapture(event.pointerId);
      event.preventDefault();
    }

    function onPointerMove(event: PointerEvent) {
      if (!isDragging) return;

      manualOffset = dragStartOffset + (event.clientX - dragStartX);
      normalizeOffset();
      applyManualTransform();
    }

    function endDrag(event: PointerEvent) {
      if (!isDragging) return;

      isDragging = false;
      viewport.classList.remove("is-dragging");
      clearManualTransform();
      syncPausedClass();

      if (viewport.hasPointerCapture(event.pointerId)) {
        viewport.releasePointerCapture(event.pointerId);
      }
    }

    if (canHover) {
      viewport.addEventListener("pointerdown", onPointerDown);
      viewport.addEventListener("pointermove", onPointerMove);
      viewport.addEventListener("pointerup", endDrag);
      viewport.addEventListener("pointercancel", endDrag);
      viewport.addEventListener("lostpointercapture", () => {
        isDragging = false;
        viewport.classList.remove("is-dragging");
        clearManualTransform();
        syncPausedClass();
      });

      viewport.addEventListener("mouseenter", () => {
        viewport.classList.add("is-paused");
      });

      viewport.addEventListener("mouseleave", () => {
        if (!isDragging && !offscreen) viewport.classList.remove("is-paused");
      });
    }

    const resizeObserver = new ResizeObserver(updateMarqueeDuration);
    resizeObserver.observe(viewport);

    track.querySelectorAll("img").forEach((img) => {
      if (!(img as HTMLImageElement).complete) {
        img.addEventListener("load", updateMarqueeDuration, { once: true });
      }
    });

    updateMarqueeDuration();
    requestAnimationFrame(updateMarqueeDuration);

    return () => {
      resizeObserver.disconnect();
      visibilityObs?.disconnect();
    };
  }

  function initAllClientLogos() {
    document.querySelectorAll<HTMLElement>("[data-client-logos]").forEach((viewport) => {
      initClientLogos(viewport);
    });
  }

  initAllClientLogos();
  document.addEventListener("astro:page-load", initAllClientLogos);
</script>
