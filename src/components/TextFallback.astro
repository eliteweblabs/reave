---
// Accessibility fallback for the voice-first homepage.
// After a few seconds with no audio input, a typed-conversation panel fades in so
// the experience works without speaking/hearing. It reuses the conversational
// contact-form's visual language and feeds the same `vapi-transcript` / `audioLevel`
// events, so typed messages still drive the reactive quantum-core logo.
---

<div id="text-fallback" class="text-fallback" aria-live="polite">
  <div class="tf-caption" id="tf-caption">
    No sound detected — you can type instead.
  </div>
  <div class="tf-conversation" id="tf-conversation"></div>
  <form class="tf-input-area" id="tf-form">
    <input
      type="text"
      id="tf-input"
      placeholder="Type your message…"
      autocomplete="off"
      aria-label="Type your message"
    />
    <button type="submit" aria-label="Send message">Send</button>
  </form>
  <button type="button" class="tf-hide" id="tf-hide">Use voice instead</button>
</div>

<style>
  .text-fallback {
    position: fixed;
    bottom: calc(108px + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    width: 92%;
    max-width: 600px;
    z-index: 120;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    font-family: "Inter", -apple-system, sans-serif;
    /* Hidden until revealed; container itself doesn't block the scene. */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.6s ease,
      transform 0.6s ease,
      visibility 0s linear 0.6s;
  }

  .text-fallback.tf-visible {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .tf-caption {
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, rgba(255, 255, 255, 0.45));
  }

  .tf-conversation {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 34vh;
    overflow-y: auto;
    padding: 2px;
    scrollbar-width: none;
  }

  .tf-conversation::-webkit-scrollbar {
    display: none;
  }

  .tf-input-area {
    display: flex;
    gap: 10px;
    pointer-events: auto;
  }

  .tf-input-area input {
    flex: 1;
    padding: 14px 18px;
    border-radius: 12px;
    border: 1px solid var(--panel-border, rgba(168, 85, 247, 0.3));
    background: var(--elabel-bg, rgba(255, 255, 255, 0.06));
    color: var(--fg, #fff);
    font-size: 16px;
    outline: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }

  .tf-input-area input:focus {
    border-color: #a855f7;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .tf-input-area button[type="submit"] {
    padding: 14px 22px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: #fff;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .tf-input-area button[type="submit"]:hover {
    transform: translateY(-2px);
  }

  .tf-hide {
    align-self: center;
    margin-top: 2px;
    padding: 4px 8px;
    background: none;
    border: none;
    color: var(--muted, rgba(255, 255, 255, 0.4));
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    pointer-events: auto;
    transition: color 0.2s;
  }

  .tf-hide:hover {
    color: var(--nav-icon-hover, rgba(255, 255, 255, 0.75));
  }

  @media (max-width: 768px) {
    .text-fallback {
      bottom: calc(96px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>

<!--
  Messages are created in JS (document.createElement), so Astro's scoped-style
  attribute never lands on them. These rules must be global; we keep them tightly
  scoped under #text-fallback so nothing leaks.
-->
<style is:global>
  #text-fallback .tf-message {
    max-width: 85%;
    line-height: 1.5;
    font-size: 15px;
    padding: 9px 14px;
    border-radius: 14px;
    animation: tfMsgIn 0.3s ease;
    word-wrap: break-word;
    color: var(--fg, #fff);
    background: var(--elabel-bg, rgba(18, 16, 26, 0.9));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-shadow: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  #text-fallback .tf-message.robot {
    align-self: flex-start;
    border: 1px solid rgba(168, 85, 247, 0.65);
    border-bottom-left-radius: 4px;
  }

  #text-fallback .tf-message.user {
    align-self: flex-end;
    text-align: right;
    border: 1px solid rgba(236, 72, 153, 0.65);
    border-bottom-right-radius: 4px;
  }

  @keyframes tfMsgIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    #text-fallback .tf-message {
      font-size: 14px;
    }
  }
</style>

<script>
  const REVEAL_AFTER_MS = 7000;
  const AUDIO_THRESHOLD = 0.04;
  const MAX_MESSAGES = 8;

  const panel = document.getElementById("text-fallback");
  const conversation = document.getElementById("tf-conversation");
  const form = document.getElementById("tf-form") as HTMLFormElement | null;
  const input = document.getElementById("tf-input") as HTMLInputElement | null;
  const hideBtn = document.getElementById("tf-hide");

  if (panel && conversation && form && input) {
    let started = false;
    let revealed = false;
    let dismissed = false;
    let lastAudioTs = Date.now();
    let greeted = false;

    function reveal() {
      if (revealed || dismissed) return;
      revealed = true;
      panel!.classList.add("tf-visible");
      if (!greeted) {
        greeted = true;
        appendMessage(
          "I didn't catch any audio — type your message here and I'll keep up.",
          "robot",
        );
      }
    }

    function hide() {
      revealed = false;
      dismissed = true;
      panel!.classList.remove("tf-visible");
    }

    function appendMessage(text: string, type: "user" | "robot") {
      const msg = document.createElement("div");
      msg.className = `tf-message ${type}`;
      msg.textContent = text;
      conversation!.appendChild(msg);
      conversation!.scrollTop = conversation!.scrollHeight;
      const msgs = conversation!.querySelectorAll(".tf-message");
      if (msgs.length > MAX_MESSAGES) msgs[0].remove();
    }

    /** Make the reactive logo respond to typed input (parity with speaking). */
    function pulseVisual(type: "user" | "robot", text: string) {
      window.dispatchEvent(
        new CustomEvent("vapi-transcript", {
          detail: { type: type === "user" ? "user" : "assistant", text },
        }),
      );
      let n = 0;
      const id = window.setInterval(() => {
        window.dispatchEvent(
          new CustomEvent("audioLevel", {
            detail: { level: 0.5 + Math.random() * 0.4 },
          }),
        );
        if (++n > 10) {
          window.clearInterval(id);
          window.dispatchEvent(
            new CustomEvent("audioLevel", { detail: { level: 0 } }),
          );
        }
      }, 60);
    }

    async function respond(text: string) {
      // Extension hook: assign `window.__reaveTextRespond` to wire a real text
      // assistant. It may return a string or a Promise<string>.
      const hook = (window as unknown as {
        __reaveTextRespond?: (t: string) => string | Promise<string>;
      }).__reaveTextRespond;
      let reply =
        "Got it — I've noted that. Keep typing, or press the fingerprint to talk out loud.";
      try {
        if (typeof hook === "function") {
          reply = await hook(text);
        }
      } catch {
        reply = "Sorry — something went wrong. Please try again.";
      }
      window.setTimeout(() => {
        appendMessage(reply, "robot");
        pulseVisual("robot", reply);
      }, 450);
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const value = input!.value.trim();
      if (!value) return;
      appendMessage(value, "user");
      input!.value = "";
      pulseVisual("user", value);
      respond(value);
    });

    hideBtn?.addEventListener("click", hide);

    // Any real audio activity resets the silence timer — if the user is actually
    // speaking we don't need to offer the text fallback.
    window.addEventListener("audioLevel", ((ev: Event) => {
      const lvl = (ev as CustomEvent<{ level?: number }>).detail?.level ?? 0;
      if (lvl > AUDIO_THRESHOLD) lastAudioTs = Date.now();
    }) as EventListener);

    // The whole flow only begins once the user presses the fingerprint (which
    // starts the voice session). Each press re-arms the silence watch.
    window.addEventListener("vapi-call-start", () => {
      started = true;
      dismissed = false;
      lastAudioTs = Date.now();
    });

    // When the session ends, stop watching and hide so it can re-trigger on the
    // next press.
    window.addEventListener("vapi-call-end", () => {
      started = false;
      revealed = false;
      lastAudioTs = Date.now();
      panel!.classList.remove("tf-visible");
    });

    // After the user has pressed the fingerprint, reveal the text panel if no
    // audio comes through for a stretch (e.g. a deaf user who can't speak).
    window.setInterval(() => {
      if (!started || revealed || dismissed) return;
      if (Date.now() - lastAudioTs > REVEAL_AFTER_MS) reveal();
    }, 1000);
  }
</script>
