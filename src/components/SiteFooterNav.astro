---
import { Home, Info, Briefcase, LayoutGrid, Mail, Mic } from "lucide-astro";
import VoiceChatButton from "./VoiceChatButton.astro";
import Transcript from "./Transcript.astro";
import TextFallback from "./TextFallback.astro";
import { getCompanyConfig } from "../lib/companyConfig";
import { isHomepageVoiceWidgetEnabled } from "../lib/vapiPlugin";

export type SiteNavId = "home" | "about" | "services" | "portfolio" | "contact";

interface Props {
  active?: SiteNavId;
}

const { active } = Astro.props;

// The voice assistant shows anywhere the footer nav renders (not just the
// homepage), gated only by whether the install has the voice widget enabled.
const company = await getCompanyConfig(Astro.request);
const voice = isHomepageVoiceWidgetEnabled(company);

const pathNorm = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHomePage = pathNorm === "/" || pathNorm === "/index.html";

function resolveActive(): SiteNavId {
  if (active) return active;
  if (isHomePage) return "home";
  return "home";
}

const current = resolveActive();

const items: Array<{
  id: SiteNavId;
  href: string;
  label: string;
  Icon: typeof Home;
}> = [
  { id: "home", href: "/#home", label: "Home", Icon: Home },
  { id: "about", href: "/#about", label: "About", Icon: Info },
  { id: "services", href: "/#services", label: "Services", Icon: Briefcase },
  { id: "portfolio", href: "/#portfolio", label: "Portfolio", Icon: LayoutGrid },
  { id: "contact", href: "/#contact", label: "Contact", Icon: Mail },
];
---

<nav id="site-footer-nav" class="site-footer-nav" aria-label="Site navigation" data-home-nav={isHomePage ? "true" : undefined}>
  <div class="site-footer-nav-bar">
    <div class="site-footer-nav-pill">
      <div id="site-footer-nav-indicator" class="footer-nav-indicator" hidden aria-hidden="true"></div>
      {
        items.map(({ id, href, label, Icon }) => (
          <a
            href={href}
            class:list={["footer-nav-btn", { active: current === id }]}
            data-nav={id}
            aria-label={label}
            aria-current={current === id ? "true" : undefined}
          >
            <Icon size={20} strokeWidth={1.75} />
          </a>
        ))
      }
      {
        voice && (
          <button
            type="button"
            id="footer-nav-voice-btn"
            class="footer-nav-btn footer-nav-voice"
            data-nav="voice"
            aria-label="Talk to our AI assistant"
          >
            <Mic size={20} strokeWidth={1.75} />
          </button>
        )
      }
    </div>
  </div>
</nav>

{
  voice && (
    <>
      <VoiceChatButton
        position="center-bottom"
        assistantId={company.vapiAssistantId || undefined}
        companyName={company.name}
        companyDescription={company.description}
        companyDomain={company.domain}
      />
      <Transcript />
      <TextFallback />
    </>
  )
}

<script>
  const SECTION_IDS = ["home", "about", "services", "portfolio", "contact"] as const;
  type NavId = (typeof SECTION_IDS)[number];

  function positionSiteFooterIndicator() {
    const pill = document.querySelector(".site-footer-nav-pill");
    const indicator = document.getElementById("site-footer-nav-indicator");
    const active = pill?.querySelector<HTMLElement>(".footer-nav-btn.active");
    if (!pill || !indicator || !active) {
      if (indicator) indicator.hidden = true;
      return;
    }

    indicator.hidden = false;
    indicator.classList.add("is-visible");
    indicator.style.width = `${active.offsetWidth}px`;
    indicator.style.transform = `translateX(${active.offsetLeft}px)`;
  }

  function setActiveNav(id: NavId, { updateHash = false }: { updateHash?: boolean } = {}) {
    const pill = document.querySelector(".site-footer-nav-pill");
    if (!pill) return;

    pill.querySelectorAll<HTMLAnchorElement>(".footer-nav-btn[data-nav]").forEach((btn) => {
      const navId = btn.dataset.nav;
      if (!navId || navId === "voice") return;
      const isActive = navId === id;
      btn.classList.toggle("active", isActive);
      if (isActive) btn.setAttribute("aria-current", "true");
      else btn.removeAttribute("aria-current");
    });

    positionSiteFooterIndicator();

    if (updateHash) {
      const next = id === "home" ? "/" : `/#${id}`;
      if (`${location.pathname}${location.hash}` !== next && location.pathname === "/") {
        history.replaceState(null, "", next === "/" ? "/" : `#${id}`);
      }
    }
  }

  function scrollToSection(id: NavId) {
    const el = document.getElementById(id);
    if (!el) return false;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    el.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "start" });
    setActiveNav(id, { updateHash: true });
    return true;
  }

  function wireFooterNavAnchors() {
    const nav = document.getElementById("site-footer-nav");
    if (!nav || nav.dataset.anchorsWired === "1") return;
    nav.dataset.anchorsWired = "1";

    nav.querySelectorAll<HTMLAnchorElement>("a.footer-nav-btn[data-nav]").forEach((link) => {
      link.addEventListener("click", (event) => {
        const id = link.dataset.nav as NavId | undefined;
        if (!id || !SECTION_IDS.includes(id)) return;

        // Already on homepage — smooth-scroll to the section.
        if (document.getElementById(id)) {
          event.preventDefault();
          scrollToSection(id);
          return;
        }

        // Off-homepage: let the browser navigate to `/#section`.
      });
    });
  }

  function wireScrollSpy() {
    const nav = document.getElementById("site-footer-nav");
    if (!nav || nav.dataset.homeNav !== "true") return;
    if (nav.dataset.spyWired === "1") return;
    nav.dataset.spyWired = "1";

    const sections = SECTION_IDS.map((id) => document.getElementById(id)).filter(
      (el): el is HTMLElement => !!el,
    );
    if (!sections.length) return;

    const ratios = new Map<Element, number>();
    let scrollingTo: NavId | null = null;
    let scrollTimer = 0;

    const activateBest = () => {
      if (scrollingTo) {
        setActiveNav(scrollingTo);
        return;
      }
      let bestId: NavId | null = null;
      let bestRatio = 0;
      for (const section of sections) {
        const r = ratios.get(section) || 0;
        if (r > bestRatio) {
          bestRatio = r;
          const id = section.id as NavId;
          if (SECTION_IDS.includes(id)) bestId = id;
        }
      }
      if (bestId && bestRatio > 0.15) {
        setActiveNav(bestId, { updateHash: true });
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          ratios.set(entry.target, entry.intersectionRatio);
        });
        activateBest();
      },
      {
        root: null,
        // Bias toward the section occupying the upper/mid viewport (above the footer pill).
        rootMargin: "-18% 0px -42% 0px",
        threshold: [0, 0.2, 0.4, 0.6, 0.8, 1],
      },
    );

    sections.forEach((section) => observer.observe(section));

    // While a nav click smooth-scroll is in flight, pin the active item.
    nav.querySelectorAll<HTMLAnchorElement>("a.footer-nav-btn[data-nav]").forEach((link) => {
      link.addEventListener("click", () => {
        const id = link.dataset.nav as NavId | undefined;
        if (!id || !SECTION_IDS.includes(id)) return;
        scrollingTo = id;
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(() => {
          scrollingTo = null;
          activateBest();
        }, 900);
      });
    });

    // Deep links: `/#about` or `/?section=about`
    const params = new URLSearchParams(location.search);
    const fromQuery = params.get("section");
    const fromHash = location.hash.replace(/^#/, "");
    const target = (fromQuery || fromHash) as NavId;
    if (SECTION_IDS.includes(target)) {
      // Defer so layout/fonts settle before scrolling.
      requestAnimationFrame(() => {
        scrollToSection(target);
        if (fromQuery) {
          history.replaceState(null, "", target === "home" ? "/" : `/#${target}`);
        }
      });
    }
  }

  function bootSiteFooterNav() {
    positionSiteFooterIndicator();
    wireFooterNavAnchors();
    wireScrollSpy();
  }

  bootSiteFooterNav();
  window.addEventListener("resize", positionSiteFooterIndicator, { passive: true });
  document.addEventListener("astro:page-load", bootSiteFooterNav);

  // Wire the footer voice button to the hidden VoiceChatButton widget and
  // reflect the call state (active while a call is in progress).
  function wireFooterVoiceButton() {
    const voiceBtn = document.getElementById("footer-nav-voice-btn");
    if (!voiceBtn || voiceBtn.dataset.wired === "1") return;
    voiceBtn.dataset.wired = "1";

    voiceBtn.addEventListener("click", () => {
      document.getElementById("vapi-voice-button")?.click();
    });

    window.addEventListener("vapi-call-start", () => {
      voiceBtn.classList.add("active");
      voiceBtn.setAttribute("aria-label", "End voice chat");
    });
    window.addEventListener("vapi-call-end", () => {
      voiceBtn.classList.remove("active");
      voiceBtn.setAttribute("aria-label", "Talk to our AI assistant");
    });
  }

  wireFooterVoiceButton();
  document.addEventListener("astro:page-load", wireFooterVoiceButton);
</script>

<style is:global>
  :root {
    --site-footer-nav-offset: calc(var(--footer-nav-pill-h, 2.5rem) + 0.85rem);
  }

  .site-footer-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2000;
    display: flex;
    justify-content: center;
    padding:
      0 max(0.5rem, env(safe-area-inset-right, 0px))
      calc(env(safe-area-inset-bottom, 0px) + 0.35rem)
      max(0.5rem, env(safe-area-inset-left, 0px));
    background: transparent;
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .site-footer-nav-bar {
    display: flex;
    align-items: center;
    pointer-events: auto;
  }

  .site-footer-nav-pill {
    position: relative;
    display: flex;
    align-items: stretch;
    gap: 0.15rem;
    height: var(--footer-nav-pill-h, 2.5rem);
    padding: 0;
    border-radius: var(--radius-input, 8px);
    background: rgba(10, 10, 12, 0.62);
    backdrop-filter: blur(18px) saturate(1.15);
    -webkit-backdrop-filter: blur(18px) saturate(1.15);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
    overflow: visible;
  }

  .site-footer-nav .footer-nav-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    border-radius: var(--radius-input, 8px);
    background: var(--brand-gradient);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transform: translateX(0);
    transition:
      transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.18s ease;
  }

  .site-footer-nav .footer-nav-indicator.is-visible {
    opacity: 1;
  }

  .site-footer-nav .footer-nav-indicator[hidden] {
    display: none !important;
  }

  .site-footer-nav .footer-nav-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--footer-nav-pill-h, 2.5rem);
    height: 100%;
    max-width: var(--footer-nav-pill-h, 2.5rem);
    padding: 0;
    border: none;
    border-radius: var(--radius-input, 8px);
    appearance: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    flex-shrink: 0;
    text-decoration: none;
    transition:
      color 0.15s,
      background 0.15s;
    -webkit-tap-highlight-color: transparent;
  }

  .site-footer-nav .footer-nav-btn:hover {
    color: rgba(255, 255, 255, 0.88);
  }

  .site-footer-nav .footer-nav-btn.active {
    color: #fff;
    background: transparent;
  }

  .site-footer-nav .footer-nav-btn svg {
    display: block;
    pointer-events: none;
  }

  /* Voice-assistant button: active while a Vapi call is in progress. */
  .site-footer-nav .footer-nav-voice.active {
    color: #fff;
    background: var(--brand-gradient);
  }

  .site-footer-nav .footer-nav-voice.active svg {
    animation: footer-nav-voice-pulse 1.4s ease-in-out infinite;
  }

  @keyframes footer-nav-voice-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.65;
      transform: scale(0.88);
    }
  }

  @media print {
    .site-footer-nav {
      display: none !important;
    }
  }

  /* The voice widget's own floating button is never shown — the visible control
     lives in the footer nav pill (#footer-nav-voice-btn) and forwards clicks to
     the hidden #vapi-voice-button. Keep the widget mounted for its call logic
     but hide the floating button across every viewport size and icon state.
     (Astro 5 scopes component styles with :where() — zero specificity — so the
     component's own `display: flex` can win on cascade order without the
     !important here.) */
  .vapi-widget-container {
    display: none !important;
  }

  /* Keep the typed-fallback panel above the footer nav wherever it appears. */
  #text-fallback {
    bottom: calc(108px + var(--site-footer-nav-offset, 3.35rem) + env(safe-area-inset-bottom, 0px));
  }
</style>
