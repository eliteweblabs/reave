const squareImage = (seed: string) => `https://picsum.photos/seed/${seed}/600/600`;
---

<div class="portfolio-masonry" data-portfolio-masonry>
  {
    sections.map((section) => (
      <div class:list={["masonry-grid", `masonry-grid--${section.columns}`]}>
        {
          section.items.map((item) => (
            <article class="masonry-item">
              <button
                type="button"
                class="masonry-card"
                aria-label={`${item.title} — ${item.description}`}
                data-masonry-card
              >
                <img
                  src={squareImage(item.seed)}
                  alt=""
                  width="600"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="masonry-image"
                />
                <div class="masonry-overlay">
                  <div class="masonry-overlay-inner">
                    <h3 class="masonry-title">{item.title}</h3>
                    <p class="masonry-desc">{item.description}</p>
                    <ul class="masonry-tags" aria-label="Tags">
                      {item.tags.map((tag) => (
                        <li>{tag}</li>
                      ))}
                    </ul>
                    {
                      item.button ? (
                        <a class="masonry-btn" href={item.button.href} data-masonry-btn>
                          {item.button.label}
                        </a>
                      ) : null
                    }
                  </div>
                </div>
              </button>
            </article>
          ))
        }
      </div>
    ))
  }
</div>

<style>
  .portfolio-masonry {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2.5vw, 28px);
    padding: 0 clamp(12px, 2vw, 28px);
  }

  .masonry-grid {
    display: grid;
    gap: clamp(8px, 1.2vw, 12px);
  }

  .masonry-grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .masonry-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .masonry-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .masonry-item {
    min-width: 0;
  }

  .masonry-card {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    padding: 0;
    border: none;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.04);
    text-align: left;
    -webkit-tap-highlight-color: transparent;
  }

  .masonry-card:focus-visible {
    outline: 2px solid #a855f7;
    outline-offset: 2px;
  }

  .masonry-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      filter 1.5s ease;
  }

  .masonry-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(10px, 1.5vw, 16px);
    background: linear-gradient(
      180deg,
      rgba(5, 5, 5, 0) 0%,
      rgba(5, 5, 5, 0.35) 38%,
      rgba(5, 5, 5, 0.88) 100%
    );
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.35s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .masonry-overlay-inner {
    transform: translateY(8px);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .masonry-title {
    font-family: var(--font-display);
    font-size: clamp(12px, 1.1vw, 15px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0 0 6px;
    line-height: 1.2;
  }

  .masonry-desc {
    font-family: var(--font-body);
    font-size: clamp(10px, 0.95vw, 12px);
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .masonry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0 0 8px;
  }

  .masonry-tags li {
    font-family: var(--font-display);
    font-size: clamp(8px, 0.75vw, 10px);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    padding: 3px 7px;
    border-radius: 999px;
    border: 1px solid rgba(168, 85, 247, 0.45);
    background: rgba(168, 85, 247, 0.18);
    margin: 0;
    line-height: 1.2;
  }

  .masonry-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(9px, 0.8vw, 11px);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    padding: 7px 12px;
    border-radius: 999px;
    background: var(--brand-gradient);
    box-shadow: 0 2px 12px rgba(168, 85, 247, 0.35);
    pointer-events: auto;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .masonry-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(168, 85, 247, 0.5);
  }

  @media (hover: hover) and (pointer: fine) {
    .masonry-card:hover .masonry-image,
    .masonry-card:focus-visible .masonry-image {
      transform: scale(1.04);
      filter: grayscale(0%);
    }

    .masonry-card:hover .masonry-overlay,
    .masonry-card:focus-visible .masonry-overlay {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .masonry-card:hover .masonry-overlay-inner,
    .masonry-card:focus-visible .masonry-overlay-inner {
      transform: translateY(0);
    }
  }

  .masonry-card.is-active .masonry-image {
    transform: scale(1.02);
    filter: grayscale(0%);
  }

  .masonry-card.is-active .masonry-overlay {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .masonry-card.is-active .masonry-overlay-inner {
    transform: translateY(0);
  }

  @media (max-width: 960px) {
    .masonry-grid--4 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 720px) {
    .masonry-grid--4,
    .masonry-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .masonry-grid--4,
    .masonry-grid--3,
    .masonry-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  function initPortfolioMasonry(root: HTMLElement) {
    const cards = root.querySelectorAll<HTMLButtonElement>("[data-masonry-card]");

    const closeAll = (except?: HTMLButtonElement) => {
      cards.forEach((card) => {
        if (card !== except) card.classList.remove("is-active");
      });
    };

    cards.forEach((card) => {
      card.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        if (target.closest("[data-masonry-btn]")) return;

        const isActive = card.classList.contains("is-active");
        closeAll();
        if (!isActive) card.classList.add("is-active");
      });
    });

    document.addEventListener("click", (event) => {
      const target = event.target as Node;
      if (!root.contains(target)) closeAll();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeAll();
    });
  }

  document.querySelectorAll<HTMLElement>("[data-portfolio-masonry]").forEach(initPortfolioMasonry);
</script>
