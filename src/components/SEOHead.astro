---
/**
 * Drop this inside any <head> to get standardized title, description,
 * canonical URL, OG, and Twitter Card tags.
 *
 * Usage in Layout.astro (or any standalone page):
 *   <SEOHead title="My Page" description="About us" />
 */

export interface Props {
  /** Page-specific title. Rendered as "Page | /\V". Omit to show just "/\V". */
  title?: string;
  /** Meta description for search results and OG cards. */
  description?: string;
  /**
   * Absolute or root-relative path to the OG / social-share image.
   * Defaults to /reave-logo.png.
   */
  ogImage?: string;
  /** OG type. Defaults to "website". */
  ogType?: "website" | "article";
  /** Override the canonical URL. Defaults to the current request URL. */
  canonicalUrl?: string;
  /**
   * Set true on private or internal pages (dev tools, client portals, etc.)
   * that should not appear in search engines.
   */
  noIndex?: boolean;
}

const {
  title,
  description = "Reave",
  ogImage = "/reave-logo.png",
  ogType = "website",
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const SITE_NAME = "/\\V";
const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const canonical = canonicalUrl ?? Astro.url.href;
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${Astro.url.origin}${ogImage}`;
---

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/favicon-1.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/favicon-1.png" />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:site_name" content={SITE_NAME} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
