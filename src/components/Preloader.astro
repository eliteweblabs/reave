---
import QuantumLogo from './QuantumLogo.astro';

export interface Props {
  /** Homepage quantum mask URL, or null to show the company name fallback. */
  heroMask?: string | null;
  /** Full-color logo PNG for the intro resolve. */
  heroLogo?: string | null;
  /** Shown when heroMask is null. */
  fallbackName?: string;
}

const { heroMask = null, heroLogo = null, fallbackName = '' } = Astro.props;
---

<div id="boot" class="preloader" aria-hidden="true">
  {
    heroMask ? (
      <QuantumLogo
        heroMask={heroMask}
        logoSrc={heroLogo ?? heroMask}
        hostId="preloaderQuantumHost"
        layout="centered"
        class="preloader-logo"
      />
    ) : (
      <div class="preloader-fallback" aria-hidden="true">{fallbackName}</div>
    )
  }
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    background: #050505;
    z-index: 100000;
    transition: opacity 0.7s ease;
  }

  .preloader-logo {
    z-index: 1;
  }

  .preloader-fallback {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    max-width: min(92vmin, 96vw, 820px);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-weight: 800;
    font-size: clamp(1.35rem, 5vmin, 2.5rem);
    letter-spacing: -0.03em;
    text-align: center;
    color: rgba(255, 255, 255, 0.85);
  }
</style>
