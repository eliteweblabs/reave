---
interface Testimonial {
  quote: string;
  name: string;
  title: string;
}

const testimonials: Testimonial[] = [
  {
    quote:
      "I am extremely pleased with the result of our website. Incredibly professional and tuned in to the needs of his clients. High quality work with a quick turn. He delivered on every level.",
    name: "Torey Champagne",
    title: "13x Emmy Winner — ESPN / Comcast",
  },
  {
    quote:
      "His assistance was critical in the smooth launch of Worcester Polytechnic Institute's new website. His abilities with CSS, Photoshop and Dreamweaver were crucial in maintaining our strict timeline.",
    name: "L. Salsich",
    title: "Web Project Manager — Worcester Polytechnic Institute",
  },
  {
    quote:
      "He did a fantastic job building our website from scratch. His creativity and cutting edge web designing skills were exactly what we needed to establish a current, fresh and modern presence.",
    name: "Kathy Singh",
    title: "Director — Stem & Regenerative Medicine Int.",
  },
  {
    quote:
      "Being able to trust one company for my marketing needs is a huge asset. Cost effective pricing, prompt service and quality work.",
    name: "Nick Chacharone",
    title: "President — Aster Group",
  },
];

const count = testimonials.length;
---

<section
  class="testimonials-carousel section--full-bleed"
  aria-label="Client testimonials"
  data-testimonials-scroll
  style={`--testimonial-count: ${count}`}
>
  <div class="testimonials-scroll-track" data-testimonials-track>
    <div class="testimonials-sticky">
      <div
        class="testimonials-viewport"
        data-testimonials-carousel
        tabindex="0"
        role="region"
        aria-roledescription="carousel"
        aria-label="Client testimonials. Tap or scroll to change."
      >
        {
          testimonials.map((testimonial, index) => (
            <article
              class="testimonial-slide"
              data-testimonial-slide
              data-index={index}
              aria-hidden={index === 0 ? "false" : "true"}
            >
              <blockquote>&ldquo;{testimonial.quote}&rdquo;</blockquote>
              <p>
                <strong>{testimonial.name}</strong>, {testimonial.title}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-carousel {
    margin-bottom: 40px;
  }

  .testimonials-scroll-track {
    position: relative;
    height: calc(var(--testimonial-count) * 55dvh);
    min-height: calc(var(--testimonial-count) * 280px);
  }

  .testimonials-sticky {
    position: sticky;
    top: calc(var(--app-header-h, 3.25rem) + 16px);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: min(52dvh, 420px);
    padding-bottom: 8px;
  }

  .testimonials-viewport {
    display: grid;
    width: 100%;
    padding: 28px 24px;
    box-sizing: border-box;
    text-align: center;
    cursor: pointer;
    touch-action: manipulation;
    outline: none;
  }

  .testimonials-viewport:focus-visible {
    outline: 2px solid rgba(168, 85, 247, 0.65);
    outline-offset: 6px;
    border-radius: 12px;
  }

  .testimonial-slide {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
  }

  .testimonial-slide blockquote {
    max-width: 52ch;
    margin: 0 0 16px;
    font-size: clamp(15px, 2.4vw, 18px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
  }

  .testimonial-slide p {
    max-width: 52ch;
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.72);
  }

  .testimonial-slide strong {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials-scroll-track {
      height: auto;
      min-height: 0;
    }

    .testimonials-sticky {
      position: relative;
      top: auto;
      min-height: 0;
    }
  }
</style>

<script>
  function clamp(value: number, min: number, max: number) {
    return Math.min(max, Math.max(min, value));
  }

  function initTestimonialsCarousel(viewport: HTMLElement) {
    if (viewport.dataset.testimonialsInit === "true") return;
    viewport.dataset.testimonialsInit = "true";

    const track = viewport.closest<HTMLElement>("[data-testimonials-track]");
    if (!track) return;

    const slides = Array.from(
      viewport.querySelectorAll<HTMLElement>("[data-testimonial-slide]"),
    );
    const count = slides.length;
    if (count <= 1) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (prefersReducedMotion) {
      let activeIndex = 0;

      function showSlide(index: number) {
        slides.forEach((slide, i) => {
          slide.style.opacity = i === index ? "1" : "0";
          slide.setAttribute("aria-hidden", i === index ? "false" : "true");
        });
        viewport.setAttribute(
          "aria-label",
          `Client testimonial ${index + 1} of ${count}. Tap to advance.`,
        );
      }

      showSlide(activeIndex);

      const advance = () => {
        activeIndex = (activeIndex + 1) % count;
        showSlide(activeIndex);
      };

      viewport.addEventListener("click", advance);
      viewport.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          advance();
        }
      });

      return;
    }

    let rafId = 0;
    let lastScrollY = window.scrollY;
    let lastScrollTime = performance.now();
    let scrollVelocity = 0;
    let scrollIdleTimer = 0;

    function getScrollProgress(): number {
      const rect = track.getBoundingClientRect();
      const top = window.scrollY + rect.top;
      const range = Math.max(track.offsetHeight - window.innerHeight, 1);
      return clamp((window.scrollY - top) / range, 0, 1);
    }

    function fadeWidthForVelocity(): number {
      if (prefersReducedMotion) return 0.08 / count;

      const segment = 1 / count;
      const normalized = clamp(scrollVelocity * 0.012, 0, 1);
      return clamp(segment * (0.28 - normalized * 0.22), segment * 0.04, segment * 0.28);
    }

    function opacityForSlide(index: number, progress: number, fadeWidth: number): number {
      const segStart = index / count;
      const segEnd = (index + 1) / count;
      const innerStart = segStart + fadeWidth;
      const innerEnd = segEnd - fadeWidth;

      if (progress >= innerStart && progress <= innerEnd) return 1;
      if (progress < segStart || progress > segEnd) return 0;

      if (progress < innerStart) {
        return clamp((progress - segStart) / fadeWidth, 0, 1);
      }

      return clamp((segEnd - progress) / fadeWidth, 0, 1);
    }

    function applyFrame() {
      const progress = getScrollProgress();
      const fadeWidth = fadeWidthForVelocity();
      let dominantIndex = 0;
      let dominantOpacity = 0;

      slides.forEach((slide, index) => {
        const opacity = opacityForSlide(index, progress, fadeWidth);
        slide.style.opacity = String(opacity);

        if (opacity > dominantOpacity) {
          dominantOpacity = opacity;
          dominantIndex = index;
        }
      });

      slides.forEach((slide, index) => {
        slide.setAttribute("aria-hidden", index === dominantIndex ? "false" : "true");
      });

      viewport.setAttribute("aria-label", `Client testimonial ${dominantIndex + 1} of ${count}. Tap to advance.`);
    }

    function onScroll() {
      const now = performance.now();
      const dt = Math.max(now - lastScrollTime, 1);
      scrollVelocity = Math.abs(window.scrollY - lastScrollY) / dt;
      lastScrollY = window.scrollY;
      lastScrollTime = now;

      if (rafId) return;
      rafId = window.requestAnimationFrame(() => {
        rafId = 0;
        applyFrame();
      });
    }

    function scrollToIndex(index: number, behavior: ScrollBehavior = "smooth") {
      const rect = track.getBoundingClientRect();
      const top = window.scrollY + rect.top;
      const range = Math.max(track.offsetHeight - window.innerHeight, 1);
      const targetProgress = (index + 0.5) / count;
      const targetY = top + targetProgress * range;

      window.scrollTo({
        top: targetY,
        behavior: prefersReducedMotion ? "auto" : behavior,
      });
    }

    function advanceOnTap() {
      const progress = getScrollProgress();
      const current = clamp(Math.floor(progress * count), 0, count - 1);
      scrollToIndex((current + 1) % count);
    }

    viewport.addEventListener("click", advanceOnTap);

    viewport.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        advanceOnTap();
      } else if (event.key === "ArrowRight" || event.key === "ArrowDown") {
        event.preventDefault();
        const progress = getScrollProgress();
        const current = clamp(Math.floor(progress * count), 0, count - 1);
        scrollToIndex((current + 1) % count);
      } else if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
        event.preventDefault();
        const progress = getScrollProgress();
        const current = clamp(Math.floor(progress * count), 0, count - 1);
        scrollToIndex((current - 1 + count) % count);
      }
    });

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });

    applyFrame();

    return () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onScroll);
      if (rafId) window.cancelAnimationFrame(rafId);
    };
  }

  function initAllTestimonialsCarousels() {
    document.querySelectorAll<HTMLElement>("[data-testimonials-carousel]").forEach((viewport) => {
      initTestimonialsCarousel(viewport);
    });
  }

  initAllTestimonialsCarousels();
  document.addEventListener("astro:page-load", initAllTestimonialsCarousels);
</script>
