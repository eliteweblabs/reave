---
interface Testimonial {
  quote: string;
  name: string;
  title: string;
}

const testimonials: Testimonial[] = [
  {
    quote:
      "I am extremely pleased with the result of our website. Incredibly professional and tuned in to the needs of his clients. High quality work with a quick turn. He delivered on every level.",
    name: "Torey Champagne",
    title: "13x Emmy Winner — ESPN / Comcast",
  },
  {
    quote:
      "His assistance was critical in the smooth launch of Worcester Polytechnic Institute's new website. His abilities with CSS, Photoshop and Dreamweaver were crucial in maintaining our strict timeline.",
    name: "L. Salsich",
    title: "Web Project Manager — Worcester Polytechnic Institute",
  },
  {
    quote:
      "He did a fantastic job building our website from scratch. His creativity and cutting edge web designing skills were exactly what we needed to establish a current, fresh and modern presence.",
    name: "Kathy Singh",
    title: "Director — Stem & Regenerative Medicine Int.",
  },
  {
    quote:
      "Being able to trust one company for my marketing needs is a huge asset. Cost effective pricing, prompt service and quality work.",
    name: "Nick Chacharone",
    title: "President — Aster Group",
  },
];
---

<section class="testimonials-carousel section--full-bleed" aria-label="Client testimonials">
  <div class="testimonials-viewport" data-testimonials-carousel>
    {
      testimonials.map((testimonial, index) => (
        <article
          class:list={["testimonial-slide", index === 0 && "is-active"]}
          data-testimonial-slide
          aria-hidden={index === 0 ? "false" : "true"}
        >
          <blockquote>&ldquo;{testimonial.quote}&rdquo;</blockquote>
          <p>
            <strong>{testimonial.name}</strong>, {testimonial.title}
          </p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .testimonials-carousel {
    margin-bottom: 40px;
  }

  .testimonials-viewport {
    display: grid;
    width: 100%;
    padding: 28px 24px;
    box-sizing: border-box;
    text-align: center;
  }

  .testimonial-slide {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.8s ease;
    pointer-events: none;
  }

  .testimonial-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .testimonial-slide blockquote {
    max-width: 52ch;
    margin: 0 0 16px;
    font-size: clamp(15px, 2.4vw, 18px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
  }

  .testimonial-slide p {
    max-width: 52ch;
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.72);
  }

  .testimonial-slide strong {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide {
      transition: none;
    }
  }
</style>

<script>
  const DISPLAY_MS = 5000;

  function initTestimonialsCarousel(viewport: HTMLElement) {
    if (viewport.dataset.testimonialsInit === "true") return;
    viewport.dataset.testimonialsInit = "true";

    const slides = Array.from(
      viewport.querySelectorAll<HTMLElement>("[data-testimonial-slide]"),
    );
    if (slides.length <= 1) return;

    let activeIndex = slides.findIndex((slide) => slide.classList.contains("is-active"));
    if (activeIndex < 0) activeIndex = 0;

    let timerId = 0;

    function showSlide(nextIndex: number) {
      slides.forEach((slide, index) => {
        const isActive = index === nextIndex;
        slide.classList.toggle("is-active", isActive);
        slide.setAttribute("aria-hidden", isActive ? "false" : "true");
      });
      activeIndex = nextIndex;
    }

    function advance() {
      showSlide((activeIndex + 1) % slides.length);
    }

    function scheduleNext() {
      window.clearTimeout(timerId);
      timerId = window.setTimeout(() => {
        advance();
        scheduleNext();
      }, DISPLAY_MS);
    }

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!prefersReducedMotion) {
      scheduleNext();
    }

    return () => {
      window.clearTimeout(timerId);
    };
  }

  function initAllTestimonialsCarousels() {
    document.querySelectorAll<HTMLElement>("[data-testimonials-carousel]").forEach((viewport) => {
      initTestimonialsCarousel(viewport);
    });
  }

  initAllTestimonialsCarousels();
  document.addEventListener("astro:page-load", initAllTestimonialsCarousels);
</script>
