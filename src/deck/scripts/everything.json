    {
      "id": "scheduling",
      "title": "Scheduling",
      "summary": "Live availability and bookings wired to Cal.com — public book links and admin schedule views.",
      "features": [
        {
          "id": "scheduling-calendar",
          "title": "Pick a day",
          "body": "Prospects see real availability. The calendar is the product — not a “request a time” dead end.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/schedule.html"
            },
            {
              "type": "stage.caption",
              "text": "Scheduling — live calendar"
            },
            {
              "type": "stage.highlight",
              "selector": "#day-12"
            }
          ]
        },
        {
          "id": "scheduling-slots",
          "title": "Confirm a slot",
          "body": "Time slots and confirmation flow straight into the booking API — reminders and admin visibility follow.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/schedule.html"
            },
            {
              "type": "stage.caption",
              "text": "Choose a slot · confirm"
            },
            {
              "type": "stage.highlight",
              "selector": "#slot-2"
            },
            {
              "type": "wait",
              "ms": 400
            },
            {
              "type": "stage.highlight",
              "selector": "#sched-confirm"
            }
          ]
        }
      ]
    },
    {
      "id": "voice",
