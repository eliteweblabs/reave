{
  "id": "everything",
  "title": "Business OS \u2014 everything",
  "sections": [
    {
      "id": "homepage",
      "title": "Dynamic mobile-forward homepage",
      "summary": "Design first \u2014 custom, mobile-forward surfaces that feel like the brand, not a template.",
      "features": [
        {
          "id": "homepage-hero",
          "title": "Brand-first homepage",
          "body": "A dynamic, mobile-forward homepage built around the brand mark \u2014 interactive presence, not a brochure layout.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/homepage.html"
            },
            {
              "type": "stage.caption",
              "text": "Homepage \u2014 brand mark as the hero"
            },
            {
              "type": "stage.highlight",
              "selector": "#brand-mark"
            }
          ]
        },
        {
          "id": "homepage-portal",
          "title": "Client pages that work",
          "body": "Every client gets a shareable portal \u2014 overview, work, and billing when enabled. iOS-first, on-brand, no login friction.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/portal.html"
            },
            {
              "type": "stage.caption",
              "text": "Client portal \u2014 /c/:uid"
            },
            {
              "type": "stage.highlight",
              "selector": "#portal-overview"
            },
            {
              "type": "nav.pulse",
              "tab": "overview"
            }
          ]
        },
        {
          "id": "homepage-contact",
          "title": "Contact & intake",
          "body": "Conversational contact flows capture the right details on mobile \u2014 then route into the team inbox and CRM.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/contact.html"
            },
            {
              "type": "stage.caption",
              "text": "Conversational contact form"
            },
            {
              "type": "stage.highlight",
              "selector": "#contact-input"
            }
          ]
        }
      ]
    },
    {
      "id": "pwa",
      "title": "PWA \u2014 alerts & home screen",
      "summary": "iOS-style push banners, permission alerts, and home-screen badges. Installable Progressive Web App \u2014 the visual pattern of a real phone app.",
      "features": [
        {
          "id": "pwa-install",
          "title": "Install as a PWA",
          "body": "Add to Home Screen turns the Business OS into a full-screen app on iPhone \u2014 no App Store. Same URL, native shell.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/pwa-alerts.html?scene=install"
            },
            {
              "type": "stage.caption",
              "text": "PWA \u2014 Add to Home Screen"
            },
            {
              "type": "stage.highlight",
              "selector": "#install-sheet"
            },
            {
              "type": "wait",
              "ms": 400
            },
            {
              "type": "stage.highlight",
              "selector": "#install-row"
            }
          ]
        },
        {
          "id": "pwa-banner",
          "title": "iOS-style push notices",
          "body": "Inbox, bookings, and monitoring land as lock-screen style banners \u2014 the same Web Push stack that powers the admin PWA.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/pwa-alerts.html?scene=banner"
            },
            {
              "type": "stage.caption",
              "text": "Push notice \u2014 lock-screen banner"
            },
            {
              "type": "wait",
              "ms": 350
            },
            {
              "type": "stage.highlight",
              "selector": "#push-banner"
            }
          ]
        },
        {
          "id": "pwa-alert",
          "title": "Permission alerts",
          "body": "Classic iOS alert chrome for notification permission \u2014 clear choices, familiar UX, no browser chrome surprises.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/pwa-alerts.html?scene=alert"
            },
            {
              "type": "stage.caption",
              "text": "iOS-style alert \u2014 Allow notifications?"
            },
            {
              "type": "stage.highlight",
              "selector": "#ios-alert"
            },
            {
              "type": "wait",
              "ms": 450
            },
            {
              "type": "stage.highlight",
              "selector": "#alert-allow"
            }
          ]
        },
        {
          "id": "pwa-badge",
          "title": "Home-screen badges",
          "body": "Unread counts show on the app icon \u2014 inbox and alerts stay visible even when the tab is closed.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/pwa-alerts.html?scene=badge"
            },
            {
              "type": "stage.caption",
              "text": "App badge \u2014 unread at a glance"
            },
            {
              "type": "stage.highlight",
              "selector": "#pwa-icon"
            },
            {
              "type": "wait",
              "ms": 400
            },
            {
              "type": "stage.highlight",
              "selector": "#app-badge"
            }
          ]
        }
      ]
    },
    {
      "id": "scheduling",
