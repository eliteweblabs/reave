            {
              "type": "stage.highlight",
              "selector": "#route-inbound"
            },
            {
              "type": "wait",
              "ms": 500
            },
            {
              "type": "stage.highlight",
              "selector": "#route-agent"
            },
            {
              "type": "wait",
              "ms": 500
            },
            {
              "type": "stage.highlight",
              "selector": "#route-handoff"
            }
          ]
        },
        {
          "id": "voice-widget",
