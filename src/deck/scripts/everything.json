{
  "id": "everything",
  "title": "Business OS — everything",
  "sections": [
    {
      "id": "homepage",
      "title": "Dynamic mobile-forward homepage",
      "summary": "Custom-designed, mobile-first public surfaces that feel like the brand — not a template.",
      "features": [
        {
          "id": "homepage-hero",
          "title": "Brand-first homepage",
          "body": "A dynamic, mobile-forward homepage built around the brand mark — interactive presence, not a brochure layout.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/homepage.html"
            },
            {
              "type": "stage.caption",
              "text": "Homepage — brand mark as the hero"
            },
            {
              "type": "stage.highlight",
              "selector": "#brand-mark"
            }
          ]
        },
        {
          "id": "homepage-portal",
          "title": "Client pages that work",
          "body": "Every client gets a shareable portal — overview, work, and billing when enabled. iOS-first, on-brand, no login friction.",
          "scrollHeight": 110,
          "actions": [
            {
              "type": "stage.set",
              "surface": "phone",
              "url": "/deck/surfaces/portal.html"
            },
            {
              "type": "stage.caption",
              "text": "Client portal — /c/:uid"
            },
            {
              "type": "stage.highlight",
              "selector": "#portal-overview"
            },
            {
              "type": "nav.pulse",
              "tab": "overview"
            }
          ]
        },
        {
          "id": "homepage-contact",
          "title": "Contact & intake",
