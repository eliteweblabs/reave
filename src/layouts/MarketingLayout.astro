---
import Layout from "./Layout.astro";
import SiteFooterNav from "../components/SiteFooterNav.astro";

type SiteNavId = "home" | "about" | "services" | "portfolio" | "contact";

interface Props {
  title: string;
  description?: string;
  label?: string;
  active?: SiteNavId;
  /** Full-width fixed hero background (about page, etc.). */
  backgroundImage?: string;
}

const { title, description, label = "Explore", active, backgroundImage } = Astro.props;
---

<Layout title={title} description={description}>
  {
    backgroundImage ? (
      <div class="marketing-bg" aria-hidden="true">
        <img class="marketing-bg-photo" src={backgroundImage} alt="" decoding="async" />
        <div class="marketing-bg-grain" />
        <div class="marketing-bg-scrim" />
      </div>
    ) : null
  }
  <div class:list={["marketing-page", backgroundImage && "marketing-page--photo"]}>
    <header class="marketing-hero">
      <p class="marketing-label">{label}</p>
      <h1>{title}</h1>
      {description ? <p class="marketing-lead">{description}</p> : null}
    </header>
    <div class="marketing-body">
      <slot />
    </div>
  </div>
  <SiteFooterNav active={active} />
</Layout>

{/*
  The dark background/text color is set globally in Layout.astro.
  (A previous version tried to set it here by wrapping `html`/`body` in
  `:global(...)` inside an already-global `<style is:global>` block — Astro
  doesn't strip that syntax there, so it shipped as literal, invalid CSS that
  browsers silently dropped. That's why these pages rendered white text on a
  white background.)
*/}

<style>
  .marketing-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .marketing-bg-photo {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    min-height: 100vh;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(100%) contrast(1.08) brightness(0.82);
  }

  .marketing-bg-grain {
    position: absolute;
    inset: 0;
    opacity: 0.28;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }

  .marketing-bg-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        rgba(5, 5, 5, 0.18) 0%,
        rgba(5, 5, 5, 0.55) 42%,
        rgba(5, 5, 5, 0.88) 100%
      ),
      radial-gradient(ellipse at center, transparent 18%, rgba(5, 5, 5, 0.45) 100%);
  }

  .marketing-page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    padding:
      calc(var(--app-header-h, 3.25rem) + 48px)
      24px
      calc(var(--site-footer-nav-offset, 3.35rem) + 32px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .marketing-hero,
  .marketing-body {
    width: 100%;
    max-width: 760px;
  }

  .marketing-hero {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .marketing-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a855f7;
    margin: 0 0 12px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 36px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
  }

  .marketing-lead {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
    margin: 0;
    max-width: 52ch;
  }

  .marketing-body :global(section) {
    margin-bottom: 32px;
  }

  .marketing-body :global(h2) {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 12px;
  }

  .marketing-body :global(h3) {
    font-size: 15px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    margin: 16px 0 8px;
  }

  .marketing-body :global(p),
  .marketing-body :global(li),
  .marketing-body :global(blockquote) {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 12px;
  }

  .marketing-body :global(ul) {
    padding-left: 20px;
    margin: 0 0 12px;
  }

  .marketing-body :global(a) {
    color: #a855f7;
    text-decoration: none;
  }

  .marketing-body :global(a:hover) {
    text-decoration: underline;
  }

  .marketing-body :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 8px;
  }

  .marketing-body :global(.card) {
    padding: 18px 20px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .marketing-body :global(.card h3) {
    margin-top: 0;
  }

  .marketing-body :global(.contact-list) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .marketing-body :global(.contact-list li) {
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .marketing-body :global(.contact-list li:last-child) {
    border-bottom: none;
  }

  .marketing-page--photo .marketing-hero,
  .marketing-page--photo .marketing-body :global(.card) {
    background: rgba(5, 5, 5, 0.42);
    backdrop-filter: blur(8px);
  }

  .marketing-page--photo .marketing-hero {
    padding: 24px 24px 32px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 768px) {
    .marketing-page {
      padding-left: 18px;
      padding-right: 18px;
    }
  }
</style>
