---
import Header from "../components/Header.astro";
import Favicon from "../components/Favicon.astro";
import { SITE } from "../config/site";
import { getCompanyConfig } from "../lib/companyConfig";
import { requestOrigin } from "../lib/requestOrigin";

export interface Props {
  /** Page-specific title. Rendered as "Page | {company name}". Omit to show just the company name. */
  title?: string;
  /** Meta description for search results and OG cards. */
  description?: string;
  /**
   * Absolute or root-relative path to the OG / social-share image.
   * Defaults to SITE.ogImage.
   */
  ogImage?: string;
  /** OG type. Defaults to "website". */
  ogType?: "website" | "article";
  /** Override the canonical URL. Defaults to the current request URL. */
  canonicalUrl?: string;
  /**
   * Set true on private or internal pages (dev tools, client portals, etc.)
   * that should not appear in search engines.
   */
  noIndex?: boolean;
}

const {
  title,
  description: descriptionProp,
  ogImage = SITE.ogImage,
  ogType = SITE.ogType,
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const company = await getCompanyConfig(Astro.request);
const description = descriptionProp ?? company.description;
const pageTitle = title ? `${title} | ${company.name}` : company.name;
const origin = requestOrigin(Astro.request);
const canonical =
  canonicalUrl ?? `${origin}${Astro.url.pathname}${Astro.url.search}`;
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${origin}${ogImage}`;

const pathNorm = Astro.url.pathname.replace(/\/$/, "") || "/";
const isIndexPage = pathNorm === "/" || pathNorm === "/index.html";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, maximum-scale=1.0, user-scalable=no" />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0d14" media="(prefers-color-scheme: dark)" />
		<meta name="generator" content={Astro.generator} />

		<!-- Favicons -->
		<Favicon />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{noIndex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph -->
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageAbsolute} />
		<meta property="og:site_name" content={company.name} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsolute} />
	</head>
	<body>
		<Header hideLogo={isIndexPage} homeAdminEntry={isIndexPage} />
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light dark;
		--bg: #ffffff;
		--fg: #0f172a;
		--muted: #64748b;
		--panel-border: #e2e8f0;
		--elabel-bg: rgba(255, 255, 255, 0.92);
		--footer-nav-glass-border: 1px solid rgba(0, 0, 0, 0.08);
		--footer-nav-glass-bg: transparent;
		--footer-nav-glass-blur: blur(18px) saturate(1.15);
		--nav-icon: rgba(0, 0, 0, 0.45);
		--nav-icon-hover: rgba(0, 0, 0, 0.72);
		--nav-icon-active: #0f172a;
		--radius-input: 8px;
		--control-h: 2.75rem;
		--footer-nav-pill-h: var(--control-h);
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #0a0d14;
			--fg: #e9eef6;
			--muted: #8b97a8;
			--panel-border: #283142;
			--elabel-bg: rgba(10, 13, 20, 0.82);
			--footer-nav-glass-border: 1px solid rgba(255, 255, 255, 0.08);
			--nav-icon: rgba(255, 255, 255, 0.58);
			--nav-icon-hover: rgba(255, 255, 255, 0.88);
			--nav-icon-active: #ffffff;
		}
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	/*
	 * Interactive chrome — prevent accidental text/emoji selection on tap (esp. iOS).
	 * Content areas (inputs, textareas, article copy) stay selectable by default.
	 */
	button:not(:disabled),
	input[type="button"],
	input[type="submit"],
	input[type="reset"],
	input[type="checkbox"],
	input[type="radio"],
	select,
	summary,
	[role="button"] {
		-webkit-user-select: none;
		user-select: none;
		-webkit-touch-callout: none;
	}

	.app-header,
	.app-header a,
	.app-header button {
		-webkit-user-select: none;
		user-select: none;
		-webkit-touch-callout: none;
	}

	button svg,
	a[aria-label] svg,
	[role="button"] svg {
		-webkit-user-select: none;
		user-select: none;
	}
</style>
