---
import Layout from "../../layouts/Layout.astro";

const { slug } = Astro.params;
const bookingApiUrl = import.meta.env.PUBLIC_BOOKING_API_URL || '';
---

<Layout>
  <div class="form-container">
    <form id="conversational-form" class="conversation">
      <div id="questions-container"></div>

      <div class="input-area" id="input-area">
        <button type="button" id="mic-btn" title="Voice input">🎤</button>
        <input
          type="text"
          id="user-input"
          placeholder=""
          autocomplete="off"
        />
        <button type="submit">Send</button>
      </div>
    </form>

    <div id="success-message" class="hidden">
      <h2>&#10003; All done!</h2>
      <p id="success-text"></p>
    </div>

    <div id="error-message" class="hidden">
      <p id="error-text"></p>
      <button id="retry-btn" onclick="window.location.reload()"
        >Try again</button
      >
    </div>
  </div>
</Layout>

<style is:global>
  body {
    margin: 0;
    background: #0a0a0a;
  }

  .form-container {
    max-width: 640px;
    margin: 0 auto;
    padding: calc(16vw + 48px) 20px 120px;
    color: #fff;
    font-family: "Inter", sans-serif;
  }

  .conversation {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .message {
    max-width: 85%;
    animation: fadeIn 0.3s ease;
    line-height: 1.6;
    font-size: 15px;
  }

  .message.robot {
    background: transparent;
    border: none;
    align-self: flex-start;
    padding: 0;
    color: rgba(255, 255, 255, 0.9);
  }

  .message.robot .word {
    display: inline;
  }

  .message.robot .word.just-typed {
    filter: blur(0);
    opacity: 1;
  }

  .message.user {
    align-self: flex-end;
    text-align: right;
    color: rgba(255, 255, 255, 0.5);
  }

  .options-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-self: flex-start;
    max-width: 100%;
    animation: fadeIn 0.3s ease;
  }

  .option-btn {
    padding: 10px 18px;
    border-radius: 10px;
    border: 1px solid rgba(168, 85, 247, 0.5);
    background: rgba(168, 85, 247, 0.12);
    color: #fff;
    font-size: 14px;
    cursor: pointer;
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.15s;
  }

  .option-btn:hover {
    background: rgba(168, 85, 247, 0.28);
    border-color: #a855f7;
    transform: translateY(-1px);
  }

  .loading-msg {
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
    font-size: 14px;
    align-self: flex-start;
    animation: fadeIn 0.3s ease;
  }

  .input-area {
    display: flex;
    gap: 10px;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 640px;
    width: 90%;
  }

  .input-area input {
    flex: 1;
    padding: 14px 20px;
    border-radius: 12px;
    border: 1px solid rgba(168, 85, 247, 0.3);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    font-size: 16px;
    outline: none;
  }

  #mic-btn {
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(168, 85, 247, 0.3);
    background: rgba(255, 255, 255, 0.06);
    font-size: 18px;
    cursor: pointer;
    transition: all 0.2s;
  }

  #mic-btn:hover {
    background: rgba(168, 85, 247, 0.2);
    border-color: #a855f7;
  }

  #mic-btn.recording {
    background: rgba(239, 68, 68, 0.3);
    border-color: #ef4444;
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  .input-area input:focus {
    border-color: #a855f7;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .input-area button[type="submit"] {
    padding: 14px 24px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .input-area button[type="submit"]:hover {
    transform: translateY(-2px);
  }

  #success-message h2 {
    background: linear-gradient(135deg, #a855f7, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  #error-message {
    padding: 20px;
    border-radius: 12px;
    border: 1px solid rgba(239, 68, 68, 0.4);
    background: rgba(239, 68, 68, 0.1);
    color: #fca5a5;
  }

  #retry-btn {
    margin-top: 12px;
    padding: 10px 20px;
    border-radius: 10px;
    border: 1px solid rgba(239, 68, 68, 0.5);
    background: transparent;
    color: #fca5a5;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
  }

  #retry-btn:hover {
    background: rgba(239, 68, 68, 0.15);
  }

  .hidden {
    display: none !important;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script define:vars={{ bookingApiUrl }}>
  const BOOKING_API = bookingApiUrl;

  let currentFieldIndex = 0;
  let formData = {};
  let formDef = null;
  let recognition = null;
  let isRecording = false;
  let availabilityDays = [];
  let typewriterInProgress = false;

  const container = () => document.getElementById("questions-container");
  const inputArea = () => document.getElementById("input-area");
  const userInput = () => document.getElementById("user-input");

  // Initialize speech recognition
  if ("webkitSpeechRecognition" in window || "SpeechRecognition" in window) {
    const SpeechRecognition =
      window.webkitSpeechRecognition || window.SpeechRecognition;
    recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = true;
    recognition.lang = "en-US";

    recognition.onresult = (event) => {
      const transcript = Array.from(event.results)
        .map((result) => result[0].transcript)
        .join("");
      userInput().value = transcript;
    };

    recognition.onend = () => {
      isRecording = false;
      const micBtn = document.getElementById("mic-btn");
      if (micBtn) micBtn.classList.remove("recording");
    };

    recognition.onerror = (event) => {
      console.error("Speech recognition error:", event.error);
      isRecording = false;
      const micBtn = document.getElementById("mic-btn");
      if (micBtn) micBtn.classList.remove("recording");
    };
  }

  function toggleRecording() {
    if (!recognition) {
      appendMessage(
        "Voice input not supported in this browser. Try Chrome.",
        "robot",
      );
      return;
    }
    if (isRecording) {
      recognition.stop();
    } else {
      isRecording = true;
      const micBtn = document.getElementById("mic-btn");
      if (micBtn) micBtn.classList.add("recording");
      recognition.start();
    }
  }

  async function loadForm() {
    const slug = window.location.pathname.split("/").pop();
    try {
      const res = await fetch(`/forms/${slug}.json`);
      if (!res.ok) throw new Error("Form not found");
      formDef = await res.json();
      await showQuestion();
    } catch (err) {
      console.error(err);
    }
  }

  function appendMessage(text, type) {
    const msg = document.createElement("div");
    msg.className = `message ${type}`;
    msg.textContent = text;
    container().appendChild(msg);
    msg.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  async function appendTypewriter(text) {
    const msg = document.createElement("div");
    msg.className = "message robot";
    container().appendChild(msg);
    msg.scrollIntoView({ behavior: "smooth", block: "nearest" });

    const words = text.split(" ");
    typewriterInProgress = true;

    for (let i = 0; i < words.length; i++) {
      const wordSpan = document.createElement("span");
      wordSpan.className = "word just-typed";
      wordSpan.textContent = words[i] + (i < words.length - 1 ? " " : "");

      wordSpan.style.filter = "blur(8px)";
      wordSpan.style.opacity = "0.3";
      wordSpan.style.transition = "filter 0.15s ease-out, opacity 0.15s ease-out";

      msg.appendChild(wordSpan);

      wordSpan.offsetHeight;

      wordSpan.style.filter = "blur(0)";
      wordSpan.style.opacity = "1";

      await new Promise(r => setTimeout(r, 60));
    }

    typewriterInProgress = false;
  }

  function appendLoading(text) {
    const el = document.createElement("div");
    el.className = "loading-msg";
    el.textContent = text;
    container().appendChild(el);
    el.scrollIntoView({ behavior: "smooth", block: "nearest" });
    return el;
  }

  function showOptionButtons(options, onPick) {
    document.getElementById("current-options")?.remove();

    const wrapper = document.createElement("div");
    wrapper.className = "options-wrapper";
    wrapper.id = "current-options";

    options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.className = "option-btn";
      btn.textContent = opt.label;
      btn.type = "button";
      btn.addEventListener("click", () => {
        wrapper.remove();
        onPick(opt.value, opt.label);
      });
      wrapper.appendChild(btn);
    });

    container().appendChild(wrapper);
    wrapper.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function setInputVisible(visible) {
    inputArea().style.display = visible ? "flex" : "none";
  }

  async function delay(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  async function showMessages(text) {
    const parts = text.split("&&").map((s) => s.trim());
    for (let i = 0; i < parts.length; i++) {
      if (i > 0) await delay(500);
      // Use typewriter for robot messages
      await appendTypewriter(parts[i]);
    }
    await delay(300);
  }

  async function showQuestion() {
    if (!formDef || currentFieldIndex >= formDef.fields.length) {
      await submitForm();
      return;
    }

    const field = formDef.fields[currentFieldIndex];
    const questionText = field["cf-questions"] || `What's your ${field.name}?`;
    const parts = questionText.split("&&").map((s) => s.trim());

    if (field.type === "availability" || (field.type === "select" && field.options)) {
      // Show all parts as messages for non-text fields (no placeholder available)
      await showMessages(questionText);
      if (field.type === "availability") {
        setInputVisible(false);
        await handleAvailabilityField(field);
      } else {
        setInputVisible(false);
        showOptionButtons(field.options, (value, label) => {
          appendMessage(label, "user");
          formData[field.name] = value;
          currentFieldIndex++;
          setTimeout(showQuestion, 500);
        });
      }
    } else {
      // Show only intro lines as messages; last part becomes the placeholder
      const introLines = parts.slice(0, -1);
      const promptLine = parts[parts.length - 1];
      for (let i = 0; i < introLines.length; i++) {
        if (i > 0) await delay(500);
        appendMessage(introLines[i], "robot");
      }
      if (introLines.length > 0) await delay(300);
      setInputVisible(true);
      userInput().placeholder = promptLine;
      userInput().focus();
    }
  }

  async function handleAvailabilityField(field) {
    const loadingEl = appendLoading("Checking availability...");
    try {
      const res = await fetch(`${BOOKING_API}/api/booking/availability`);
      const data = await res.json();
      loadingEl.remove();

      if (!res.ok || !data.days || data.days.length === 0) {
        appendMessage(
          "No available times found. Please contact us directly.",
          "robot",
        );
        return;
      }

      availabilityDays = data.days;

      appendMessage("Pick a day:", "robot");
      showOptionButtons(
        availabilityDays.map((d) => ({ value: d.date, label: d.label })),
        (value, label) => {
          const pickedDay = availabilityDays.find((d) => d.date === value);
          appendMessage(label, "user");
          setTimeout(() => {
            appendMessage("Pick a time:", "robot");
            showOptionButtons(
              (pickedDay?.slots || []).map((s) => ({
                value: s.iso,
                label: s.label,
              })),
              (slotIso, slotLabel) => {
                appendMessage(slotLabel, "user");
                formData[field.name] = slotIso;
                currentFieldIndex++;
                setTimeout(showQuestion, 500);
              },
            );
          }, 400);
        },
      );
    } catch (err) {
      loadingEl.remove();
      appendMessage("Failed to load availability. Please try again.", "robot");
      console.error(err);
    }
  }

  async function submitForm() {
    document.getElementById("conversational-form").classList.add("hidden");

    if (formDef.submitEndpoint) {
      const loadingEl = appendLoading("Booking your meeting...");
      try {
        const endpoint = formDef.submitEndpoint.startsWith("/")
          ? `${BOOKING_API}${formDef.submitEndpoint}`
          : formDef.submitEndpoint;
        await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(formData),
        });
        loadingEl.remove();
      } catch (err) {
        loadingEl.remove();
        showError("Network error. Please try again.");
        return;
      }
    }

    document.getElementById("success-message").classList.remove("hidden");
    document.getElementById("success-text").textContent =
      formDef.onComplete?.message || "Thanks!";

    if (formDef.onComplete?.redirect) {
      setTimeout(
        () => (window.location.href = formDef.onComplete.redirect),
        2000,
      );
    }
  }

  function showError(msg) {
    document.getElementById("error-message").classList.remove("hidden");
    document.getElementById("error-text").textContent = msg;
  }

  function handleSubmit(e) {
    e.preventDefault();
    const value = userInput().value.trim();
    if (!value) return;

    const field = formDef?.fields[currentFieldIndex];
    if (!field) return;

    appendMessage(value, "user");
    formData[field.name] = value;
    userInput().value = "";
    setInputVisible(false);

    currentFieldIndex++;
    setTimeout(showQuestion, 500);
  }

  document
    .getElementById("conversational-form")
    .addEventListener("submit", handleSubmit);
  document
    .getElementById("mic-btn")
    .addEventListener("click", toggleRecording);
  loadForm();
</script>