---
import Layout from "../../layouts/Layout.astro";
import ConversationalForm from "../../components/ConversationalForm.astro";

const { slug } = Astro.params;
---

<Layout>
  <style is:global>
    body {
      margin: 0;
      background: #0a0a0a;
    }
  </style>
  {slug ? <ConversationalForm slug={slug} /> : null}
</Layout>
