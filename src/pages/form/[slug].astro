---
import Layout from "../../layouts/Layout.astro";

const { slug } = Astro.params;
---

<Layout>
  <div class="form-container">
    <h1 id="form-title">Loading...</h1>
    <p id="form-description"></p>
    
    <form id="conversational-form" class="conversation">
      <div id="questions-container"></div>
      
      <div class="input-area">
        <input type="text" id="user-input" placeholder="Type your answer..." autocomplete="off" />
        <button type="submit">Send</button>
      </div>
    </form>
    
    <div id="success-message" class="hidden">
      <h2>✓ All done!</h2>
      <p id="success-text"></p>
    </div>
  </div>
</Layout>

<style is:global>
  body {
    margin: 0;
    background: #0a0a0a;
  }

  .form-container {
    max-width: 640px;
    margin: 0 auto;
    padding: 40px 20px;
    color: #fff;
    font-family: 'Inter', sans-serif;
  }

  h1 {
    background: linear-gradient(135deg, #a855f7, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
  }

  #form-description {
    color: rgba(255,255,255,0.7);
    margin-bottom: 30px;
  }

  .conversation {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .message {
    padding: 14px 18px;
    border-radius: 12px;
    max-width: 85%;
    animation: fadeIn 0.3s ease;
  }

  .message.robot {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15));
    border: 1px solid rgba(168, 85, 247, 0.3);
    align-self: flex-start;
  }

  .message.user {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    align-self: flex-end;
    text-align: right;
  }

  .input-area {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    max-width: 640px;
    width: 90%;
  }

  .input-area input {
    flex: 1;
    padding: 14px 20px;
    border-radius: 12px;
    border: 1px solid rgba(168, 85, 247, 0.3);
    background: rgba(255,255,255,0.06);
    color: #fff;
    font-size: 16px;
    outline: none;
  }

  .input-area input:focus {
    border-color: #a855f7;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .input-area button {
    padding: 14px 24px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .input-area button:hover {
    transform: translateY(-2px);
  }

  .hidden { display: none !important; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  let currentFieldIndex = 0;
  let formData: Record<string, string> = {};
  let formDef: any = null;

  async function loadForm() {
    const slug = window.location.pathname.split('/').pop();
    
    try {
      const res = await fetch(`/forms/${slug}.json`);
      if (!res.ok) throw new Error('Form not found');
      formDef = await res.json();
      
      document.getElementById('form-title').textContent = formDef.title || 'Form';
      document.getElementById('form-description').textContent = formDef.description || '';
      
      // Show first question
      showQuestion();
    } catch (error) {
      document.getElementById('form-title').textContent = 'Error loading form';
      console.error(error);
    }
  }

  function showQuestion() {
    const container = document.getElementById('questions-container');
    const input = document.getElementById('user-input') as HTMLInputElement;
    
    if (!formDef || currentFieldIndex >= formDef.fields.length) {
      // All done
      showSuccess();
      return;
    }
    
    const field = formDef.fields[currentFieldIndex];
    const question = field['cf-questions'] || `What's your ${field.name}?`;
    
    // Split questions with && for multiple messages
    const questions = question.split('&&');
    
    // Show robot messages
    questions.forEach((q: string, i: number) => {
      setTimeout(() => {
        const msg = document.createElement('div');
        msg.className = 'message robot';
        msg.textContent = q.trim();
        container.appendChild(msg);
        window.scrollTo(0, document.body.scrollHeight);
      }, i * 500);
    });
    
    // Focus input after messages
    setTimeout(() => {
      input.focus();
    }, questions.length * 500 + 300);
  }

  function handleSubmit(e: Event) {
    e.preventDefault();
    const input = document.getElementById('user-input') as HTMLInputElement;
    const value = input.value.trim();
    
    if (!value) return;
    
    const container = document.getElementById('questions-container');
    const field = formDef.fields[currentFieldIndex];
    
    // Show user response
    const userMsg = document.createElement('div');
    userMsg.className = 'message user';
    userMsg.textContent = value;
    container.appendChild(userMsg);
    
    // Store answer
    formData[field.name] = value;
    input.value = '';
    
    // Next field
    currentFieldIndex++;
    window.scrollTo(0, document.body.scrollHeight);
    
    setTimeout(showQuestion, 500);
  }

  function showSuccess() {
    document.getElementById('conversational-form').classList.add('hidden');
    document.getElementById('success-message').classList.remove('hidden');
    document.getElementById('success-text').textContent = formDef.onComplete?.message || 'Thanks!';
    
    // Submit to endpoint if defined
    if (formDef.submitEndpoint) {
      fetch(formDef.submitEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      }).catch(() => {});
    }
    
    // Redirect if specified
    if (formDef.onComplete?.redirect) {
      setTimeout(() => {
        window.location.href = formDef.onComplete.redirect;
      }, 2000);
    }
  }

  document.getElementById('conversational-form').addEventListener('submit', handleSubmit);
  loadForm();
</script>
