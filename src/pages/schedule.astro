---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="chat-container">
    <div class="messages" id="messages"></div>
    
    <div class="input-area" id="inputArea">
      <input 
        type="text" 
        id="userInput" 
        placeholder="Type your answer..." 
        autocomplete="off"
      />
      <button id="sendBtn">Send</button>
    </div>

    <div class="options" id="options"></div>
  </div>
</Layout>

<style>
  .chat-container {
    min-height: 100vh;
    background: #0a0a0a;
    display: flex;
    flex-direction: column;
    padding: 40px 20px 120px;
  }

  .messages {
    max-width: 640px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .message {
    padding: 12px 18px;
    border-radius: 12px;
    font-size: 1rem;
    line-height: 1.5;
    max-width: 80%;
    animation: fadeIn 0.3s ease;
  }

  .message.bot {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15));
    border: 1px solid rgba(168, 85, 247, 0.3);
    color: #fff;
    align-self: flex-start;
  }

  .message.user {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    align-self: flex-end;
  }

  .input-area {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(transparent, #0a0a0a 30%);
    display: none;
    justify-content: center;
    gap: 10px;
  }

  .input-area.active {
    display: flex;
  }

  .input-area input {
    flex: 1;
    max-width: 580px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 12px;
    padding: 14px 20px;
    color: #fff;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: all 0.3s;
  }

  .input-area input:focus {
    border-color: #a855f7;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .input-area button {
    background: linear-gradient(135deg, #a855f7, #ec4899);
    border: none;
    border-radius: 12px;
    padding: 14px 24px;
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .input-area button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(168, 85, 247, 0.5);
  }

  .options {
    position: fixed;
    bottom: 80px;
    left: 0;
    right: 0;
    padding: 0 20px;
    display: none;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    max-width: 640px;
    margin: 0 auto;
  }

  .options.active {
    display: flex;
  }

  .options button {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 12px;
    padding: 12px 20px;
    color: #fff;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s;
  }

  .options button:hover {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(236, 72, 153, 0.1));
    border-color: #a855f7;
    transform: translateY(-2px);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const messages = document.getElementById('messages')!;
  const inputArea = document.getElementById('inputArea')!;
  const userInput = document.getElementById('userInput') as HTMLInputElement;
  const sendBtn = document.getElementById('sendBtn')!;
  const optionsEl = document.getElementById('options')!;

  let state = {
    name: '',
    email: '',
    purpose: '',
  };

  function addMessage(text: string, isBot: boolean) {
    const msg = document.createElement('div');
    msg.className = `message ${isBot ? 'bot' : 'user'}`;
    msg.textContent = text;
    messages.appendChild(msg);
  }

  function showInput() {
    optionsEl.classList.remove('active');
    inputArea.classList.add('active');
    userInput.value = '';
    userInput.focus();
  }

  function hideInput() {
    inputArea.classList.remove('active');
  }

  function showOptions(options: string[], callback: (value: string) => void) {
    hideInput();
    optionsEl.innerHTML = '';
    optionsEl.classList.add('active');
    
    options.forEach(opt => {
      const btn = document.createElement('button');
      btn.textContent = opt;
      btn.onclick = () => {
        optionsEl.classList.remove('active');
        addMessage(opt, false);
        callback(opt);
      };
      optionsEl.appendChild(btn);
    });
  }

  async function waitForInput(): Promise<string> {
    return new Promise((resolve) => {
      showInput();
      const handler = () => {
        const value = userInput.value.trim();
        if (!value) return;
        hideInput();
        addMessage(value, false);
        sendBtn.removeEventListener('click', handler);
        userInput.removeEventListener('keypress', keypressHandler);
        resolve(value);
      };
      const keypressHandler = (e: KeyboardEvent) => {
        if (e.key === 'Enter') handler();
      };
      sendBtn.addEventListener('click', handler);
      userInput.addEventListener('keypress', keypressHandler);
    });
  }

  async function delay(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  async function run() {
    await delay(500);
    addMessage("Hi there! I'm here to help you schedule a meeting.", true);
    await delay(800);
    addMessage("Let's find a time that works.", true);
    await delay(600);

    // Name
    addMessage("First, what's your name?", true);
    state.name = await waitForInput();
    await delay(400);

    // Email
    addMessage(`Nice to meet you, ${state.name}! What's your email address?`, true);
    state.email = await waitForInput();
    await delay(400);

    // Purpose
    addMessage("What would you like to discuss?", true);
    await delay(200);
    
    await new Promise<void>((resolve) => {
      showOptions(['Consultation', 'Project Inquiry', 'General Question'], (value) => {
        state.purpose = value;
        resolve();
      });
    });
    
    await delay(400);

    // Check availability
    addMessage("Let me check the calendar...", true);
    await delay(800);

    try {
      const res = await fetch('/api/booking/availability');
      const data = await res.json();
      
      if (data.days && data.days.length > 0) {
        addMessage(`Found ${data.days.length} available days! I'll send you a confirmation email at ${state.email} with booking details.`, true);
      } else {
        addMessage(`Sorry, no availability found right now. Please email us directly at hello@reave.app and we'll get back to you soon!`, true);
      }
    } catch (error) {
      addMessage("I'm having trouble checking the calendar. Please email hello@reave.app directly.", true);
    }
    
    await delay(600);
    addMessage("Thanks for reaching out! 🎉", true);
  }

  run();
</script>
