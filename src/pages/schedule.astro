<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <title>Schedule — Reave</title>
  <meta name="description" content="Book a meeting with Reave" />
</head>
<body>
  <div class="schedule-page">
    <div class="conversation" id="conversation">
      <!-- Messages will be injected here -->
    </div>
    <div class="input-area" id="inputArea" style="display:none;">
      <input type="text" id="userInput" placeholder="Type your answer..." autocomplete="off" />
      <button id="sendBtn" aria-label="Send">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</body>
</html>

<style>
  :root {
    --primary: #a855f7;
    --primary-light: #c084fc;
    --secondary: #ec4899;
    --accent: #06b6d4;
    --bg-dark: #0a0a0a;
    --bg-card: rgba(255,255,255,0.03);
  }

  * { font-family: 'Inter', sans-serif; }

  .schedule-page {
    background: var(--bg-dark);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 120px 20px 100px;
    position: relative;
    overflow: hidden;
  }

  /* Ambient gradient background - infinite coverage */
  .schedule-page::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: 
      radial-gradient(circle 800px at 20% 10%, rgba(168, 85, 247, 0.15) 0%, rgba(168, 85, 247, 0.05) 30%, transparent 60%),
      radial-gradient(circle 1000px at 80% 90%, rgba(236, 72, 153, 0.12) 0%, rgba(236, 72, 153, 0.04) 35%, transparent 65%),
      radial-gradient(circle 600px at 50% 50%, rgba(6, 182, 212, 0.08) 0%, rgba(6, 182, 212, 0.02) 40%, transparent 70%),
      radial-gradient(circle 700px at 10% 70%, rgba(168, 85, 247, 0.1) 0%, rgba(168, 85, 247, 0.03) 35%, transparent 65%),
      radial-gradient(circle 900px at 90% 30%, rgba(236, 72, 153, 0.08) 0%, rgba(236, 72, 153, 0.02) 40%, transparent 70%),
      radial-gradient(circle 500px at 30% 85%, rgba(192, 132, 252, 0.06) 0%, transparent 60%),
      radial-gradient(circle 650px at 75% 15%, rgba(236, 72, 153, 0.05) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
    opacity: 0.8;
  }

  .conversation {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: relative;
    z-index: 1;
  }

  /* Assistant message bubble with gradient text effect */
  .msg-assistant {
    opacity: 0;
    transform: translateY(12px);
    animation: msgIn 0.4s ease forwards;
  }
  .msg-assistant .bubble {
    font-size: 1.35rem;
    line-height: 1.6;
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  /* Gradient text that animates as it types */
  .msg-assistant .bubble .char {
    display: inline;
    background: linear-gradient(135deg, 
      var(--secondary) 0%, 
      var(--primary) 30%, 
      var(--primary-light) 60%, 
      var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: coolDown 2s ease forwards;
  }

  @keyframes coolDown {
    0% {
      filter: brightness(1.8) saturate(1.5);
    }
    100% {
      filter: brightness(1) saturate(1);
    }
  }

  .msg-assistant .bubble .cursor {
    display: inline-block;
    width: 2px;
    height: 1.2em;
    background: linear-gradient(135deg, var(--secondary), var(--primary));
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 0.8s step-end infinite;
    box-shadow: 0 0 10px var(--primary);
  }

  /* User message bubble */
  .msg-user {
    align-self: flex-end;
    opacity: 0;
    transform: translateY(12px);
    animation: msgIn 0.3s ease forwards;
  }
  .msg-user .bubble {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.12), rgba(236, 72, 153, 0.08));
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 16px 16px 4px 16px;
    padding: 12px 20px;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 400;
    backdrop-filter: blur(10px);
  }

  /* Options grid */
  .options {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 12px;
    opacity: 0;
    animation: msgIn 0.3s ease 0.1s forwards;
  }
  .options button {
    background: var(--bg-card);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 12px;
    padding: 10px 20px;
    color: #fff;
    font-size: 0.95rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .options button::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .options button:hover::before {
    opacity: 0.15;
  }
  .options button:hover {
    border-color: var(--primary);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
  }
  .options button.selected {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15));
    border-color: var(--primary-light);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.4);
  }
  .options button span {
    position: relative;
    z-index: 1;
  }

  /* Date/time grid */
  .date-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
    margin-top: 12px;
    opacity: 0;
    animation: msgIn 0.3s ease 0.1s forwards;
  }
  .date-grid button {
    background: var(--bg-card);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 12px;
    padding: 14px 16px;
    color: #fff;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
  }
  .date-grid button:hover {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(236, 72, 153, 0.1));
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
  }

  .time-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    opacity: 0;
    animation: msgIn 0.3s ease 0.1s forwards;
  }
  .time-grid button {
    background: var(--bg-card);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 10px;
    padding: 10px 18px;
    color: #fff;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .time-grid button:hover {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(236, 72, 153, 0.1));
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(168, 85, 247, 0.3);
  }

  /* Confirmation card */
  .confirm-card {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.08), rgba(236, 72, 153, 0.05));
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 16px;
    padding: 24px;
    margin-top: 12px;
    opacity: 0;
    animation: msgIn 0.3s ease 0.1s forwards;
    backdrop-filter: blur(10px);
  }
  .confirm-card .detail {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(168, 85, 247, 0.15);
    color: rgba(255,255,255,0.8);
    font-size: 0.95rem;
  }
  .confirm-card .detail:last-child { border-bottom: none; }
  .confirm-card .detail .label { 
    color: rgba(255,255,255,0.5);
    background: linear-gradient(135deg, var(--primary-light), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .confirm-card .detail .value { color: #fff; font-weight: 500; }

  /* Success checkmark */
  .success-mark {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    opacity: 0;
    animation: popIn 0.5s ease 0.2s forwards;
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.5);
    background: radial-gradient(circle, rgba(168, 85, 247, 0.2), transparent);
  }
  .success-mark svg {
    width: 32px;
    height: 32px;
    stroke: var(--primary-light);
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: drawCheck 0.6s ease 0.5s forwards;
    filter: drop-shadow(0 0 8px var(--primary));
  }

  /* Loading dots */
  .loading-dots {
    display: flex;
    gap: 6px;
    padding: 8px 0;
  }
  .loading-dots span {
    width: 8px;
    height: 8px;
    background: rgba(255,255,255,0.3);
    border-radius: 50%;
    animation: dotPulse 1.2s ease infinite;
  }
  .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

  /* Input area */
  .input-area {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 20px 24px;
    display: flex;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(transparent, var(--bg-dark) 40%);
    z-index: 10;
  }
  .input-area input {
    width: 100%;
    max-width: 580px;
    background: var(--bg-card);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 14px;
    padding: 14px 20px;
    color: #fff;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: all 0.3s;
    backdrop-filter: blur(10px);
  }
  .input-area input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }
  .input-area input::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .input-area button {
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border: none;
    border-radius: 14px;
    padding: 14px 16px;
    color: #fff;
    cursor: pointer;
    transition: all 0.3s;
    flex-shrink: 0;
  }
  .input-area button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(168, 85, 247, 0.5);
  }

  @keyframes msgIn {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  @keyframes popIn {
    0% { opacity: 0; transform: scale(0.5); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }
  @keyframes dotPulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 640px) {
    .schedule-page { padding: 100px 16px 90px; }
    .msg-assistant .bubble { font-size: 1.15rem; }
    .date-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
  }
</style>

<script>
  const conv = document.getElementById('conversation')!;
  const inputArea = document.getElementById('inputArea')!;
  const userInput = document.getElementById('userInput') as HTMLInputElement;
  const sendBtn = document.getElementById('sendBtn')!;

  // State
  let state: {
    step: string;
    name: string;
    email: string;
    purpose: string;
    date: string;
    dateLabel: string;
    time: string;
    timeISO: string;
    availability: any;
  } = {
    step: 'greeting',
    name: '', email: '', purpose: '',
    date: '', dateLabel: '', time: '', timeISO: '',
    availability: null,
  };

  let inputResolve: ((val: string) => void) | null = null;

  // --- Typewriter ---
  function typewrite(el: HTMLElement, text: string, speed = 25): Promise<void> {
    return new Promise((resolve) => {
      const cursor = document.createElement('span');
      cursor.className = 'cursor';
      el.appendChild(cursor);
      let i = 0;
      const tick = () => {
        if (i < text.length) {
          // Wrap each character in a span with gradient class
          const char = document.createElement('span');
          char.className = 'char';
          char.textContent = text[i];
          cursor.before(char);
          i++;
          scrollToBottom();
          setTimeout(tick, speed + Math.random() * 15);
        } else {
          setTimeout(() => { cursor.remove(); resolve(); }, 400);
        }
      };
      tick();
    });
  }

  function scrollToBottom() {
    window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
  }

  // --- Message helpers ---
  function addAssistantMsg(): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'msg-assistant';
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    wrap.appendChild(bubble);
    conv.appendChild(wrap);
    scrollToBottom();
    return bubble;
  }

  function addUserMsg(text: string) {
    const wrap = document.createElement('div');
    wrap.className = 'msg-user';
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.textContent = text;
    wrap.appendChild(bubble);
    conv.appendChild(wrap);
    scrollToBottom();
  }

  function addLoading(): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'msg-assistant';
    wrap.innerHTML = '<div class="loading-dots"><span></span><span></span><span></span></div>';
    conv.appendChild(wrap);
    scrollToBottom();
    return wrap;
  }

  async function say(text: string, pause = 300): Promise<void> {
    await delay(pause);
    const bubble = addAssistantMsg();
    await typewrite(bubble, text);
  }

  function delay(ms: number): Promise<void> {
    return new Promise(r => setTimeout(r, ms));
  }

  // --- Input handling ---
  function waitForText(): Promise<string> {
    return new Promise((resolve) => {
      inputArea.style.display = 'flex';
      userInput.value = '';
      userInput.focus();
      inputResolve = resolve;
    });
  }

  function submitInput() {
    const val = userInput.value.trim();
    if (!val || !inputResolve) return;
    inputArea.style.display = 'none';
    addUserMsg(val);
    const r = inputResolve;
    inputResolve = null;
    r(val);
  }

  sendBtn.addEventListener('click', submitInput);
  userInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') submitInput();
  });

  function showOptions(options: string[]): Promise<string> {
    return new Promise((resolve) => {
      const wrap = document.createElement('div');
      wrap.className = 'options';
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.textContent = opt;
        btn.addEventListener('click', () => {
          wrap.querySelectorAll('button').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          addUserMsg(opt);
          wrap.remove();
          resolve(opt);
        });
        wrap.appendChild(btn);
      });
      conv.appendChild(wrap);
      scrollToBottom();
    });
  }

  function showDatePicker(days: any[]): Promise<{ date: string; label: string }> {
    return new Promise((resolve) => {
      const grid = document.createElement('div');
      grid.className = 'date-grid';
      days.slice(0, 8).forEach(day => {
        const btn = document.createElement('button');
        btn.textContent = day.label;
        btn.addEventListener('click', () => {
          addUserMsg(day.label);
          grid.remove();
          resolve({ date: day.date, label: day.label });
        });
        grid.appendChild(btn);
      });
      conv.appendChild(grid);
      scrollToBottom();
    });
  }

  function showTimePicker(slots: string[], date: string): Promise<{ time: string; iso: string }> {
    return new Promise((resolve) => {
      const grid = document.createElement('div');
      grid.className = 'time-grid';
      slots.forEach(slot => {
        const btn = document.createElement('button');
        // Format HH:MM to readable time
        const [h, m] = slot.split(':').map(Number);
        const ampm = h >= 12 ? 'pm' : 'am';
        const h12 = h % 12 || 12;
        const display = m === 0 ? `${h12}${ampm}` : `${h12}:${m.toString().padStart(2, '0')}${ampm}`;
        btn.textContent = display;

        btn.addEventListener('click', () => {
          addUserMsg(display);
          grid.remove();
          resolve({
            time: display,
            iso: `${date}T${slot}:00`,
          });
        });
        grid.appendChild(btn);
      });
      conv.appendChild(grid);
      scrollToBottom();
    });
  }

  function showConfirmation(): Promise<boolean> {
    return new Promise((resolve) => {
      const card = document.createElement('div');
      card.className = 'confirm-card';
      card.innerHTML = `
        <div class="detail"><span class="label">Name</span><span class="value">${esc(state.name)}</span></div>
        <div class="detail"><span class="label">Email</span><span class="value">${esc(state.email)}</span></div>
        <div class="detail"><span class="label">Purpose</span><span class="value">${esc(state.purpose)}</span></div>
        <div class="detail"><span class="label">When</span><span class="value">${esc(state.dateLabel)} at ${esc(state.time)}</span></div>
      `;
      conv.appendChild(card);

      const opts = document.createElement('div');
      opts.className = 'options';
      const confirmBtn = document.createElement('button');
      confirmBtn.textContent = 'Confirm Booking';
      confirmBtn.style.borderColor = 'rgba(255,255,255,0.4)';
      const restartBtn = document.createElement('button');
      restartBtn.textContent = 'Start Over';

      confirmBtn.addEventListener('click', () => { opts.remove(); resolve(true); });
      restartBtn.addEventListener('click', () => { opts.remove(); card.remove(); resolve(false); });

      opts.appendChild(confirmBtn);
      opts.appendChild(restartBtn);
      conv.appendChild(opts);
      scrollToBottom();
    });
  }

  function showSuccess() {
    const wrap = document.createElement('div');
    wrap.className = 'msg-assistant';
    wrap.style.textAlign = 'center';
    wrap.innerHTML = `
      <div class="success-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
    `;
    conv.appendChild(wrap);
    scrollToBottom();
  }

  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // --- Main flow ---
  async function run() {
    // Greeting
    await say("Hi there! I'm here to help you schedule a meeting.", 500);
    await say("Let's find a time that works.", 600);

    // Name
    await say("First, what's your name?", 400);
    state.name = await waitForText();

    // Email
    await say(`Nice to meet you, ${state.name}! What's your email address?`, 300);
    state.email = await waitForText();

    // Purpose
    await say("What would you like to discuss?", 300);
    state.purpose = await showOptions(['Consultation', 'Project Inquiry', 'General Question']);

    // Fetch availability
    await say("Let me check the calendar...", 300);
    const loader = addLoading();

    try {
      const res = await fetch('/api/booking/availability');
      const data = await res.json();
      loader.remove();

      if (!data.days || data.days.length === 0) {
        await say("I'm sorry, there are no available times in the next two weeks. Please reach out directly and we'll find something that works.");
        return;
      }

      state.availability = data;

      // Date selection
      await say("Here are some available days:", 300);
      const picked = await showDatePicker(data.days);
      state.date = picked.date;
      state.dateLabel = picked.label;

      // Time selection
      const dayData = data.days.find((d: any) => d.date === state.date);
      if (!dayData || dayData.slots.length === 0) {
        await say("Hmm, looks like that day just filled up. Let me show the dates again.");
        // Could restart date picker here — keeping it simple for now
        return;
      }

      await say(`Great choice! Here are the available times for ${state.dateLabel}:`, 300);
      const timePick = await showTimePicker(dayData.slots, state.date);
      state.time = timePick.time;
      state.timeISO = timePick.iso;

      // Confirmation
      await say("Perfect! Here's a summary:", 300);
      const confirmed = await showConfirmation();

      if (!confirmed) {
        // Restart
        conv.innerHTML = '';
        state = { step: 'greeting', name: '', email: '', purpose: '', date: '', dateLabel: '', time: '', timeISO: '', availability: null };
        run();
        return;
      }

      // Book it
      addUserMsg("Confirmed!");
      await say("Booking your appointment...", 200);
      const bookLoader = addLoading();

      const bookRes = await fetch('/api/booking/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: state.name,
          email: state.email,
          start: state.timeISO,
          notes: state.purpose,
        }),
      });

      bookLoader.remove();

      if (bookRes.ok) {
        showSuccess();
        await say(`You're all set! A confirmation will be sent to ${state.email}.`, 400);
        await say("See you then! ✨", 500);
      } else {
        const err = await bookRes.json();
        await say("That slot may have just been taken. Let me show you the available times again.", 300);
        // Could restart from date selection — keeping simple
      }

    } catch (err) {
      loader.remove();
      await say("I'm having trouble reaching the calendar right now. Please try again in a moment.", 300);
    }
  }

  // Kick it off
  run();
</script>
