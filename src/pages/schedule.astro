---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div id="cf-context"></div>
</Layout>

<style is:global>
  body {
    margin: 0;
    background: #0a0a0a;
  }

  #cf-context {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  conversational-form {
    --cf-color-background: #0a0a0a;
    --cf-color-foreground: #ffffff;
    --cf-color-primary: #a855f7;
    --cf-color-secondary: #ec4899;
    --cf-color-tertiary: rgba(255, 255, 255, 0.1);
    --cf-font-family: 'Inter', sans-serif;
  }

  cf-chat {
    max-width: 640px;
    width: 100%;
  }

  cf-chat-response {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.15)) !important;
    border: 1px solid rgba(168, 85, 247, 0.3) !important;
    border-radius: 12px !important;
  }

  cf-input-button button {
    background: rgba(255, 255, 255, 0.06) !important;
    border: 1px solid rgba(168, 85, 247, 0.3) !important;
    border-radius: 12px !important;
    transition: all 0.3s !important;
  }

  cf-input-button button:hover {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(236, 72, 153, 0.1)) !important;
    border-color: #a855f7 !important;
    transform: translateY(-2px) !important;
  }

  cf-input input {
    background: rgba(255, 255, 255, 0.06) !important;
    border: 1px solid rgba(168, 85, 247, 0.3) !important;
    border-radius: 12px !important;
    color: #fff !important;
  }

  cf-input input:focus {
    border-color: #a855f7 !important;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3) !important;
  }
</style>

<script>
  import cf from 'conversational-form';

  const formFields = [
    {
      'tag': 'input',
      'type': 'text',
      'name': 'name',
      'cf-questions': "Hi there! I'm here to help you schedule a meeting.&&Let's find a time that works.&&First, what's your name?"
    },
    {
      'tag': 'input',
      'type': 'email',
      'name': 'email',
      'cf-questions': "Nice to meet you! What's your email address?"
    },
    {
      'tag': 'select',
      'name': 'purpose',
      'cf-questions': "What would you like to discuss?",
      'children': [
        {
          'tag': 'option',
          'value': 'consultation',
          'cf-label': 'Consultation'
        },
        {
          'tag': 'option',
          'value': 'project',
          'cf-label': 'Project Inquiry'
        },
        {
          'tag': 'option',
          'value': 'general',
          'cf-label': 'General Question'
        }
      ]
    }
  ];

  const conversationalForm = cf.ConversationalForm.startTheConversation({
    formEl: document.createElement('form'),
    context: document.getElementById('cf-context'),
    tags: formFields,
    submitCallback: async function() {
      const formData = this.getFormData(true);
      
      conversationalForm.addRobotChatResponse("Let me check the calendar...");

      try {
        const res = await fetch('/api/booking/availability');
        const data = await res.json();

        if (data.days && data.days.length > 0) {
          conversationalForm.addRobotChatResponse(
            `Found ${data.days.length} available days! I'll send you a confirmation email at ${formData.email} with booking details.`
          );
        } else {
          conversationalForm.addRobotChatResponse(
            "Sorry, no availability found right now. Please email us directly at hello@reave.app and we'll get back to you soon!"
          );
        }
      } catch (error) {
        conversationalForm.addRobotChatResponse(
          "I'm having trouble checking the calendar. Please email hello@reave.app directly."
        );
      }

      setTimeout(() => {
        conversationalForm.addRobotChatResponse("Thanks for reaching out! 🎉");
      }, 1000);

      return false; // Prevent actual form submission
    }
  });
</script>
