---
import Layout from "../layouts/Layout.astro";
import { getCompanyConfig } from "../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
const siteUrl = company.domain ? `https://${company.domain}` : Astro.url.origin;
const supportMail = company.supportEmail || (company.domain ? `support@${company.domain}` : "");
---

<Layout
  title="Terms of Service"
  description={`Terms of Service for ${company.name} — the rules and conditions for using our platform.`}
>
  <div class="page">
    <div class="doc">
      <div class="doc-header">
        <p class="doc-label">Legal</p>
        <h1>Terms of Service</h1>
        <p class="doc-meta">{company.name} &mdash; Last updated June 16, 2025</p>
      </div>

      <div class="doc-body">
        <section>
          <h2>1. Acceptance of Terms</h2>
          <p>
            By accessing or using the {company.name} platform ("we," "us," or "our")
            {company.domain ? ` at ${company.domain}` : ''}, you agree to be bound by these Terms of Service. If you do not agree,
            do not use the platform.
          </p>
        </section>

        <section>
          <h2>2. Description of Service</h2>
          <p>
            {company.name} is an automated client communication platform that delivers requested information
            to clients via SMS, voice, and web interfaces. Features may change or be discontinued
            at any time without notice.
          </p>
        </section>

        <section>
          <h2>3. Eligibility</h2>
          <p>
            You must be at least 18 years old and legally capable of entering a binding agreement
            to use {company.name}. By using the platform you represent that you meet these requirements.
          </p>
        </section>

        <section>
          <h2>4. SMS Communications</h2>
          <p>
            By providing your phone number and requesting information through the platform, you
            consent to receive transactional SMS messages from {company.name}. These messages
            are sent only in direct response to your explicit request — we do not send marketing
            or promotional SMS without separate consent.
          </p>
          <p>
            You can opt out of SMS at any time by replying <strong>STOP</strong> to any message. For
            help, reply <strong>HELP</strong>
            {supportMail ? (
              <> or contact us at <a href={`mailto:${supportMail}`}>{supportMail}</a></>
            ) : null}.
            Message and data rates may apply.
          </p>
        </section>

        <section>
          <h2>5. Acceptable Use</h2>
          <p>
            You agree not to misuse the platform, attempt unauthorized access, interfere with other
            users, or use the service for unlawful purposes. We reserve the right to suspend or
            terminate access for violations.
          </p>
        </section>

        <section>
          <h2>6. Intellectual Property</h2>
          <p>
            All content, design, code, and materials on the platform are the property of {company.legalName || company.name}
            or its licensors and are protected by applicable intellectual property laws.
          </p>
        </section>

        <section>
          <h2>7. Disclaimer of Warranties</h2>
          <p>
            The platform is provided "as is" without warranties of any kind, express or implied.
            We do not guarantee uninterrupted or error-free operation.
          </p>
        </section>

        <section>
          <h2>8. Limitation of Liability</h2>
          <p>
            To the fullest extent permitted by law, {company.legalName || company.name} shall not be liable for any
            indirect, incidental, special, consequential, or punitive damages arising from your use
            of the platform.
          </p>
        </section>

        <section>
          <h2>9. Changes to These Terms</h2>
          <p>
            We may update these Terms from time to time. When we do, we will revise the "Last
            updated" date at the top. Continued use of the platform after changes constitutes
            acceptance of the updated Terms.
          </p>
        </section>

        <section>
          <h2>10. Contact</h2>
          <p>
            Questions?
            {supportMail ? (
              <> Reach us at <a href={`mailto:${supportMail}`}>{supportMail}</a></>
            ) : ' Contact us through the platform.'}
            {company.domain ? (
              <> or visit <a href={siteUrl}>{company.domain}</a>.</>
            ) : '.'}
          </p>
        </section>
      </div>
    </div>
  </div>
</Layout>

<style>
  * { box-sizing: border-box; }

  /* Dark background/text default now lives in Layout.astro. */

  .page {
    min-height: 100vh;
    padding: calc(64px + 48px) 24px 80px;
    display: flex;
    justify-content: center;
  }

  .doc {
    width: 100%;
    max-width: 720px;
  }

  .doc-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .doc-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a855f7;
    margin: 0 0 12px;
  }

  h1 {
    font-size: 32px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .doc-meta {
    font-size: 14px;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  .doc-body section {
    margin-bottom: 32px;
  }

  h2 {
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin: 0 0 12px;
  }

  p, li {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin: 0 0 12px;
  }

  ul {
    padding-left: 20px;
    margin: 0 0 12px;
  }

  a {
    color: #a855f7;
    text-decoration: none;
  }

  a:hover { text-decoration: underline; }

  strong { color: rgba(255,255,255,0.9); }
</style>
