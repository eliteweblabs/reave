---
/**
 * Public client portal — a shareable, iOS-first page per contact.
 *
 * URL: /c/<uid>  (uid is an unguessable UUID from contact-api, so the link
 * itself is the access token — only people you send it to can open it.)
 *
 * Rendered server-side so the CONTACT_API_KEY never reaches the browser. Content
 * comes from the `portal` link metadata on the contact (see src/lib/contactApi).
 * Internal `notes` are intentionally NOT shown.
 *
 * Tabs: Overview (headline/body/fields), Billing (Crater invoices), Data
 * (web-design handoff: passwords/DNS/hosting). Tabs only appear when populated.
 */
import {
  getContact,
  extractPortal,
  contactStringField,
  contactTelHref,
  type ContactRecord,
  type ClientPortal,
  type PortalDocument,
} from '../../lib/contactApi';
import { getCompanyConfig, poweredByLabel } from '../../lib/companyConfig';
import { hasFeature } from '../../lib/features';
import { isCraterConfigured, craterGetClientBilling, type ClientBilling } from '../../lib/craterClient';
import { storeListWorkForContact, storeReadWork, type WorkJobSummary } from '../../lib/workStore';
import { storeListWorkCommentsForSlugs, type WorkJobComment } from '../../lib/workComments';
import { enrichClientPortalBrand } from '../../lib/clientBrand';
import { getClientUptimeView } from '../../lib/uptimeMonitoring';
import { uptimeStatusLabel } from '../../lib/uptimerobotClient';
import { PORTAL_OG_HEIGHT, PORTAL_OG_WIDTH } from '../../lib/portalOgImage';
import { requestOrigin } from '../../lib/requestOrigin';
import { SITE } from '../../config/site';
import PortalWorkPanel, { type PortalWorkJobItem } from '../../components/PortalWorkPanel.astro';
import Header from '../../components/Header.astro';
import Favicon from '../../components/Favicon.astro';

const org = await getCompanyConfig(Astro.request);
const poweredBy = poweredByLabel(org);

const { slug } = Astro.params;
const uid = (slug ?? '').trim();

let contact: ContactRecord | null = null;
let portal: ClientPortal = {};
let notFound = false;

if (uid) {
  const res = await getContact(uid);
  if (res.ok && !res.data.archived) {
    const p = extractPortal(res.data);
    // Every client has a page by default; only an explicit `enabled:false`
    // (revoked) hides it. Custom content is optional.
    if (!p || p.enabled !== false) {
      contact = res.data;
      portal = p ?? {};
      // Best-effort: fetch logo + tagline from their website on first visit.
      if (!contactStringField(portal.logoUrl)) {
        await enrichClientPortalBrand(uid);
        const refreshed = await getContact(uid);
        if (refreshed.ok) {
          contact = refreshed.data;
          portal = extractPortal(refreshed.data) ?? portal;
        }
      }
    }
  }
}
if (!contact) notFound = true;
if (notFound) Astro.response.status = 404;

// Billing from Crater (best-effort; skipped if not configured/matched).
let billing: ClientBilling | null = null;
if (contact && hasFeature('billing') && isCraterConfigured()) {
  try {
    const b = await craterGetClientBilling({
      email: contactStringField(contact.email) || undefined,
      name: contactStringField(contact.name) || undefined,
    });
    if (b.ok && b.data && (b.data.outstanding.length > 0 || b.data.previous.length > 0 || b.data.upcoming.length > 0)) {
      billing = b.data;
    }
  } catch {
    // Crater is optional on the portal — never take down the page for billing drift.
  }
}

const money = (n: number) => `$${Number(n).toFixed(2)}`;
const fmtDate = (s: string | null | undefined) => {
  if (!s) return '';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '' : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
function richText(s: string): string {
  const escaped = escapeHtml(s);
  const linked = escaped.replace(
    /(https?:\/\/[^\s<]+)/g,
    (url) => `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
  );
  return linked.replace(/\n/g, '<br />');
}

const displayName = contactStringField(contact?.name) || 'Client';
const company = contactStringField(contact?.company);
const logoUrl = contactStringField(portal?.logoUrl);
const clientWebsite = contactStringField(portal?.website);
const clientTagline = contactStringField(portal?.tagline);
const brandTitle = company || displayName;
const headline = contactStringField(portal?.headline);
const bodyRaw = contactStringField(portal?.body);
const bodyHtml = bodyRaw ? richText(bodyRaw) : '';
const fields = (portal?.fields ?? []).filter((f) => f && f.label && f.value);

const dataEntries = hasFeature('web_handoff')
  ? (portal?.data ?? []).filter(
      (e) => e && e.label && (e.value || e.username || e.password || e.url)
    )
  : [];

const portalDocs = hasFeature('documents')
  ? (portal?.documents ?? [])
      .slice()
      .sort((a, b) => {
        const bt = Date.parse(contactStringField(b.signedAt));
        const at = Date.parse(contactStringField(a.signedAt));
        return (Number.isNaN(bt) ? 0 : bt) - (Number.isNaN(at) ? 0 : at);
      })
  : [];

const providerTelHref = contactTelHref(org.supportPhone);
const providerEmail = org.supportEmail?.trim() || '';
const providerName = org.name?.trim() || 'us';

const updatedAt = fmtDate(portal?.updatedAt);

const CLIENT_WORK_STATUS: Record<string, string> = {
  inquiry: 'Submitted',
  active: 'In progress',
  done: 'Complete',
};

// Jobs linked to this client (non-archived only — internal archive stays hidden).
let clientJobs: WorkJobSummary[] = [];
let commentsBySlug: Record<string, WorkJobComment[]> = {};
const jobBodies: Record<string, string> = {};
if (contact && uid) {
  try {
    clientJobs = (await storeListWorkForContact(uid)).filter((j) => j.status !== 'archived');
    if (clientJobs.length) {
      commentsBySlug = await storeListWorkCommentsForSlugs(clientJobs.map((j) => j.slug));
      await Promise.all(
        clientJobs.map(async (job) => {
          const doc = await storeReadWork(job.slug);
          if (doc?.body?.trim()) jobBodies[job.slug] = doc.body.trim();
        }),
      );
    }
  } catch {
    // Jobs are optional on the portal — never take down the page for storage drift.
  }
}

const portalWorkJobs: PortalWorkJobItem[] = clientJobs.map((job) => ({
  slug: job.slug,
  title: job.title,
  status: job.status,
  statusLabel: CLIENT_WORK_STATUS[job.status] || job.status,
  bodyHtml: jobBodies[job.slug] ? richText(jobBodies[job.slug]) : '',
}));

let clientUptimeMonitors: Awaited<ReturnType<typeof getClientUptimeView>>['monitors'] = [];
let clientUptimeIncidents: Awaited<ReturnType<typeof getClientUptimeView>>['incidents'] = [];
if (contact && uid && hasFeature('uptime_monitoring')) {
  try {
    const uptimeView = await getClientUptimeView(uid);
    clientUptimeMonitors = uptimeView.monitors;
    clientUptimeIncidents = uptimeView.incidents;
  } catch {
    // Uptime is optional on the portal.
  }
}
const hasUptime = clientUptimeMonitors.length > 0 || clientUptimeIncidents.length > 0;

// Which tabs to show
const hasOverview = Boolean(headline || bodyHtml || fields.length > 0);
const hasBilling = Boolean(billing);
const hasData = dataEntries.length > 0;
const hasDocs = portalDocs.length > 0;
const hasWork = clientJobs.length > 0;
const tabs: Array<{ id: string; label: string }> = [];
tabs.push({ id: 'overview', label: 'Overview' });
if (hasWork) tabs.push({ id: 'work', label: 'Work' });
if (hasBilling) tabs.push({ id: 'billing', label: 'Billing' });
if (hasData) tabs.push({ id: 'data', label: 'Data' });
if (hasDocs) tabs.push({ id: 'documents', label: 'Documents' });
const showTabs = tabs.length > 1;

const initialTab = (() => {
  const raw = Astro.url.searchParams.get('tab')?.trim().toLowerCase();
  if (raw && tabs.some((t) => t.id === raw)) return raw;
  return tabs[0]?.id ?? 'overview';
})();

const pageTitle = company ? `${displayName} · ${company}` : displayName;
const appTitle = brandTitle;
const manifestHref = uid ? `/c/${encodeURIComponent(uid)}/manifest.json` : '';
const themeColor = '#0a0a0a';
const origin = requestOrigin(Astro.request);
const portalUrl = uid ? `${origin}/c/${encodeURIComponent(uid)}` : origin;
const ogDescription = clientTagline || `${brandTitle} client portal`;
const ogImagePath = uid ? `/c/${encodeURIComponent(uid)}/og.png` : SITE.ogImage;
const ogImageAbsolute = ogImagePath.startsWith('http') ? ogImagePath : `${origin}${ogImagePath}`;

// ?submit — show a focused data-submission form instead of the full portal.
const submitMode = !notFound && Astro.url.searchParams.has('submit');
const submitEndpoint = `/api/c/${encodeURIComponent(uid)}/submit`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{notFound ? 'Not found' : pageTitle}</title>
    {!notFound && (
      <>
        <meta name="description" content={ogDescription} />
        <link rel="canonical" href={portalUrl} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={ogDescription} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={portalUrl} />
        <meta property="og:image" content={ogImageAbsolute} />
        <meta property="og:image:width" content={String(PORTAL_OG_WIDTH)} />
        <meta property="og:image:height" content={String(PORTAL_OG_HEIGHT)} />
        <meta property="og:image:alt" content={`${brandTitle} client portal`} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={ogDescription} />
        <meta name="twitter:image" content={ogImageAbsolute} />
      </>
    )}
    <Favicon />
    {!notFound && manifestHref && <link rel="manifest" href={manifestHref} />}
    <meta name="theme-color" content={themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    {!notFound && <meta name="apple-mobile-web-app-title" content={appTitle} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header staffPreview />
    {
      notFound ? (
        <main class="wrap empty">
          <div class="card">
            <h1>This page isn’t available</h1>
            <p>The link may be expired or incorrect. Please reach out and we’ll send you a fresh one.</p>
          </div>
        </main>
      ) : submitMode ? (
        <main class="wrap">
          <header class="hero">
            <h1>{displayName}</h1>
            {company && <p class="company">{company}</p>}
          </header>

          <div id="submit-form">
            <p class="submit-intro">Fill in the details below and tap <strong>Submit</strong>. Add as many entries as you need.</p>

            <div id="entries-list"></div>

            <button class="add-btn" id="add-entry" type="button">+ Add another</button>

            <button class="submit-btn" id="submit-btn" type="button">Submit</button>
          </div>

          <div id="submit-success" style="display:none">
            <div class="success-card">
              <div class="success-icon">&#x2713;</div>
              <h2>Submitted</h2>
              <p>Your info has been received. You can close this page.</p>
            </div>
          </div>

          <footer class="foot">
            <span class="brand">{poweredBy}</span>
          </footer>
        </main>
      ) : (
        <main class="wrap">
          <header class="hero">
            {logoUrl ? (
              <>
                <img class="client-logo" src={logoUrl} alt={brandTitle} width="160" height="64" loading="eager" />
                <p class="client-brand-name">{brandTitle}</p>
              </>
            ) : (
              <h1>{brandTitle}</h1>
            )}
            {clientTagline && <p class="client-tagline">{clientTagline}</p>}
            {clientWebsite && (
              <a class="client-website" href={clientWebsite.startsWith('http') ? clientWebsite : `https://${clientWebsite}`} target="_blank" rel="noopener noreferrer">
                {clientWebsite.replace(/^https?:\/\//i, '').replace(/\/$/, '')}
              </a>
            )}
            {company && displayName !== company && displayName !== brandTitle && (
              <p class="client-contact">{displayName}</p>
            )}
          </header>

          {(providerTelHref || providerEmail) && (
            <nav class="actions" aria-label={`Contact ${providerName}`}>
              {providerTelHref && (
                <a class="action" href={`tel:${providerTelHref}`}>
                  <span class="ico" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span><span>Call</span>
                </a>
              )}
              {providerTelHref && (
                <a class="action" href={`sms:${providerTelHref}`}>
                  <span class="ico" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span><span>Text</span>
                </a>
              )}
              {providerEmail && (
                <a class="action" href={`mailto:${providerEmail}`}>
                  <span class="ico" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></span><span>Email</span>
                </a>
              )}
            </nav>
          )}

          {showTabs && (
            <div class="tabbar" role="tablist">
              {tabs.map((t) => (
                <button class={`tab ${t.id === initialTab ? 'active' : ''}`} data-tab-btn={t.id} type="button">
                  {t.label}
                </button>
              ))}
            </div>
          )}

          {/* Overview */}
          <section class={`panel ${initialTab === 'overview' ? 'active' : ''}`} data-tab-panel="overview">
            {headline && <h2 class="headline">{headline}</h2>}
            {bodyHtml && <div class="body" set:html={bodyHtml} />}
            {fields.length > 0 && (
              <div class="fields">
                {fields.map((f) => (
                  <div class="field">
                    <div class="field-label">{f.label}</div>
                    <div class="field-value">{f.value}</div>
                  </div>
                ))}
              </div>
            )}
            {!hasOverview && !hasWork && !hasUptime && <p class="muted">Welcome{company ? `, ${company}` : ''}. Use the tabs above to view your billing and account details.</p>}
            {!hasOverview && hasWork && !hasUptime && <p class="muted">Welcome{company ? `, ${company}` : ''}. Check the Work tab for your active projects.</p>}
            {hasUptime && (
              <div class="uptime-block">
                <h3 class="group-title">Site uptime</h3>
                {clientUptimeMonitors.length > 0 && (
                  <ul class="uptime-monitors">
                    {clientUptimeMonitors.map((m) => (
                      <li class={`uptime-monitor ${m.status === 8 || m.status === 9 ? 'down' : m.status === 2 ? 'up' : ''}`}>
                        <span class="uptime-dot" aria-hidden="true" />
                        <div class="uptime-main">
                          <span class="uptime-name">{m.friendly_name}</span>
                          <span class="uptime-meta">
                            {uptimeStatusLabel(m.status)}
                            {m.uptime_ratio_7d != null ? ` · ${Number(m.uptime_ratio_7d).toFixed(2)}% (7d)` : ''}
                          </span>
                        </div>
                      </li>
                    ))}
                  </ul>
                )}
                {clientUptimeIncidents.length > 0 && (
                  <ul class="uptime-incidents">
                    {clientUptimeIncidents.slice(0, 8).map((inc) => (
                      <li class="uptime-incident">
                        <span class="uptime-incident-type">{inc.alert_type || 'incident'}</span>
                        <span class="uptime-incident-when">{fmtDate(inc.created_at)}</span>
                        {inc.message && <span class="uptime-incident-msg">{inc.message}</span>}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            )}
          </section>

          {/* Work (client-visible jobs + comments) */}
          {hasWork && uid && (
            <PortalWorkPanel
              jobs={portalWorkJobs}
              commentsBySlug={commentsBySlug}
              contactUid={uid}
              active={initialTab === 'work'}
              autoExpand={clientJobs.length === 1}
            />
          )}

          {/* Billing */}
          {hasBilling && billing && (
            <section class={`panel ${initialTab === 'billing' ? 'active' : ''}`} data-tab-panel="billing">
              <div class="billing-head">
                <span class="billing-title">Balance due</span>
                <span class={`billing-total ${billing.totalDue > 0 ? 'due' : 'clear'}`}>{money(billing.totalDue)}</span>
              </div>

              {billing.outstanding.length > 0 && (
                <div class="bill-group">
                  <h3 class="group-title">Outstanding</h3>
                  <ul class="invoices">
                    {billing.outstanding.map((inv) => (
                      <li class="invoice">
                        <div class="inv-main">
                          <span class="inv-num">#{inv.number}</span>
                          <span class="inv-meta">{fmtDate(inv.date)} · {inv.status}</span>
                        </div>
                        <div class="inv-side">
                          <span class="inv-due">{money(inv.due)}</span>
                          {inv.url && <a class="pay" href={inv.url} target="_blank" rel="noopener noreferrer">Pay</a>}
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {billing.upcoming.length > 0 && (
                <div class="bill-group">
                  <h3 class="group-title">Upcoming</h3>
                  <ul class="invoices">
                    {billing.upcoming.map((r) => (
                      <li class="invoice">
                        <div class="inv-main">
                          <span class="inv-num">{r.frequency || 'Recurring'}</span>
                          <span class="inv-meta">{r.nextAt ? `Next: ${fmtDate(r.nextAt)}` : r.status}</span>
                        </div>
                        <div class="inv-side">
                          <span class="inv-due upcoming">{money(r.total)}</span>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {billing.previous.length > 0 && (
                <div class="bill-group">
                  <h3 class="group-title">Previous</h3>
                  <ul class="invoices">
                    {billing.previous.map((inv) => (
                      <li class="invoice">
                        <div class="inv-main">
                          <span class="inv-num">#{inv.number}</span>
                          <span class="inv-meta">{fmtDate(inv.date)} · Paid</span>
                        </div>
                        <div class="inv-side">
                          <span class="inv-due paid">{money(inv.total)}</span>
                          {inv.url && <a class="view" href={inv.url} target="_blank" rel="noopener noreferrer">View</a>}
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </section>
          )}

          {/* Data (web-design handoff) */}
          {hasData && (
            <section class={`panel ${initialTab === 'data' ? 'active' : ''}`} data-tab-panel="data">
              <p class="data-note">Account details &amp; credentials for your project. Keep this link private.</p>
              {dataEntries.map((e) => (
                <div class="data-card">
                  <div class="data-label">{e.label}</div>
                  {e.url && (
                    <a class="data-url" href={e.url} target="_blank" rel="noopener noreferrer">{e.url}</a>
                  )}
                  {e.username && (
                    <div class="cred">
                      <span class="cred-key">User</span>
                      <code class="cred-val">{e.username}</code>
                      <button class="mini" data-copy type="button">Copy</button>
                    </div>
                  )}
                  {e.password && (
                    <div class="cred">
                      <span class="cred-key">Pass</span>
                      <code class="cred-val secret">{e.password}</code>
                      <button class="mini" data-reveal type="button">Show</button>
                      <button class="mini" data-copy type="button">Copy</button>
                    </div>
                  )}
                  {e.value && <div class="data-value">{e.value}</div>}
                </div>
              ))}
            </section>
          )}

          {/* Documents */}
          {hasDocs && (
            <section class={`panel ${initialTab === 'documents' ? 'active' : ''}`} data-tab-panel="documents">
              <p class="data-note">Signed documents — tap to view or download as PDF.</p>
              {portalDocs.map((doc) => (
                <a
                  class="doc-card"
                  href={`/doc/${encodeURIComponent(uid)}/view/${encodeURIComponent(doc.id)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="doc-card-left">
                    <div class="doc-card-title">{doc.title}</div>
                    <div class="doc-card-meta">Signed by {doc.signerName} · {fmtDate(doc.signedAt)}</div>
                  </div>
                  <span class="doc-card-arrow">↗</span>
                </a>
              ))}
            </section>
          )}

          <footer class="foot">
            {updatedAt && <span>Updated {updatedAt}</span>}
            <span class="brand">{poweredBy}</span>
          </footer>
        </main>
      )
    }

    <script define:vars={{ submitEndpoint, submitMode }}>
      document.querySelectorAll('[data-tab-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-tab-btn');
          document.querySelectorAll('[data-tab-btn]').forEach((b) => b.classList.toggle('active', b === btn));
          document
            .querySelectorAll('[data-tab-panel]')
            .forEach((p) => p.classList.toggle('active', p.getAttribute('data-tab-panel') === id));
        });
      });
      document.querySelectorAll('[data-reveal]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const code = btn.parentElement?.querySelector('code');
          if (!code) return;
          const revealed = code.classList.toggle('revealed');
          btn.textContent = revealed ? 'Hide' : 'Show';
        });
      });
      document.querySelectorAll('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const code = btn.parentElement?.querySelector('code');
          if (!code) return;
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            const prev = btn.textContent;
            btn.textContent = 'Copied';
            setTimeout(() => (btn.textContent = prev), 1200);
          } catch {}
        });
      });

      // Submit-mode form logic
      const entriesList = document.getElementById('entries-list');
      const addBtn = document.getElementById('add-entry');
      const submitBtn = document.getElementById('submit-btn');
      const submitForm = document.getElementById('submit-form');
      const submitSuccess = document.getElementById('submit-success');

      if (entriesList && addBtn && submitBtn) {
        let entryCount = 0;

        function addEntry() {
          entryCount++;
          const idx = entryCount;
          const card = document.createElement('div');
          card.className = 'entry-card';
          card.dataset.idx = String(idx);
          card.innerHTML = `
            <div class="entry-header">
              <span class="entry-num">Entry ${idx}</span>
              ${idx > 1 ? '<button class="entry-remove" type="button" aria-label="Remove">✕</button>' : ''}
            </div>
            <input class="entry-label" type="text" placeholder="Label (e.g. Hosting, cPanel, Domain…)" autocomplete="off" />
            <textarea class="entry-value" rows="4" placeholder="Paste your info here…"></textarea>
          `;
          const removeBtn = card.querySelector('.entry-remove');
          if (removeBtn) {
            removeBtn.addEventListener('click', () => {
              card.remove();
              // Renumber remaining entries
              entriesList.querySelectorAll('.entry-card').forEach((c, i) => {
                const numEl = c.querySelector('.entry-num');
                if (numEl) numEl.textContent = `Entry ${i + 1}`;
              });
              entryCount = entriesList.querySelectorAll('.entry-card').length;
            });
          }
          entriesList.appendChild(card);
          card.querySelector('input')?.focus();
        }

        addEntry(); // start with one

        addBtn.addEventListener('click', addEntry);

        submitBtn.addEventListener('click', async () => {
          const cards = entriesList.querySelectorAll('.entry-card');
          const entries = [];
          let hasError = false;

          cards.forEach((card) => {
            const label = (card.querySelector('.entry-label')).value.trim();
            const value = (card.querySelector('.entry-value')).value.trim();
            if (!label) {
              (card.querySelector('.entry-label')).classList.add('input-error');
              hasError = true;
              return;
            }
            (card.querySelector('.entry-label')).classList.remove('input-error');
            if (label || value) entries.push({ label, value });
          });

          if (hasError || entries.length === 0) return;

          submitBtn.disabled = true;
          submitBtn.textContent = 'Submitting…';

          try {
            const res = await fetch(submitEndpoint, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ entries }),
            });
            const json = await res.json();
            if (!res.ok || !json.ok) throw new Error(json.error || 'Submit failed');
            if (submitForm) submitForm.style.display = 'none';
            if (submitSuccess) submitSuccess.style.display = '';
          } catch (err) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit';
            alert('Something went wrong. Please try again or contact us directly.');
          }
        });
      }
    </script>

