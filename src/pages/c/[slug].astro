---
/**
 * Public client portal — a shareable, iOS-first page per contact.
 *
 * URL: /c/<uid>  (uid is an unguessable UUID from contact-api, so the link
 * itself is the access token — only people you send it to can open it.)
 *
 * Rendered server-side so the CONTACT_API_KEY never reaches the browser. Content
 * comes from the `portal` link metadata on the contact (see src/lib/contactApi).
 * Internal `notes` are intentionally NOT shown.
 */
import { getContact, extractPortal, type ContactRecord, type ClientPortal } from '../../lib/contactApi';

const { slug } = Astro.params;
const uid = (slug ?? '').trim();

let contact: ContactRecord | null = null;
let portal: ClientPortal = {};
let notFound = false;

if (uid) {
  const res = await getContact(uid);
  if (res.ok && !res.data.archived) {
    const p = extractPortal(res.data);
    // Every client has a page by default; only an explicit `enabled:false`
    // (revoked) hides it. Custom content (headline/body/fields) is optional.
    if (!p || p.enabled !== false) {
      contact = res.data;
      portal = p ?? {};
    }
  }
}
if (!contact) notFound = true;

if (notFound) {
  Astro.response.status = 404;
}

// ---- Presentation helpers (run server-side) -------------------------------
function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/** Escape first, then turn bare URLs into links and preserve line breaks. */
function richText(s: string): string {
  const escaped = escapeHtml(s);
  const linked = escaped.replace(
    /(https?:\/\/[^\s<]+)/g,
    (url) => `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
  );
  return linked.replace(/\n/g, '<br />');
}

const displayName = contact?.name ?? 'Client';
const company = contact?.company?.trim() || '';
const headline = portal?.headline?.trim() || '';
const bodyHtml = portal?.body?.trim() ? richText(portal.body.trim()) : '';
const fields = (portal?.fields ?? []).filter((f) => f && f.label && f.value);

const email = contact?.email?.trim() || '';
const phone = contact?.phone?.trim() || '';
const telHref = phone ? phone.replace(/[^\d+]/g, '') : '';

const updatedAt = portal?.updatedAt
  ? new Date(portal.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : '';

const pageTitle = company ? `${displayName} · ${company}` : displayName;
const appTitle = displayName;
const manifestHref = uid ? `/c/${encodeURIComponent(uid)}/manifest.json` : '';
const themeColor = '#0a0a0a';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{notFound ? 'Not found' : pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* PWA / iOS "Add to Home Screen" */}
    {!notFound && manifestHref && <link rel="manifest" href={manifestHref} />}
    <meta name="theme-color" content={themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    {!notFound && <meta name="apple-mobile-web-app-title" content={appTitle} />}
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      notFound ? (
        <main class="wrap empty">
          <div class="card">
            <div class="logo">/\V</div>
            <h1>This page isn’t available</h1>
            <p>The link may be expired or incorrect. Please reach out and we’ll send you a fresh one.</p>
          </div>
        </main>
      ) : (
        <main class="wrap">
          <header class="hero">
            <div class="logo">/\V</div>
            <h1>{displayName}</h1>
            {company && <p class="company">{company}</p>}
          </header>

          {(
            <nav class="actions" aria-label="Quick contact">
              {telHref && (
                <a class="action" href={`tel:${telHref}`}>
                  <span class="ico">📞</span>
                  <span>Call</span>
                </a>
              )}
              {telHref && (
                <a class="action" href={`sms:${telHref}`}>
                  <span class="ico">💬</span>
                  <span>Text</span>
                </a>
              )}
              {email && (
                <a class="action" href={`mailto:${email}`}>
                  <span class="ico">✉️</span>
                  <span>Email</span>
                </a>
              )}
              <a class="action" href={`/c/${encodeURIComponent(uid)}.vcf`}>
                <span class="ico">👤</span>
                <span>Save</span>
              </a>
            </nav>
          )}

          {headline && <h2 class="headline">{headline}</h2>}

          {bodyHtml && <section class="body" set:html={bodyHtml} />}

          {fields.length > 0 && (
            <section class="fields">
              {fields.map((f) => (
                <div class="field">
                  <div class="field-label">{f.label}</div>
                  <div class="field-value">{f.value}</div>
                </div>
              ))}
            </section>
          )}

          <footer class="foot">
            {updatedAt && <span>Updated {updatedAt}</span>}
            <span class="brand">Powered by Reave</span>
          </footer>
        </main>
      )
    }

    <style is:global>
      :root {
        color-scheme: dark;
      }
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
      }
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: #0a0a0a;
        color: #fff;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      body {
        background:
          radial-gradient(1200px 600px at 50% -10%, rgba(168, 85, 247, 0.18), transparent 60%),
          radial-gradient(900px 500px at 100% 0%, rgba(236, 72, 153, 0.12), transparent 55%),
          #0a0a0a;
      }
      .wrap {
        max-width: 560px;
        margin: 0 auto;
        padding: calc(env(safe-area-inset-top) + 40px) 20px calc(env(safe-area-inset-bottom) + 56px);
      }
      .logo {
        font-weight: 700;
        letter-spacing: 2px;
        font-size: 18px;
        color: rgba(255, 255, 255, 0.55);
      }
      .hero {
        text-align: center;
        margin-bottom: 28px;
      }
      .hero h1 {
        margin: 18px 0 4px;
        font-size: 30px;
        font-weight: 700;
        line-height: 1.15;
      }
      .company {
        margin: 0;
        color: rgba(255, 255, 255, 0.55);
        font-size: 15px;
      }
      .actions {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: 1fr;
        gap: 12px;
        margin-bottom: 28px;
      }
      .action {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 16px 8px;
        border-radius: 16px;
        border: 1px solid rgba(168, 85, 247, 0.35);
        background: rgba(168, 85, 247, 0.1);
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: transform 0.15s, background 0.2s, border-color 0.2s;
      }
      .action:active {
        transform: scale(0.97);
        background: rgba(168, 85, 247, 0.22);
        border-color: #a855f7;
      }
      .action .ico {
        font-size: 22px;
      }
      .headline {
        font-size: 20px;
        font-weight: 600;
        margin: 0 0 12px;
      }
      .body {
        font-size: 16px;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.9);
        padding: 18px 20px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
        word-wrap: break-word;
        overflow-wrap: anywhere;
      }
      .body a {
        color: #d8b4fe;
      }
      .fields {
        margin-top: 18px;
        display: flex;
        flex-direction: column;
        gap: 1px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .field {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 18px;
        background: rgba(255, 255, 255, 0.04);
      }
      .field-label {
        color: rgba(255, 255, 255, 0.5);
        font-size: 14px;
      }
      .field-value {
        text-align: right;
        font-size: 15px;
        font-weight: 500;
        word-break: break-word;
      }
      .foot {
        margin-top: 36px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.35);
      }
      .brand {
        letter-spacing: 0.5px;
      }
      .empty {
        display: flex;
        min-height: 80vh;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .empty .card h1 {
        font-size: 22px;
        margin: 18px 0 10px;
      }
      .empty .card p {
        color: rgba(255, 255, 255, 0.55);
        font-size: 15px;
        line-height: 1.6;
        max-width: 340px;
        margin: 0 auto;
      }
    </style>
  </body>
</html>
