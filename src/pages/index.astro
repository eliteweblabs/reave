---
import Layout from "../layouts/Layout.astro";
import QuantumLogo from "../components/QuantumLogo.astro";
import SiteFooterNav from "../components/SiteFooterNav.astro";
import HomeAboutSection from "../components/home/HomeAboutSection.astro";
import HomeServicesSection from "../components/home/HomeServicesSection.astro";
import HomePortfolioSection from "../components/home/HomePortfolioSection.astro";
import HomeContactSection from "../components/home/HomeContactSection.astro";
import { getCompanyConfig, homepageHeroMask, homepageHeroLogo } from "../lib/companyConfig";
import "../styles/marketing-sections.css";

const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);
const heroLogo = homepageHeroLogo(company);
---

<Layout>
  <div class="home-scroll">
    <section
      id="home"
      class="home-hero"
      data-home-section="home"
      aria-label={company.name}
    >
      {
        heroLogo && (
          <QuantumLogo
            heroMask={heroMask ?? undefined}
            logoSrc={heroLogo}
            layout="homepage"
          />
        )
      }
      <div class="quantum-vignette" aria-hidden="true"></div>
    </section>

    <HomeAboutSection />
    <HomeServicesSection />
    <HomePortfolioSection />
    <HomeContactSection />
  </div>

  <SiteFooterNav active="home" />
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
    scroll-padding-top: calc(var(--app-header-h, 3.25rem) + 8px);
    scroll-padding-bottom: calc(var(--site-footer-nav-offset, 3.35rem) + 16px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html) {
      scroll-behavior: auto;
    }
  }

  :global(html),
  :global(body) {
    min-height: 100%;
  }

  /* Allow page scroll through the decorative hero canvas. */
  :global(html.quantum-page-touch),
  :global(html.quantum-page-touch body) {
    touch-action: pan-y;
    overscroll-behavior-y: none;
  }

  .home-scroll {
    position: relative;
    z-index: 1;
    padding-bottom: calc(var(--site-footer-nav-offset, 3.35rem) + 24px);
  }

  .home-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    /* svh stays fixed while scrolling; dvh shrinks/grows with the mobile URL bar. */
    min-height: 100svh;
    overflow: hidden;
    scroll-margin-top: 0;
  }

  .quantum-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(
      ellipse 120% 120% at center,
      transparent 48%,
      rgba(0, 0, 0, 0.35) 78%,
      rgba(0, 0, 0, 0.72) 115%
    );
  }

  @media screen and (max-width: 768px) {
    .quantum-vignette {
      background: radial-gradient(
        ellipse 125% 125% at center,
        transparent 52%,
        rgba(0, 0, 0, 0.28) 80%,
        rgba(0, 0, 0, 0.65) 118%
      );
    }
  }
</style>
