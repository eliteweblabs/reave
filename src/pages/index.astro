---
import Layout from "../layouts/Layout.astro";
import VoiceChatButton from "../components/VoiceChatButton.astro";
import Transcript from "../components/Transcript.astro";
import TextFallback from "../components/TextFallback.astro";
---

<Layout>
  <!-- Mask clips the WebGL layer (mask on the painted content, not an empty box). -->
  <div class="quantum-logo-stack" aria-hidden="true">
    <div id="quantumCanvasHost" class="quantum-host"></div>
  </div>
  <div class="quantum-vignette" aria-hidden="true"></div>

  <div class="quantum-controls-dock" aria-label="Background controls">
    <div class="quantum-controls">
      <button type="button" class="quantum-btn" id="btn-stabilize">Focus</button>
      <button type="button" class="quantum-btn quantum-btn--alert" id="btn-destabilize">Warp</button>
      <button type="button" class="quantum-btn" id="btn-reset">Reset</button>
    </div>
  </div>

  <VoiceChatButton position="center-bottom" />
  <Transcript />
  <TextFallback />
  <div class="container">
    <div class="watermark">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
        <line
          x1="241.9"
          y1="170.2"
          x2="241.9"
          y2="318.2"
          fill="#fff"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></line>
        <line
          x1="165.6"
          y1="248.2"
          x2="314.6"
          y2="248.2"
          fill="#fff"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></line>
        <path
          d="M242.1,332.5v14.8c0,54.4,44.1,98.6,98.6,98.6s98.6-44.1,98.6-98.6-44.1-98.6-98.6-98.6h-12.8"
          fill="none"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></path>
        <path
          d="M241.4,152.4v-45.9c0-27.7-22.4-50.1-50.1-50.1s-60.1,22.4-60.1,50.1l-1,11.4,2,19.4-12.3-2-16.4,1c-27.7,0-50.1,34.4-50.1,62.1s22.4,50.1,50.1,50.1h48.4"
          fill="none"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></path>
      </svg>
    </div>
  </div>
</Layout>

<style>
  :root {
    --quantum-neon-blue: #00f3ff;
    --quantum-neon-purple: #bc13fe;
    --quantum-neon-red: #ff0055;
    --quantum-glass: rgba(10, 10, 12, 0.6);
    --quantum-border: rgba(255, 255, 255, 0.1);
  }

  :global(html),
  :global(body) {
    min-height: 100%;
    background: #050505;
  }

  /* Let drags reach the scene on iOS (otherwise Safari keeps scroll/rubber-band). */
  :global(html.quantum-page-touch),
  :global(html.quantum-page-touch body) {
    touch-action: none;
    overscroll-behavior: none;
  }

  /* Wrapper is masked; canvas paints only inside the logo SVG silhouette. */
  .quantum-logo-stack {
    position: fixed;
    inset: 0;
    z-index: 0;
    /* Must not be `none` — some engines skip hit-testing the whole subtree (incl. canvas). */
    pointer-events: auto;
    cursor: default;
    touch-action: none;
    overflow: hidden;
    mask-image: url("/logo-mask.svg");
    -webkit-mask-image: url("/logo-mask.svg");
    /* Resolved size/position are read in JS so the WebGL camera matches this box (tight fit in the letters). */
    mask-size: min(92vmin, 96vw, 820px);
    -webkit-mask-size: min(92vmin, 96vw, 820px);
    mask-position: 42% center;
    -webkit-mask-position: 42% center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
    filter: drop-shadow(0 0 18px rgba(255, 255, 255, 0.45))
      drop-shadow(0 0 36px rgba(255, 100, 200, 0.28));
    animation: quantumLogoIntro 1.4s ease-out forwards;
  }

  .quantum-host {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* Host still targets the canvas; stack owns pointer-events + cursor. */
    pointer-events: auto;
    touch-action: none;
    overflow: hidden;
  }

  .quantum-host :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
    max-width: none;
    object-fit: cover;
  }

  .quantum-vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(
      circle at center,
      transparent 40%,
      rgba(0, 0, 0, 0.8) 110%
    );
  }

  .quantum-controls-dock {
    /* Hidden. When showing again, set `display: flex`. */
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9000;
    justify-content: center;
    padding-top: 12px;
    padding-left: 16px;
    padding-right: 16px;
    padding-bottom: max(
      calc(12px + env(safe-area-inset-bottom, 0px)),
      clamp(88px, 18vh, 140px)
    );
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(5, 5, 5, 0.85) 0%,
      rgba(5, 5, 5, 0.35) 55%,
      transparent 100%
    );
  }

  .quantum-controls {
    pointer-events: auto;
    background: var(--quantum-glass);
    padding: 10px;
    border: 1px solid var(--quantum-border);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    backdrop-filter: blur(20px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    transform: skewX(-10deg);
  }

  .quantum-btn {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 15px 24px;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    transform: skewX(10deg);
    min-width: 100px;
  }

  .quantum-btn:hover {
    background: var(--quantum-neon-blue);
    color: #000;
    box-shadow: 0 0 25px var(--quantum-neon-blue);
    border-color: var(--quantum-neon-blue);
  }

  .quantum-btn--alert:hover {
    background: var(--quantum-neon-red);
    color: #fff;
    box-shadow: 0 0 30px var(--quantum-neon-red);
    border-color: var(--quantum-neon-red);
  }

  .container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    overflow: hidden;
    margin: 0;
    padding: 0;
    pointer-events: none;
    z-index: 3;
  }

  .watermark {
    display: none;
    position: fixed;
    bottom: 20px;
    left: 20px;
    width: 40px;
    height: 40px;
    opacity: 0.6;
    z-index: 10;
    pointer-events: none;
  }

  .watermark svg {
    width: 100%;
    height: 100%;
  }

  @keyframes quantumLogoIntro {
    0% {
      mask-position: 42% center;
      -webkit-mask-position: 42% center;
    }
    100% {
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  /* iOS/WebKit: animating mask + filtered WebGL in the same layer often tears or “replays” the first frames. */
  @media (hover: none) {
    .quantum-logo-stack {
      animation: none;
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  /* On phones the logo edges fall in the vignette's dark band, killing the
     effect. Push the falloff outward and lighten it so the tint stays visible. */
  @media screen and (max-width: 768px) {
    .quantum-vignette {
      background: radial-gradient(
        circle at center,
        transparent 55%,
        rgba(0, 0, 0, 0.6) 120%
      );
    }
  }

  @media screen and (min-width: 1024px) {
    .quantum-logo-stack {
      mask-size: min(88vmin, 94vw, 880px);
      -webkit-mask-size: min(88vmin, 94vw, 880px);
    }
  }

  @media screen and (min-width: 1440px) {
    .quantum-logo-stack {
      mask-size: min(84vmin, 92vw, 960px);
      -webkit-mask-size: min(84vmin, 92vw, 960px);
    }
  }

  @media screen and (min-width: 1920px) {
    .quantum-logo-stack {
      mask-size: min(80vmin, 90vw, 1040px);
      -webkit-mask-size: min(80vmin, 90vw, 1040px);
    }
  }

  @media screen and (min-width: 2560px) {
    .quantum-logo-stack {
      mask-size: min(76vmin, 88vw, 1180px);
      -webkit-mask-size: min(76vmin, 88vw, 1180px);
    }
  }
</style>

<script>
  import { attachQuantumCoreOpticalEngine } from "../lib/quantumCoreOpticalEngine";

  function prefersReducedMotion(): boolean {
    return (
      typeof matchMedia !== "undefined" &&
      matchMedia("(prefers-reduced-motion: reduce)").matches
    );
  }

  function init(): () => void {
    const host = document.getElementById("quantumCanvasHost");
    if (!host) return () => {};

    document.documentElement.classList.add("quantum-page-touch");
    document.body.classList.add("quantum-page-touch");

    let detach: (() => void) | undefined;

    const start = () => {
      detach = attachQuantumCoreOpticalEngine(host);
    };

    const touchUi =
      typeof matchMedia !== "undefined" &&
      (matchMedia("(pointer: coarse)").matches ||
        matchMedia("(hover: none)").matches);
    const delayMs = prefersReducedMotion() || touchUi ? 0 : 400;
    const delayId = window.setTimeout(start, delayMs);

    return () => {
      window.clearTimeout(delayId);
      detach?.();
      document.documentElement.classList.remove("quantum-page-touch");
      document.body.classList.remove("quantum-page-touch");
    };
  }

  let cleanup: (() => void) | undefined;

  function boot() {
    cleanup?.();
    cleanup = init();
    window.addEventListener(
      "pagehide",
      () => {
        cleanup?.();
        cleanup = undefined;
      },
      { once: true },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }
</script>
