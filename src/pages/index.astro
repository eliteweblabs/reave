---
import Layout from "../layouts/Layout.astro";
import VoiceChatButton from "../components/VoiceChatButton.astro";
import Transcript from "../components/Transcript.astro";
---

<Layout>
  <div class="page-lava-wrap" id="pageLavaWrap" aria-hidden="true">
    <div id="pageLava" class="page-lava"></div>
  </div>

  <!-- One masked copy of the same field (mask on the painted layer, not an empty box) -->
  <div class="logo-stack">
    <div class="page-lava page-lava--logo-cutout" aria-hidden="true"></div>
  </div>

  <VoiceChatButton position="center-bottom" />
  <Transcript />
  <div class="container">
    <div class="watermark">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
        <line
          x1="241.9"
          y1="170.2"
          x2="241.9"
          y2="318.2"
          fill="#fff"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></line>
        <line
          x1="165.6"
          y1="248.2"
          x2="314.6"
          y2="248.2"
          fill="#fff"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></line>
        <path
          d="M242.1,332.5v14.8c0,54.4,44.1,98.6,98.6,98.6s98.6-44.1,98.6-98.6-44.1-98.6-98.6-98.6h-12.8"
          fill="none"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></path>
        <path
          d="M241.4,152.4v-45.9c0-27.7-22.4-50.1-50.1-50.1s-60.1,22.4-60.1,50.1l-1,11.4,2,19.4-12.3-2-16.4,1c-27.7,0-50.1,34.4-50.1,62.1s22.4,50.1,50.1,50.1h48.4"
          fill="none"
          stroke="#fff"
          stroke-miterlimit="10"
          stroke-width="30"></path>
      </svg>
    </div>
  </div>
</Layout>

<style>
  /*
   * Defaults on :root only. Never set --bx* / --hue on `.page-lava` — that shadows
   * these values and kills motion (all blobs stuck at 50%,50%).
   */
  :global(:root) {
    --bx0: 50%;
    --by0: 50%;
    --bx1: 50%;
    --by1: 50%;
    --bx2: 50%;
    --by2: 50%;
    --bx3: 50%;
    --by3: 50%;
    --bx4: 50%;
    --by4: 50%;
    --bx5: 50%;
    --by5: 50%;
    --c0: #ff0080;
    --c1: #ff00ff;
    --c2: #00ffff;
    --c3: #00ff00;
    --c4: #ffff00;
    --c5: #ff0000;
    --hue: 0deg;
  }

  :global(html),
  :global(body) {
    min-height: 100%;
    background: rgb(6, 0, 12);
  }

  .page-lava-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    transform: scale(calc(1.1 + var(--audio-boost, 0) * 0.08));
    transform-origin: center center;
  }

  .logo-stack {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: visible;
  }

  .page-lava {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    background:
      radial-gradient(
        circle at var(--bx0) var(--by0),
        var(--c0) 0%,
        transparent 56%
      ),
      radial-gradient(
        circle at var(--bx1) var(--by1),
        var(--c1) 0%,
        transparent 56%
      ),
      radial-gradient(
        circle at var(--bx2) var(--by2),
        var(--c2) 0%,
        transparent 56%
      ),
      radial-gradient(
        circle at var(--bx3) var(--by3),
        var(--c3) 0%,
        transparent 56%
      ),
      radial-gradient(
        circle at var(--bx4) var(--by4),
        var(--c4) 0%,
        transparent 56%
      ),
      radial-gradient(
        circle at var(--bx5) var(--by5),
        var(--c5) 0%,
        transparent 56%
      ),
      radial-gradient(
        ellipse 115% 115% at 50% 50%,
        rgba(120, 40, 180, 0.32) 0%,
        rgba(35, 6, 55, 0.85) 55%,
        rgb(10, 0, 18) 100%
      );
    filter: blur(48px) saturate(1.42) hue-rotate(var(--hue));
    will-change: filter;
  }

  .page-lava-wrap .page-lava {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
  }

  .page-lava--logo-cutout {
    position: fixed;
    left: -10vw;
    top: -10vh;
    width: 120vw;
    height: 120vh;
    z-index: 0;
    mask-image: url("/logo-mask.svg");
    -webkit-mask-image: url("/logo-mask.svg");
    mask-size: contain;
    -webkit-mask-size: contain;
    mask-position: 42% center;
    -webkit-mask-position: 42% center;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
    mask-mode: alpha;
    -webkit-mask-mode: alpha;
    filter: blur(48px) saturate(1.42) hue-rotate(var(--hue))
      drop-shadow(0 0 18px rgba(255, 255, 255, 0.45))
      drop-shadow(0 0 36px rgba(255, 100, 200, 0.28));
    animation: logoMaskIntro 1.4s ease-out forwards;
  }

  .container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    overflow: hidden;
    margin: 0;
    padding: 0;
    pointer-events: none;
    z-index: 2;
  }

  .watermark {
    position: fixed;
    bottom: 20px;
    left: 20px;
    width: 40px;
    height: 40px;
    opacity: 0.6;
    z-index: 10;
    pointer-events: none;
  }

  .watermark svg {
    width: 100%;
    height: 100%;
  }

  @keyframes logoMaskIntro {
    0% {
      mask-position: 42% center;
      -webkit-mask-position: 42% center;
    }
    100% {
      mask-position: center center;
      -webkit-mask-position: center center;
    }
  }

  @media screen and (min-width: 1024px) {
    .page-lava--logo-cutout {
      mask-size: 600px 600px;
      -webkit-mask-size: 600px 600px;
    }
  }

  @media screen and (min-width: 1440px) {
    .page-lava--logo-cutout {
      mask-size: 800px 800px;
      -webkit-mask-size: 800px 800px;
    }
  }

  @media screen and (min-width: 1920px) {
    .page-lava--logo-cutout {
      mask-size: 1000px 1000px;
      -webkit-mask-size: 1000px 1000px;
    }
  }

  @media screen and (min-width: 2560px) {
    .page-lava--logo-cutout {
      mask-size: 1200px 1200px;
      -webkit-mask-size: 1200px 1200px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-lava,
    .page-lava--logo-cutout {
      filter: blur(36px) saturate(1.2) hue-rotate(var(--hue));
    }
  }
</style>

<script>
  import { attachMorphingPageLava } from "../lib/morphingPageLava";

  window.addEventListener(
    "audioLevel",
    ((event: CustomEvent<{ level: number }>) => {
      const wrap = document.getElementById("pageLavaWrap");
      if (!wrap || !event.detail || typeof event.detail.level !== "number") {
        return;
      }
      wrap.style.setProperty("--audio-boost", String(event.detail.level));
    }) as EventListener,
  );

  function init() {
    const params = new URLSearchParams(window.location.search);
    const lavaSeedRaw = params.get("lavaSeed");
    const lavaSeedParsed =
      lavaSeedRaw !== null ? Number.parseInt(lavaSeedRaw, 10) : NaN;

    attachMorphingPageLava({
      seed: Number.isFinite(lavaSeedParsed) ? lavaSeedParsed : undefined,
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
