---
import Layout from "../layouts/Layout.astro";
import QuantumLogo from "../components/QuantumLogo.astro";
import SiteFooterNav from "../components/SiteFooterNav.astro";

import { getCompanyConfig, homepageHeroMask, homepageHeroLogo } from "../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);
const heroLogo = homepageHeroLogo(company);
---

<Layout>
  {
    heroLogo && (
      <QuantumLogo
        heroMask={heroMask ?? undefined}
        logoSrc={heroLogo}
        layout="homepage"
      />
    )
  }
  <div class="quantum-vignette" aria-hidden="true"></div>

  <SiteFooterNav active="home" />
</Layout>

<style>
  /* Dark background default now lives in Layout.astro; keep min-height here. */
  :global(html),
  :global(body) {
    min-height: 100%;
  }

  /* Let drags reach the scene on iOS (otherwise Safari keeps scroll/rubber-band). */
  :global(html.quantum-page-touch),
  :global(html.quantum-page-touch body) {
    touch-action: none;
    overscroll-behavior: none;
  }

  .quantum-vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(
      circle at center,
      transparent 32%,
      rgba(0, 0, 0, 0.82) 100%
    );
  }

  @media screen and (max-width: 768px) {
    .quantum-vignette {
      background: radial-gradient(
        circle at center,
        transparent 42%,
        rgba(0, 0, 0, 0.72) 110%
      );
    }
  }
</style>
