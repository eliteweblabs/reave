---
/**
 * /dev/telegram — plain cheat-sheet of what to say to the Telegram bot.
 * A simpler companion to the os-map "Telegram" tab: just the commands and
 * example phrases, no node graph. noindex.
 */
export const prerender = true;

type Cmd = { say: string; does: string };
type Section = { title: string; note?: string; items: Cmd[] };

const slash: Cmd[] = [
  { say: '/help', does: 'Show the in-chat menu of commands + examples' },
  { say: '/list', does: 'List bundled knowledge docs (slugs)' },
  { say: '/get <slug>', does: 'Read a knowledge doc' },
  { say: '/resolve <name>  (or /who)', does: 'Fuzzy-find a client in contact-api' },
  { say: '/invoice <customer> | <amount> | <description>', does: 'Create a Crater invoice (description optional)' },
  { say: '/railway project <name>', does: 'Create a new empty Railway project' },
  { say: '/voice on|off', does: 'Enable or disable the AI phone agent for inbound Telnyx calls' },
  { say: '/calls', does: 'List active calls with caller, mode, and duration' },
  { say: '/takeover <phone>', does: 'Transfer that active call to TELNYX_OPERATOR_NUMBER (your phone)' },
  { say: '/clear  (or /reset)', does: 'Forget this chat’s conversation history' },
];

const sections: Section[] = [
  {
    title: 'Clients',
    items: [
      { say: '“List my contacts.”', does: 'See everyone, each with their portal link' },
      { say: '“Add a client named Jane Doe, email …, phone …”', does: 'Create a contact (or a test client)' },
      { say: '“What’s Jane’s portal link?”', does: 'Get one client’s shareable page link' },
      { say: '“Who is t. smith?”', does: 'Fuzzy lookup (typos / nicknames)' },
    ],
  },
  {
    title: 'Client portal',
    note: 'Every client already has a page at reave.app/c/<id>. These edit what’s on it.',
    items: [
      { say: '“Set Jane’s page headline … and body …”', does: 'Overview tab content' },
      { say: '“Add a field to Jane’s page: Plan → Annual.”', does: 'Labeled rows on Overview' },
      { say: '“Add Data to Jane: WordPress admin, user …, pass …”', does: 'Data tab (passwords/DNS/hosting)' },
      { say: '“Hide Jane’s page.” / “Re-enable Jane’s page.”', does: 'Revoke or restore the link' },
    ],
  },
  {
    title: 'Send to the client',
    items: [
      { say: '“Send Jane her link.”', does: 'Emails it (or texts, if no email on file)' },
      { say: '“Text Jane her portal link.”', does: 'Force SMS via Telnyx' },
    ],
  },
  {
    title: 'Billing (Crater)',
    items: [
      { say: '“Invoice Jane $100 for website work.”', does: 'Create a draft invoice' },
      { say: '“Who has an unpaid invoice?”', does: 'Find clients with a balance due' },
      { say: '“Record a $50 cash payment from Jane.”', does: 'Log an offline payment' },
      { say: '“List recent invoices.”', does: 'Recent invoices with totals + links' },
    ],
  },
  {
    title: 'Dev & deploy',
    items: [
      { say: '“Is the latest code live?”', does: 'Compare deployed commit vs GitHub + health ping' },
      { say: '“Show recent commits.” / “git status”', does: 'Repo state from GitHub' },
      { say: '“List open branches.”', does: 'In-progress work' },
      { say: '“Run a service status check.”', does: 'Which integrations are configured/reachable' },
    ],
  },
  {
    title: 'Voice & SMS (Telnyx)',
    note: 'TELNYX_API_KEY required. Voice agent must be enabled via /voice on or VOICE_AGENT_ENABLED=1.',
    items: [
      { say: '/voice on', does: 'Enable AI phone agent for inbound calls' },
      { say: '/voice off', does: 'Disable AI agent (callers hear unavailable message)' },
      { say: '/calls', does: 'List active calls with caller number, mode, and duration' },
      { say: '/takeover +1234567890', does: 'Transfer that call to TELNYX_OPERATOR_NUMBER' },
    ],
  },
  {
    title: 'Knowledge',
    items: [
      { say: '“What’s our email triage rule?”', does: 'Answers from bundled docs' },
      { say: '“Summarize the business OS overview.”', does: 'Reads + summarizes a doc' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Telegram bot — cheat sheet</title>
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: #0a0d14; color: #e9eef6; min-height: 100vh;
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      }
      a { color: #93c5fd; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 28px 20px calc(env(safe-area-inset-bottom) + 64px); }
      .head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
      h1 { font-size: 22px; margin: 0; }
      .sub { color: #8b97a8; font-size: 13px; margin-top: 4px; }
      h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.6px; color: #8b97a8; margin: 28px 0 10px; }
      .note { color: #8b97a8; font-size: 12px; margin: -4px 0 10px; }
      .list { display: flex; flex-direction: column; gap: 8px; }
      .row {
        background: #11151d; border: 1px solid #232c3a; border-radius: 12px; padding: 12px 14px;
      }
      .say { font-size: 15px; font-weight: 600; }
      .say code { background: #161b25; padding: 2px 6px; border-radius: 6px; font-size: 14px; }
      .does { color: #8b97a8; font-size: 13px; margin-top: 4px; }
      .tip { margin-top: 28px; color: #8b97a8; font-size: 13px; line-height: 1.6; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="head">
        <div>
          <h1>Telegram bot — what to say</h1>
          <div class="sub">Type a command, or just talk to it in plain English.</div>
        </div>
        <a href="/dev/os-map">OS map →</a>
      </div>

      <h2>Slash commands</h2>
      <div class="list">
        {slash.map((c) => (
          <div class="row">
            <div class="say"><code>{c.say}</code></div>
            <div class="does">{c.does}</div>
          </div>
        ))}
      </div>

      {sections.map((s) => (
        <>
          <h2>{s.title}</h2>
          {s.note && <div class="note">{s.note}</div>}
          <div class="list">
            {s.items.map((c) => (
              <div class="row">
                <div class="say">{c.say}</div>
                <div class="does">{c.does}</div>
              </div>
            ))}
          </div>
        </>
      ))}

      <p class="tip">
        Plain-English requests use Claude (needs <code>ANTHROPIC_API_KEY</code>) and keep recent chat
        history, so follow-ups like “yes, do it” work. Names are fuzzy-matched; if ambiguous the bot
        asks you to confirm.
        SMS uses Telnyx (<code>TELNYX_API_KEY</code> + <code>TELNYX_FROM_NUMBER</code>).
        Voice agent needs <code>TELNYX_WEBHOOK_PUBLIC_KEY</code> configured and webhook URL set in the Telnyx portal.
      </p>
    </main>
  </body>
</html>
