---
/**
 * Personal Business OS map (v2): interactive, Railway-style canvas.
 * /dashboard redirects here. Nodes/edges live in `public/dev/os-map-data.js`.
 * Tabs switch between the "System" runtime map and the "MCP & CLI" tooling map.
 * Drag cards (snap to grid), drag background to pan, wheel/±/Fit to zoom.
 */
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Business OS — map</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0a0d14;
        --grid: #1a2230;
        --fg: #e9eef6;
        --muted: #8b97a8;
        --card: #11151d;
        --card-border: #232c3a;
        --panel: #121722;
        --panel-border: #283142;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: var(--bg);
        color: var(--fg);
        overflow: hidden;
      }

      #wrap {
        position: fixed;
        inset: 0;
        overflow: hidden;
        cursor: grab;
        background-color: var(--bg);
        background-image: radial-gradient(circle at 1px 1px, var(--grid) 1.4px, transparent 0);
        background-size: 24px 24px;
        background-position: 0 0;
        touch-action: none;
      }
      #wrap.panning { cursor: grabbing; }

      #world {
        position: absolute;
        top: 0;
        left: 0;
        transform-origin: 0 0;
        width: 0;
        height: 0;
      }
      #edges {
        position: absolute;
        top: 0;
        left: 0;
        width: 6000px;
        height: 4200px;
        overflow: visible;
        pointer-events: none;
      }
      .edge { fill: none; stroke-width: 1.6; stroke-dasharray: 6 6; opacity: 0.85; }
      .edge.solid { stroke-dasharray: none; }

      .group {
        position: absolute;
        border: 1px solid hsl(var(--h) 45% 45% / 0.35);
        background: hsl(var(--h) 50% 50% / 0.05);
        border-radius: 16px;
        pointer-events: none;
      }
      .group > .g-label {
        position: absolute;
        top: -0.7rem;
        left: 0.9rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: hsl(var(--h) 70% 72%);
        background: var(--bg);
        padding: 0.1rem 0.5rem;
        border: 1px solid hsl(var(--h) 45% 45% / 0.4);
        border-radius: 7px;
        pointer-events: auto;
        cursor: grab;
        user-select: none;
      }
      .group > .g-label:hover { border-color: hsl(var(--h) 70% 60% / 0.8); }
      .group > .g-label.dragging { cursor: grabbing; }

      .elabel {
        position: absolute;
        transform: translate(-50%, -50%);
        font-size: 0.66rem;
        color: var(--muted);
        background: rgba(10, 13, 20, 0.82);
        padding: 0.05rem 0.32rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
      }

      .node {
        position: absolute;
        width: 210px;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-left: 3px solid hsl(var(--h) 75% 58%);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
        cursor: grab;
        user-select: none;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.02) inset,
          0 6px 20px rgba(0, 0, 0, 0.35),
          0 0 0 0 hsl(var(--h) 80% 55% / 0);
        transition: box-shadow 0.15s ease, border-color 0.15s ease;
      }
      .node:hover {
        border-color: hsl(var(--h) 75% 58% / 0.8);
        box-shadow:
          0 6px 22px rgba(0, 0, 0, 0.45),
          0 0 22px hsl(var(--h) 85% 55% / 0.28);
      }
      .node.dragging { cursor: grabbing; z-index: 50; }
      .node.ghost { opacity: 0.6; border-style: dashed; }

      .node .row { display: flex; align-items: center; gap: 0.45rem; }
      .node .chip {
        width: 1.5rem;
        height: 1.5rem;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        border-radius: 7px;
        background: hsl(var(--h) 70% 55% / 0.16);
        border: 1px solid hsl(var(--h) 70% 60% / 0.4);
      }
      /* Real brand logo (Simple Icons) tinted to the node hue via CSS mask. */
      .node .chip .bi {
        width: 0.95rem;
        height: 0.95rem;
        background-color: hsl(var(--h) 90% 72%);
        -webkit-mask: var(--icon) center / contain no-repeat;
        mask: var(--icon) center / contain no-repeat;
      }
      .node .ttl { font-size: 0.85rem; font-weight: 600; color: var(--fg); }
      .node .sub {
        margin-top: 0.2rem;
        font-size: 0.72rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .status {
        margin-top: 0.4rem;
        font-size: 0.7rem;
        color: var(--sc, #8b97a8);
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .node .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc, #8b97a8);
        box-shadow: 0 0 6px var(--sc, #8b97a8);
      }

      /* Status states (driven by /api/health) */
      .st-up { --sc: #3fb950; }
      .st-down { --sc: #f85149; }
      .st-degraded { --sc: #d29922; }
      .st-configured { --sc: #58a6ff; }
      .st-unconfigured { --sc: #6e7681; }
      .st-unknown { --sc: #6e7681; }
      .st-checking { --sc: #8b97a8; }
      .node .status.st-checking::before { animation: stpulse 1.1s ease-in-out infinite; }
      @keyframes stpulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
      }

      /* Top bar */
      #topbar {
        position: fixed;
        top: 0.7rem;
        left: 0.7rem;
        right: 0.7rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        pointer-events: none;
        z-index: 20;
      }
      #topbar .brand {
        pointer-events: auto;
        display: inline-flex;
        align-items: center;
        flex: 0 0 auto;
        line-height: 0;
      }
      #topbar .brand-icon { height: 1.7rem; width: auto; display: block; }
      #topbar .brand-logo { height: 1.4rem; width: auto; display: none; }
      @media (min-width: 640px) {
        #topbar .brand-icon { display: none; }
        #topbar .brand-logo { display: block; }
      }
      #topbar .note { font-size: 0.72rem; color: var(--muted); }

      /* Tabs */
      #tabs {
        display: flex;
        gap: 0.25rem;
        pointer-events: auto;
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        padding: 0.18rem;
      }
      #tabs button {
        pointer-events: auto;
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 7px;
        padding: 0.28rem 0.7rem;
        cursor: pointer;
      }
      #tabs button:hover { color: var(--fg); }
      #tabs button.active {
        color: var(--fg);
        background: #1b2230;
        border-color: var(--panel-border);
      }
      #topbar .note code { background: var(--panel); padding: 0.06rem 0.3rem; border-radius: 4px; }
      #topbar .spacer { flex: 1; }
      #topbar button {
        pointer-events: auto;
        font: inherit;
        font-size: 0.78rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        padding: 0.35rem 0.7rem;
        cursor: pointer;
      }
      #topbar button:hover { border-color: #4b5563; }

      /* Left toolbar */
      #tools {
        position: fixed;
        left: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        z-index: 20;
      }
      #tools button {
        width: 2.1rem;
        height: 2.1rem;
        display: grid;
        place-items: center;
        font-size: 1rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        cursor: pointer;
      }
      #tools button:hover { border-color: #58a6ff; color: #58a6ff; }

      /* Todo node: chip is the click-to-toggle zone */
      .node.todo-done .ttl { text-decoration: line-through; text-decoration-color: #3d4a5c; }
      .node.todo-done .chip { cursor: pointer; }
      .node:not(.todo-done) .chip { cursor: pointer; }

      /* Legend */
      #legend {
        position: fixed;
        right: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        max-width: 60vw;
        justify-content: flex-end;
        z-index: 20;
      }
      #legend .chip {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.7rem;
        color: var(--muted);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.2rem 0.55rem;
      }
      #legend .dot { width: 9px; height: 9px; border-radius: 50%; }
      #legend .st-key { color: var(--sc, var(--muted)); }
      #legend .st-key .st-dot {
        background: var(--sc, #6e7681);
        box-shadow: 0 0 5px var(--sc, transparent);
      }
      #health-checked {
        font-size: 0.68rem;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }
    </style>
  </head>
  <body>
    <div id="topbar">
      <a href="/" class="brand" aria-label="Reave">
        <img class="brand-icon" src="/favicon.svg" alt="Reave" width="128" height="128" />
        <img class="brand-logo" src="/reave-logo.png" alt="Reave" />
      </a>
      <div id="tabs"></div>
      <span class="note">
        ⚠️ Keep current — edit <code>public/dev/os-map-data.js</code> when the system changes.
      </span>
      <span class="spacer"></span>
      <span id="health-checked"></span>
      <button id="reset">Reset layout</button>
    </div>

    <div id="tools">
      <button data-act="in" title="Zoom in">+</button>
      <button data-act="out" title="Zoom out">−</button>
      <button data-act="fit" title="Fit to screen">⤢</button>
    </div>

    <div id="legend"></div>

    <div id="wrap">
      <div id="world">
        <svg id="edges" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <script is:inline type="module" src="/dev/os-map-loader.js"></script>
  </body>
</html>
