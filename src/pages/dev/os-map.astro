---
/**
 * Personal Business OS map (v2): interactive, Railway-style canvas.
 * /dashboard redirects here. Nodes/edges live in `public/dev/os-map-data.js`.
 * Tabs switch between the "System" runtime map and the "MCP & CLI" tooling map.
 * Drag cards (snap to grid), drag background to pan, wheel/±/Fit to zoom.
 */
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Business OS — map</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0a0d14;
        --grid: #1a2230;
        --fg: #e9eef6;
        --muted: #8b97a8;
        --card: #11151d;
        --card-border: #232c3a;
        --panel: #121722;
        --panel-border: #283142;
        --topbar-h: 3.4rem;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: var(--bg);
        color: var(--fg);
        overflow: hidden;
        touch-action: manipulation;
      }

      #wrap {
        position: fixed;
        inset: 0;
        overflow: hidden;
        cursor: grab;
        background-color: var(--bg);
        background-image: radial-gradient(circle at 1px 1px, var(--grid) 1.4px, transparent 0);
        background-size: 24px 24px;
        background-position: 0 0;
        touch-action: none;
      }
      #wrap.panning { cursor: grabbing; }

      #world {
        position: absolute;
        top: 0;
        left: 0;
        transform-origin: 0 0;
        width: 0;
        height: 0;
      }
      #edges {
        position: absolute;
        top: 0;
        left: 0;
        width: 6000px;
        height: 4200px;
        overflow: visible;
        pointer-events: none;
      }
      .edge { fill: none; stroke-width: 1.6; stroke-dasharray: 6 6; opacity: 0.85; }
      .edge.solid { stroke-dasharray: none; }

      .group {
        position: absolute;
        border: 1px solid hsl(var(--h) 45% 45% / 0.35);
        background: hsl(var(--h) 50% 50% / 0.05);
        border-radius: 16px;
        pointer-events: none;
      }
      .group > .g-label {
        position: absolute;
        top: -0.7rem;
        left: 0.9rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: hsl(var(--h) 70% 72%);
        background: var(--bg);
        padding: 0.1rem 0.5rem;
        border: 1px solid hsl(var(--h) 45% 45% / 0.4);
        border-radius: 7px;
        pointer-events: auto;
        cursor: grab;
        user-select: none;
      }
      .group > .g-label:hover { border-color: hsl(var(--h) 70% 60% / 0.8); }
      .group > .g-label.dragging { cursor: grabbing; }

      .elabel {
        position: absolute;
        transform: translate(-50%, -50%);
        font-size: 0.66rem;
        color: var(--muted);
        background: rgba(10, 13, 20, 0.82);
        padding: 0.05rem 0.32rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
      }

      .node {
        position: absolute;
        width: 210px;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-left: 3px solid hsl(var(--h) 75% 58%);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
        cursor: grab;
        user-select: none;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.02) inset,
          0 6px 20px rgba(0, 0, 0, 0.35),
          0 0 0 0 hsl(var(--h) 80% 55% / 0);
        transition: box-shadow 0.15s ease, border-color 0.15s ease;
      }
      .node:hover {
        border-color: hsl(var(--h) 75% 58% / 0.8);
        box-shadow:
          0 6px 22px rgba(0, 0, 0, 0.45),
          0 0 22px hsl(var(--h) 85% 55% / 0.28);
      }
      .node.dragging { cursor: grabbing; z-index: 50; }
      .node.ghost { opacity: 0.6; border-style: dashed; }

      .node .row { display: flex; align-items: center; gap: 0.45rem; }
      .node .chip {
        width: 1.5rem;
        height: 1.5rem;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        border-radius: 7px;
        background: hsl(var(--h) 70% 55% / 0.16);
        border: 1px solid hsl(var(--h) 70% 60% / 0.4);
      }
      /* Real brand logo (Simple Icons) tinted to the node hue via CSS mask. */
      .node .chip .bi {
        width: 0.95rem;
        height: 0.95rem;
        background-color: hsl(var(--h) 90% 72%);
        -webkit-mask: var(--icon) center / contain no-repeat;
        mask: var(--icon) center / contain no-repeat;
      }
      .node .ttl { font-size: 0.85rem; font-weight: 600; color: var(--fg); }
      .node .sub {
        margin-top: 0.2rem;
        font-size: 0.72rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .status {
        margin-top: 0.4rem;
        font-size: 0.7rem;
        color: var(--sc, #8b97a8);
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .node .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc, #8b97a8);
        box-shadow: 0 0 6px var(--sc, #8b97a8);
      }

      /* Status states (driven by /api/health) */
      .st-up { --sc: #3fb950; }
      .st-down { --sc: #f85149; }
      .st-degraded { --sc: #d29922; }
      .st-configured { --sc: #58a6ff; }
      .st-unconfigured { --sc: #6e7681; }
      .st-unknown { --sc: #6e7681; }
      .st-checking { --sc: #8b97a8; }
      .node .status.st-checking::before { animation: stpulse 1.1s ease-in-out infinite; }
      @keyframes stpulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
      }

      /* Top bar */
      #topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 0.7rem;
        pointer-events: none;
        z-index: 20;
        background: rgba(10, 13, 20, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(35, 44, 58, 0.5);
      }
      #topbar .brand {
        pointer-events: auto;
        display: inline-flex;
        align-items: center;
        flex: 0 0 auto;
        line-height: 0;
      }
      #topbar .brand-img { height: 1.4rem; width: auto; display: block; }
      #topbar .note { font-size: 0.72rem; color: var(--muted); }
      @media (max-width: 639px) {
        #topbar .note { display: none; }
      }

      /* Tabs */
      #tabs {
        display: flex;
        gap: 0.25rem;
        pointer-events: auto;
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        padding: 0.18rem;
      }
      #tabs button {
        pointer-events: auto;
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 7px;
        padding: 0.28rem 0.7rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      #tabs button:hover { color: var(--fg); }
      #tabs button.active {
        color: var(--fg);
        background: #1b2230;
        border-color: var(--panel-border);
      }
      .tab-icon { font-size: 0.9rem; line-height: 1; flex: 0 0 auto; }
      @media (max-width: 600px) {
        .tab-label { display: none; }
        #tabs button { padding: 0.28rem 0.5rem; }
      }
      #topbar .note code { background: var(--panel); padding: 0.06rem 0.3rem; border-radius: 4px; }
      #topbar .spacer { flex: 1; }
      #topbar button {
        pointer-events: auto;
        font: inherit;
        font-size: 0.78rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        padding: 0.35rem 0.7rem;
        cursor: pointer;
      }
      #topbar button:hover { border-color: #4b5563; }

      /* Left toolbar */
      #tools {
        position: fixed;
        left: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        z-index: 20;
      }
      #tools button {
        width: 2.1rem;
        height: 2.1rem;
        display: grid;
        place-items: center;
        font-size: 1rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        cursor: pointer;
      }
      #tools button:hover { border-color: #58a6ff; color: #58a6ff; }

      /* Todo node: chip is the click-to-toggle zone */
      .node.todo-done .ttl { text-decoration: line-through; text-decoration-color: #3d4a5c; }
      .node.todo-done .chip { cursor: pointer; }
      .node:not(.todo-done) .chip { cursor: pointer; }

      /* Legend */
      #legend {
        position: fixed;
        right: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        max-width: 60vw;
        justify-content: flex-end;
        z-index: 20;
      }
      #legend .chip {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.7rem;
        color: var(--muted);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.2rem 0.55rem;
      }
      #legend .dot { width: 9px; height: 9px; border-radius: 50%; }
      #legend .st-key { color: var(--sc, var(--muted)); }
      #legend .st-key .st-dot {
        background: var(--sc, #6e7681);
        box-shadow: 0 0 5px var(--sc, transparent);
      }
      #health-checked {
        font-size: 0.68rem;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
      }

      /* ── Documents editor tab ── */
      #doc-editor {
        position: fixed;
        inset: 0;
        top: var(--topbar-h);
        display: flex;
        flex-direction: row;
        background: var(--bg);
        z-index: 10;
      }

      .de-loading {
        margin: auto;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .de-error { color: #f85149; }

      /* Sidebar */
      .de-sidebar {
        width: 260px;
        flex: 0 0 260px;
        border-right: 1px solid var(--panel-border);
        display: flex;
        flex-direction: column;
        background: var(--panel);
        overflow: hidden;
      }

      /* Mobile: single-pane navigation */
      @media (max-width: 639px) {
        #doc-editor {
          flex-direction: column;
        }
        .de-sidebar {
          width: 100%;
          flex: 1 1 auto;
          border-right: none;
          border-bottom: 1px solid var(--panel-border);
        }
        .de-pane {
          display: none;
        }
        /* When a document is open on mobile, hide sidebar and show pane */
        #doc-editor.de-pane-active .de-sidebar {
          display: none;
        }
        #doc-editor.de-pane-active .de-pane {
          display: flex;
          flex: 1 1 auto;
        }
      }
      .de-new-btn {
        margin: 0.7rem;
        padding: 0.45rem 0.8rem;
        font: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--fg);
        background: #1e3a5f;
        border: 1px solid #2d5a94;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        flex: 0 0 auto;
      }
      .de-new-btn:hover { background: #265080; border-color: #3a72b8; }

      .de-list {
        flex: 1;
        overflow-y: auto;
        padding: 0 0.5rem 0.5rem;
      }
      .de-empty {
        padding: 0.8rem 0.4rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .de-list-item {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
        padding: 0.55rem 0.65rem;
        font: inherit;
        font-size: 0.8rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        margin-bottom: 0.15rem;
      }
      .de-list-item:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .de-list-item.active { color: var(--fg); background: #11253d; border-color: #2d5a94; }
      .de-item-title { font-weight: 600; font-size: 0.82rem; color: inherit; }
      .de-item-slug { font-size: 0.69rem; color: var(--muted); font-family: ui-monospace, monospace; }

      /* Editor pane */
      .de-pane {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 0;
      }
      .de-placeholder {
        margin: auto;
        text-align: center;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .de-placeholder-icon { font-size: 2.5rem; margin-bottom: 0.6rem; }

      .de-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem 0.6rem;
        border-bottom: 1px solid var(--panel-border);
        flex: 0 0 auto;
      }
      .de-back-btn {
        display: none;
        font: inherit;
        font-size: 0.8rem;
        color: #58a6ff;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.1rem 0.2rem;
        flex: 0 0 auto;
      }
      @media (max-width: 639px) {
        .de-back-btn { display: inline-flex; align-items: center; gap: 0.25rem; }
        .de-doc-name { font-size: 0.88rem; }
      }
      .de-doc-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--fg);
      }
      .de-doc-slug {
        font-size: 0.72rem;
        color: var(--muted);
        font-family: ui-monospace, monospace;
      }

      .de-fields {
        padding: 0.7rem 1rem 0;
        flex: 0 0 auto;
      }
      .de-label {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        font-size: 0.78rem;
        color: var(--muted);
        font-weight: 600;
      }
      .de-input {
        font: inherit;
        font-size: 0.84rem;
        font-family: ui-monospace, monospace;
        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 7px;
        padding: 0.4rem 0.6rem;
        outline: none;
        width: 100%;
        max-width: 340px;
      }
      .de-input:focus { border-color: #3b82f6; }

      .de-textarea {
        flex: 1;
        resize: none;
        margin: 0.6rem 1rem;
        padding: 0.7rem 0.9rem;
        font: 0.83rem/1.6 ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
        color: #c9d1d9;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 9px;
        outline: none;
        tab-size: 2;
        white-space: pre;
        overflow-wrap: normal;
        overflow-x: auto;
      }
      .de-textarea:focus { border-color: #3b82f6; }

      .de-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 1rem;
        border-top: 1px solid var(--panel-border);
        flex: 0 0 auto;
      }
      .de-btn {
        font: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 0.38rem 0.9rem;
        cursor: pointer;
        border: 1px solid transparent;
      }
      .de-btn:disabled { opacity: 0.45; cursor: default; }
      .de-btn-primary {
        color: #fff;
        background: #2563eb;
        border-color: #3b82f6;
      }
      .de-btn-primary:not(:disabled):hover { background: #1d4ed8; }
      .de-btn-ghost {
        color: var(--muted);
        background: transparent;
        border-color: var(--panel-border);
      }
      .de-btn-ghost:hover { color: var(--fg); border-color: #4b5563; }
      .de-btn-danger {
        color: #f85149;
        background: transparent;
        border-color: #f8514940;
      }
      .de-btn-danger:hover { background: #f8514915; border-color: #f85149; }
    </style>
  </head>
  <body>
    <div id="topbar">
      <a href="/" class="brand" aria-label="Reave">
        <img class="brand-img" src="/reave-logo.png" alt="Reave" />
      </a>
      <div id="tabs"></div>
      <span class="note">
        ⚠️ Keep current — edit <code>public/dev/os-map-data.js</code> when the system changes.
      </span>
      <span class="spacer"></span>
      <span id="health-checked"></span>
    </div>

    <div id="tools">
      <button data-act="in" title="Zoom in">+</button>
      <button data-act="out" title="Zoom out">−</button>
      <button data-act="fit" title="Fit to screen">⤢</button>
    </div>

    <div id="legend"></div>

    <div id="wrap">
      <div id="world">
        <svg id="edges" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <!-- Documents tab panel (hidden unless documents tab is active) -->
    <div id="doc-editor" style="display:none"></div>

    <script is:inline type="module" src="/dev/os-map-loader.js"></script>
  </body>
</html>
