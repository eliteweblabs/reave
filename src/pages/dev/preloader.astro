---
import Favicon from '../../components/Favicon.astro';
import Preloader from '../../components/Preloader.astro';
import { getCompanyConfig, homepageHeroMask } from '../../lib/companyConfig';

export const prerender = false;

const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Preloader</title>
    <Favicon />
  </head>
  <body>
    <Preloader heroMask={heroMask} fallbackName={company.name} persist />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    height: 100%;
    background: #050505;
  }
</style>
