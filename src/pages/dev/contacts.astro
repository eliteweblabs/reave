---
/**
 * /dev/contacts — visualization of the master contact database (contact-api).
 *
 * SENSITIVE: lists every client (PII + links through to portal credentials), so
 * it is gated behind DASHBOARD_KEY. Provide the key once via ?key=… (stored in
 * an httpOnly cookie) or it stays locked. noindex; never prerendered.
 */
export const prerender = false;

import { listContacts, clientPortalUrl, type ContactRecord } from '../../lib/contactApi';
import { serverEnv } from '../../lib/serverEnv';

const COOKIE = 'dev_contacts_key';
const expectedKey = serverEnv('DASHBOARD_KEY')?.trim() || '';

const queryKey = Astro.url.searchParams.get('key')?.trim() || '';
const cookieKey = Astro.cookies.get(COOKIE)?.value || '';

let authorized = false;
let lockReason = '';

if (!expectedKey) {
  lockReason = 'DASHBOARD_KEY is not set on the server. Set it to enable this dashboard.';
} else if (queryKey && queryKey === expectedKey) {
  Astro.cookies.set(COOKIE, queryKey, {
    httpOnly: true,
    sameSite: 'lax',
    secure: Astro.url.protocol === 'https:',
    path: '/dev',
    maxAge: 60 * 60 * 24 * 30,
  });
  authorized = true;
} else if (cookieKey && cookieKey === expectedKey) {
  authorized = true;
} else if (queryKey) {
  lockReason = 'Incorrect key.';
}

let contacts: ContactRecord[] = [];
let total = 0;
let loadError = '';

if (authorized) {
  const res = await listContacts({ limit: 200 });
  if (res.ok) {
    contacts = res.data.contacts;
    total = res.data.total;
  } else {
    loadError = res.error;
  }
}

if (!authorized) Astro.response.status = 401;

const stats = {
  shown: contacts.length,
  withEmail: contacts.filter((c) => c.email?.trim()).length,
  withPhone: contacts.filter((c) => c.phone?.trim()).length,
  withCompany: contacts.filter((c) => c.company?.trim()).length,
};
const fmtDate = (s?: string | null) => {
  if (!s) return '';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '' : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Master contacts</title>
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: #0a0d14; color: #e9eef6; min-height: 100vh;
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      }
      a { color: #93c5fd; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 28px 20px 80px; }
      .head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
      h1 { font-size: 22px; margin: 0; }
      .sub { color: #8b97a8; font-size: 13px; }

      .gate { max-width: 380px; margin: 14vh auto 0; text-align: center; }
      .gate h1 { margin-bottom: 8px; }
      .gate p { color: #8b97a8; font-size: 14px; line-height: 1.6; }
      .gate form { margin-top: 18px; display: flex; gap: 8px; }
      .gate input {
        flex: 1; padding: 12px 14px; border-radius: 10px; border: 1px solid #283142;
        background: #11151d; color: #fff; font: inherit;
      }
      .gate button {
        padding: 12px 18px; border-radius: 10px; border: none; cursor: pointer;
        background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; font: inherit; font-weight: 600;
      }
      .err { color: #fca5a5; font-size: 13px; margin-top: 10px; }

      .stats { display: flex; flex-wrap: wrap; gap: 10px; margin: 18px 0 14px; }
      .stat {
        background: #11151d; border: 1px solid #232c3a; border-radius: 12px;
        padding: 10px 16px; min-width: 110px;
      }
      .stat .n { font-size: 22px; font-weight: 700; }
      .stat .l { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #8b97a8; }

      .search {
        width: 100%; padding: 12px 14px; margin-bottom: 16px; border-radius: 10px;
        border: 1px solid #283142; background: #11151d; color: #fff; font: inherit;
      }

      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 12px; }
      .card {
        background: #11151d; border: 1px solid #232c3a; border-radius: 14px; padding: 14px 16px;
        display: flex; flex-direction: column; gap: 6px;
      }
      .card .name { font-size: 16px; font-weight: 600; }
      .card .company { font-size: 13px; color: #8b97a8; }
      .card .meta { font-size: 13px; color: #c7d0dc; word-break: break-word; }
      .card .meta a { text-decoration: none; }
      .card .when { font-size: 11px; color: #6e7681; margin-top: 2px; }
      .card .links { display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; }
      .card .links a {
        font-size: 12px; text-decoration: none; padding: 5px 10px; border-radius: 8px;
        border: 1px solid #283142; background: #161b25; color: #cbd5e1;
      }
      .card .links a:hover { border-color: #4b5563; color: #fff; }
      .empty-note { color: #8b97a8; margin-top: 20px; }
      .no-match { color: #8b97a8; display: none; margin-top: 20px; }
    </style>
  </head>
  <body>
    {
      !authorized ? (
        <main class="wrap">
          <div class="gate">
            <h1>Master contacts</h1>
            <p>{lockReason || 'Enter the dashboard key to continue.'}</p>
            {expectedKey && (
              <form method="get" action="/dev/contacts">
                <input type="password" name="key" placeholder="Dashboard key" autocomplete="off" autofocus />
                <button type="submit">Unlock</button>
              </form>
            )}
            {lockReason === 'Incorrect key.' && <div class="err">That key didn’t work.</div>}
          </div>
        </main>
      ) : (
        <main class="wrap">
          <div class="head">
            <div>
              <h1>Master contacts</h1>
              <div class="sub">contact-api · contact-postgres</div>
            </div>
            <a href="/dev/os-map">← OS map</a>
          </div>

          {loadError ? (
            <p class="empty-note">Couldn’t load contacts: {loadError}</p>
          ) : (
            <>
              <div class="stats">
                <div class="stat"><div class="n">{total}</div><div class="l">Total</div></div>
                <div class="stat"><div class="n">{stats.withCompany}</div><div class="l">Company</div></div>
                <div class="stat"><div class="n">{stats.withEmail}</div><div class="l">Email</div></div>
                <div class="stat"><div class="n">{stats.withPhone}</div><div class="l">Phone</div></div>
                {total > stats.shown && (
                  <div class="stat"><div class="n">{stats.shown}</div><div class="l">Shown</div></div>
                )}
              </div>

              <input id="search" class="search" type="search" placeholder="Search name, company, email, phone…" autocomplete="off" />

              <div class="grid" id="grid">
                {contacts.map((c) => {
                  const portal = clientPortalUrl(c.uid);
                  const search = [c.name, c.company, c.email, c.phone].filter(Boolean).join(' ').toLowerCase();
                  return (
                    <div class="card" data-search={search}>
                      <div class="name">{c.name}</div>
                      {c.company && <div class="company">{c.company}</div>}
                      {c.email && <div class="meta"><a href={`mailto:${c.email}`}>{c.email}</a></div>}
                      {c.phone && <div class="meta"><a href={`tel:${c.phone.replace(/[^\d+]/g, '')}`}>{c.phone}</a></div>}
                      {c.updatedAt && <div class="when">Updated {fmtDate(c.updatedAt)}</div>}
                      <div class="links">
                        <a href={portal} target="_blank" rel="noopener noreferrer">Portal</a>
                        <a href={`/c/${encodeURIComponent(c.uid)}.vcf`}>vCard</a>
                        <a href={`/c/${encodeURIComponent(c.uid)}/note.txt`} target="_blank" rel="noopener noreferrer">Notes</a>
                      </div>
                    </div>
                  );
                })}
              </div>
              <p class="no-match" id="noMatch">No contacts match your search.</p>
              {contacts.length === 0 && <p class="empty-note">No contacts yet.</p>}
            </>
          )}
        </main>
      )
    }

    <script>
      const search = document.getElementById('search') as HTMLInputElement | null;
      const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid .card'));
      const noMatch = document.getElementById('noMatch');
      search?.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        let visible = 0;
        for (const card of cards) {
          const hay = card.getAttribute('data-search') || '';
          const show = !q || hay.includes(q);
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (noMatch) noMatch.style.display = visible === 0 && cards.length > 0 ? 'block' : 'none';
      });
    </script>
  </body>
</html>
