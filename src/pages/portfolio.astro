---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import PortfolioMasonry from "../components/PortfolioMasonry.astro";
import { getCompanyConfig } from "../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
---

<MarketingLayout
  title="Portfolio"
  description="Selected work including WordPress builds, custom web apps, brand design and more. 20+ years, nearly 100 brand portfolios."
  label="Recent Work"
  active="portfolio"
>
  <section>
    <h2>Selected Projects</h2>
    <p>
      Much of the work from the last ten years is under copyright but available for private viewing.
      Full case studies and references are available on request —{" "}
      <a href="/contact">get in touch</a> to learn more.
    </p>
  </section>

  <section class="section--full-bleed">
    <PortfolioMasonry />
  </section>

  <section>
    <h2>There's More</h2>
    <p>
      I have developed dozens of scripts, training videos, and concepts not displayed here —
      including a Drag &amp; Drop Floorplan Builder, Custom Admin Dashboard, Proposal System, QR
      Code Shipping Manager, Digital Contract Module, and much more.
    </p>
    <p>
      <a href="/contact">Wanna see? Get in touch.</a>
    </p>
  </section>
</MarketingLayout>
