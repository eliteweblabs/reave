---
/**
 * /deck — scroll-snap sales narrative.
 * Left: scene copy. Right (sm+): section nav controller.
 */
import Favicon from '../components/Favicon.astro';
import Header from '../components/Header.astro';
import { assertDeckScript } from '../deck/validate';
import { getCompanyConfig, homepageHeroMask } from '../lib/companyConfig';
import everythingRaw from '../deck/scripts/everything.json';
import {
  Home,
  Bell,
  Calendar,
  Mic,
  Users,
  Mail,
  Briefcase,
  FileText,
  BookOpen,
  Monitor,
  Wallet,
  type LucideIcon,
} from 'lucide-astro';

export const prerender = false;

const script = assertDeckScript(everythingRaw);
const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);

/** Same Lucide set as admin header/footer nav, mapped to deck sections. */
const DOCK_ICONS: Record<string, LucideIcon> = {
  homepage: Home,
  pwa: Bell,
  scheduling: Calendar,
  voice: Mic,
  clients: Users,
  inbox: Mail,
  work: Briefcase,
  documents: FileText,
  knowledge: BookOpen,
  monitoring: Monitor,
  billing: Wallet,
};

const DOCK_LABELS: Record<string, string> = {
  homepage: 'Homepage',
  pwa: 'PWA alerts',
  scheduling: 'Scheduling',
  voice: 'Voice',
  clients: 'Clients',
  inbox: 'Inbox',
  work: 'Work',
  documents: 'Documents',
  knowledge: 'Knowledge',
  monitoring: 'Monitoring',
  billing: 'Billing',
};

const sections = script.sections.map((section) => {
  const feature = section.features[0];
  return {
    id: section.id,
    label: DOCK_LABELS[section.id] ?? section.title,
    featureTitle: feature?.title ?? section.title,
    featureBody: feature?.body ?? section.summary ?? '',
  };
});

const deckPayload = { sections: sections.map((s) => ({ id: s.id })) };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{script.title} | {company.name}</title>
    <meta
      name="description"
      content="See the Business OS in motion — design first, then how every piece interacts."
    />
    <Favicon />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <div id="boot" aria-hidden="true">
      {
        heroMask ? (
          <div
            class="boot-logo-stack"
            style={`--hero-logo-mask: url("${heroMask}")`}
            aria-hidden="true"
          >
            <div id="bootQuantumHost" class="boot-quantum-host"></div>
          </div>
        ) : (
          <div class="boot-logo-fallback" aria-hidden="true">{company.name}</div>
        )
      }
      <div class="boot-bar-wrap">
        <div class="boot-bar"><div class="boot-fill" id="boot-fill"></div></div>
      </div>
    </div>

    <nav id="dock-wrap" aria-label="Deck sections">
      <div id="dock">
        {
          sections.map((s, i) => {
            const Icon = DOCK_ICONS[s.id] ?? Home;
            return (
              <>
                {i === 2 && <div class="d-sep" aria-hidden="true" />}
                <button
                  type="button"
                  class="d-item"
                  id={`d-${s.id}`}
                  data-app={s.id}
                  aria-label={s.label}
                >
                  <span class={`ico ico-${s.id}`} aria-hidden="true">
                    <Icon size={22} strokeWidth={1.75} />
                  </span>
                  <span class="d-dot" aria-hidden="true"></span>
                  <span class="d-tooltip" role="tooltip">{s.label}</span>
                </button>
              </>
            );
          })
        }
      </div>
    </nav>

    <main id="scroll-track" data-deck-scroll>
      {
        sections.map((s, i) => (
          <section
            class:list={['deck-scene', { 'deck-scene--lead': i === 0 }]}
            id={`scene-${s.id}`}
            data-deck-scene={s.id}
          >
            <div class="deck-scene-copy">
              <p class="deck-scene-kicker">{s.label}</p>
              <h2 class="deck-scene-title">{s.featureTitle}</h2>
              <p class="deck-scene-body">{s.featureBody}</p>
            </div>
          </section>
        ))
      }
    </main>

    <script id="deck-data" type="application/json" set:html={JSON.stringify(deckPayload)} />

    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --dock-bg: rgba(30, 30, 34, 0.5);
        --accent: #5eead4;
        --text: #e8eef8;
        --border: rgba(255, 255, 255, 0.1);
        --font: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        --display: 'Syne', ui-sans-serif, system-ui, sans-serif;
      }
      html,
      body {
        width: 100%;
        height: 100dvh;
        max-height: 100dvh;
        margin: 0;
        overflow: hidden;
        font-family: var(--font);
        color: var(--text);
        background: #07090e;
        cursor: default;
      }
      body {
        background-image:
          radial-gradient(ellipse 80% 60% at 18% 85%, rgba(94, 234, 212, 0.14) 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at 85% 15%, rgba(56, 189, 248, 0.1) 0%, transparent 55%),
          radial-gradient(ellipse 40% 40% at 50% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);
      }

      .app-header {
        z-index: 7000;
      }

      #boot {
        position: fixed;
        inset: 0;
        background: #050505;
        z-index: 100000;
        transition: opacity 0.7s ease;
      }
      .boot-logo-stack {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
        -webkit-mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
        mask-size: 210px;
        -webkit-mask-size: 210px;
        mask-position: center calc(50% - 28px);
        -webkit-mask-position: center calc(50% - 28px);
        mask-repeat: no-repeat;
        -webkit-mask-repeat: no-repeat;
        mask-mode: alpha;
        -webkit-mask-mode: alpha;
        filter: drop-shadow(0 0 14px rgba(255, 255, 255, 0.4))
          drop-shadow(0 0 28px rgba(255, 100, 200, 0.24));
      }
      .boot-quantum-host {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      .boot-quantum-host canvas {
        display: block;
        width: 100% !important;
        height: 100% !important;
      }
      .boot-logo-fallback {
        position: absolute;
        left: 50%;
        top: calc(50% - 40px);
        transform: translate(-50%, -50%);
        max-width: 210px;
        font-family: var(--display);
        font-weight: 800;
        font-size: 1.35rem;
        letter-spacing: -0.03em;
        text-align: center;
        color: rgba(255, 255, 255, 0.85);
      }
      .boot-bar-wrap {
        position: absolute;
        left: 50%;
        top: calc(50% + 96px);
        transform: translateX(-50%);
      }
      .boot-bar {
        width: 180px;
        height: 5px;
        background: #222;
        border-radius: 3px;
        overflow: hidden;
      }
      .boot-fill {
        height: 100%;
        width: 0;
        background: #fff;
        border-radius: 3px;
        transition: width 2.4s ease-in-out;
      }

      #scroll-track {
        position: fixed;
        inset: 0;
        z-index: 10;
        height: 100dvh;
        overflow-x: hidden;
        overflow-y: auto;
        scroll-snap-type: y mandatory;
        scroll-behavior: smooth;
        overscroll-behavior: none;
        -webkit-overflow-scrolling: touch;
      }
      .deck-scene {
        box-sizing: border-box;
        height: 100dvh;
        min-height: 100dvh;
        max-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding:
          calc(var(--app-header-h, 4rem) + env(safe-area-inset-top, 0px) + 1.25rem)
          clamp(1rem, 4vw, 2.5rem)
          5.5rem;
        scroll-snap-align: start;
        scroll-snap-stop: always;
      }
      @media (min-width: 640px) {
        .deck-scene {
          padding-right: calc(88px + clamp(1rem, 4vw, 2.5rem));
        }
        .deck-scene-copy {
          max-width: min(34rem, calc(100% - 7rem));
        }
      }
      .deck-scene-copy {
        max-width: 34rem;
        pointer-events: none;
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.45s ease,
          transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .deck-scene.is-active .deck-scene-copy {
        opacity: 1;
        transform: translateY(0);
      }
      .deck-scene-kicker {
        margin: 0 0 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
      }
      .deck-scene-title {
        margin: 0 0 0.75rem;
        font-family: var(--display);
        font-size: clamp(1.45rem, 3.2vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        color: #f4f7fb;
      }
      .deck-scene-body {
        margin: 0;
        font-size: 1.02rem;
        line-height: 1.55;
        color: rgba(233, 238, 246, 0.72);
      }

      #dock-wrap {
        position: fixed;
        bottom: 10px;
        left: 0;
        right: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        z-index: 6000;
        padding: 40px 12px 0;
        overflow: visible;
        pointer-events: none;
      }
      #dock {
        pointer-events: auto;
        background: var(--dock-bg);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid var(--border);
        height: 68px;
        padding: 6px 10px;
        border-radius: 18px;
        display: flex;
        flex-direction: row;
        align-items: flex-end;
        gap: 6px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
        max-width: 100%;
        overflow: visible;
      }
      .d-item {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        position: relative;
        cursor: pointer;
        border: 0;
        padding: 0;
        background: transparent;
        color: #fff;
        transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), margin 0.2s ease;
        flex-shrink: 0;
        overflow: visible;
      }
      .d-item:hover {
        transform: scale(1.18) translateY(-8px);
        margin: 0 4px;
        z-index: 2;
      }
      .d-item:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }
      .d-item:focus-visible .d-tooltip,
      .d-item:hover .d-tooltip {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .d-dot {
        width: 4px;
        height: 4px;
        background: rgba(255, 255, 255, 0.45);
        border-radius: 50%;
        position: absolute;
        bottom: -7px;
        left: 50%;
        transform: translateX(-50%);
        display: none;
      }
      .d-item.active .ico {
        box-shadow:
          0 0 0 2px rgba(94, 234, 212, 0.95),
          0 0 18px rgba(94, 234, 212, 0.35);
        transform: scale(1.04);
      }
      .d-item.active .d-dot {
        display: block;
        background: var(--accent);
      }
      .d-sep {
        width: 1px;
        height: 36px;
        background: rgba(255, 255, 255, 0.18);
        margin: 0 4px;
        flex-shrink: 0;
        align-self: center;
      }
      .d-tooltip {
        position: absolute;
        bottom: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%) translateY(4px);
        background: rgba(20, 22, 28, 0.96);
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: var(--text);
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        border: 1px solid var(--border);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.35);
        z-index: 5;
        transition:
          opacity 0.15s ease,
          transform 0.15s ease,
          visibility 0.15s ease;
      }

      @media (min-width: 640px) {
        #dock-wrap {
          top: 0;
          bottom: 0;
          left: auto;
          right: 10px;
          width: auto;
          height: 100%;
          align-items: center;
          justify-content: center;
          padding: 72px 0 16px;
        }
        #dock {
          flex-direction: column;
          align-items: center;
          height: auto;
          max-height: calc(100dvh - 96px);
          width: 68px;
          padding: 10px 6px;
          overflow-y: auto;
          overflow-x: visible;
        }
        .d-item:hover {
          transform: scale(1.14) translateX(-6px);
          margin: 4px 0;
        }
        .d-item:focus-visible .d-tooltip,
        .d-item:hover .d-tooltip {
          transform: translateY(-50%) translateX(0);
        }
        .d-dot {
          bottom: 50%;
          left: auto;
          right: -7px;
          transform: translateY(50%);
        }
        .d-sep {
          width: 36px;
          height: 1px;
          margin: 4px 0;
        }
        .d-tooltip {
          bottom: auto;
          top: 50%;
          left: auto;
          right: calc(100% + 12px);
          transform: translateY(-50%) translateX(4px);
        }
      }
      .ico {
        width: 100%;
        height: 100%;
        border-radius: 13px;
        display: grid;
        place-items: center;
        color: #fff;
      }
      .ico svg {
        display: block;
        pointer-events: none;
      }
      .ico-homepage { background: linear-gradient(135deg, #5eead4, #38bdf8); color: #041016; }
      .ico-pwa { background: linear-gradient(135deg, #f472b6, #fb7185); }
      .ico-scheduling { background: linear-gradient(135deg, #34d399, #10b981); }
      .ico-voice { background: linear-gradient(135deg, #a78bfa, #818cf8); }
      .ico-clients { background: linear-gradient(135deg, #38bdf8, #0ea5e9); }
      .ico-inbox { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1c1408; }
      .ico-work { background: linear-gradient(135deg, #94a3b8, #64748b); }
      .ico-documents { background: linear-gradient(135deg, #67e8f9, #22d3ee); color: #042f2e; }
      .ico-knowledge { background: linear-gradient(135deg, #c4b5fd, #a78bfa); }
      .ico-monitoring { background: linear-gradient(135deg, #4ade80, #22c55e); color: #052e16; }
      .ico-billing { background: linear-gradient(135deg, #fde68a, #fbbf24); color: #1c1408; }

      @media (max-width: 639px) {
        #dock {
          height: 58px;
          padding: 4px 8px;
        }
        .d-item {
          width: 44px;
          height: 44px;
        }
      }
    </style>

    <script src="/deck/deck-nav.js" defer></script>
    <script>
      import { attachQuantumCoreOpticalEngine } from '../lib/quantumCoreOpticalEngine';

      const host = document.getElementById('bootQuantumHost');
      if (host) {
        const detach = attachQuantumCoreOpticalEngine(host);
        const boot = document.getElementById('boot');
        const parent = boot?.parentElement;
        if (parent) {
          const obs = new MutationObserver(() => {
            if (!document.getElementById('boot')) {
              detach();
              obs.disconnect();
            }
          });
          obs.observe(parent, { childList: true });
        }
      }
    </script>
  </body>
</html>
