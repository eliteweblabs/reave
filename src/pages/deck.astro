---
/**
 * /deck — macOS-style desktop sales experience.
 * Sections from everything.json open as draggable windows;
 * each shows a recorded GIF mapped into a device frame.
 */
import Favicon from '../components/Favicon.astro';
import { assertDeckScript } from '../deck/validate';
import { getCompanyConfig } from '../lib/companyConfig';
import everythingRaw from '../deck/scripts/everything.json';

export const prerender = false;

const script = assertDeckScript(everythingRaw);
const company = await getCompanyConfig(Astro.request);

const DOCK_ICONS: Record<string, string> = {
  homepage: 'home',
  pwa: 'bell',
  scheduling: 'calendar',
  voice: 'mic',
  clients: 'users',
  inbox: 'mail',
  work: 'briefcase',
  documents: 'file',
  knowledge: 'book',
  monitoring: 'activity',
  billing: 'dollar',
};

const sections = script.sections.map((section, i) => {
  const feature = section.features[0];
  const setAction = feature?.actions.find((a) => a.type === 'stage.set');
  const gif = setAction && setAction.type === 'stage.set' ? setAction.gif : undefined;
  const device =
    setAction && setAction.type === 'stage.set'
      ? setAction.device ?? (setAction.surface === 'desktop' ? 'laptop' : 'phone-hand')
      : 'phone-hand';
  return {
    id: section.id,
    name: section.title,
    summary: section.summary ?? '',
    featureTitle: feature?.title ?? section.title,
    featureBody: feature?.body ?? '',
    gif: gif ?? `/deck/gifs/${section.id}.gif`,
    device,
    icon: DOCK_ICONS[section.id] ?? 'app',
    w: device === 'laptop' ? 720 : 520,
    h: device === 'laptop' ? 520 : 640,
    top: 48 + (i % 4) * 28,
    left: 48 + (i % 5) * 36,
  };
});

const deckPayload = {
  companyName: company.name,
  sections,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{script.title} | {company.name}</title>
    <meta
      name="description"
      content="See the Business OS in motion — design first, then how every piece interacts."
    />
    <Favicon />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="boot" aria-hidden="true">
      <div class="boot-mark">{company.name.slice(0, 1)}</div>
      <div class="boot-name">{company.name}</div>
      <div class="boot-bar"><div class="boot-fill" id="boot-fill"></div></div>
    </div>

    <div id="desktop">
      <div id="menubar">
        <div class="bar-l">
          <div class="bar-item bar-brand">{company.name}</div>
          <div class="bar-item" id="app-name">Desktop</div>
          <div class="bar-item hide-m">File</div>
          <div class="bar-item hide-m">Edit</div>
          <div class="bar-item hide-m">View</div>
          <div class="bar-item hide-m">Window</div>
        </div>
        <div class="bar-r">
          <a class="bar-item" href="/">Home</a>
          <a class="bar-item" href="/sign-in">Sign in</a>
          <div class="bar-item" id="clock"></div>
        </div>
      </div>

      <div id="wins"></div>

      <div id="ctx" hidden>
        {
          sections.slice(0, 6).map((s) => (
            <button type="button" class="ctx-i" data-app={s.id}>
              Open {s.name}
            </button>
          ))
        }
      </div>

      <div id="dock-wrap">
        <div id="dock">
          {
            sections.map((s, i) => (
              <>
                {i === 2 && <div class="d-sep" aria-hidden="true" />}
                <button type="button" class="d-item" id={`d-${s.id}`} data-app={s.id} title={s.name}>
                  <span class={`ico ico-${s.icon}`} aria-hidden="true"></span>
                  <span class="d-dot" aria-hidden="true"></span>
                  <span class="d-tooltip">{s.name}</span>
                </button>
              </>
            ))
          }
        </div>
      </div>
    </div>

    <script id="deck-data" type="application/json" set:html={JSON.stringify(deckPayload)} />

    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --win-bg: rgba(22, 22, 26, 0.88);
        --dock-bg: rgba(30, 30, 34, 0.5);
        --bar-bg: rgba(12, 14, 20, 0.72);
        --accent: #5eead4;
        --accent-dim: rgba(94, 234, 212, 0.18);
        --green: #34d399;
        --text: #e8eef8;
        --dim: #8b97a8;
        --border: rgba(255, 255, 255, 0.1);
        --card: rgba(255, 255, 255, 0.04);
        --font: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        --display: 'Syne', ui-sans-serif, system-ui, sans-serif;
      }
      html,
      body {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        margin: 0;
        font-family: var(--font);
        color: var(--text);
        background: #07090e;
        cursor: default;
      }
      body {
        background-image:
          radial-gradient(ellipse 80% 60% at 18% 85%, rgba(94, 234, 212, 0.14) 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at 85% 15%, rgba(56, 189, 248, 0.1) 0%, transparent 55%),
          radial-gradient(ellipse 40% 40% at 50% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);
      }

      #boot {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 100000;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        transition: opacity 0.7s ease;
      }
      .boot-mark {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        font-family: var(--display);
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(145deg, #5eead4, #38bdf8);
        color: #041016;
        margin-bottom: 1rem;
      }
      .boot-name {
        font-family: var(--display);
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
        margin-bottom: 2rem;
      }
      .boot-bar {
        width: 180px;
        height: 5px;
        background: #222;
        border-radius: 3px;
        overflow: hidden;
      }
      .boot-fill {
        height: 100%;
        width: 0;
        background: #fff;
        border-radius: 3px;
        transition: width 2.4s ease-in-out;
      }

      #desktop {
        width: 100%;
        height: 100%;
        position: relative;
      }
      #wins {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      #wins .win {
        pointer-events: auto;
      }

      #menubar {
        position: absolute;
        top: 0;
        width: 100%;
        height: 28px;
        background: var(--bar-bg);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 14px;
        font-size: 12.5px;
        font-weight: 500;
        z-index: 5000;
        border-bottom: 1px solid var(--border);
      }
      .bar-l,
      .bar-r {
        display: flex;
        gap: 10px;
        align-items: center;
      }
      .bar-item {
        padding: 2px 6px;
        border-radius: 4px;
        color: inherit;
        text-decoration: none;
        white-space: nowrap;
      }
      .bar-item:hover {
        background: rgba(255, 255, 255, 0.08);
      }
      .bar-brand {
        font-weight: 700;
        font-family: var(--display);
      }
      #app-name {
        font-weight: 600;
      }
      #clock {
        color: var(--dim);
      }

      #dock-wrap {
        position: absolute;
        bottom: 10px;
        width: 100%;
        display: flex;
        justify-content: center;
        z-index: 6000;
        padding: 0 12px;
      }
      #dock {
        background: var(--dock-bg);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid var(--border);
        height: 68px;
        padding: 6px 10px;
        border-radius: 18px;
        display: flex;
        align-items: flex-end;
        gap: 6px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
        max-width: 100%;
        overflow-x: auto;
      }
      .d-item {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        position: relative;
        cursor: pointer;
        border: 0;
        padding: 0;
        background: transparent;
        color: #fff;
        transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), margin 0.2s ease;
        flex-shrink: 0;
      }
      .d-item:hover {
        transform: scale(1.18) translateY(-8px);
        margin: 0 4px;
      }
      .d-dot {
        width: 4px;
        height: 4px;
        background: rgba(255, 255, 255, 0.45);
        border-radius: 50%;
        position: absolute;
        bottom: -7px;
        left: 50%;
        transform: translateX(-50%);
        display: none;
      }
      .d-item.open .d-dot {
        display: block;
      }
      .d-sep {
        width: 1px;
        height: 36px;
        background: rgba(255, 255, 255, 0.18);
        margin: 0 4px;
        flex-shrink: 0;
        align-self: center;
      }
      .d-tooltip {
        position: absolute;
        top: -32px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(20, 22, 28, 0.95);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        border: 1px solid var(--border);
      }
      .d-item:hover .d-tooltip {
        opacity: 1;
      }
      .ico {
        width: 100%;
        height: 100%;
        border-radius: 13px;
        display: grid;
        place-items: center;
        font-size: 1.15rem;
        font-weight: 700;
      }
      .ico-home { background: linear-gradient(135deg, #5eead4, #38bdf8); color: #041016; }
      .ico-bell { background: linear-gradient(135deg, #f472b6, #fb7185); }
      .ico-calendar { background: linear-gradient(135deg, #34d399, #10b981); }
      .ico-mic { background: linear-gradient(135deg, #a78bfa, #818cf8); }
      .ico-users { background: linear-gradient(135deg, #38bdf8, #0ea5e9); }
      .ico-mail { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1c1408; }
      .ico-briefcase { background: linear-gradient(135deg, #94a3b8, #64748b); }
      .ico-file { background: linear-gradient(135deg, #67e8f9, #22d3ee); color: #042f2e; }
      .ico-book { background: linear-gradient(135deg, #c4b5fd, #a78bfa); }
      .ico-activity { background: linear-gradient(135deg, #4ade80, #22c55e); color: #052e16; }
      .ico-dollar { background: linear-gradient(135deg, #fde68a, #fbbf24); color: #1c1408; }
      .ico-home::before { content: '⌂'; }
      .ico-bell::before { content: '⌁'; }
      .ico-calendar::before { content: '▦'; }
      .ico-mic::before { content: '◉'; }
      .ico-users::before { content: '☺'; }
      .ico-mail::before { content: '✉'; }
      .ico-briefcase::before { content: '▣'; }
      .ico-file::before { content: '▤'; }
      .ico-book::before { content: '◈'; }
      .ico-activity::before { content: '◎'; }
      .ico-dollar::before { content: '$'; }

      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-18px);
        }
      }
      .bouncing {
        animation: bounce 0.55s ease infinite;
      }

      .win {
        position: absolute;
        background: var(--win-bg);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.42);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 280px;
        min-height: 200px;
      }
      .win.opening {
        animation: wOpen 0.22s cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes wOpen {
        from {
          transform: scale(0.86);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
      .win.inactive {
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
        border-color: rgba(255, 255, 255, 0.06);
      }
      .win.inactive .tl span {
        background-color: #555 !important;
      }
      .win-head {
        height: 32px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        position: relative;
        cursor: grab;
        flex-shrink: 0;
        user-select: none;
      }
      .win-head:active {
        cursor: grabbing;
      }
      .tl {
        display: flex;
        gap: 7px;
        margin-left: 12px;
        z-index: 2;
      }
      .tl span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        cursor: pointer;
      }
      .tl .c {
        background: #ff5f56;
      }
      .tl .m {
        background: #ffbd2e;
      }
      .tl .x {
        background: #27c93f;
      }
      .win-title {
        position: absolute;
        width: 100%;
        text-align: center;
        font-size: 12.5px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        pointer-events: none;
      }
      .win-body {
        flex: 1;
        overflow: auto;
        position: relative;
        background: rgba(0, 0, 0, 0.18);
      }

      .s-home {
        padding: 1.75rem 1.5rem;
        display: grid;
        grid-template-columns: minmax(180px, 42%) 1fr;
        gap: 1.25rem;
        min-height: 100%;
        align-items: center;
      }
      @media (max-width: 700px) {
        .s-home {
          grid-template-columns: 1fr;
        }
      }
      .s-home .copy h2 {
        margin: 0 0 0.5rem;
        font-family: var(--display);
        font-size: clamp(1.35rem, 2.5vw, 1.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
      }
      .s-home .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-dim);
        border: 1px solid rgba(94, 234, 212, 0.3);
        padding: 3px 12px;
        border-radius: 100px;
        font-size: 11px;
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 0.75rem;
      }
      .s-home .tag .pulse {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.45);
        animation: pulse 2s ease infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.4);
        }
        50% {
          box-shadow: 0 0 0 6px transparent;
        }
      }
      .s-home p {
        margin: 0;
        font-size: 0.92rem;
        color: var(--dim);
        line-height: 1.55;
      }
      .s-home .preview {
        display: flex;
        justify-content: center;
      }

      /* Device preview inside windows */
      .gif-device {
        width: 100%;
        max-width: 220px;
      }
      .gif-device--laptop {
        max-width: 100%;
      }
      .gif-device-shell {
        position: relative;
        background: #0a0a0c;
        overflow: hidden;
        border: 2px solid #2a2a30;
      }
      .gif-device--phone-hand .gif-device-shell,
      .gif-device--phone-desk .gif-device-shell {
        aspect-ratio: 9 / 19.5;
        border-radius: 20px;
        margin: 0 auto;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
      }
      .gif-device--laptop .gif-device-shell {
        aspect-ratio: 16 / 10;
        border-radius: 8px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      }
      .gif-device-shell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }
      .gif-ph {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 1rem;
        text-align: center;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        background: linear-gradient(160deg, #1a2438, #0d121c);
      }
      .gif-ph[hidden] {
        display: none;
      }

      #ctx {
        position: absolute;
        background: rgba(28, 30, 38, 0.94);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 5px 0;
        min-width: 180px;
        z-index: 99999;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        font-size: 13px;
      }
      .ctx-i {
        display: block;
        width: 100%;
        text-align: left;
        padding: 7px 14px;
        border: 0;
        background: transparent;
        color: var(--text);
        font: inherit;
        cursor: pointer;
      }
      .ctx-i:hover {
        background: rgba(94, 234, 212, 0.18);
        color: #fff;
      }

      @media (max-width: 768px) {
        #menubar {
          font-size: 11px;
          padding: 0 8px;
        }
        .hide-m {
          display: none;
        }
        #dock {
          height: 58px;
          padding: 4px 8px;
        }
        .d-item {
          width: 44px;
          height: 44px;
        }
        .win {
          left: 8px !important;
          right: 8px;
          width: auto !important;
          max-width: calc(100vw - 16px);
        }
      }
    </style>

    <script src="/deck/macos-desktop.js" defer></script>
  </body>
</html>
