---
/**
 * /deck — scroll-snap sales narrative.
 * Left: scene copy. Right (sm+): section nav controller.
 */
import Favicon from '../components/Favicon.astro';
import Header from '../components/Header.astro';
import Preloader from '../components/Preloader.astro';
import { assertDeckScript } from '../deck/validate';
import type { DeckVideoEnter } from '../deck/types';
import { getCompanyConfig, homepageHeroMask, homepageHeroLogo } from '../lib/companyConfig';
import everythingRaw from '../deck/scripts/everything.json';
import {
  Home,
  Bell,
  Calendar,
  Mic,
  Users,
  Mail,
  Briefcase,
  FileText,
  BookOpen,
  Monitor,
  Wallet,
  ClipboardList,
} from 'lucide-astro';

export const prerender = false;

const script = assertDeckScript(everythingRaw);
const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);
const heroLogo = homepageHeroLogo(company);

/** Same Lucide set as admin header/footer nav, mapped to deck sections. */
const DOCK_ICONS: Record<string, typeof Home> = {
  homepage: Home,
  pwa: Bell,
  scheduling: Calendar,
  voice: Mic,
  clients: Users,
  inbox: Mail,
  work: Briefcase,
  documents: FileText,
  knowledge: BookOpen,
  monitoring: Monitor,
  billing: Wallet,
};

const DOCK_LABELS: Record<string, string> = {
  homepage: 'Homepage',
  pwa: 'PWA alerts',
  scheduling: 'Scheduling',
  voice: 'Voice',
  clients: 'Clients',
  inbox: 'Inbox',
  work: 'Work',
  documents: 'Documents',
  knowledge: 'Knowledge',
  monitoring: 'Monitoring',
  billing: 'Billing',
};

const VIDEO_ENTER: DeckVideoEnter[] = ['right', 'up', 'left', 'down'];

const sections = script.sections.map((section, index) => {
  const feature = section.features[0];
  return {
    id: section.id,
    label: DOCK_LABELS[section.id] ?? section.title,
    title: section.title,
    quoteLabel: section.quoteLabel?.trim() || section.title,
    optional: section.optional === true,
    featureTitle: feature?.title ?? section.title,
    featureBody: feature?.body ?? section.summary ?? '',
    video: section.video?.trim() || `/deck/videos/${section.id}.mp4`,
    videoEnter: section.videoEnter ?? VIDEO_ENTER[index % VIDEO_ENTER.length],
    videoHue: (index * 47 + 168) % 360,
  };
});

const deckPayload = {
  sections: sections.map((s) => ({
    id: s.id,
    label: s.label,
    quoteLabel: s.quoteLabel,
    optional: s.optional,
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{script.title} | {company.name}</title>
    <meta
      name="description"
      content="See the Business OS in motion — design first, then how every piece interacts."
    />
    <Favicon />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <Preloader heroMask={heroMask} heroLogo={heroLogo} fallbackName={company.name} />

    <nav
      id="dock"
      aria-label="Deck sections"
      style={`--dock-items: ${sections.length + 1}`}
    >
      {
        sections.map((s) => {
          const Icon = DOCK_ICONS[s.id] ?? Home;
          return (
            <button
              type="button"
              class="d-item"
              id={`d-${s.id}`}
              data-app={s.id}
              aria-label={s.label}
            >
              <span class="ico" aria-hidden="true">
                <Icon size={20} strokeWidth={1.75} />
              </span>
              <span class="d-dot" aria-hidden="true"></span>
              <span class="d-tooltip" role="tooltip">{s.label}</span>
            </button>
          );
        })
      }
      <button
        type="button"
        class="d-item"
        id="d-quote"
        data-app="quote"
        aria-label="Quote package"
      >
        <span class="ico" aria-hidden="true">
          <ClipboardList size={20} strokeWidth={1.75} />
        </span>
        <span class="d-dot" aria-hidden="true"></span>
        <span class="d-tooltip" role="tooltip">Quote</span>
      </button>
    </nav>

    <div id="deck-video-stage" aria-hidden="true">
      {
        sections.map((s) => (
          <div
            class="deck-video-layer"
            data-deck-video={s.id}
            data-enter={s.videoEnter}
            style={`--video-hue: ${s.videoHue}`}
          >
            <div class="deck-video-media">
              <video
                class="deck-video-el"
                muted
                loop
                playsinline
                preload="none"
                data-src={s.video}
              />
              <div class="deck-video-placeholder">
                <span class="deck-video-placeholder-label">{s.label}</span>
              </div>
              <div class="deck-video-scrim"></div>
            </div>
          </div>
        ))
      }
      <div class="deck-video-layer deck-video-layer--quote" data-deck-video="quote">
        <div class="deck-video-media deck-video-media--quote">
          <div class="deck-video-scrim deck-video-scrim--quote"></div>
        </div>
      </div>
    </div>

    <main id="scroll-track" data-deck-scroll>
      {
        sections.map((s, i) => (
          <section
            class:list={['deck-scene', { 'deck-scene--lead': i === 0 }]}
            id={`scene-${s.id}`}
            data-deck-scene={s.id}
            data-optional={s.optional ? 'true' : 'false'}
          >
            <div class="deck-scene-copy">
              <p class="deck-scene-kicker">{s.title}</p>
              <h2 class="deck-scene-title">{s.featureTitle}</h2>
              <p class="deck-scene-body">{s.featureBody}</p>
              {
                s.optional && (
                  <p class="deck-opt-note" data-opt-note={s.id} hidden>
                    Opted out of the quote — flip the switch to include it again.
                  </p>
                )
              }
              {
                s.optional && (
                  <label class="deck-opt">
                    <input
                      type="checkbox"
                      class="deck-opt-input"
                      data-opt-toggle={s.id}
                      checked
                    />
                    <span class="deck-opt-ui" aria-hidden="true"></span>
                    <span class="deck-opt-label">Include in quote</span>
                  </label>
                )
              }
            </div>
            <div class="deck-dock-sentinel" aria-hidden="true"></div>
          </section>
        ))
      }

      <section class="deck-scene deck-scene--quote" id="scene-quote" data-deck-scene="quote">
        <div class="deck-scene-copy deck-quote">
          <p class="deck-scene-kicker">Quote package</p>
          <h2 class="deck-scene-title">Ready for a quote</h2>
          <p class="deck-scene-body">
            Included modules and anything you opted out of are listed below. Copy this
            summary when you request a quote.
          </p>
          <div class="deck-quote-cols">
            <div>
              <h3 class="deck-quote-h">Included</h3>
              <ul id="quote-included" class="deck-quote-list"></ul>
            </div>
            <div>
              <h3 class="deck-quote-h">Opted out</h3>
              <ul id="quote-declined" class="deck-quote-list deck-quote-list--out"></ul>
            </div>
          </div>
          <label class="deck-quote-desc-label" for="quote-description">Quote description</label>
          <textarea id="quote-description" class="deck-quote-desc" rows="8" readonly></textarea>
          <button type="button" id="quote-copy" class="deck-quote-copy">Copy description</button>
        </div>
        <div class="deck-dock-sentinel" aria-hidden="true"></div>
      </section>
    </main>

    <script id="deck-data" type="application/json" set:html={JSON.stringify(deckPayload)} />

    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --accent: #5eead4;
        --text: #e8eef8;
        --border: rgba(255, 255, 255, 0.1);
        --font: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        --display: 'Syne', ui-sans-serif, system-ui, sans-serif;
      }
      html,
      body {
        width: 100%;
        height: 100dvh;
        max-height: 100dvh;
        margin: 0;
        overflow: hidden;
        font-family: var(--font);
        color: var(--text);
        background: #07090e;
        cursor: default;
      }
      body {
        background: #07090e;
      }

      #deck-video-stage {
        position: fixed;
        inset: 0;
        z-index: 1;
        overflow: hidden;
        pointer-events: none;
        background: #07090e;
      }
      .deck-video-layer {
        position: absolute;
        inset: 0;
        z-index: 0;
        opacity: 0;
        visibility: hidden;
      }
      .deck-video-layer.is-live {
        visibility: visible;
      }
      .deck-video-media {
        position: absolute;
        width: 122%;
        height: 122%;
        left: -11%;
        top: -11%;
        will-change: transform, opacity;
        transform: translate3d(var(--vx, 0%), var(--vy, 0%), 0)
          scale(var(--vscale, 1));
        opacity: var(--vopacity, 0);
      }
      .deck-video-el {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.35s ease;
      }
      .deck-video-el.is-ready {
        opacity: 1;
      }
      .deck-video-placeholder {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        background:
          radial-gradient(
            ellipse 70% 55% at 22% 78%,
            hsl(var(--video-hue, 168) 62% 42% / 0.34) 0%,
            transparent 58%
          ),
          radial-gradient(
            ellipse 55% 45% at 82% 18%,
            hsl(calc(var(--video-hue, 168) + 38) 58% 48% / 0.22) 0%,
            transparent 55%
          ),
          linear-gradient(145deg, #0a0d14 0%, #07090e 48%, #050608 100%);
        animation: deck-video-placeholder-drift 14s ease-in-out infinite alternate;
      }
      .deck-video-el.is-ready + .deck-video-placeholder {
        opacity: 0;
        visibility: hidden;
      }
      .deck-video-placeholder-label {
        font-family: var(--display);
        font-size: clamp(1.1rem, 2.4vw, 1.45rem);
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.16);
      }
      @keyframes deck-video-placeholder-drift {
        from {
          transform: scale(1) translate3d(-1.5%, 0.5%, 0);
        }
        to {
          transform: scale(1.04) translate3d(1.5%, -0.5%, 0);
        }
      }
      .deck-video-scrim {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            105deg,
            rgba(7, 9, 14, 0.94) 0%,
            rgba(7, 9, 14, 0.62) 38%,
            rgba(7, 9, 14, 0.28) 68%,
            rgba(7, 9, 14, 0.42) 100%
          ),
          linear-gradient(to top, rgba(7, 9, 14, 0.82) 0%, transparent 42%);
        pointer-events: none;
      }
      .deck-video-media--quote {
        width: 100%;
        height: 100%;
        left: 0;
        top: 0;
        background:
          radial-gradient(ellipse 80% 60% at 18% 85%, rgba(94, 234, 212, 0.14) 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at 85% 15%, rgba(56, 189, 248, 0.1) 0%, transparent 55%),
          #07090e;
      }
      .deck-video-scrim--quote {
        background: linear-gradient(
          105deg,
          rgba(7, 9, 14, 0.88) 0%,
          rgba(7, 9, 14, 0.5) 45%,
          rgba(7, 9, 14, 0.35) 100%
        );
      }

      .app-header {
        z-index: 7000;
      }

      #scroll-track {
        position: fixed;
        inset: 0;
        z-index: 10;
        height: 100dvh;
        overflow-x: hidden;
        overflow-y: auto;
        scroll-snap-type: y mandatory;
        scroll-behavior: smooth;
        overscroll-behavior: none;
        -webkit-overflow-scrolling: touch;
      }
      .deck-scene {
        box-sizing: border-box;
        position: relative;
        z-index: 2;
        height: 100dvh;
        min-height: 100dvh;
        max-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding:
          calc(var(--app-header-h, 4rem) + env(safe-area-inset-top, 0px) + 1.25rem)
          clamp(1rem, 4vw, 2.5rem)
          5.5rem;
        scroll-snap-align: start;
        scroll-snap-stop: always;
      }
      .deck-scene-copy {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 0;
      }
      .deck-dock-sentinel {
        flex: 0 0 0;
        width: 100%;
        height: 0;
        pointer-events: none;
      }
      @media (min-width: 640px) {
        .deck-scene {
          padding-right: calc(48px + clamp(1rem, 4vw, 2.5rem));
        }
        .deck-scene-copy {
          max-width: min(34rem, calc(100% - 4rem));
        }
      }
      .deck-scene-copy {
        max-width: 34rem;
        width: 100%;
        pointer-events: none;
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.45s ease,
          transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
          filter 0.3s ease;
      }
      .deck-scene.is-active .deck-scene-copy {
        opacity: 1;
        transform: translateY(0);
      }
      .deck-scene.is-declined .deck-scene-copy {
        filter: grayscale(1) brightness(0.72);
      }
      .deck-scene.is-active.is-declined .deck-scene-copy {
        opacity: 0.55;
      }
      .deck-scene-kicker {
        margin: 0 0 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
      }
      .deck-opt {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-start;
        align-self: flex-start;
        gap: 0.45rem;
        margin-top: auto;
        padding-top: 1.25rem;
        cursor: pointer;
        user-select: none;
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(232, 238, 248, 0.78);
        pointer-events: auto;
        position: relative;
        z-index: 2;
      }
      .deck-scene.is-declined .deck-opt {
        color: rgba(94, 234, 212, 0.95);
      }
      .deck-opt-input {
        position: absolute;
        opacity: 0;
        width: 1px;
        height: 1px;
        pointer-events: none;
      }
      .deck-opt-ui {
        width: 2.4rem;
        height: 1.3rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.18);
        position: relative;
        flex-shrink: 0;
        transition: background 0.2s ease, border-color 0.2s ease;
      }
      .deck-opt-ui::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 0.95rem;
        height: 0.95rem;
        border-radius: 50%;
        background: #fff;
        transition: transform 0.2s ease;
      }
      .deck-opt-input:checked + .deck-opt-ui {
        background: rgba(94, 234, 212, 0.35);
        border-color: rgba(94, 234, 212, 0.55);
      }
      .deck-opt-input:checked + .deck-opt-ui::after {
        transform: translateX(1.05rem);
        background: #5eead4;
      }
      .deck-opt-input:focus-visible + .deck-opt-ui {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .deck-opt-note {
        margin: 0.85rem 0 0;
        font-size: 0.85rem;
        color: rgba(251, 191, 36, 0.9);
      }
      .deck-scene-title {
        margin: 0 0 0.75rem;
        font-family: var(--display);
        font-size: clamp(1.45rem, 3.2vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        color: #f4f7fb;
        text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
      }
      .deck-scene-body {
        margin: 0;
        font-size: 1.02rem;
        line-height: 1.55;
        color: rgba(233, 238, 246, 0.82);
        text-shadow: 0 1px 16px rgba(0, 0, 0, 0.4);
      }

      .deck-quote {
        pointer-events: auto;
        max-width: 40rem;
      }
      .deck-quote-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem 1.5rem;
        margin: 1.25rem 0 1rem;
      }
      @media (max-width: 560px) {
        .deck-quote-cols {
          grid-template-columns: 1fr;
        }
      }
      .deck-quote-h {
        margin: 0 0 0.45rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }
      .deck-quote-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .deck-quote-list li {
        font-size: 0.92rem;
        color: rgba(233, 238, 246, 0.88);
        padding: 0.35rem 0.55rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
      }
      .deck-quote-list--out li {
        color: rgba(233, 238, 246, 0.45);
        text-decoration: line-through;
      }
      .deck-quote-list .deck-quote-empty {
        color: rgba(233, 238, 246, 0.4);
        font-style: italic;
        text-decoration: none;
        background: transparent;
        border-style: dashed;
      }
      .deck-quote-desc-label {
        display: block;
        margin: 0.5rem 0 0.4rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }
      .deck-quote-desc {
        width: 100%;
        resize: vertical;
        min-height: 9rem;
        padding: 0.75rem 0.85rem;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(0, 0, 0, 0.35);
        color: #e8eef8;
        font: inherit;
        font-size: 0.88rem;
        line-height: 1.45;
      }
      .deck-quote-copy {
        margin-top: 0.75rem;
        border: 0;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font: inherit;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        color: #041016;
        background: linear-gradient(135deg, #5eead4, #38bdf8);
      }
      .deck-quote-copy:hover {
        filter: brightness(1.06);
      }

      #dock {
        position: fixed;
        bottom: max(10px, env(safe-area-inset-bottom, 0px));
        left: max(0.35rem, env(safe-area-inset-left, 0px));
        right: max(0.35rem, env(safe-area-inset-right, 0px));
        z-index: 6000;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: clamp(0px, 0.4vw, 3px);
        width: auto;
        max-width: calc(100% - 0.7rem);
        margin: 0 auto;
        padding: 0 clamp(0.1rem, 1vw, 0.35rem);
        border: 0;
        background: transparent;
        box-shadow: none;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        pointer-events: none;
        overflow: visible;
        transition: top 0.18s ease, bottom 0.18s ease;
      }
      #dock.dock--riding,
      #dock.dock--at-top {
        bottom: auto;
      }
      #dock.dock--at-top {
        top: calc(var(--app-header-h, 3.25rem) + env(safe-area-inset-top, 0px) + 0.35rem);
      }
      .d-item {
        pointer-events: auto;
        width: 40px;
        height: 40px;
        margin: 0;
        padding: 0;
        border: 0;
        border-radius: 8px;
        position: relative;
        cursor: pointer;
        background: transparent;
        color: rgba(255, 255, 255, 0.42);
        flex: 1 1 0;
        min-width: 0;
        max-width: 40px;
        overflow: visible;
        transition:
          color 0.15s ease,
          background 0.15s ease,
          transform 0.15s ease;
      }
      .d-item .ico {
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        border-radius: inherit;
        background: transparent;
        color: inherit;
      }
      .d-item .ico svg {
        display: block;
        width: min(20px, 100%);
        height: min(20px, 100%);
        pointer-events: none;
      }
      .d-item:hover {
        color: rgba(255, 255, 255, 0.92);
        background: rgba(255, 255, 255, 0.08);
        z-index: 2;
      }
      .d-item:focus-visible {
        outline: 1px solid rgba(255, 255, 255, 0.55);
        outline-offset: 2px;
        color: rgba(255, 255, 255, 0.92);
      }
      .d-item.active {
        color: #fff;
        background: rgba(255, 255, 255, 0.12);
      }
      .d-item.active .d-dot {
        display: block;
        background: rgba(255, 255, 255, 0.85);
      }
      .d-item.is-declined {
        opacity: 0.28;
      }
      .d-item.is-declined:hover,
      .d-item.is-declined.active {
        opacity: 0.55;
      }
      .d-dot {
        width: 3px;
        height: 3px;
        background: rgba(255, 255, 255, 0.55);
        border-radius: 50%;
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%);
        display: none;
      }
      .d-tooltip {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%) translateY(4px);
        background: rgba(12, 14, 18, 0.92);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: rgba(255, 255, 255, 0.88);
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        border: 1px solid rgba(255, 255, 255, 0.1);
        z-index: 5;
        transition:
          opacity 0.15s ease,
          transform 0.15s ease,
          visibility 0.15s ease;
      }
      .d-item:focus-visible .d-tooltip,
      .d-item:hover .d-tooltip {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }

      @media (min-width: 640px) {
        #dock {
          top: 0;
          bottom: 0;
          left: auto;
          right: 8px;
          width: auto;
          max-width: none;
          height: 100%;
          flex-direction: column;
          justify-content: center;
          gap: 0;
          margin: 0;
          padding: calc(var(--app-header-h, 4rem) + 0.5rem) 0 1rem;
        }
        #dock.dock--riding,
        #dock.dock--at-top {
