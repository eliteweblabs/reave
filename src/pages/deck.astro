---
/**
 * /deck — macOS-style desktop sales experience.
 * Sections from everything.json open as draggable windows;
 * each shows a recorded GIF mapped into a device frame.
 */
import Favicon from '../components/Favicon.astro';
import Header from '../components/Header.astro';
import { assertDeckScript } from '../deck/validate';
import { getCompanyConfig, homepageHeroMask } from '../lib/companyConfig';
import everythingRaw from '../deck/scripts/everything.json';
import {
  Home,
  Bell,
  Calendar,
  Mic,
  Users,
  Mail,
  Briefcase,
  FileText,
  BookOpen,
  Monitor,
  Wallet,
  type LucideIcon,
} from 'lucide-astro';

export const prerender = false;

const script = assertDeckScript(everythingRaw);
const company = await getCompanyConfig(Astro.request);
const heroMask = homepageHeroMask(company);

/** Same Lucide set as admin header/footer nav, mapped to deck sections. */
const DOCK_ICONS: Record<string, LucideIcon> = {
  homepage: Home,
  pwa: Bell,
  scheduling: Calendar,
  voice: Mic,
  clients: Users,
  inbox: Mail,
  work: Briefcase,
  documents: FileText,
  knowledge: BookOpen,
  monitoring: Monitor,
  billing: Wallet,
};

const DOCK_LABELS: Record<string, string> = {
  homepage: 'Homepage',
  pwa: 'PWA alerts',
  scheduling: 'Scheduling',
  voice: 'Voice',
  clients: 'Clients',
  inbox: 'Inbox',
  work: 'Work',
  documents: 'Documents',
  knowledge: 'Knowledge',
  monitoring: 'Monitoring',
  billing: 'Billing',
};

const sections = script.sections.map((section, i) => {
  const feature = section.features[0];
  const setAction = feature?.actions.find((a) => a.type === 'stage.set');
  const gif = setAction && setAction.type === 'stage.set' ? setAction.gif : undefined;
  const device =
    setAction && setAction.type === 'stage.set'
      ? setAction.device ?? (setAction.surface === 'desktop' ? 'laptop' : 'phone-hand')
      : 'phone-hand';
  return {
    id: section.id,
    name: section.title,
    label: DOCK_LABELS[section.id] ?? section.title,
    summary: section.summary ?? '',
    featureTitle: feature?.title ?? section.title,
    featureBody: feature?.body ?? '',
    scrollHeight: feature?.scrollHeight ?? 100,
    gif: gif ?? `/deck/gifs/${section.id}.gif`,
    device,
    w: device === 'laptop' ? 720 : 520,
    h: device === 'laptop' ? 520 : 640,
    top: 72 + (i % 4) * 28,
    left: 48 + (i % 5) * 36,
  };
});

const deckPayload = {
  companyName: company.name,
  sections,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{script.title} | {company.name}</title>
    <meta
      name="description"
      content="See the Business OS in motion — design first, then how every piece interacts."
    />
    <Favicon />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <div id="boot" aria-hidden="true">
      {
        heroMask ? (
          <div
            class="boot-logo-stack"
            style={`--hero-logo-mask: url("${heroMask}")`}
            aria-hidden="true"
          >
            <div id="bootQuantumHost" class="boot-quantum-host"></div>
          </div>
        ) : (
          <div class="boot-logo-fallback" aria-hidden="true">{company.name}</div>
        )
      }
      <div class="boot-bar-wrap">
        <div class="boot-bar"><div class="boot-fill" id="boot-fill"></div></div>
      </div>
    </div>

    <div id="desktop" aria-hidden="false">
      <div id="wins"></div>

      <div id="ctx" hidden>
        {
          sections.slice(0, 6).map((s) => (
            <button type="button" class="ctx-i" data-app={s.id}>
              Open {s.label}
            </button>
          ))
        }
      </div>

      <div id="dock-wrap">
        <div id="dock">
          {
            sections.map((s, i) => {
              const Icon = DOCK_ICONS[s.id] ?? Home;
              return (
                <>
                  {i === 2 && <div class="d-sep" aria-hidden="true" />}
                  <button
                    type="button"
                    class="d-item"
                    id={`d-${s.id}`}
                    data-app={s.id}
                    aria-label={s.label}
                  >
                    <span class={`ico ico-${s.id}`} aria-hidden="true">
                      <Icon size={22} strokeWidth={1.75} />
                    </span>
                    <span class="d-dot" aria-hidden="true"></span>
                    <span class="d-tooltip" role="tooltip">{s.label}</span>
                  </button>
                </>
              );
            })
          }
        </div>
      </div>
    </div>

    <main id="scroll-track" data-deck-scroll>
      {
        sections.map((s, i) => (
          <section
            class:list={['deck-scene', { 'deck-scene--lead': i === 0 }]}
            id={`scene-${s.id}`}
            data-deck-scene={s.id}
            style={`min-height: ${s.scrollHeight}vh`}
          >
            <div class="deck-scene-copy">
              <p class="deck-scene-kicker">{s.label}</p>
              <h2 class="deck-scene-title">{s.featureTitle}</h2>
              <p class="deck-scene-body">{s.featureBody || s.summary}</p>
            </div>
          </section>
        ))
      }
    </main>

    <script id="deck-data" type="application/json" set:html={JSON.stringify(deckPayload)} />
    <style is:global>
      * {
        box-sizing: border-box;
      }
      :root {
        --win-bg: rgba(22, 22, 26, 0.88);
        --dock-bg: rgba(30, 30, 34, 0.5);
        --accent: #5eead4;
        --accent-dim: rgba(94, 234, 212, 0.18);
        --green: #34d399;
        --text: #e8eef8;
        --dim: #8b97a8;
        --border: rgba(255, 255, 255, 0.1);
        --card: rgba(255, 255, 255, 0.04);
        --font: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
        --display: 'Syne', ui-sans-serif, system-ui, sans-serif;
      }
      html,
      body {
        width: 100%;
        min-height: 100%;
        margin: 0;
        font-family: var(--font);
        color: var(--text);
        background: #07090e;
        cursor: default;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background-image:
          radial-gradient(ellipse 80% 60% at 18% 85%, rgba(94, 234, 212, 0.14) 0%, transparent 55%),
          radial-gradient(ellipse 55% 45% at 85% 15%, rgba(56, 189, 248, 0.1) 0%, transparent 55%),
          radial-gradient(ellipse 40% 40% at 50% 50%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);
      }

      /* Site header above dock/windows so menus stay usable */
      .app-header {
        z-index: 7000;
      }

      #boot {
        position: fixed;
        inset: 0;
        background: #050505;
        z-index: 100000;
        transition: opacity 0.7s ease;
      }
      /* Same plasma-mask treatment as homepage, sized just above the progress bar. */
      .boot-logo-stack {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
        -webkit-mask-image: var(--hero-logo-mask, url('/logo-mask.svg'));
        mask-size: 210px;
        -webkit-mask-size: 210px;
        mask-position: center calc(50% - 28px);
        -webkit-mask-position: center calc(50% - 28px);
        mask-repeat: no-repeat;
        -webkit-mask-repeat: no-repeat;
        mask-mode: alpha;
        -webkit-mask-mode: alpha;
        filter: drop-shadow(0 0 14px rgba(255, 255, 255, 0.4))
          drop-shadow(0 0 28px rgba(255, 100, 200, 0.24));
      }
      .boot-quantum-host {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      .boot-quantum-host canvas {
        display: block;
        width: 100% !important;
        height: 100% !important;
      }
      .boot-logo-fallback {
        position: absolute;
        left: 50%;
        top: calc(50% - 40px);
        transform: translate(-50%, -50%);
        max-width: 210px;
        font-family: var(--display);
        font-weight: 800;
        font-size: 1.35rem;
        letter-spacing: -0.03em;
        text-align: center;
        color: rgba(255, 255, 255, 0.85);
      }
      .boot-bar-wrap {
        position: absolute;
        left: 50%;
        top: calc(50% + 96px);
        transform: translateX(-50%);
      }
      .boot-bar {
        width: 180px;
        height: 5px;
        background: #222;
        border-radius: 3px;
        overflow: hidden;
      }
      .boot-fill {
        height: 100%;
        width: 0;
        background: #fff;
        border-radius: 3px;
        transition: width 2.4s ease-in-out;
      }

      #desktop {
        position: fixed;
        inset: 0;
        z-index: 40;
        pointer-events: none;
      }
      #wins {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      #wins .win {
        pointer-events: auto;
      }
      #dock-wrap,
      #ctx {
        pointer-events: auto;
      }

      #scroll-track {
        position: relative;
        z-index: 10;
        padding:
          calc(var(--app-header-h, 4rem) + env(safe-area-inset-top, 0px) + 1.5rem)
          clamp(1rem, 4vw, 2.5rem)
          6rem;
      }
      @media (min-width: 640px) {
        #scroll-track {
          padding-right: calc(88px + clamp(1rem, 4vw, 2.5rem));
          max-width: min(42rem, calc(100% - 7rem));
        }
      }
      .deck-scene {
        display: flex;
        flex-direction: column;
        justify-content: center;
        scroll-margin-top: 22vh;
        opacity: 0.34;
        transition: opacity 0.35s ease;
      }
      .deck-scene.is-active {
        opacity: 1;
      }
      .deck-scene-copy {
        max-width: 34rem;
        pointer-events: none;
      }
      .deck-scene-kicker {
        margin: 0 0 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
      }
      .deck-scene-title {
        margin: 0 0 0.75rem;
        font-family: var(--display);
        font-size: clamp(1.45rem, 3.2vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        color: #f4f7fb;
      }
      .deck-scene-body {
        margin: 0;
        font-size: 1.02rem;
        line-height: 1.55;
        color: rgba(233, 238, 246, 0.72);
      }

      #dock-wrap {
        position: absolute;
        bottom: 10px;
        left: 0;
        right: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        z-index: 6000;
        padding: 40px 12px 0;
        overflow: visible;
      }
      #dock {
        background: var(--dock-bg);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid var(--border);
        height: 68px;
        padding: 6px 10px;
        border-radius: 18px;
        display: flex;
        flex-direction: row;
        align-items: flex-end;
        gap: 6px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
        max-width: 100%;
        overflow: visible;
      }
      .d-item {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        position: relative;
        cursor: pointer;
        border: 0;
        padding: 0;
        background: transparent;
        color: #fff;
        transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1), margin 0.2s ease;
        flex-shrink: 0;
        overflow: visible;
      }
      .d-item:hover {
        transform: scale(1.18) translateY(-8px);
        margin: 0 4px;
        z-index: 2;
      }
      .d-item:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }
      .d-item:focus-visible .d-tooltip,
      .d-item:hover .d-tooltip {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      .d-dot {
        width: 4px;
        height: 4px;
        background: rgba(255, 255, 255, 0.45);
        border-radius: 50%;
        position: absolute;
        bottom: -7px;
        left: 50%;
        transform: translateX(-50%);
        display: none;
      }
      .d-item.open .d-dot {
        display: block;
      }
      .d-item.active .ico {
        box-shadow:
          0 0 0 2px rgba(94, 234, 212, 0.95),
          0 0 18px rgba(94, 234, 212, 0.35);
        transform: scale(1.04);
      }
      .d-item.active .d-dot {
        display: block;
        background: var(--accent);
      }
      .d-sep {
        width: 1px;
        height: 36px;
        background: rgba(255, 255, 255, 0.18);
        margin: 0 4px;
        flex-shrink: 0;
        align-self: center;
      }
      .d-tooltip {
        position: absolute;
        bottom: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%) translateY(4px);
        background: rgba(20, 22, 28, 0.96);
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: var(--text);
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        border: 1px solid var(--border);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.35);
        z-index: 5;
        transition:
          opacity 0.15s ease,
          transform 0.15s ease,
          visibility 0.15s ease;
      }

      /* Bigger than small: vertical dock on the right */
      @media (min-width: 640px) {
        #dock-wrap {
          top: 0;
          bottom: 0;
          left: auto;
          right: 10px;
          width: auto;
          height: 100%;
          align-items: center;
          justify-content: center;
          padding: 72px 0 16px;
        }
        #dock {
          flex-direction: column;
          align-items: center;
          height: auto;
          max-height: calc(100vh - 96px);
          width: 68px;
          padding: 10px 6px;
          overflow-y: auto;
          overflow-x: visible;
        }
        .d-item:hover {
          transform: scale(1.14) translateX(-6px);
          margin: 4px 0;
        }
        .d-item:focus-visible .d-tooltip,
        .d-item:hover .d-tooltip {
          transform: translateY(-50%) translateX(0);
        }
        .d-dot {
          bottom: 50%;
          left: auto;
          right: -7px;
          transform: translateY(50%);
        }
        .d-sep {
          width: 36px;
          height: 1px;
          margin: 4px 0;
        }
        .d-tooltip {
          bottom: auto;
          top: 50%;
          left: auto;
          right: calc(100% + 12px);
          transform: translateY(-50%) translateX(4px);
        }
      }
      .ico {
        width: 100%;
        height: 100%;
        border-radius: 13px;
        display: grid;
        place-items: center;
        color: #fff;
      }
      .ico svg {
        display: block;
        pointer-events: none;
      }
      .ico-homepage { background: linear-gradient(135deg, #5eead4, #38bdf8); color: #041016; }
      .ico-pwa { background: linear-gradient(135deg, #f472b6, #fb7185); }
      .ico-scheduling { background: linear-gradient(135deg, #34d399, #10b981); }
      .ico-voice { background: linear-gradient(135deg, #a78bfa, #818cf8); }
      .ico-clients { background: linear-gradient(135deg, #38bdf8, #0ea5e9); }
      .ico-inbox { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1c1408; }
      .ico-work { background: linear-gradient(135deg, #94a3b8, #64748b); }
      .ico-documents { background: linear-gradient(135deg, #67e8f9, #22d3ee); color: #042f2e; }
      .ico-knowledge { background: linear-gradient(135deg, #c4b5fd, #a78bfa); }
      .ico-monitoring { background: linear-gradient(135deg, #4ade80, #22c55e); color: #052e16; }
      .ico-billing { background: linear-gradient(135deg, #fde68a, #fbbf24); color: #1c1408; }

      @keyframes bounce {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-18px);
        }
      }
      .bouncing {
        animation: bounce 0.55s ease infinite;
      }

      .win {
        position: absolute;
        background: var(--win-bg);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.42);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 280px;
        min-height: 200px;
      }
      .win.opening {
        animation: wOpen 0.22s cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes wOpen {
        from {
          transform: scale(0.86);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
      .win.inactive {
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
        border-color: rgba(255, 255, 255, 0.06);
      }
      .win.inactive .tl span {
        background-color: #555 !important;
      }
      .win-head {
        height: 32px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        position: relative;
        cursor: grab;
        flex-shrink: 0;
        user-select: none;
      }
      .win-head:active {
        cursor: grabbing;
      }
      .tl {
        display: flex;
        gap: 7px;
        margin-left: 12px;
        z-index: 2;
      }
      .tl span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        cursor: pointer;
      }
      .tl .c {
        background: #ff5f56;
      }
      .tl .m {
        background: #ffbd2e;
      }
      .tl .x {
        background: #27c93f;
      }
      .win-title {
        position: absolute;
        width: 100%;
        text-align: center;
        font-size: 12.5px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        pointer-events: none;
      }
      .win-body {
        flex: 1;
        overflow: auto;
        position: relative;
        background: rgba(0, 0, 0, 0.18);
      }

      .s-home {
        padding: 1.75rem 1.5rem;
        display: grid;
        grid-template-columns: minmax(180px, 42%) 1fr;
        gap: 1.25rem;
        min-height: 100%;
        align-items: center;
      }
      @media (max-width: 700px) {
        .s-home {
          grid-template-columns: 1fr;
        }
      }
      .s-home .copy h2 {
        margin: 0 0 0.5rem;
        font-family: var(--display);
        font-size: clamp(1.35rem, 2.5vw, 1.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
      }
      .s-home .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-dim);
        border: 1px solid rgba(94, 234, 212, 0.3);
        padding: 3px 12px;
        border-radius: 100px;
        font-size: 11px;
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 0.75rem;
      }
      .s-home .tag .pulse {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.45);
        animation: pulse 2s ease infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.4);
        }
        50% {
          box-shadow: 0 0 0 6px transparent;
        }
      }
      .s-home p {
        margin: 0;
        font-size: 0.92rem;
        color: var(--dim);
        line-height: 1.55;
      }
      .s-home .preview {
        display: flex;
        justify-content: center;
      }

      /* Device preview inside windows */
      .gif-device {
        width: 100%;
        max-width: 220px;
      }
      .gif-device--laptop {
        max-width: 100%;
      }
      .gif-device-shell {
        position: relative;
        background: #0a0a0c;
        overflow: hidden;
        border: 2px solid #2a2a30;
      }
      .gif-device--phone-hand .gif-device-shell,
      .gif-device--phone-desk .gif-device-shell {
        aspect-ratio: 9 / 19.5;
        border-radius: 20px;
        margin: 0 auto;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
      }
      .gif-device--laptop .gif-device-shell {
        aspect-ratio: 16 / 10;
        border-radius: 8px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      }
      .gif-device-shell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }
      .gif-ph {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 1rem;
        text-align: center;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        background: linear-gradient(160deg, #1a2438, #0d121c);
      }
      .gif-ph[hidden] {
        display: none;
      }

      #ctx {
        position: absolute;
        background: rgba(28, 30, 38, 0.94);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 5px 0;
        min-width: 180px;
        z-index: 99999;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        font-size: 13px;
      }
      .ctx-i {
        display: block;
        width: 100%;
        text-align: left;
        padding: 7px 14px;
        border: 0;
        background: transparent;
        color: var(--text);
        font: inherit;
        cursor: pointer;
      }
      .ctx-i:hover {
        background: rgba(94, 234, 212, 0.18);
        color: #fff;
      }

      @media (max-width: 639px) {
        #dock {
          height: 58px;
          padding: 4px 8px;
        }
        .d-item {
          width: 44px;
          height: 44px;
        }
        .win {
          left: 8px !important;
          right: 8px;
          width: auto !important;
          max-width: calc(100vw - 16px);
        }
      }
    </style>
    <script src="/deck/macos-desktop.js" defer></script>
    <script>
      import { attachQuantumCoreOpticalEngine } from '../lib/quantumCoreOpticalEngine';

      const host = document.getElementById('bootQuantumHost');
      if (host) {
        const detach = attachQuantumCoreOpticalEngine(host);
        const boot = document.getElementById('boot');
        const parent = boot?.parentElement;
        if (parent) {
          const obs = new MutationObserver(() => {
            if (!document.getElementById('boot')) {
              detach();
              obs.disconnect();
            }
          });
          obs.observe(parent, { childList: true });
        }
      }
    </script>
  </body>
</html>
