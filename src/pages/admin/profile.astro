---
import { clerkClient } from "@clerk/astro/server";
import Layout from "../../layouts/Layout.astro";
import { getCompanyConfig } from "../../lib/companyConfig";

export const prerender = false;

const { userId } = Astro.locals.auth();
if (!userId) return Astro.redirect("/sign-in");

const client = clerkClient(Astro);
const user = await client.users.getUser(userId);
const company = await getCompanyConfig(Astro.request);

const meta = (user.publicMetadata ?? {}) as Record<string, string>;
const profileCompanyName = meta.companyName ?? "";
const phone = meta.phone ?? "";
const timezone = meta.timezone ?? "";
const firstName = user.firstName ?? "";
const lastName = user.lastName ?? "";
const email = user.emailAddresses?.[0]?.emailAddress ?? "";
---

<Layout title="Profile" noIndex>
    <div class="page">
      <main class="main">
        <div class="card">
          <h1 class="title">Profile</h1>
          <p class="subtitle">Your account details and preferences.</p>

          <div id="profile-alert" class="alert" style="display:none;"></div>

          <form id="profile-form" class="form">
            <div class="field-row">
              <div class="field">
                <label for="firstName">First Name</label>
                <input id="firstName" name="firstName" type="text" value={firstName} autocomplete="given-name" />
              </div>
              <div class="field">
                <label for="lastName">Last Name</label>
                <input id="lastName" name="lastName" type="text" value={lastName} autocomplete="family-name" />
              </div>
            </div>

            <div class="field">
              <label for="profileCompanyName">Your Company (optional)</label>
              <input id="profileCompanyName" name="companyName" type="text" value={profileCompanyName} autocomplete="organization" />
              <span class="field-hint">Your personal affiliation — not the platform brand shown to clients.</span>
            </div>

            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" value={email} disabled autocomplete="email" />
              <span class="field-hint">Email is managed through your Clerk account.</span>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="phone">Phone</label>
                <input id="phone" name="phone" type="tel" value={phone} autocomplete="tel" placeholder="+1 (555) 000-0000" />
              </div>
              <div class="field">
                <label for="timezone">Time Zone</label>
                <select id="timezone" name="timezone">
                  {[
                    "America/New_York",
                    "America/Chicago",
                    "America/Denver",
                    "America/Los_Angeles",
                    "America/Anchorage",
                    "Pacific/Honolulu",
                    "America/Toronto",
                    "America/Vancouver",
                    "Europe/London",
                    "Europe/Paris",
                    "Europe/Berlin",
                    "Asia/Tokyo",
                    "Asia/Shanghai",
                    "Asia/Kolkata",
                    "Australia/Sydney",
                    "Pacific/Auckland",
                    "UTC",
                  ].map((tz) => (
                    <option value={tz} selected={tz === timezone}>{tz.replace(/_/g, " ")}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="actions">
              <button type="submit" id="save-btn" class="btn-primary">Save Profile</button>
            </div>
          </form>
        </div>

        <div class="card card--company">
          <h2 class="title title--section">Company details</h2>
          <p class="subtitle">Branding shown on client pages, emails, documents, and legal pages.</p>

          <div id="company-alert" class="alert" style="display:none;"></div>

          <form id="company-form" class="form">
            <div class="field">
              <label for="companyName">Display name</label>
              <input id="companyName" name="name" type="text" value={company.name} placeholder="Acme Corp" autocomplete="organization" />
            </div>

            <div class="field">
              <label for="legalName">Legal name</label>
              <input id="legalName" name="legalName" type="text" value={company.legalName} placeholder="Acme Corporation LLC" />
              <span class="field-hint">Used in contracts and NDAs. Defaults to display name if empty.</span>
            </div>

            <div class="field">
              <label for="description">Tagline / description</label>
              <input id="description" name="description" type="text" value={company.description} placeholder="Automated client communication" />
            </div>

            <div class="field-row">
              <div class="field">
                <label for="domain">Website domain</label>
                <input id="domain" name="domain" type="text" value={company.domain} placeholder="example.com" autocomplete="url" />
              </div>
              <div class="field">
                <label for="logoPath">Logo path</label>
                <input id="logoPath" name="logoPath" type="text" value={company.logoPath} placeholder="/logo.png" />
              </div>
            </div>
            <span class="field-hint field-hint--block">Upload your logo to <code>/public</code> and enter the path here (e.g. <code>/logo.png</code>).</span>

            <div class="field-row">
              <div class="field">
                <label for="supportEmail">Support email</label>
                <input id="supportEmail" name="supportEmail" type="email" value={company.supportEmail} placeholder="support@example.com" autocomplete="email" />
              </div>
              <div class="field">
                <label for="fromEmail">Outbound email (From)</label>
                <input id="fromEmail" name="fromEmail" type="email" value={company.fromEmail} placeholder="noreply@example.com" autocomplete="email" />
              </div>
            </div>
            <span class="field-hint field-hint--block">Outbound email is used when <code>RESEND_FROM</code> is not set. Domain must be verified in Resend.</span>

            <div class="actions">
              <button type="submit" id="company-save-btn" class="btn-primary">Save Company Details</button>
            </div>
          </form>
        </div>
      </main>
    </div>

  <script>
      const profileForm = document.getElementById("profile-form") as HTMLFormElement;
      const profileBtn = document.getElementById("save-btn") as HTMLButtonElement;
      const profileAlert = document.getElementById("profile-alert") as HTMLDivElement;

      const companyForm = document.getElementById("company-form") as HTMLFormElement;
      const companyBtn = document.getElementById("company-save-btn") as HTMLButtonElement;
      const companyAlert = document.getElementById("company-alert") as HTMLDivElement;

      function showAlert(el: HTMLDivElement, msg: string, type: "success" | "error") {
        el.textContent = msg;
        el.className = `alert alert--${type}`;
        el.style.display = "block";
        setTimeout(() => { el.style.display = "none"; }, 4000);
      }

      profileForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        profileBtn.disabled = true;
        profileBtn.textContent = "Saving…";

        const data = Object.fromEntries(new FormData(profileForm));

        try {
          const res = await fetch("/api/admin/profile", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
          const json = await res.json();
          if (res.ok) {
            showAlert(profileAlert, "Profile saved.", "success");
          } else {
            showAlert(profileAlert, json.error ?? "Save failed.", "error");
          }
        } catch {
          showAlert(profileAlert, "Network error — please try again.", "error");
        } finally {
          profileBtn.disabled = false;
          profileBtn.textContent = "Save Profile";
        }
      });

      companyForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        companyBtn.disabled = true;
        companyBtn.textContent = "Saving…";

        const data = Object.fromEntries(new FormData(companyForm));

        try {
          const res = await fetch("/api/admin/company", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
          const json = await res.json();
          if (res.ok) {
            showAlert(companyAlert, "Company details saved.", "success");
          } else {
            showAlert(companyAlert, json.error ?? "Save failed.", "error");
          }
        } catch {
          showAlert(companyAlert, "Network error — please try again.", "error");
        } finally {
          companyBtn.disabled = false;
          companyBtn.textContent = "Save Company Details";
        }
      });
    </script>
</Layout>

<style>
  * { box-sizing: border-box; }

  :global(html),
  :global(body) {
    background: #050505;
    color: #e5e5e5;
  }

  /* ── Page ── */
  .page { min-height: 100vh; }

  .main {
    padding-top: calc(64px + 32px);
    padding-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-left: 24px;
    padding-right: 24px;
  }

  /* ── Card ── */
  .card {
    width: 100%;
    max-width: 560px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 36px 32px;
  }

  .title {
    margin: 0 0 4px;
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }

  .title--section {
    font-size: 18px;
  }

  .subtitle {
    margin: 0 0 28px;
    font-size: 14px;
    color: rgba(255,255,255,0.45);
  }

  /* ── Alert ── */
  .alert {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 20px;
  }
  .alert--success {
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #4ade80;
  }
  .alert--error {
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #f87171;
  }

  /* ── Form ── */
  .form { display: flex; flex-direction: column; gap: 18px; }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .field { display: flex; flex-direction: column; gap: 6px; }

  label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  input, select {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14px;
    color: #fff;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
    width: 100%;
  }

  input:focus, select:focus {
    border-color: rgba(168, 85, 247, 0.6);
    background: rgba(255,255,255,0.08);
  }

  input:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  select option { background: #1a1a1a; color: #fff; }

  .field-hint {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
  }

  .field-hint--block {
    display: block;
    margin-top: -8px;
  }

  .field-hint code {
    font-size: 10px;
    color: rgba(255,255,255,0.45);
  }

  .actions { margin-top: 8px; }

  .btn-primary {
    background: #a855f7;
    border: none;
    border-radius: 8px;
    padding: 11px 24px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    color: #fff;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .btn-primary:hover {
    background: #9333ea;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.4);
  }

  .btn-primary:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  @media (max-width: 520px) {
    .card { padding: 28px 20px; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>
