      /* ── Top bar — Header.astro (id=topbar, app-header--admin) ── */
      #topbar-utilities {
        display: none !important;
      }

      #tabs-scroll {
        display: none !important;
      }

      /* Hidden status / model controls (still updated by os-map-loader.js) */
      #health-checked {
        opacity: 0.35;
        transition: opacity 0.2s ease;
        display: inline-flex;
        align-items: center;
        color: var(--muted);
      }
      #health-checked svg,
      #topbar-stale-warn svg {
        display: block;
      }
      #topbar-stale-warn {
        display: inline-flex;
        align-items: center;
        color: #fbbf24;
      }

      #model-select {
        font: inherit;
        font-size: 0.72rem;
        color: var(--fg);
        background: var(--accent-select-bg);
        border: 1px solid var(--panel-border);
        border-radius: 7px;
        padding: 0.28rem 1.6rem 0.28rem 0.55rem;
        max-width: 13rem;
        cursor: pointer;
        appearance: none;
      }
      #model-select:hover:not(:disabled) { border-color: #3b82f6; }
      #model-select:disabled { opacity: 0.55; cursor: default; }

      /* ── Tooltips ──
         Default: centered below the trigger.
         .tt-left anchors to left edge (for items near right edge of screen). */
      [data-tooltip] { position: relative; }
      [data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        top: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        background: var(--tooltip-bg);
        border: 1px solid var(--tooltip-border);
        color: var(--tooltip-fg);
        font-size: 0.68rem;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-variant-numeric: tabular-nums;
        padding: 3px 8px;
        border-radius: 5px;
        pointer-events: none;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.12s;
        z-index: 9999;
      }
      [data-tooltip]:hover::after { opacity: 1; visibility: visible; }
      [data-tooltip].tooltip-open::after { opacity: 1; visibility: visible; }
      /* Items near the right edge: right-align the tooltip */
      [data-tooltip].tt-left::after { left: auto; right: 0; transform: none; }
      .topbar-deploy-dot[data-tooltip]::after {
        white-space: normal;
        max-width: min(72vw, 16rem);
        text-align: left;
        line-height: 1.35;
      }

      /* Tabs — scroll wrapper keeps items from overlapping the right cluster */
      #tabs-scroll {
        display: flex;
        flex: 1 1 auto;
        min-width: 0;
        align-items: center;
        pointer-events: auto;
        overflow-x: auto;
        overflow-y: visible;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      #tabs-scroll::-webkit-scrollbar { display: none; }
      #tabs {
        display: flex;
        flex-wrap: nowrap;
        gap: 0.25rem;
        pointer-events: auto;
        align-items: center;
        min-width: 0;
      }
      .tab-item,
      .tab-item.tab-dropdown {
        flex-shrink: 0;
      }
      .tab-item {
        pointer-events: auto;
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 7px;
        padding: 0.28rem 0.7rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        text-decoration: none;
        white-space: nowrap;
      }
      .tab-item:hover { color: var(--fg); }
      .tab-item.active {
        color: var(--fg);
        background: var(--tab-active-bg);
        border-color: var(--panel-border);
      }
      .tab-item.tab-dragging { opacity: 0.55; }
      .tab-item.tab-drop-before { box-shadow: inset 2px 0 0 #58a6ff; }
      .tab-item.tab-drop-after { box-shadow: inset -2px 0 0 #58a6ff; }
      .tab-item.tab-link { padding: 0; border: none; background: none; }
      .tab-item.tab-link > a {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.28rem 0.7rem;
        color: inherit;
        text-decoration: none;
        border-radius: 7px;
        white-space: nowrap;
      }
      .tab-grip {
        cursor: grab;
        opacity: 0.4;
        font-size: 0.62rem;
        letter-spacing: -0.12em;
        line-height: 1;
        flex: 0 0 auto;
      }
      .tab-grip:active { cursor: grabbing; }
      .tab-icon,
      .tab-caret {
        flex: 0 0 auto;
        pointer-events: none;
      }
      .tab-icon { font-size: 0.9rem; line-height: 1; display: inline-flex; align-items: center; }
      .tab-icon svg { display: block; }
      .tab-label {
        white-space: nowrap;
        flex-shrink: 0;
      }
      .tab-caret { font-size: 0.55rem; opacity: 0.65; margin-left: -0.1rem; }
      .tab-dropdown { position: relative; }
      .tab-dropdown-trigger {
        font: inherit;
        font-size: inherit;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        white-space: nowrap;
      }
      .tab-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        min-width: 10.5rem;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.3rem;
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        box-shadow: var(--shadow-lg);
        z-index: 30;
      }
      .tab-dropdown.open .tab-dropdown-menu { display: flex; }
      .tab-dropdown-item {
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 6px;
        padding: 0.35rem 0.55rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        text-align: left;
      }
      .tab-dropdown-item:hover { color: var(--fg); background: var(--tab-active-bg); }
      .tab-dropdown-item.active {
        color: var(--fg);
        background: var(--tab-active-bg);
        border-color: var(--panel-border);
      }

      /* Left toolbar */
      #tools {
        position: fixed;
        left: 0.7rem;
        bottom: calc(var(--footer-nav-h) + 0.5rem);
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        z-index: 20;
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }
      #tools button {
        width: 2.1rem;
        height: 2.1rem;
