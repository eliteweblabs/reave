        color: var(--fg);
        cursor: pointer;
        white-space: nowrap;
      }
      .admin-setup-alert-btn--primary {
        border-color: rgba(251, 191, 36, 0.45);
        background: rgba(251, 191, 36, 0.14);
        color: var(--fg);
      }
      .admin-setup-alert-btn--primary:hover {
        background: rgba(251, 191, 36, 0.22);
      }
      .admin-setup-alert-btn--danger {
