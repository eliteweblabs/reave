        background: color-mix(in srgb, var(--accent, #3b82f6) 8%, var(--surface-subtle));
      }
      .cl-archived {
        font-size: 0.62rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
