---
/**
 * Personal Business OS map (v2): interactive, Railway-style canvas.
 * /dashboard redirects here. Nodes/edges live in `public/admin/os-map-data.js`.
 * Tabs switch between the "System" runtime map and the "MCP & CLI" tooling map.
 * Drag cards (snap to grid), drag background to pan, wheel/±/Fit to zoom.
 */
import Favicon from "../../components/Favicon.astro";
import Header from "../../components/Header.astro";
import AdminFooterNav from "../../components/AdminFooterNav.astro";
import { getCompanyConfig, companyToBrandContext } from "../../lib/companyConfig";
import { getInstallConfigClient, PROFILE_MENU_LABELS } from "../../lib/installConfig";
import { isDeploymentOwner } from "../../lib/deploymentOwner";
import "../../styles/brand.css";

export const prerender = false;

const { userId } = Astro.locals.auth();
const company = await getCompanyConfig(Astro.request);
const companyBrand = companyToBrandContext(company, Astro.request);
const installConfigClient = getInstallConfigClient();
const isOwner = userId ? await isDeploymentOwner(Astro) : false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover, interactive-widget=resizes-content" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0d14" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={company.name || 'Business OS'} />
    <meta name="application-name" content={company.name || 'Business OS'} />
    <link rel="manifest" href="/admin/manifest.webmanifest" />
    <title>{company.name} Admin</title>
    <Favicon />
    <link rel="stylesheet" href="/ios-sheet.css" />
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #ffffff;
        --grid: #e2e8f0;
        --fg: #0f172a;
        --muted: #64748b;
        --card: #ffffff;
        --card-border: #e2e8f0;
        --panel: #f8fafc;
        --panel-border: #e2e8f0;
        --fg-secondary: #334155;
        --surface-hover: rgba(0, 0, 0, 0.04);
        --surface-hover-strong: rgba(0, 0, 0, 0.06);
        --surface-subtle: rgba(0, 0, 0, 0.02);
        --surface-muted: rgba(0, 0, 0, 0.03);
        --surface-raised: rgba(0, 0, 0, 0.02);
        --border-hover: rgba(0, 0, 0, 0.12);
        --border-strong-hover: rgba(0, 0, 0, 0.18);
        --tab-active-bg: #f1f5f9;
        --mode-tab-active-bg: #e2e8f0;
        --list-item-active-bg: #eff6ff;
        --list-item-active-border: #93c5fd;
        --dropdown-bg: #ffffff;
        --dropdown-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
        --tooltip-bg: #ffffff;
        --tooltip-border: #e2e8f0;
        --tooltip-fg: #475569;
        --popover-bg: #ffffff;
        --popover-border: #e2e8f0;
        --popover-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
        --code-bg: #f1f5f9;
        --code-border: #cbd5e1;
        --code-fg: #2563eb;
        --code-label-fg: #475569;
        --textarea-fg: #1e293b;
        --elabel-bg: rgba(255, 255, 255, 0.92);
        --overlay-bg: rgba(255, 255, 255, 0.96);
        --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.1);
        --shadow-node-inset: 0 1px 0 rgba(255, 255, 255, 0.8) inset;
        --shadow-node: 0 6px 20px rgba(0, 0, 0, 0.08);
        --shadow-node-hover: 0 6px 22px rgba(0, 0, 0, 0.12);
        --nav-icon: rgba(0, 0, 0, 0.45);
        --nav-icon-hover: rgba(0, 0, 0, 0.72);
        --nav-icon-active: #0f172a;
        --nav-indicator-bg: rgba(0, 0, 0, 0.05);
        --footer-nav-glass-border: 1px solid rgba(0, 0, 0, 0.08);
        --footer-nav-glass-bg: transparent;
        --footer-nav-glass-blur: blur(18px) saturate(1.15);
        --badge-ring: rgba(255, 255, 255, 0.85);
        --accent-select-bg: rgba(0, 0, 0, 0.04);
        --sc-pop-row-hover: #eff6ff;
        --sc-pop-row-border: #93c5fd;
        --sc-copied-bg: #ecfdf5;
        --msg-user-bg: #dbeafe;
        --msg-user-border: #93c5fd;
        --msg-action-hover: rgba(0, 0, 0, 0.06);
        --msg-action-hover-user: rgba(0, 0, 0, 0.08);
        --img-border: rgba(0, 0, 0, 0.08);
        --underline-fg: rgba(0, 0, 0, 0.25);
        --search-close: rgba(0, 0, 0, 0.55);
        --search-icon: rgba(0, 0, 0, 0.5);
        --icon-muted: rgba(0, 0, 0, 0.55);
        --list-row-odd: #f1f5f9;
        --list-row-even: #ffffff;
        --safe-top: env(safe-area-inset-top, 0px);
        --safe-bottom: env(safe-area-inset-bottom, 0px);
        --topbar-h: calc(var(--app-header-h, 3.25rem) + var(--safe-top));
        --footer-nav-pill-h: var(--control-h);
        --footer-nav-bottom-gap: 0px;
        --footer-nav-h: calc(var(--footer-nav-pill-h) + var(--safe-bottom) + var(--footer-nav-bottom-gap));
        --ch-compose-gap: 0.35rem;
        --ch-compose-h: var(--control-h);
        --ch-inline-home-w: 2.25rem;
        --ch-inline-home-gap: 0.4rem;
        --footer-chat-stack: calc(var(--footer-nav-h) + var(--ch-compose-gap) + var(--ch-compose-h));
        --footer-scroll-pad: calc(var(--footer-nav-h) + 0.5rem);
        --create-fab-bg: var(--brand-gradient);
        --create-fab-shadow: var(--brand-gradient-shadow);
        --radius-pill: var(--radius-input);
        --radius-input: 8px;
        --control-h: 2.75rem;
        --control-inset: 0.22rem;
        --sidebar-w: 260px;
        --sidebar-min-w: 200px;
        --sidebar-max-w: 520px;
      }
      @media (min-width: 640px) {
        :root {
          --footer-nav-bottom-gap: 1.25rem;
        }
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0a0d14;
          --grid: #1a2230;
          --fg: #e9eef6;
          --muted: #8b97a8;
          --card: #11151d;
          --card-border: #232c3a;
          --panel: #121722;
          --panel-border: #283142;
          --fg-secondary: rgba(255, 255, 255, 0.88);
          --surface-hover: rgba(255, 255, 255, 0.04);
          --surface-hover-strong: rgba(255, 255, 255, 0.06);
          --surface-subtle: rgba(255, 255, 255, 0.02);
          --surface-muted: rgba(255, 255, 255, 0.03);
          --surface-raised: rgba(255, 255, 255, 0.02);
          --border-hover: rgba(255, 255, 255, 0.18);
          --border-strong-hover: rgba(255, 255, 255, 0.2);
          --tab-active-bg: #1b2230;
          --mode-tab-active-bg: #1e2b3c;
          --list-item-active-bg: #11253d;
          --list-item-active-border: #2d5a94;
          --dropdown-bg: rgba(14, 17, 24, 0.98);
          --dropdown-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
          --tooltip-bg: #1a2030;
          --tooltip-border: #2d3a4f;
          --tooltip-fg: #c8d4e3;
          --popover-bg: #111827;
          --popover-border: #283142;
          --popover-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 2px 8px rgba(0, 0, 0, 0.4);
          --code-bg: #0f1825;
          --code-border: #1e3a5f;
          --code-fg: #93c5fd;
          --code-label-fg: #c7d0dc;
          --textarea-fg: #c9d1d9;
          --elabel-bg: rgba(10, 13, 20, 0.82);
          --overlay-bg: rgba(10, 13, 20, 0.96);
          --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.35);
          --shadow-node-inset: 0 1px 0 rgba(255, 255, 255, 0.02) inset;
          --shadow-node: 0 6px 20px rgba(0, 0, 0, 0.35);
          --shadow-node-hover: 0 6px 22px rgba(0, 0, 0, 0.45);
          --nav-icon: rgba(255, 255, 255, 0.58);
          --nav-icon-hover: rgba(255, 255, 255, 0.88);
          --nav-icon-active: #ffffff;
          --nav-indicator-bg: rgba(255, 255, 255, 0.05);
          --footer-nav-glass-border: 1px solid rgba(255, 255, 255, 0.08);
          --badge-ring: rgba(10, 13, 20, 0.55);
          --accent-select-bg: rgba(255, 255, 255, 0.04);
          --sc-pop-row-hover: #1e3a5f;
          --sc-pop-row-border: #2d5a94;
          --sc-copied-bg: #0f2c1e;
          --msg-user-bg: #1e3a5f;
          --msg-user-border: #2d5a94;
          --msg-action-hover: rgba(255, 255, 255, 0.08);
          --msg-action-hover-user: rgba(255, 255, 255, 0.12);
          --img-border: rgba(255, 255, 255, 0.08);
          --underline-fg: rgba(255, 255, 255, 0.25);
          --search-close: rgba(255, 255, 255, 0.7);
          --search-icon: rgba(255, 255, 255, 0.75);
          --icon-muted: rgba(255, 255, 255, 0.72);
          --list-row-odd: #121722;
          --list-row-even: #171d2a;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        width: 100%;
        height: 100%;
        height: 100dvh;
        min-height: 100%;
        min-height: 100dvh;
        min-height: -webkit-fill-available;
        margin: 0;
        padding: 0;
        overflow: hidden;
        overscroll-behavior: none;
        background: var(--bg);
      }
      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
        position: fixed;
        inset: 0;
      }
      body {
        position: fixed;
        inset: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        color: var(--fg);
        touch-action: manipulation;
      }

      /* Pad scroll regions for the floating footer; panel shells stay edge-to-edge. */
      :is(
        .ch-list,
        .ch-messages,
        .de-list,
        .em-detail,
        .search-overlay-results,
        .re-form-scroll,
        .de-sc-dir-body,
        .home-dashboard-scroll,
        .profile-panel-scroll,
        .schedule-panel-scroll
      ) {
        scroll-padding-bottom: var(--footer-scroll-pad);
      }

      /* Floating header clearance — transparent top bar; inset on columns, not panel shells. */
      #chat-panel > .ch-sidebar,
      #chat-panel > .ch-pane,
      #email-panel > .ch-sidebar,
      #email-panel > .ch-pane,
      #doc-editor > .de-sidebar,
      #doc-editor > .de-pane,
      #doc-editor > .ch-sidebar,
      #knowledge-editor > .de-sidebar,
      #knowledge-editor > .de-pane,
      #knowledge-editor > .ch-sidebar,
      #work-editor > .de-sidebar,
      #work-editor > .de-pane,
      #work-editor > .ch-sidebar,
      #todo-editor > .de-sidebar,
      #todo-editor > .de-pane,
      #todo-editor > .ch-sidebar,
      #schedule-panel > .ch-sidebar,
      #schedule-panel > .de-pane,
      #clients-editor > .de-sidebar,
      #clients-editor > .de-pane,
      #clients-editor > .ch-sidebar,
      #rule-editor > .de-sidebar,
      #rule-editor > .de-pane,
      #rule-editor > .ch-sidebar,
      .de-pane {
        padding-top: calc(var(--topbar-h) + var(--setup-alert-h, 0px));
      }

      /* App panels — no browser zoom; canvas (#wrap) keeps custom pinch/pan. */
      #topbar,
      #tools,
      #legend,
      #doc-editor,
      #chat-panel,
      #email-panel,
      #knowledge-editor,
      #work-editor,
      #todo-editor,
      #schedule-panel,
      #clients-editor,
      #rule-editor,
      #home-dashboard,
      #settings-panel,
      #search-overlay,
      #os-dialog-backdrop {
        touch-action: manipulation;
      }

      /* iOS still auto-zooms sub-16px inputs even with user-scalable=no. */
      input,
      textarea,
      select {
        font-size: max(16px, 1em);
      }

      /* Editor chrome — keep inputs/message bodies selectable */
      button,
      select,
      .ch-msg-action,
      .ios-icon-btn,
      .os-dialog-btn,
      .tab-dropdown-item {
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }

      /* Pill field — inset buttons/actions live inside the input shell. */
      .control-field {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        width: 100%;
        min-height: var(--control-h);
        padding: var(--control-inset);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-input);
        background: var(--card);
        box-sizing: border-box;
        transition: border-color 0.12s;
      }
      .control-field:has(textarea) {
        border-radius: var(--radius-input);
        align-items: flex-end;
      }
      .control-field:focus-within {
        border-color: #3b82f6;
      }
      .control-field > :is(input, textarea) {
        flex: 1;
        min-width: 0;
        width: 100%;
        margin: 0;
        border: none !important;
        background: transparent !important;
        border-radius: 0 !important;
        outline: none;
        box-shadow: none;
        padding: 0.2rem 0.5rem;
      }
      .control-field > :is(input, textarea):focus {
        border-color: transparent !important;
      }
      .control-field > button,
      .control-field > .ch-compose-actions {
        flex-shrink: 0;
        margin: 0;
        position: static;
        transform: none;
      }
      .control-field > .de-new-btn.ch-new-btn {
        width: calc(var(--control-h) - var(--control-inset) * 2);
        height: calc(var(--control-h) - var(--control-inset) * 2);
        min-width: calc(var(--control-h) - var(--control-inset) * 2);
        padding: 0;
      }
      .control-field > .de-new-btn.ch-new-btn:active {
        transform: scale(0.94);
      }
      .control-field > .panel-list-search-clear,
      .control-field > .search-overlay-clear,
      .control-field > .ch-send,
      .control-field > .ch-compose-actions > .ch-send {
        width: calc(var(--control-h) - var(--control-inset) * 2);
        height: calc(var(--control-h) - var(--control-inset) * 2);
        min-height: calc(var(--control-h) - var(--control-inset) * 2);
        min-width: calc(var(--control-h) - var(--control-inset) * 2);
        padding: 0;
      }
      .control-field > .ch-stop,
      .control-field > .ch-compose-actions > .ch-stop {
        height: calc(var(--control-h) - var(--control-inset) * 2);
        min-height: calc(var(--control-h) - var(--control-inset) * 2);
        min-width: calc(var(--control-h) - var(--control-inset) * 2);
        padding: 0 0.75rem;
      }

      #wrap {
        position: fixed;
        inset: 0;
        height: 100dvh;
        overflow: hidden;
        cursor: grab;
        background-color: var(--bg);
        background-image: radial-gradient(circle at 1px 1px, var(--grid) 1.4px, transparent 0);
        background-size: 24px 24px;
        background-position: 0 0;
        touch-action: none;
      }
      #wrap.panning { cursor: grabbing; }

      #world {
        position: absolute;
        top: 0;
        left: 0;
        transform-origin: 0 0;
        width: 0;
        height: 0;
      }
      #edges {
        position: absolute;
        top: 0;
        left: 0;
        width: 6000px;
        height: 4200px;
        overflow: visible;
        pointer-events: none;
      }
      .edge { fill: none; stroke-width: 1.6; stroke-dasharray: 6 6; opacity: 0.85; }
      .edge.solid { stroke-dasharray: none; }

      .group {
        position: absolute;
        border: 1px solid hsl(var(--h) 45% 45% / 0.35);
        background: hsl(var(--h) 50% 50% / 0.05);
        border-radius: 16px;
        pointer-events: none;
      }
      .group > .g-label {
        position: absolute;
        top: -0.7rem;
        left: 0.9rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: hsl(var(--h) 70% 72%);
        background: var(--bg);
        padding: 0.1rem 0.5rem;
        border: 1px solid hsl(var(--h) 45% 45% / 0.4);
        border-radius: 7px;
        pointer-events: auto;
        cursor: grab;
        user-select: none;
      }
      .group > .g-label:hover { border-color: hsl(var(--h) 70% 60% / 0.8); }
      .group > .g-label.dragging { cursor: grabbing; }

      .elabel {
        position: absolute;
        transform: translate(-50%, -50%);
        font-size: 0.66rem;
        color: var(--muted);
        background: var(--elabel-bg);
        padding: 0.05rem 0.32rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
      }

      .node {
        position: absolute;
        width: 210px;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-left: 3px solid hsl(var(--h) 75% 58%);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
        cursor: grab;
        user-select: none;
        box-shadow:
          var(--shadow-node-inset),
          var(--shadow-node),
          0 0 0 0 hsl(var(--h) 80% 55% / 0);
        transition: box-shadow 0.15s ease, border-color 0.15s ease;
      }
      .node:hover {
        border-color: hsl(var(--h) 75% 58% / 0.8);
        box-shadow:
          var(--shadow-node-hover),
          0 0 22px hsl(var(--h) 85% 55% / 0.28);
      }
      .node.dragging { cursor: grabbing; z-index: 50; }
      .node.ghost { opacity: 0.6; border-style: dashed; }

      .node .row { display: flex; align-items: center; gap: 0.45rem; }
      .node .chip {
        width: 1.5rem;
        height: 1.5rem;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        border-radius: 7px;
        background: hsl(var(--h) 70% 55% / 0.16);
        border: 1px solid hsl(var(--h) 70% 60% / 0.4);
      }
      /* Real brand logo (Simple Icons) tinted to the node hue via CSS mask. */
      .node .chip .bi {
        width: 0.95rem;
        height: 0.95rem;
        background-color: hsl(var(--h) 90% 72%);
        -webkit-mask: var(--icon) center / contain no-repeat;
        mask: var(--icon) center / contain no-repeat;
      }
      .node .chip-svg svg {
        display: block;
        color: hsl(var(--h) 90% 72%);
      }
      .node .ttl {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--fg);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .sub {
        margin-top: 0.2rem;
        font-size: 0.72rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .sub.sub-multi {
        white-space: normal;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .node .status {
        margin-top: 0.4rem;
        font-size: 0.7rem;
        color: var(--sc, #8b97a8);
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .node .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc, #8b97a8);
        box-shadow: 0 0 6px var(--sc, #8b97a8);
      }

      /* Status states (driven by /api/health) */
      .st-up { --sc: #3fb950; }
      .st-down { --sc: #f85149; }
      .st-degraded { --sc: #d29922; }
      .st-configured { --sc: #58a6ff; }
      .st-unconfigured { --sc: #6e7681; }
      .st-unknown { --sc: #6e7681; }
      .st-checking { --sc: #8b97a8; }
      .node .status.st-checking::before { animation: stpulse 1.1s ease-in-out infinite; }
      @keyframes stpulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
      }

      /* ── Setup alerts (PWA install + push permission) ── */
      .admin-setup-alerts {
        width: 100%;
        flex-shrink: 0;
        padding: 0.45rem max(0.65rem, env(safe-area-inset-right, 0px)) 0.45rem
          max(0.65rem, env(safe-area-inset-left, 0px));
      }
      .admin-setup-alerts[hidden] {
        display: none !important;
      }
      .admin-setup-alert {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        max-width: 52rem;
        margin: 0 auto;
        padding: 0.65rem 0.75rem;
        border-radius: 10px;
        border: 1px solid var(--panel-border);
        background: var(--overlay-bg);
        box-shadow: var(--shadow-lg);
      }
      .admin-setup-alert--pwa {
        border-color: rgba(94, 234, 212, 0.35);
        background: color-mix(in srgb, var(--overlay-bg) 88%, rgba(94, 234, 212, 0.14));
      }
      .admin-setup-alert--push {
        border-color: rgba(251, 191, 36, 0.35);
        background: color-mix(in srgb, var(--overlay-bg) 88%, rgba(251, 191, 36, 0.12));
      }
      .admin-setup-alert--confirm {
        border-color: rgba(248, 113, 113, 0.35);
        background: color-mix(in srgb, var(--overlay-bg) 88%, rgba(248, 113, 113, 0.1));
      }
      .admin-setup-alert-copy {
        flex: 1;
        min-width: 0;
      }
      .admin-setup-alert-copy strong {
        display: block;
        font-size: 0.82rem;
        font-weight: 650;
        line-height: 1.25;
        margin-bottom: 0.2rem;
      }
      .admin-setup-alert-copy p {
        margin: 0;
        font-size: 0.76rem;
        line-height: 1.4;
        color: var(--muted);
      }
      .admin-setup-alert-error {
        margin: 0.35rem 0 0;
        font-size: 0.74rem;
        color: #f87171;
      }
      .admin-setup-alert-actions {
        display: flex;
        align-items: flex-start;
        gap: 0.35rem;
        flex-shrink: 0;
      }
      .admin-setup-alert-btn {
        font: inherit;
        font-size: 0.74rem;
        font-weight: 600;
        padding: 0.42rem 0.7rem;
        border-radius: 8px;
        border: 1px solid var(--panel-border);
