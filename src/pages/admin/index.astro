---
/**
 * Personal Business OS map (v2): interactive, Railway-style canvas.
 * /dashboard redirects here. Nodes/edges live in `public/admin/os-map-data.js`.
 * Tabs switch between the "System" runtime map and the "MCP & CLI" tooling map.
 * Drag cards (snap to grid), drag background to pan, wheel/±/Fit to zoom.
 */
import Favicon from "../../components/Favicon.astro";
import { clerkClient } from "@clerk/astro/server";
import { getCompanyConfig } from "../../lib/companyConfig";

export const prerender = false;

const { userId } = Astro.locals.auth();
const company = await getCompanyConfig(Astro.request);

let avatarUrl: string | null = null;
let userInitials = "";

if (userId) {
  try {
    const client = clerkClient(Astro);
    const user = await client.users.getUser(userId);
    avatarUrl = user.imageUrl ?? null;
    const first = user.firstName?.[0] ?? "";
    const last = user.lastName?.[0] ?? "";
    userInitials =
      ((first + last).toUpperCase() ||
        user.emailAddresses?.[0]?.emailAddress?.[0]?.toUpperCase()) ??
      "?";
  } catch {
    // Clerk unreachable — fall back to initials placeholder
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0a0d14" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="manifest" href="/admin/manifest.webmanifest" />
    <title>Business OS — map</title>
    <Favicon />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0a0d14;
        --grid: #1a2230;
        --fg: #e9eef6;
        --muted: #8b97a8;
        --card: #11151d;
        --card-border: #232c3a;
        --panel: #121722;
        --panel-border: #283142;
        --topbar-h: 3.4rem;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: var(--bg);
        color: var(--fg);
        overflow: hidden;
        touch-action: manipulation;
      }

      /* App panels — no browser zoom; canvas (#wrap) keeps custom pinch/pan. */
      #topbar,
      #tools,
      #legend,
      #doc-editor,
      #chat-panel,
      #email-panel,
      #knowledge-editor,
      #work-editor,
      #clients-editor,
      #rule-editor,
      #os-dialog-backdrop {
        touch-action: manipulation;
      }

      /* iOS still auto-zooms sub-16px inputs even with user-scalable=no. */
      input,
      textarea,
      select {
        font-size: max(16px, 1em);
      }

      /* Editor chrome — keep inputs/message bodies selectable */
      button,
      select,
      .ch-msg-action,
      .ios-icon-btn,
      .os-dialog-btn,
      .tab-dropdown-item {
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }

      #wrap {
        position: fixed;
        inset: 0;
        overflow: hidden;
        cursor: grab;
        background-color: var(--bg);
        background-image: radial-gradient(circle at 1px 1px, var(--grid) 1.4px, transparent 0);
        background-size: 24px 24px;
        background-position: 0 0;
        touch-action: none;
      }
      #wrap.panning { cursor: grabbing; }

      #world {
        position: absolute;
        top: 0;
        left: 0;
        transform-origin: 0 0;
        width: 0;
        height: 0;
      }
      #edges {
        position: absolute;
        top: 0;
        left: 0;
        width: 6000px;
        height: 4200px;
        overflow: visible;
        pointer-events: none;
      }
      .edge { fill: none; stroke-width: 1.6; stroke-dasharray: 6 6; opacity: 0.85; }
      .edge.solid { stroke-dasharray: none; }

      .group {
        position: absolute;
        border: 1px solid hsl(var(--h) 45% 45% / 0.35);
        background: hsl(var(--h) 50% 50% / 0.05);
        border-radius: 16px;
        pointer-events: none;
      }
      .group > .g-label {
        position: absolute;
        top: -0.7rem;
        left: 0.9rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: hsl(var(--h) 70% 72%);
        background: var(--bg);
        padding: 0.1rem 0.5rem;
        border: 1px solid hsl(var(--h) 45% 45% / 0.4);
        border-radius: 7px;
        pointer-events: auto;
        cursor: grab;
        user-select: none;
      }
      .group > .g-label:hover { border-color: hsl(var(--h) 70% 60% / 0.8); }
      .group > .g-label.dragging { cursor: grabbing; }

      .elabel {
        position: absolute;
        transform: translate(-50%, -50%);
        font-size: 0.66rem;
        color: var(--muted);
        background: rgba(10, 13, 20, 0.82);
        padding: 0.05rem 0.32rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
      }

      .node {
        position: absolute;
        width: 210px;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-left: 3px solid hsl(var(--h) 75% 58%);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
        cursor: grab;
        user-select: none;
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.02) inset,
          0 6px 20px rgba(0, 0, 0, 0.35),
          0 0 0 0 hsl(var(--h) 80% 55% / 0);
        transition: box-shadow 0.15s ease, border-color 0.15s ease;
      }
      .node:hover {
        border-color: hsl(var(--h) 75% 58% / 0.8);
        box-shadow:
          0 6px 22px rgba(0, 0, 0, 0.45),
          0 0 22px hsl(var(--h) 85% 55% / 0.28);
      }
      .node.dragging { cursor: grabbing; z-index: 50; }
      .node.ghost { opacity: 0.6; border-style: dashed; }

      .node .row { display: flex; align-items: center; gap: 0.45rem; }
      .node .chip {
        width: 1.5rem;
        height: 1.5rem;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        font-size: 0.9rem;
        border-radius: 7px;
        background: hsl(var(--h) 70% 55% / 0.16);
        border: 1px solid hsl(var(--h) 70% 60% / 0.4);
      }
      /* Real brand logo (Simple Icons) tinted to the node hue via CSS mask. */
      .node .chip .bi {
        width: 0.95rem;
        height: 0.95rem;
        background-color: hsl(var(--h) 90% 72%);
        -webkit-mask: var(--icon) center / contain no-repeat;
        mask: var(--icon) center / contain no-repeat;
      }
      .node .ttl {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--fg);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .sub {
        margin-top: 0.2rem;
        font-size: 0.72rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .node .sub.sub-multi {
        white-space: normal;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .node.rule-card { cursor: pointer; }

      #rule-editor {
        display: none;
        flex-direction: column;
        position: fixed;
        top: var(--topbar-h);
        right: 0;
        bottom: 0;
        width: min(400px, 100vw);
        z-index: 35;
        background: var(--panel);
        border-left: 1px solid var(--panel-border);
        box-shadow: -8px 0 32px rgba(0, 0, 0, 0.35);
      }
      #rule-editor.re-pane-active { display: flex; }
      #rule-editor .re-idle {
        padding: 1rem 1.1rem;
        font-size: 0.82rem;
        color: var(--muted);
        line-height: 1.45;
      }
      #rule-editor .re-idle strong { color: var(--fg); }
      #rule-editor .re-warn { color: #f85149; margin-top: 0.75rem; font-size: 0.75rem; }
      #rule-editor .re-head {
        padding: 0.65rem 0.85rem;
        border-bottom: 1px solid var(--panel-border);
      }
      #rule-editor .re-form {
        flex: 1 1 auto;
        overflow: auto;
        padding: 0.85rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      #rule-editor .re-field { display: flex; flex-direction: column; gap: 0.3rem; }
      #rule-editor .re-label {
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
      }
      #rule-editor .re-field input,
      #rule-editor .re-field textarea,
      #rule-editor .re-field select {
        font: inherit;
        font-size: max(16px, 0.82rem);
        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 8px;
        padding: 0.45rem 0.55rem;
        resize: vertical;
      }
      #rule-editor .re-checks { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; }
      #rule-editor .re-check {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: var(--fg);
        cursor: pointer;
      }
      #rule-editor .re-actions {
        display: flex;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        border-top: 1px solid var(--panel-border);
      }
      .node .status {
        margin-top: 0.4rem;
        font-size: 0.7rem;
        color: var(--sc, #8b97a8);
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .node .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--sc, #8b97a8);
        box-shadow: 0 0 6px var(--sc, #8b97a8);
      }

      /* Status states (driven by /api/health) */
      .st-up { --sc: #3fb950; }
      .st-down { --sc: #f85149; }
      .st-degraded { --sc: #d29922; }
      .st-configured { --sc: #58a6ff; }
      .st-unconfigured { --sc: #6e7681; }
      .st-unknown { --sc: #6e7681; }
      .st-checking { --sc: #8b97a8; }
      .node .status.st-checking::before { animation: stpulse 1.1s ease-in-out infinite; }
      @keyframes stpulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 1; }
      }

      /* ── Top bar ── */
      #topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--topbar-h);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 0.75rem;
        pointer-events: none;
        z-index: 20;
        overflow: visible;
        background: rgba(10, 13, 20, 0.72);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(35, 44, 58, 0.6);
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }

      /* Every direct child that needs clicks opts in */
      #topbar > * { pointer-events: auto; }
      #topbar .spacer { display: none; }

      #topbar .brand {
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
        line-height: 0;
      }
      #topbar .brand-img {
        height: 1.4rem;
        width: auto;
        display: block;
        pointer-events: none;
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }

      /* Right-side icon cluster */
      .topbar-end {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
      }

      /* Shared style for the small icon/emoji items */
      .tb-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        line-height: 1;
        color: var(--muted);
        cursor: default;
      }
      #health-checked {
        opacity: 0.35;
        transition: opacity 0.2s ease;
        padding-right: 0.5rem;
        border-right: 1px solid var(--panel-border);
      }

      #model-select {
        font: inherit;
        font-size: 0.72rem;
        color: var(--fg);
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--panel-border);
        border-radius: 7px;
        padding: 0.28rem 1.6rem 0.28rem 0.55rem;
        max-width: 13rem;
        cursor: pointer;
        appearance: none;
        background-image:
          linear-gradient(45deg, transparent 50%, var(--muted) 50%),
          linear-gradient(135deg, var(--muted) 50%, transparent 50%);
        background-position:
          calc(100% - 12px) calc(50% + 1px),
          calc(100% - 7px) calc(50% + 1px);
        background-size: 5px 5px, 5px 5px;
        background-repeat: no-repeat;
      }
      #model-select:hover:not(:disabled) { border-color: #3b82f6; }
      #model-select:disabled { opacity: 0.55; cursor: default; }

      /* Profile button — matches site Header.astro */
      .topbar-profile-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid rgba(168, 85, 247, 0.5);
        background: transparent;
        cursor: pointer;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .topbar-profile-btn:hover {
        border-color: rgba(168, 85, 247, 0.9);
        box-shadow: 0 0 14px rgba(168, 85, 247, 0.4);
      }
      .topbar-profile-avatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        pointer-events: none;
      }
      .topbar-profile-initials {
        font-size: 13px;
        font-weight: 700;
        color: #a855f7;
        letter-spacing: 0.02em;
        pointer-events: none;
      }

      .topbar-icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        border: 1px solid var(--panel-border);
        background: var(--panel);
        color: var(--muted);
        cursor: pointer;
        padding: 0;
        font-size: 1rem;
        line-height: 1;
        transition: border-color 0.15s, background 0.15s, color 0.15s;
      }
      .topbar-icon-btn:hover {
        color: var(--fg);
        border-color: #4b5563;
      }

      /* ── Tooltips ──
         Default: centered below the trigger.
         .tt-left anchors to left edge (for items near right edge of screen). */
      [data-tooltip] { position: relative; }
      [data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        top: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        background: #1a2030;
        border: 1px solid #2d3a4f;
        color: #c8d4e3;
        font-size: 0.68rem;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-variant-numeric: tabular-nums;
        padding: 3px 8px;
        border-radius: 5px;
        pointer-events: none;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.12s;
        z-index: 9999;
      }
      [data-tooltip]:hover::after { opacity: 1; visibility: visible; }
      /* Items near the right edge: right-align the tooltip */
      [data-tooltip].tt-left::after { left: auto; right: 0; transform: none; }

      /* Tabs — scroll wrapper keeps items from overlapping the right cluster */
      #tabs-scroll {
        display: flex;
        flex: 1 1 auto;
        min-width: 0;
        align-items: center;
        pointer-events: auto;
        overflow-x: auto;
        overflow-y: visible;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        -ms-overflow-style: none;
      }
      #tabs-scroll::-webkit-scrollbar { display: none; }
      #tabs {
        display: flex;
        flex-wrap: nowrap;
        gap: 0.25rem;
        pointer-events: auto;
        align-items: center;
        min-width: 0;
      }
      .tab-item,
      .tab-item.tab-dropdown {
        flex-shrink: 0;
      }
      .tab-item {
        pointer-events: auto;
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 7px;
        padding: 0.28rem 0.7rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        text-decoration: none;
        white-space: nowrap;
      }
      .tab-item:hover { color: var(--fg); }
      .tab-item.active {
        color: var(--fg);
        background: #1b2230;
        border-color: var(--panel-border);
      }
      .tab-item.tab-dragging { opacity: 0.55; }
      .tab-item.tab-drop-before { box-shadow: inset 2px 0 0 #58a6ff; }
      .tab-item.tab-drop-after { box-shadow: inset -2px 0 0 #58a6ff; }
      .tab-item.tab-link { padding: 0; border: none; background: none; }
      .tab-item.tab-link > a {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.28rem 0.7rem;
        color: inherit;
        text-decoration: none;
        border-radius: 7px;
        white-space: nowrap;
      }
      .tab-grip {
        cursor: grab;
        opacity: 0.4;
        font-size: 0.62rem;
        letter-spacing: -0.12em;
        line-height: 1;
        flex: 0 0 auto;
      }
      .tab-grip:active { cursor: grabbing; }
      .tab-icon,
      .tab-caret {
        flex: 0 0 auto;
        pointer-events: none;
      }
      .tab-icon { font-size: 0.9rem; line-height: 1; }
      .tab-label {
        white-space: nowrap;
        flex-shrink: 0;
      }
      .tab-caret { font-size: 0.55rem; opacity: 0.65; margin-left: -0.1rem; }
      .tab-dropdown { position: relative; }
      .tab-dropdown-trigger {
        font: inherit;
        font-size: inherit;
        color: inherit;
        background: transparent;
        border: none;
        padding: 0;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        white-space: nowrap;
      }
      .tab-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        min-width: 10.5rem;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.3rem;
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
        z-index: 30;
      }
      .tab-dropdown.open .tab-dropdown-menu { display: flex; }
      .tab-dropdown-item {
        font: inherit;
        font-size: 0.76rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 6px;
        padding: 0.35rem 0.55rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        text-align: left;
      }
      .tab-dropdown-item:hover { color: var(--fg); background: #1b2230; }
      .tab-dropdown-item.active {
        color: var(--fg);
        background: #1b2230;
        border-color: var(--panel-border);
      }

      /* Compact header — icon-only tabs, fewer chrome items */
      @media (max-width: 1280px) {
        #topbar {
          gap: 0.35rem;
          padding-left: max(0.5rem, env(safe-area-inset-left));
          padding-right: max(0.5rem, env(safe-area-inset-right));
        }
        #topbar .brand-img { height: 1.25rem; }
        #tabs { gap: 0.12rem; }
        .tab-item,
        .tab-item.tab-dropdown {
          padding: 0.24rem 0.42rem;
          gap: 0.15rem;
        }
        .tab-item.tab-link > a {
          padding: 0.24rem 0.42rem;
        }
        .tab-label { display: none; }
        .tab-grip { display: none; }
        .tab-caret { display: none; }
        .tab-icon { font-size: 0.88rem; }
        .topbar-end { gap: 0.35rem; }
        #health-checked,
        #topbar-stale-warn { display: none; }
        #model-select {
          max-width: 8.75rem;
          font-size: 0.68rem;
          padding: 0.22rem 1.35rem 0.22rem 0.45rem;
        }
        .tab-item.tab-link[data-tab-key="finance"] { display: none; }
      }

      @media (max-width: 639px) {
        :root {
          --topbar-h: 4rem;
        }
        #topbar {
          gap: 0.5rem;
          min-height: var(--topbar-h);
          padding:
            max(0.5rem, env(safe-area-inset-top))
            max(0.75rem, env(safe-area-inset-right))
            0.5rem
            max(0.75rem, env(safe-area-inset-left));
        }
        #topbar .brand-img { height: 1.35rem; }
        #tabs-scroll {
          flex: 1 1 0;
          min-width: 0;
        }
        #tabs {
          flex: 1 0 auto;
          gap: 0.06rem;
        }
        .tab-dropdown.open .tab-dropdown-menu {
          z-index: 100;
        }
        .tab-item,
        .tab-item.tab-dropdown {
          flex: 1 1 0;
          min-width: 1.35rem;
          max-width: 2.1rem;
          justify-content: center;
          padding: 0.2rem 0.12rem;
        }
        .tab-item.tab-link {
          flex: 1 1 0;
          min-width: 1.35rem;
          max-width: 2.1rem;
          padding: 0;
        }
        .tab-item.tab-link > a {
          width: 100%;
          justify-content: center;
          padding: 0.2rem 0.12rem;
        }
        .tab-dropdown-trigger {
          width: 100%;
          justify-content: center;
          gap: 0.1rem;
        }
        .tab-label { display: none; }
        .tab-grip { display: none; }
        .tab-caret { display: none; }
        .tab-icon { font-size: 0.82rem; }
        .topbar-end {
          gap: 0.5rem;
          flex-shrink: 0;
        }
        #health-checked,
        #topbar-stale-warn,
        #push-enable-btn,
        #model-select {
          display: none !important;
        }
        #tabs-scroll {
          display: none;
        }
        .tb-mobile-only {
          display: inline-flex !important;
        }
        .topbar-tools-menu.tb-mobile-only {
          align-items: center;
        }
        .topbar-dropdown {
          display: none !important;
        }
        .topbar-dropdown.open {
          display: flex !important;
          flex-direction: column;
          gap: 0.1rem;
        }
        .topbar-end {
          gap: 0.5rem;
          flex-shrink: 0;
          margin-left: auto;
        }
        .topbar-inbox-btn {
          position: relative;
          border-color: rgba(251, 191, 36, 0.35);
          background: rgba(251, 191, 36, 0.08);
          color: rgba(251, 191, 36, 0.9);
        }
        .topbar-inbox-btn.has-badge {
          border-color: rgba(251, 191, 36, 0.55);
        }
        .topbar-tools-btn {
          border-color: rgba(148, 163, 184, 0.35);
          background: rgba(148, 163, 184, 0.08);
          color: rgba(148, 163, 184, 0.95);
        }
        .topbar-badge {
          position: absolute;
          top: -4px;
          right: -4px;
          min-width: 16px;
          height: 16px;
          padding: 0 4px;
          border-radius: 999px;
          background: #ef4444;
          color: #fff;
          font-size: 0.58rem;
          font-weight: 700;
          line-height: 16px;
          text-align: center;
          pointer-events: none;
          box-shadow: 0 0 0 2px var(--bg);
        }
        .topbar-menu {
          position: relative;
        }
        .topbar-dropdown {
          display: none;
          position: absolute;
          top: calc(100% + 6px);
          right: 0;
          min-width: 188px;
          max-width: min(88vw, 240px);
          max-height: min(62vh, 420px);
          overflow-y: auto;
          background: rgba(14, 17, 24, 0.98);
          border: 1px solid var(--panel-border);
          border-radius: 10px;
          padding: 0.35rem;
          box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
          z-index: 120;
        }
        .topbar-dropdown.open {
          display: flex;
          flex-direction: column;
          gap: 0.1rem;
        }
        .topbar-dropdown-item {
          display: flex;
          align-items: center;
          gap: 0.45rem;
          width: 100%;
          padding: 0.5rem 0.55rem;
          font: inherit;
          font-size: 0.78rem;
          font-weight: 500;
          color: var(--muted);
          background: transparent;
          border: 1px solid transparent;
          border-radius: 7px;
          cursor: pointer;
          text-align: left;
          text-decoration: none;
        }
        .topbar-dropdown-item:hover {
          color: var(--fg);
          background: rgba(255, 255, 255, 0.05);
        }
        .topbar-dropdown-item.active {
          color: var(--fg);
          background: #11253d;
          border-color: #2d5a94;
        }
        .topbar-dropdown-item--danger {
          color: rgba(248, 113, 113, 0.9);
        }
        .topbar-dropdown-item--danger:hover {
          background: rgba(239, 68, 68, 0.12);
          color: #f87171;
        }
        .topbar-dropdown-divider {
          height: 1px;
          background: var(--panel-border);
          margin: 0.2rem 0;
        }
        .topbar-dropdown-icon {
          width: 1rem;
          flex-shrink: 0;
          text-align: center;
          font-size: 0.82rem;
          line-height: 1;
        }
      }

      .tb-mobile-only {
        display: none;
      }

      #topbar button {
        pointer-events: auto;
        font: inherit;
        font-size: 0.78rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        padding: 0.35rem 0.7rem;
        cursor: pointer;
      }
      #topbar button:hover { border-color: #4b5563; }
      #topbar .topbar-icon-btn,
      #topbar .topbar-profile-btn {
        padding: 0;
        line-height: 1;
      }

      /* Left toolbar */
      #tools {
        position: fixed;
        left: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        z-index: 20;
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }
      #tools button {
        width: 2.1rem;
        height: 2.1rem;
        display: grid;
        place-items: center;
        font-size: 1rem;
        color: var(--fg);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 9px;
        cursor: pointer;
      }
      #tools button:hover { border-color: #58a6ff; color: #58a6ff; }

      /* Todo node: chip is the click-to-toggle zone */
      .node.todo-done .ttl { text-decoration: line-through; text-decoration-color: #3d4a5c; }
      .node.todo-done .chip { cursor: pointer; }
      .node:not(.todo-done) .chip { cursor: pointer; }

      /* Legend */
      #legend {
        position: fixed;
        right: 0.7rem;
        bottom: 0.7rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        max-width: 60vw;
        justify-content: flex-end;
        z-index: 20;
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }
      #legend .chip {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.7rem;
        color: var(--muted);
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.2rem 0.55rem;
      }
      #legend .dot { width: 9px; height: 9px; border-radius: 50%; }
      #legend .st-key { color: var(--sc, var(--muted)); }
      #legend .st-key .st-dot {
        background: var(--sc, #6e7681);
        box-shadow: 0 0 5px var(--sc, transparent);
      }

      /* ── Documents editor tab ── */
      #doc-editor {
        position: fixed;
        inset: 0;
        top: var(--topbar-h);
        display: flex;
        flex-direction: row;
        background: var(--bg);
        z-index: 10;
      }

      .de-loading {
        margin: auto;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .de-error { color: #f85149; }

      /* Sidebar */
      .de-sidebar {
        width: 260px;
        flex: 0 0 260px;
        border-right: 1px solid var(--panel-border);
        display: flex;
        flex-direction: column;
        background: var(--panel);
        overflow: hidden;
      }

      /* Mobile: single-pane navigation */
      @media (max-width: 639px) {
        #doc-editor {
          flex-direction: column;
        }
        .de-sidebar {
          width: 100%;
          flex: 1 1 auto;
          border-right: none;
          border-bottom: 1px solid var(--panel-border);
        }
        .de-pane {
          display: none;
        }
        /* When a document is open on mobile, hide sidebar and show pane */
        #doc-editor.de-pane-active .de-sidebar {
          display: none;
        }
        #doc-editor.de-pane-active .de-pane {
          display: flex;
          flex: 1 1 auto;
        }
      }
      .de-new-btn {
        margin: 0.7rem;
        padding: 0.45rem 0.8rem;
        font: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--fg);
        background: #1e3a5f;
        border: 1px solid #2d5a94;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        flex: 0 0 auto;
      }
      .de-new-btn:hover { background: #265080; border-color: #3a72b8; }

      .de-list {
        flex: 1;
        overflow-y: auto;
        padding: 0 0.5rem 0.5rem;
      }
      .de-empty {
        padding: 0.8rem 0.4rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .de-list-item {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.1rem;
        padding: 0.55rem 0.65rem;
        font: inherit;
        font-size: 0.8rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        margin-bottom: 0.15rem;
      }
      .de-list-item:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .de-list-item.active { color: var(--fg); background: #11253d; border-color: #2d5a94; }
      .de-item-title { font-weight: 600; font-size: 0.82rem; color: inherit; }
      .de-item-slug { font-size: 0.69rem; color: var(--muted); font-family: ui-monospace, monospace; }

      /* Editor pane */
      .de-pane {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 0;
      }
      .de-placeholder {
        margin: auto;
        text-align: center;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .de-placeholder-icon { font-size: 2.5rem; margin-bottom: 0.6rem; }

      .de-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem 0.6rem;
        border-bottom: 1px solid var(--panel-border);
        flex: 0 0 auto;
      }
      .de-back-btn {
        display: none;
        font: inherit;
        font-size: 0.8rem;
        color: #58a6ff;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.1rem 0.2rem;
        flex: 0 0 auto;
      }
      @media (max-width: 639px) {
        .de-back-btn { display: inline-flex; align-items: center; gap: 0.25rem; }
        .de-doc-name { font-size: 0.88rem; }
      }
      .de-doc-name {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--fg);
      }
      .de-doc-slug {
        font-size: 0.72rem;
        color: var(--muted);
        font-family: ui-monospace, monospace;
      }

      .de-fields {
        padding: 0.7rem 1rem 0;
        flex: 0 0 auto;
      }
      .de-label {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        font-size: 0.78rem;
        color: var(--muted);
        font-weight: 600;
      }
      .de-input {
        font: inherit;
        font-size: max(16px, 0.84rem);
        font-family: ui-monospace, monospace;
        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 7px;
        padding: 0.4rem 0.6rem;
        outline: none;
        width: 100%;
        max-width: 340px;
      }
      .de-input:focus { border-color: #3b82f6; }

      .de-textarea {
        flex: 1;
        resize: none;
        margin: 0.6rem 1rem;
        padding: 0.7rem 0.9rem;
        font-size: max(16px, 0.83rem);
        line-height: 1.6;
        font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
        color: #c9d1d9;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 9px;
        outline: none;
        tab-size: 2;
        white-space: pre;
        overflow-wrap: normal;
        overflow-x: auto;
      }
      .de-textarea:focus { border-color: #3b82f6; }

      .de-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 1rem;
        border-top: 1px solid var(--panel-border);
        flex: 0 0 auto;
      }
      .de-btn {
        font: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 0.38rem 0.9rem;
        cursor: pointer;
        border: 1px solid transparent;
      }
      .de-btn:disabled { opacity: 0.45; cursor: default; }
      .de-btn-primary {
        color: #fff;
        background: #2563eb;
        border-color: #3b82f6;
      }
      .de-btn-primary:not(:disabled):hover { background: #1d4ed8; }
      .de-btn-ghost {
        color: var(--muted);
        background: transparent;
        border-color: var(--panel-border);
      }
      .de-btn-ghost:hover { color: var(--fg); border-color: #4b5563; }
      .de-btn-danger {
        color: #f85149;
        background: transparent;
        border-color: #f8514940;
      }
      .de-btn-danger:hover { background: #f8514915; border-color: #f85149; }

      /* ── Sidebar shortcodes directory ── */
      .de-sc-dir {
        flex: 0 0 auto;
        border-top: 1px solid var(--panel-border);
        display: flex;
        flex-direction: column;
        max-height: 40%;
        overflow: hidden;
      }
      .de-sc-dir-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.45rem 0.7rem 0.35rem;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--fg);
        letter-spacing: 0.03em;
        text-transform: uppercase;
        flex: 0 0 auto;
      }
      .de-sc-dir-hint {
        font-size: 0.65rem;
        font-weight: 400;
        color: var(--muted);
        text-transform: none;
        letter-spacing: 0;
      }
      .de-sc-dir-body {
        overflow-y: auto;
        padding: 0 0.4rem 0.5rem;
        flex: 1;
      }
      .de-sc-dir-cat {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        padding: 0.3rem 0.3rem 0.1rem;
        opacity: 0.7;
      }
      .de-sc-dir-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.28rem 0.35rem;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.1s;
        user-select: none;
      }
      .de-sc-dir-item:hover { background: rgba(255,255,255,0.05); }
      .de-sc-dir-item.de-sc-copied { background: #0f2c1e; }
      .de-sc-token {
        font: 0.7rem ui-monospace, monospace;
        color: #93c5fd;
        background: #0f1825;
        border: 1px solid #1e3a5f;
        border-radius: 4px;
        padding: 0.05rem 0.3rem;
        white-space: nowrap;
        flex: 0 0 auto;
      }
      .de-sc-lbl {
        font-size: 0.73rem;
        color: var(--muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Shortcode autocomplete popover ── */
      .de-sc-pop {
        position: fixed;
        z-index: 9999;
        display: none;
        min-width: 260px;
        max-width: 320px;
        max-height: 260px;
        overflow-y: auto;
        background: #111827;
        border: 1px solid #283142;
        border-radius: 10px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 2px 8px rgba(0,0,0,0.4);
        padding: 0.3rem;
      }
      .de-sc-pop-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.5rem;
        border-radius: 7px;
        cursor: pointer;
        border: 1px solid transparent;
        width: 100%;
        text-align: left;
        background: transparent;
        transition: background 0.08s;
      }
      .de-sc-pop-row:hover,
      .de-sc-pop-row.active {
        background: #1e3a5f;
        border-color: #2d5a94;
      }
      .de-sc-pop-token {
        font: 0.72rem ui-monospace, monospace;
        color: #93c5fd;
        background: #0f1825;
        border: 1px solid #1e3a5f;
        border-radius: 4px;
        padding: 0.05rem 0.3rem;
        white-space: nowrap;
        flex: 0 0 auto;
      }
      .de-sc-pop-lbl {
        font-size: 0.78rem;
        color: #c7d0dc;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Edit / View mode toggle ── */
      .de-mode-tabs {
        display: flex;
        gap: 0.15rem;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 7px;
        padding: 0.15rem;
        flex: 0 0 auto;
      }
      .de-mode-tab {
        font: inherit;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.25rem 0.65rem;
        border-radius: 5px;
        border: none;
        cursor: pointer;
        color: var(--muted);
        background: transparent;
        transition: color 0.12s;
      }
      .de-mode-tab:hover { color: var(--fg); }
      .de-mode-tab.active {
        color: var(--fg);
        background: #1e2b3c;
      }

      /* ── Document preview iframe ── */
      .de-preview {
        flex: 1;
        margin: 0.6rem 1rem;
        border: 1px solid var(--card-border);
        border-radius: 9px;
        background: #fff;
        overflow: hidden;
        min-height: 0;
      }

      /* ── Knowledge / Work / Clients tabs (reuse Documents editor classes) ── */
      #knowledge-editor,
      #work-editor,
      #clients-editor {
        position: fixed;
        inset: 0;
        top: var(--topbar-h);
        display: flex;
        flex-direction: row;
        background: var(--bg);
        z-index: 10;
      }
      @media (max-width: 639px) {
        #knowledge-editor,
        #work-editor,
        #clients-editor { flex-direction: column; }
        #knowledge-editor.de-pane-active .de-sidebar,
        #work-editor.de-pane-active .de-sidebar,
        #clients-editor.de-pane-active .de-sidebar { display: none; }
        #knowledge-editor.de-pane-active .de-pane,
        #work-editor.de-pane-active .de-pane,
        #clients-editor.de-pane-active .de-pane { display: flex; flex: 1 1 auto; }
      }
      .wk-status {
        font-size: 0.62rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.08rem 0.35rem;
        border-radius: 4px;
        margin-left: auto;
        flex-shrink: 0;
      }
      .wk-status-inquiry { color: #79c0ff; background: rgba(121, 192, 255, 0.12); }
      .wk-status-active { color: #3fb950; background: rgba(63, 185, 80, 0.12); }
      .wk-status-done { color: #8b97a8; background: rgba(139, 151, 168, 0.12); }
      .wk-status-archived { color: #d29922; background: rgba(210, 153, 34, 0.12); }
      .wk-meta-row { display: flex; align-items: center; gap: 0.35rem; width: 100%; }
      .wk-contact { font-size: 0.68rem; color: var(--muted); }
      .wk-client-picker { position: relative; margin-bottom: 0.5rem; }
      .wk-client-picker .de-label { display: block; margin-bottom: 0.35rem; }
      .wk-client-selected {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.55rem;
        border: 1px solid var(--panel-border);
        border-radius: 7px;
        background: var(--card);
      }
      .wk-client-selected span { flex: 1; font-size: 0.88rem; }
      .wk-client-selected button {
        font-size: 0.72rem;
        padding: 0.2rem 0.45rem;
      }
      .wk-client-dropdown {
        position: absolute;
        left: 0;
        right: 0;
        top: calc(100% + 2px);
        z-index: 40;
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid var(--panel-border);
        border-radius: 7px;
        background: var(--panel);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
      }
      .wk-client-option {
        display: block;
        width: 100%;
        text-align: left;
        padding: 0.45rem 0.6rem;
        border: none;
        background: transparent;
        color: var(--fg);
        font-size: 0.82rem;
        cursor: pointer;
      }
      .wk-client-option:hover { background: rgba(255, 255, 255, 0.06); }
      .wk-client-option .sub { display: block; font-size: 0.68rem; color: var(--muted); margin-top: 0.1rem; }
      .wk-client-option.wk-client-add {
        color: #79c0ff;
        border-top: 1px solid var(--panel-border);
        font-weight: 600;
      }
      .wk-client-new {
        margin-top: 0.5rem;
        padding: 0.6rem;
        border: 1px dashed var(--panel-border);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .wk-client-new .de-input { width: 100%; }
      .wk-client-new-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
      .cl-search {
        margin: 0 0.7rem 0.5rem;
        padding: 0.45rem 0.55rem;
        border-radius: 7px;
        border: 1px solid var(--panel-border);
        background: var(--card);
        color: var(--fg);
        font-size: 0.82rem;
        width: calc(100% - 1.4rem);
      }
      .cl-archived {
        font-size: 0.62rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.08rem 0.35rem;
        border-radius: 4px;
        margin-left: auto;
        color: #8b97a8;
        background: rgba(139, 151, 168, 0.12);
      }
      .cl-readonly {
        font-size: 0.75rem;
        color: var(--muted);
        word-break: break-all;
      }
      .cl-readonly a { color: #79c0ff; }
      .cl-portal-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }

      /* iOS-style icon toolbar buttons (SF Symbol affordances, 44pt touch targets) */
      .ios-icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        width: 2.75rem;
        height: 2.75rem;
        padding: 0;
        margin: 0;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: #0a84ff;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
        transition: color 0.12s, background 0.12s, opacity 0.12s;
      }
      .ios-icon-btn:hover {
        background: rgba(10, 132, 255, 0.12);
      }
      .ios-icon-btn:active {
        opacity: 0.55;
      }
      .ios-icon-btn svg {
        display: block;
        width: 1.25rem;
        height: 1.25rem;
      }
      .de-header .de-share-btn {
        margin-left: auto;
      }
      .cl-jobs-section { padding: 0 1rem 0.75rem; }
      .cl-jobs-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--panel-border);
        margin-top: 0.35rem;
      }
      .cl-job-row {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
