      .swipe-act-delete { background: #ff3b30; }
      .swipe-act:active { filter: brightness(0.92); }

      /* Two-step delete confirm (trash → stopwatch + ring countdown) */
      @keyframes delete-confirm-draw-ring {
        from { stroke-dashoffset: 113.1; }
        to { stroke-dashoffset: 0; }
      }
      .delete-confirm-btn {
        position: relative;
