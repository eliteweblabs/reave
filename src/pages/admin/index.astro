        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .wk-billable-item {
        font-size: max(14px, 0.8rem);
        line-height: 1.45;
        color: var(--fg);
        padding-left: 0.65rem;
        border-left: 2px solid rgba(63, 185, 80, 0.45);
