      }
      .em-item-summary {
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.35;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        text-align: left;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        overflow-wrap: anywhere;
      }
      .em-detail-summary {
