        line-height: 1.45;
        color: var(--muted);
      }
      .reave-share-note-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--muted);
      }
      .reave-share-optional {
        font-weight: 500;
        opacity: 0.75;
      }
      .reave-share-note {
        width: 100%;
        min-height: 3.2rem;
        resize: vertical;
        font: inherit;
        font-size: max(16px, 0.88rem);
        line-height: 1.45;
        padding: 0.55rem 0.65rem;
        border-radius: 10px;
        border: 1px solid var(--panel-border);
        background: var(--surface);
        color: var(--fg);
      }
      .reave-share-note:focus {
        outline: none;
        border-color: #0a84ff;
      }
      .reave-share-actions {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        margin-top: 0.15rem;
      }
      .reave-share-btn {
        width: 100%;
        font: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.72rem 0.85rem;
        border-radius: 10px;
        border: 1px solid var(--panel-border);
        background: var(--tab-active-bg);
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        -webkit-tap-highlight-color: transparent;
      }
      .reave-share-btn:hover:not(:disabled) {
        border-color: #4b5563;
      }
      .reave-share-btn:disabled {
        opacity: 0.38;
        cursor: default;
      }
      .reave-share-btn--primary {
        background: #0a84ff;
        border-color: #0a84ff;
        color: #fff;
        text-align: center;
      }
      .reave-share-btn--primary:hover:not(:disabled) {
        background: #0077e6;
        border-color: #0077e6;
      }
      .reave-share-btn--ghost {
        background: transparent;
        color: var(--muted);
        text-align: center;
      }
      .reave-share-btn--ghost:hover:not(:disabled) {
        color: var(--fg);
        background: var(--surface-hover);
      }
      .reave-share-btn small {
        display: block;
        font-size: 0.74rem;
        font-weight: 500;
        opacity: 0.82;
        margin-top: 0.12rem;
      }
      .reave-share-status {
        margin: 0;
        font-size: 0.82rem;
        padding: 0.55rem 0.65rem;
        border-radius: 8px;
        line-height: 1.4;
      }
      .reave-share-status.is-ok {
        color: #167c3e;
        background: color-mix(in srgb, #22c55e 12%, transparent);
        border: 1px solid color-mix(in srgb, #22c55e 28%, transparent);
      }
      .reave-share-status.is-err {
        color: #b42318;
        background: color-mix(in srgb, #ef4444 10%, transparent);
        border: 1px solid color-mix(in srgb, #ef4444 24%, transparent);
      }
      .reave-share-status.is-pending {
        color: var(--muted);
        background: var(--surface-hover);
      }

      /* ── Home dashboard ── */
      #home-dashboard {
        position: fixed;
        inset: 0;
        height: 100dvh;
        display: none;
        flex-direction: column;
        background: var(--bg);
        z-index: 10;
        overflow: hidden;
      }
      .home-dashboard-scroll {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow-x: hidden;
        overflow-y: auto;
        padding: calc(var(--topbar-h) + var(--setup-alert-h, 0px) + 0.65rem) 1rem var(--footer-scroll-pad);
      }
      .home-dashboard-title {
        margin: 0 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .home-dashboard-sub {
        margin: 0 0 1.25rem;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .dash-header {
        margin-bottom: 1.25rem;
      }
      .dash-date {
        margin: 0.2rem 0 0;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .dash-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.65rem;
        margin-bottom: 1.35rem;
      }
      @media (min-width: 640px) {
        .dash-stats {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }

      .dash-stat {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.15rem;
        padding: 0.9rem 0.85rem;
        border-radius: 14px;
        border: 1px solid var(--panel-border);
        background: var(--surface-muted);
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        transition: border-color 0.15s, background 0.15s, transform 0.12s;
        min-height: 5.5rem;
      }
      /* Override global pill buttons — dashboard cards stay rounded-rect. */
      #home-dashboard button.dash-stat {
        border-radius: 14px;
      }
      #home-dashboard button.dash-inbox-item {
        border-radius: 10px;
      }
      #home-dashboard button.home-dashboard-tile {
        border-radius: 12px;
      }
      .dash-stat:hover {
        border-color: var(--border-hover);
        background: var(--surface-hover-strong);
      }
      .dash-stat:active {
        transform: scale(0.98);
      }
      .dash-stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
      }
      .dash-stat-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--fg-secondary);
      }
      .dash-stat-hint {
        font-size: 0.68rem;
        color: var(--muted);
        line-height: 1.3;
      }
      .dash-stat--muted {
        cursor: default;
      }
      .dash-stat--muted:hover {
        background: var(--surface-muted);
        border-color: var(--panel-border);
        transform: none;
      }
      .dash-stat--live .dash-stat-value { color: #4ade80; }
      .dash-stat--stale .dash-stat-value { color: #fbbf24; }
      .dash-stat--failed .dash-stat-value { color: #f87171; }

      .dash-review-alerts {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        margin-bottom: 0.85rem;
      }
      .dash-review-alerts .admin-setup-alert {
        max-width: none;
        margin: 0;
      }
      .dash-review-alerts .admin-setup-alert-copy {
        cursor: pointer;
      }

      .meeting-confirm-lead {
        margin: 0 0 0.85rem;
        font-size: 0.84rem;
        line-height: 1.45;
        color: var(--muted);
      }
      .meeting-confirm-steps {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }
      .meeting-confirm-step {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 0.65rem 0.7rem;
        border-radius: 10px;
        border: 1px solid var(--panel-border);
        background: var(--card);
      }
      .meeting-confirm-step--pending {
        opacity: 0.55;
      }
      .meeting-confirm-step--active {
        border-color: rgba(45, 212, 191, 0.45);
        background: rgba(45, 212, 191, 0.08);
      }
      .meeting-confirm-step--done {
        border-color: rgba(52, 211, 153, 0.35);
        background: rgba(52, 211, 153, 0.08);
      }
      .meeting-confirm-step--error {
        border-color: rgba(248, 113, 113, 0.45);
        background: rgba(248, 113, 113, 0.08);
      }
      .meeting-confirm-step-icon {
        flex: 0 0 auto;
        width: 1.35rem;
        height: 1.35rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        background: var(--surface-muted);
        color: var(--muted);
      }
      .meeting-confirm-step--done .meeting-confirm-step-icon {
        background: rgba(52, 211, 153, 0.2);
        color: #34d399;
      }
      .meeting-confirm-step--active .meeting-confirm-step-icon {
        background: rgba(45, 212, 191, 0.2);
        color: #2dd4bf;
      }
      .meeting-confirm-step--error .meeting-confirm-step-icon {
        background: rgba(248, 113, 113, 0.2);
        color: #f87171;
      }
      .meeting-confirm-step-title {
        font-size: 0.86rem;
        font-weight: 600;
        line-height: 1.3;
      }
      .meeting-confirm-step-detail {
        margin-top: 0.15rem;
        font-size: 0.78rem;
        line-height: 1.35;
        color: var(--muted);
      }

      .dash-panel {
        margin-bottom: 1.35rem;
        min-width: 0;
        overflow: hidden;
        padding: 0.85rem 0.9rem;
        border-radius: 14px;
        border: 1px solid var(--panel-border);
        background: var(--surface-subtle);
      }
      .dash-panel-body {
        min-width: 0;
      }
      .dash-panel-today {
        display: flex;
        flex-direction: column;
      }
      .dash-panel-today .dash-panel-body {
        flex: 1;
        min-height: 0;
      }
      .dash-panel-today--empty .dash-panel-body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.35rem;
      }
      @media (max-width: 639px) {
        .home-dashboard-scroll {
          min-height: 100%;
          padding-left: max(0.75rem, env(safe-area-inset-left, 0px));
          padding-right: max(0.75rem, env(safe-area-inset-right, 0px));
          padding-top: calc(var(--topbar-h) + var(--setup-alert-h, 0px) + 0.5rem);
          gap: 0.85rem;
        }
        .dash-stats {
          gap: 0.55rem;
          margin-bottom: 0;
        }
        .dash-stat {
          padding: 0.85rem 0.75rem;
          min-height: 5rem;
        }
        .dash-stat-value {
          font-size: 1.95rem;
        }
        .dash-panel-today {
          flex: 1 1 auto;
          min-height: 10rem;
          margin-bottom: 0;
        }
        .dash-panel-today--empty .dash-panel-body {
          min-height: 6rem;
        }
      }
      .dash-panel-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.65rem;
      }
      .dash-panel-title {
        margin: 0;
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }
      .dash-panel-note {
        font-size: 0.65rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .dash-events {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .dash-event {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 0.55rem 0.5rem;
        border-radius: 10px;
        background: var(--surface-muted);
      }
      .dash-event-time {
        flex: 0 0 auto;
        min-width: 4.2rem;
        font-size: 0.72rem;
        font-weight: 600;
        color: #79c0ff;
        font-variant-numeric: tabular-nums;
      }
      .dash-event-body {
        min-width: 0;
      }
      .dash-event-title {
        font-size: 0.82rem;
        font-weight: 500;
        line-height: 1.35;
      }
      .dash-event-type {
        font-size: 0.65rem;
        color: var(--muted);
        margin-top: 0.1rem;
        text-transform: capitalize;
      }

      .dash-inbox-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .dash-inbox-item {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
        padding: 0.55rem 0.5rem;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: inherit;
        cursor: pointer;
        text-align: left;
        font: inherit;
      }
      .dash-inbox-item:hover {
        background: var(--surface-hover-strong);
      }
      .dash-inbox-subject {
        font-size: 0.82rem;
        font-weight: 500;
        min-width: 0;
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .dash-inbox-meta {
        font-size: 0.68rem;
        color: var(--muted);
        min-width: 0;
        max-width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .dash-empty {
        margin: 0;
        font-size: 0.8rem;
        color: var(--muted);
      }

      /* ── Schedule tab ── */
      #schedule-panel {
        overflow: hidden;
      }
      #schedule-panel .schedule-detail-pane {
        min-width: 0;
        flex: 1 1 auto;
      }
      .dash-panel-link {
        margin-left: auto;
        padding: 0;
        border: none;
        background: transparent;
        color: #79c0ff;
        font: inherit;
        font-size: 0.68rem;
        font-weight: 600;
        cursor: pointer;
      }
      .dash-uptime-list, .dash-uptime-incidents {
        list-style: none;
        margin: 0;
        padding: 0;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
      }
      .dash-uptime-item, .dash-uptime-incident {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        padding: 0.55rem 0.75rem;
        background: var(--card);
        border-top: 1px solid var(--border);
      }
      .dash-uptime-item:first-child, .dash-uptime-incident:first-child { border-top: none; }
      .dash-uptime-item--down { background: rgba(248, 113, 113, 0.08); }
      .dash-uptime-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-top: 0.35rem;
        background: #3fb950;
        flex-shrink: 0;
      }
      .dash-uptime-item--down .dash-uptime-dot { background: #f85149; }
      .dash-uptime-body { min-width: 0; }
      .dash-uptime-name { font-size: 0.82rem; font-weight: 600; }
      .dash-uptime-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
      .dash-uptime-inc-head {
        margin: 0.85rem 0 0.35rem;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
      }
      .dash-uptime-incident { flex-direction: column; gap: 0.15rem; }
      .dash-uptime-inc-title { font-size: 0.78rem; font-weight: 600; }
      .dash-uptime-inc-when { font-size: 0.68rem; color: var(--muted); }
      .dash-empty-link {
        display: block;
        margin: 0.35rem 0 0;
        margin-left: 0;
        text-align: left;
      }
      .dash-event-btn {
        width: 100%;
        border: none;
        font: inherit;
        color: inherit;
        text-align: left;
        cursor: pointer;
      }
      .dash-event-btn:hover {
        background: var(--surface-hover-strong);
      }
      .schedule-detail-when {
        margin: 0 0 0.75rem;
        font-size: 0.92rem;
        font-weight: 600;
        line-height: 1.45;
      }
      .schedule-detail-fields {
        margin: 0.85rem 0 0;
        display: grid;
        grid-template-columns: 5.5rem 1fr;
        gap: 0.45rem 0.75rem;
        font-size: 0.8rem;
      }
      .schedule-detail-fields dt {
        margin: 0;
        color: var(--muted);
        font-weight: 600;
      }
      .schedule-detail-fields dd {
        margin: 0;
        min-width: 0;
        word-break: break-word;
      }
      .schedule-detail-link {
        color: #79c0ff;
      }
      .schedule-detail-actions {
        margin-top: 1rem;
      }
      .schedule-cal-link {
        color: var(--muted);
      }
      .schedule-status {
        display: inline-block;
        margin-top: 0.25rem;
        padding: 0.1rem 0.4rem;
        border-radius: 6px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .wk-meta-row .schedule-status {
        margin-top: 0;
      }
      .sched-status-accepted {
        background: rgba(74, 222, 128, 0.15);
        color: #86efac;
      }
      .sched-status-pending {
        background: rgba(251, 191, 36, 0.15);
        color: #fcd34d;
      }
      .sched-status-cancelled {
        background: rgba(248, 113, 113, 0.12);
        color: #fca5a5;
      }

      /* ── Schedule calendar (iOS-style month / week / day) ── */
      #schedule-panel .ch-sidebar {
        display: flex;
        flex-direction: column;
        min-width: 0;
        min-height: 0;
      }
      .cal-toolbar {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.75rem 0.25rem;
        flex: 0 0 auto;
      }
      .cal-toolbar-nav {
        display: flex;
        align-items: center;
        gap: 0.15rem;
        flex: 1;
        min-width: 0;
      }
      .cal-toolbar-title {
        flex: 1;
        min-width: 0;
        margin: 0;
        font-size: 0.92rem;
        font-weight: 700;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .cal-toolbar-today {
        flex: 0 0 auto;
        padding: 0.28rem 0.65rem;
        border: none;
        border-radius: 999px;
        background: rgba(121, 192, 255, 0.14);
        color: #79c0ff;
        font: inherit;
        font-size: 0.72rem;
        font-weight: 700;
        cursor: pointer;
      }
      .cal-toolbar-today:hover {
        background: rgba(121, 192, 255, 0.22);
      }
      .cal-view-picker {
        padding: 0 0.75rem 0.35rem;
        flex: 0 0 auto;
      }
      .cal-view-picker .sliding-pill {
        width: 100%;
      }
      .cal-body {
        flex: 1;
        min-height: 0;
        overflow: auto;
        padding: 0 0.5rem var(--footer-scroll-pad);
      }
      .cal-weekdays {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0;
        padding: 0.15rem 0.25rem 0.35rem;
      }
      .cal-weekdays span {
        text-align: center;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .cal-month-grid {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0.15rem;
        padding: 0 0.25rem;
      }
      .cal-day {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 0.15rem;
        min-height: 2.65rem;
        padding: 0.35rem 0.1rem 0.25rem;
        border: none;
        border-radius: 0;
        background: transparent;
        color: var(--fg);
        font: inherit;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
      }
      .cal-day:hover:not(.cal-day--selected) {
        background: transparent;
      }
      .cal-day:hover:not(.cal-day--selected):not(.cal-day--today) .cal-day-num {
        background: var(--surface-hover);
      }
      .cal-day:focus {
        outline: none;
      }
      .cal-day-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.65rem;
        height: 1.65rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1;
      }
      .cal-day--other .cal-day-num {
        color: var(--muted);
        opacity: 0.55;
      }
      .cal-day--today .cal-day-num {
        background: #ff3b30;
        color: #fff;
      }
      .cal-day--selected:not(.cal-day--today) .cal-day-num {
        background: #007aff;
        color: #fff;
      }
      .cal-day--selected.cal-day--today .cal-day-num {
        background: #ff3b30;
        color: #fff;
      }
      .cal-day-dots {
        display: flex;
        gap: 0.12rem;
        min-height: 0.28rem;
      }
      .cal-day-dot {
        width: 0.28rem;
        height: 0.28rem;
        border-radius: 999px;
        background: #79c0ff;
      }
      .cal-day-agenda {
        margin-top: 0.65rem;
        padding: 0 0.25rem 0.5rem;
        border-top: 1px solid var(--panel-border);
      }
      .cal-day-agenda-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 0.55rem 0.45rem 0.35rem;
      }
      .cal-day-agenda-date {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--fg-secondary);
      }
      .cal-day-agenda-action {
        flex: 0 0 auto;
        padding: 0.18rem 0.5rem;
        border: none;
        border-radius: 999px;
        background: var(--surface-hover);
        color: #79c0ff;
        font: inherit;
        font-size: 0.68rem;
        font-weight: 700;
        cursor: pointer;
      }
      .cal-day-agenda-action:hover {
        background: var(--surface-hover-strong);
      }
      .cal-day-agenda-empty {
        margin: 0;
        padding: 0.35rem 0.45rem 0.55rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .sched-create-form {
        display: grid;
        gap: 0.75rem;
      }
      .sched-create-field {
        margin: 0;
      }
      .sched-create-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.65rem;
        min-width: 0;
      }
      .sched-create-row .control-field {
        min-width: 0;
      }
      .sched-create-row input[type="date"],
      .sched-create-row input[type="time"] {
        min-width: 0;
      }
      .sched-create-form .control-field > textarea {
        min-height: 4.5rem;
        resize: vertical;
        padding-top: 0.35rem;
        padding-bottom: 0.35rem;
      }
      .sched-guest-dropdown {
        position: fixed;
        z-index: 5100;
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        background: var(--panel);
        box-shadow: var(--shadow-lg);
      }
      .sched-guest-option {
        display: block;
        width: 100%;
        text-align: left;
        padding: 0.45rem 0.6rem;
        border: none;
        background: transparent;
        color: var(--fg);
        font-size: 0.82rem;
        cursor: pointer;
      }
      .sched-guest-option:hover { background: var(--surface-hover-strong); }
      .sched-guest-option .sub {
        display: block;
        font-size: 0.68rem;
        color: var(--muted);
        margin-top: 0.1rem;
      }
      .sched-guest-empty {
        padding: 0.45rem 0.6rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .sched-create-hint {
        margin: 0;
        font-size: 0.72rem;
        line-height: 1.45;
        color: var(--muted);
      }
      .sched-create-error {
        margin: 0;
        font-size: 0.78rem;
        color: #fca5a5;
      }
      .cal-agenda-item {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        width: 100%;
        padding: 0.55rem 0.45rem;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: inherit;
        font: inherit;
        text-align: left;
        cursor: pointer;
      }
      .cal-agenda-item:hover,
      .cal-agenda-item.active {
        background: var(--surface-hover-strong);
      }
      .cal-agenda-item--past {
        opacity: 0.52;
      }
      .cal-agenda-item--past:hover,
      .cal-agenda-item--past.active {
        opacity: 0.78;
      }
      .cal-agenda-time {
        flex: 0 0 auto;
        min-width: 3.2rem;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--muted);
      }
      .cal-agenda-main {
        flex: 1;
        min-width: 0;
      }
      .cal-agenda-title {
        display: block;
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.3;
      }
      .cal-agenda-sub {
        display: block;
        margin-top: 0.12rem;
        font-size: 0.72rem;
        color: var(--muted);
      }
      .cal-time-grid-wrap {
        position: relative;
        display: flex;
        min-height: 48rem;
      }
      .cal-time-gutter {
        flex: 0 0 2.75rem;
        position: relative;
      }
      .cal-time-label {
        position: absolute;
        right: 0.35rem;
        transform: translateY(-50%);
        font-size: 0.62rem;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap;
      }
      .cal-time-columns {
        flex: 1;
        min-width: 0;
        display: flex;
        position: relative;
      }
      .cal-time-col {
        flex: 1;
        min-width: 0;
        position: relative;
        border-left: 1px solid var(--panel-border);
        cursor: pointer;
      }
      .cal-time-col:first-child {
        border-left: none;
      }
      .cal-hour-line {
        position: absolute;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--panel-border);
        pointer-events: none;
      }
      .cal-slot-marker {
        position: absolute;
        left: 0.12rem;
        right: 0.12rem;
        height: 2px;
        z-index: 0;
        border-radius: 999px;
        background: #79c0ff;
        box-shadow: 0 0 0 3px rgba(121, 192, 255, 0.18);
        pointer-events: none;
      }
      .cal-event-block {
        position: absolute;
        left: 0.12rem;
        right: 0.12rem;
        z-index: 1;
        padding: 0.18rem 0.32rem;
        border-radius: 6px;
        border: none;
        background: rgba(121, 192, 255, 0.22);
        border-left: 3px solid #79c0ff;
        color: var(--fg);
        font: inherit;
        font-size: 0.68rem;
        line-height: 1.25;
        text-align: left;
        overflow: hidden;
        cursor: pointer;
      }
      .cal-event-block:hover,
      .cal-event-block.active {
        background: rgba(121, 192, 255, 0.32);
      }
      .cal-event-block--past {
        opacity: 0.48;
        background: rgba(121, 192, 255, 0.12);
        border-left-color: rgba(121, 192, 255, 0.45);
      }
      .cal-event-block--past:hover,
      .cal-event-block--past.active {
        opacity: 0.68;
        background: rgba(121, 192, 255, 0.2);
      }
      .cal-event-block-title {
        display: block;
        font-weight: 700;
      }
      .cal-event-block-time {
        display: block;
        margin-top: 0.08rem;
        opacity: 0.85;
      }
      .cal-week-header {
        display: flex;
        padding: 0 0 0.35rem 2.75rem;
        border-bottom: 1px solid var(--panel-border);
      }
      .cal-week-header-col {
        flex: 1;
        min-width: 0;
        padding: 0.15rem 0.1rem;
        border: none;
        background: transparent;
        color: inherit;
        font: inherit;
        text-align: center;
        cursor: pointer;
        border-radius: 0;
        -webkit-tap-highlight-color: transparent;
      }
      .cal-week-header-col:hover:not(.cal-week-header-col--selected) {
        background: transparent;
      }
      .cal-week-header-col:hover:not(.cal-week-header-col--selected):not(.cal-week-header-col--today) .cal-week-header-daynum {
        background: var(--surface-hover);
      }
      .cal-week-header-col:focus {
        outline: none;
      }
      .cal-week-header-col--today .cal-week-header-daynum {
        background: #ff3b30;
        color: #fff;
      }
      .cal-week-header-col--selected:not(.cal-week-header-col--today) .cal-week-header-daynum {
        background: #007aff;
        color: #fff;
      }
      .cal-week-header-col--selected.cal-week-header-col--today .cal-week-header-daynum {
        background: #ff3b30;
        color: #fff;
      }
      .cal-week-header-dow {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--muted);
      }
      .cal-week-header-daynum {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.55rem;
        height: 1.55rem;
        margin-top: 0.15rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .cal-day-view-header {
        padding: 0.15rem 0.75rem 0.45rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--muted);
      }
      @media (max-width: 639px) {
        .cal-time-columns {
          overflow-x: auto;
        }
        .cal-time-col {
          flex: 0 0 3.25rem;
        }
        .cal-week-header {
          overflow-x: auto;
          padding-left: 2.75rem;
        }
        .cal-week-header-col {
          flex: 0 0 3.25rem;
        }
      }

      .dash-loading {
        padding: 2rem 0;
        text-align: center;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .home-dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(9.5rem, 1fr));
        gap: 0.65rem;
        margin-top: 0.35rem;
      }
      .home-dashboard-tile {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.55rem;
        padding: 0.85rem 0.8rem;
        border-radius: 12px;
        border: 1px solid var(--panel-border);
        background: var(--surface-muted);
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        transition: border-color 0.15s, background 0.15s;
      }
      .home-dashboard-tile:hover {
        border-color: var(--border-hover);
        background: var(--surface-hover-strong);
      }
      .home-dashboard-tile-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        color: var(--fg-secondary);
      }
      .home-dashboard-tile-icon svg {
        width: 1.25rem;
        height: 1.25rem;
        display: block;
      }
      .home-dashboard-tile-label {
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.25;
      }

      /* ── Settings panel (profile, company, socials, …) ── */
      #settings-panel {
        position: fixed;
        inset: 0;
        height: 100dvh;
        display: none;
        flex-direction: column;
        background: var(--bg);
        z-index: 10;
        overflow: hidden;
      }
      .profile-panel-scroll {
        flex: 1;
        overflow-x: hidden;
        overflow-y: auto;
        padding: calc(var(--topbar-h) + var(--setup-alert-h, 0px) + 1rem) 1rem var(--footer-scroll-pad);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .prof-card {
        width: 100%;
        max-width: 560px;
        min-width: 0;
        background: var(--surface-muted);
        border: 1px solid var(--panel-border);
        border-radius: 12px;
        padding: 1.5rem 1.35rem;
      }
      #settings-panel .prof-card {
        background: transparent;
        border: none;
        border-radius: 0;
      }
      .prof-title {
        margin: 0 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .prof-title--section {
        font-size: 1.1rem;
      }
      .prof-subtitle {
        margin: 0 0 1.25rem;
        font-size: 0.82rem;
        color: var(--muted);
      }
      .prof-alert {
        padding: 0.65rem 0.85rem;
        border-radius: 8px;
        font-size: 0.82rem;
        margin-bottom: 1rem;
      }
      .prof-alert--success {
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #4ade80;
      }
      .prof-alert--error {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
      }
      .prof-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .prof-field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.85rem;
      }
      @media (max-width: 639px) {
        .prof-field-row {
          grid-template-columns: 1fr;
        }
      }
      .prof-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        min-width: 0;
      }
      .prof-field label {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prof-field input,
      .prof-field select,
      .prof-field textarea {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
        background: var(--accent-select-bg);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-input);
        padding: 0.6rem 0.75rem;
        font: inherit;
        font-size: max(16px, 0.88rem);
        color: var(--fg);
        outline: none;
      }
      .prof-field input:focus,
      .prof-field select:focus,
      .prof-field textarea:focus {
        border-color: var(--border-strong-hover);
      }
      .prof-field input:disabled {
        opacity: 0.55;
        cursor: not-allowed;
      }
      .prof-field input.form-field--saving,
      .prof-field select.form-field--saving,
      .prof-field textarea.form-field--saving,
      .de-input.form-field--saving,
      .de-textarea.form-field--saving,
      .re-textarea.form-field--saving,
      .ind-row input.form-field--saving,
      .de-header-title-input.form-field--saving {
        border-color: #3b82f6;
        box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.25);
      }
      .prof-field input.form-field--saved,
      .prof-field select.form-field--saved,
      .prof-field textarea.form-field--saved,
      .de-input.form-field--saved,
      .de-textarea.form-field--saved,
      .re-textarea.form-field--saved,
      .ind-row input.form-field--saved,
      .de-header-title-input.form-field--saved {
        border-color: #22c55e;
        box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.2);
      }
      .prof-field input.form-field--invalid,
      .prof-field select.form-field--invalid,
      .prof-field textarea.form-field--invalid,
      .de-input.form-field--invalid,
      .de-textarea.form-field--invalid,
      .re-textarea.form-field--invalid,
      .ind-row input.form-field--invalid,
      .de-header-title-input.form-field--invalid {
        border-color: #ef4444;
        box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.2);
      }
      .prof-hint {
        font-size: 0.72rem;
        color: var(--muted);
        line-height: 1.4;
      }
      .prof-hint--block {
        display: block;
        margin-top: -0.35rem;
      }
      .prof-plugin-group {
        margin-bottom: 1.25rem;
      }
      .prof-plugin-group:last-child {
        margin-bottom: 0;
      }
      .prof-plugin-group-title {
        margin: 0 0 0.5rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prof-plugin-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.55rem 0;
        border-bottom: 1px solid var(--panel-border);
      }
      .prof-plugin-row:last-child {
        border-bottom: none;
      }
      .prof-plugin-copy {
        min-width: 0;
      }
      .prof-plugin-label {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--fg);
      }
      .prof-plugin-desc {
        font-size: 0.74rem;
        color: var(--muted);
        line-height: 1.35;
      }
      .prof-plugin-toggle {
        flex-shrink: 0;
        width: 2.75rem;
        height: 1.55rem;
        border: none;
        border-radius: 999px;
        background: var(--panel-border);
        position: relative;
        cursor: pointer;
        transition: background 0.15s;
      }
      .prof-plugin-toggle[aria-checked='true'] {
        background: #22c55e;
      }
      .prof-plugin-toggle::after {
        content: '';
        position: absolute;
        top: 0.15rem;
        left: 0.15rem;
        width: 1.25rem;
        height: 1.25rem;
        border-radius: 50%;
        background: #fff;
        transition: transform 0.15s;
      }
      .prof-plugin-toggle[aria-checked='true']::after {
        transform: translateX(1.15rem);
      }
      .prof-hint code {
        font-size: 0.68rem;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .prof-actions {
        padding-top: 0.25rem;
      }
      .prof-btn-primary {
        font: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        background: #2563eb;
        border: 1px solid #3b82f6;
        border-radius: 8px;
        padding: 0.55rem 1rem;
        cursor: pointer;
      }
      .prof-btn-primary:hover {
        background: #1d4ed8;
      }
      .prof-btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .prof-btn-secondary {
        font: inherit;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--fg, #e9eef6);
        background: transparent;
        border: 1px solid var(--panel-border, rgba(255, 255, 255, 0.15));
        border-radius: 8px;
        padding: 0.45rem 0.85rem;
        cursor: pointer;
      }
      .prof-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.05);
      }
      .prof-btn-secondary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .ind-list {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        margin: 0.75rem 0 1rem;
      }
      .ind-row {
        display: grid;
        grid-template-columns: 1fr minmax(5.5rem, 7rem) auto auto;
        gap: 0.45rem;
        align-items: center;
      }
      .ind-row input[type="text"] {
        font: inherit;
        font-size: max(16px, 0.88rem);
        color: var(--fg);
        background: var(--accent-select-bg);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-input);
        padding: 0.6rem 0.75rem;
        width: 100%;
        box-sizing: border-box;
        outline: none;
      }
      .ind-row input[type="text"]:focus {
        border-color: var(--border-strong-hover);
      }
      .ind-enabled {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.78rem;
        color: var(--muted, #8b97a8);
        white-space: nowrap;
        user-select: none;
      }
      .ind-empty {
        font-size: 0.85rem;
        color: var(--muted, #8b97a8);
        padding: 0.35rem 0;
      }
      .ind-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      @media (max-width: 640px) {
        .ind-row {
          grid-template-columns: 1fr 1fr;
        }
        .ind-row .ind-remove {
          grid-column: 1 / -1;
        }
      }
      .prof-logo-upload {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.65rem;
        width: 100%;
        min-width: 0;
      }
      .prof-logo-upload input[type="file"] {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
      }
      .prof-logo-preview {
        max-width: 220px;
        max-height: 72px;
        width: auto;
        height: auto;
        object-fit: contain;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.35rem;
      }
      .prof-logo-preview[hidden] {
        display: none !important;
      }

      /* ── Search overlay ── */
      #search-overlay {
        position: fixed;
        inset: 0;
        height: 100dvh;
        display: none;
        flex-direction: column;
        background: var(--overlay-bg);
        z-index: 15;
        padding:
          calc(var(--topbar-h) + var(--setup-alert-h, 0px) + 0.75rem)
          1rem
          var(--footer-scroll-pad);
      }
      #search-overlay.open {
        display: flex;
      }
      .search-overlay-bar {
        margin-bottom: 0.75rem;
      }
      .search-overlay-field.control-field {
        background: var(--panel);
      }
      .search-overlay-input {
        flex: 1;
        padding: 0.2rem 0.5rem;
        border: none;
        background: transparent;
        color: var(--fg);
        font: inherit;
        font-size: 1rem;
        outline: none;
      }
      .search-overlay-clear {
        flex: 0 0 auto;
        border: 1px solid var(--panel-border);
        background: transparent;
        color: var(--search-close);
        cursor: pointer;
        display: grid;
        place-items: center;
        border-radius: var(--radius-input);
      }
      .search-overlay-clear[hidden],
      .panel-list-search-clear[hidden] {
        display: none !important;
      }
      .search-overlay-clear:hover { color: var(--fg); border-color: var(--border-strong-hover); }
      .search-overlay-results {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding-bottom: var(--footer-scroll-pad);
      }
      .search-result-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        padding: 0.65rem 0.75rem;
        border: 1px solid transparent;
        border-radius: 10px;
        background: transparent;
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        text-decoration: none;
      }
      .search-result-item:hover {
        background: var(--surface-hover-strong);
        border-color: var(--panel-border);
      }
      .search-result-icon {
        flex: 0 0 auto;
        width: 1.25rem;
        height: 1.25rem;
        color: var(--search-icon);
      }
      .search-result-icon svg { width: 100%; height: 100%; display: block; }
      .search-result-body { min-width: 0; }
      .search-result-title {
        font-size: 0.84rem;
        font-weight: 600;
      }
      .search-result-sub {
        font-size: 0.72rem;
        color: var(--muted);
        margin-top: 0.1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .search-result-empty {
        padding: 2rem 0.5rem;
        text-align: center;
        color: var(--muted);
        font-size: 0.84rem;
      }
    </style>
  </head>
  <body data-user-id={userId ?? ""} data-is-owner={isOwner ? "1" : ""}>
    <Header
      adminShell
      profileMenu={installConfigClient.profileMenu}
      signInAutoOpen={!userId}
    />

    <div id="topbar-utilities" hidden aria-hidden="true">
      <div id="tabs-scroll"><div id="tabs"></div></div>
      <select id="model-select" style="display:none" aria-label="Agent model">
        <option value="claude-sonnet-4-6">Sonnet 4.6</option>
      </select>
      <span id="health-checked" class="tb-icon" data-tooltip="">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </span>
      <span id="topbar-stale-warn" class="tb-icon tt-left" data-tooltip="Keep current — edit public/admin/os-map-data.js when the system changes.">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      </span>
    </div>

    <div id="tools">
      <button data-act="in" title="Zoom in">+</button>
      <button data-act="out" title="Zoom out">−</button>
      <button data-act="fit" title="Fit to screen">⤢</button>
      <button id="reset" title="Reset layout">↺</button>
    </div>

    <div id="legend"></div>

    <div id="wrap">
      <div id="world">
        <svg id="edges" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <div id="home-dashboard" style="display:none" aria-label="Dashboard"></div>

    <div id="settings-panel" style="display:none" aria-label="Settings"></div>

    <div id="search-overlay" aria-hidden="true">
      <div class="search-overlay-bar">
