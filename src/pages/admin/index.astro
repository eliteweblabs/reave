        padding-top: 0.75rem;
        border-top: 1px dashed var(--panel-border);
      }
      .wk-billable-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.45rem;
      }
