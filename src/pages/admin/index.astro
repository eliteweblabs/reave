        #schedule-panel.de-pane-active .de-pane,
        #clients-editor.de-pane-active .de-pane,
        #rule-editor.de-pane-active .de-pane,
        #todo-editor.de-pane-active .de-pane { display: flex; flex: 1 1 auto; }
      }
      .re-settings {
        padding: 0 0.65rem 0.65rem;
        border-bottom: 1px solid var(--panel-border);
      }
      .re-check {
        display: flex;
        align-items: flex-start;
        gap: 0.4rem;
        font-size: 0.78rem;
        color: var(--fg);
        cursor: pointer;
        line-height: 1.4;
      }
      .re-checks { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; }
      .re-warn-inline {
