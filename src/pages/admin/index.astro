        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Shortcode autocomplete popover ── */
      .de-sc-pop {
        position: fixed;
        z-index: 9999;
        display: none;
        min-width: 260px;
        max-width: 320px;
        max-height: 260px;
