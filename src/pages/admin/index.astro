        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: var(--radius-input);
        padding: 0.4rem 0.6rem;
        outline: none;
        width: 100%;
        max-width: 340px;
      }
      .de-input:focus { border-color: #3b82f6; }
      .de-input.de-field-valid,
      .de-textarea.de-field-valid,
