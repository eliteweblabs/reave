      @media (max-width: 639px) {
        #chat-panel { flex-direction: column; }
        #email-panel { flex-direction: column; }
        .ch-sidebar {
          width: 100%;
          flex: 1 1 auto;
          border-right: none;
          border-bottom: 1px solid var(--panel-border);
        }
        .ch-pane { display: none; }
        #chat-panel.ch-pane-active .ch-sidebar { display: none; }
        #chat-panel.ch-pane-active .ch-pane {
          display: flex;
          flex: 1 1 auto;
          padding-top: calc(var(--topbar-h) + var(--setup-alert-h, 0px) - 0.85rem);
        }
        #chat-panel.ch-pane-active .ch-pane-header {
          flex-shrink: 0;
          background: var(--bg);
          gap: 0.3rem;
          padding: 0.15rem 0.45rem 0.2rem;
        }
        #chat-panel.ch-pane-active .ch-pane-header .ios-icon-btn:not(.ch-delete-btn),
        #chat-panel.ch-pane-active .ch-pane-header .ch-model-switcher-icon {
          color: hsl(0 0% 75%);
        }
        #chat-panel.ch-pane-active .ch-pane-header .ch-model-switcher-icon {
          color: #fff;
        }
        #chat-panel.ch-pane-active .ch-pane-header .ios-icon-btn:not(.ch-delete-btn):hover {
          background: transparent;
          color: hsl(0 0% 75%);
        }
        #chat-panel.ch-pane-active .ch-pane-header .ios-icon-btn {
          width: 2.25rem;
          height: 2.25rem;
        }
        #chat-panel.ch-pane-active .ch-pane-header .ch-model-switcher,
        #chat-panel.ch-pane-active .ch-pane-header .ch-model-switcher-icon {
          width: 32px;
          height: 32px;
        }
        #chat-panel.ch-pane-active .ch-pane-header .ch-model-switcher-icon {
          border: none;
        }
        #chat-panel.ch-pane-active .ch-pane-header .de-header-actions {
          gap: 0.15rem;
        }
        #email-panel.em-pane-active .ch-sidebar { display: none; }
        #email-panel.em-pane-active .ch-pane { display: flex; flex: 1 1 auto; }
        #schedule-panel.de-pane-active .de-pane {
          padding-top: calc(var(--topbar-h) + var(--setup-alert-h, 0px) - 0.85rem);
        }
        #schedule-panel.de-pane-active .de-header {
          flex-shrink: 0;
          background: var(--bg);
          gap: 0.3rem;
          padding: 0.15rem 0.45rem 0.2rem;
        }
        #schedule-panel.de-pane-active .de-header .ios-icon-btn {
          width: 2.25rem;
          height: 2.25rem;
        }
        #schedule-panel.de-pane-active .re-form-scroll {
          padding-top: 0.45rem;
        }
        .ch-messages { padding: 0.75rem 0.85rem var(--footer-scroll-pad); }

        /* Collapsed footer: home sits on the same row as chat input (right, small). */
        body.footer-chat-inline-home #chat-panel .ch-compose,
        body.footer-chat-inline-home #chat-panel .aui-compose-footer {
          bottom: calc(var(--ch-compose-gap) + env(safe-area-inset-bottom, 0px));
          right: calc(
            var(--ch-inline-home-w) + var(--ch-inline-home-gap) +
            max(0.5rem, env(safe-area-inset-right, 0px))
          );
        }
        body.footer-chat-inline-home #chat-panel .ch-compose-main,
        body.footer-chat-inline-home #chat-panel .ch-attachments {
          max-width: none;
          margin: 0;
        }
        body.footer-chat-inline-home #chat-panel.ch-pane-active .ch-messages,
        body.footer-chat-inline-home #chat-panel.ch-pane-active .aui-viewport {
          padding-bottom: 0.75rem;
        }

        body.footer-chat-inline-home #chat-panel.ch-pane-active .aui-compose-footer {
          padding-bottom: calc(
            var(--control-h) + var(--ch-compose-gap) + 0.65rem + env(safe-area-inset-bottom, 0px)
          );
        }

        /* iOS-style: hide footer nav while typing; pin compose above keyboard. */
        body.chat-compose-focused .admin-footer-nav {
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
        }
        body.chat-compose-focused #chat-panel .ch-compose,
        body.chat-compose-focused #chat-panel .aui-compose-footer {
          left: max(0.5rem, env(safe-area-inset-left, 0px));
          right: max(0.5rem, env(safe-area-inset-right, 0px));
          bottom: calc(var(--chat-compose-bottom, 0px) + var(--ch-compose-gap));
        }
        body.chat-compose-focused #chat-panel.ch-pane-active .ch-messages,
        body.chat-compose-focused #chat-panel.ch-pane-active .aui-viewport {
          padding-bottom: 0.75rem;
        }
      }

      /* App dialog — iOS bottom sheet on mobile, centered on desktop */
      #os-dialog-backdrop {
        z-index: 5000;
      }
      #os-dialog-backdrop .ios-sheet {
        --ios-sheet-bg: var(--panel);
        --ios-sheet-fg: var(--fg);
        --ios-sheet-border: var(--panel-border);
        --ios-sheet-muted: var(--muted);
        --ios-sheet-grabber: color-mix(in srgb, var(--muted) 55%, transparent);
        --ios-sheet-close-bg: var(--surface-hover);
        --ios-sheet-close-hover: var(--surface-hover-strong);
        max-width: 400px;
      }
      #os-dialog-backdrop .ios-sheet-header {
        border-bottom-color: var(--panel-border);
      }
      #os-dialog-backdrop .os-dialog-title {
        padding: 0;
      }
      #os-dialog-backdrop .os-dialog-sheet-body {
        padding: 0;
        display: flex;
        flex-direction: column;
      }
      #os-dialog-backdrop .os-dialog-body {
        padding: 0 1.15rem 1rem;
        font-size: 0.84rem;
        line-height: 1.55;
        color: var(--muted);
      }
      #os-dialog-backdrop .os-dialog-body p { margin: 0 0 0.65rem; }
      #os-dialog-backdrop .os-dialog-body p:last-child { margin-bottom: 0; }
      .os-dialog-warn { color: #fbbf24; }
      .os-dialog-note { color: #93c5fd; font-size: 0.8rem; }
      #os-dialog-backdrop .os-dialog-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        padding: 0.75rem 1rem max(1rem, env(safe-area-inset-bottom));
        border-top: 1px solid var(--panel-border);
        background: rgba(0, 0, 0, 0.15);
        flex-shrink: 0;
      }
      .os-dialog-btn {
        font: inherit;
        font-size: 0.84rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 0.5rem 0.9rem;
        cursor: pointer;
        border: 1px solid var(--panel-border);
        background: var(--tab-active-bg);
        color: var(--fg);
      }
      .os-dialog-btn:hover { border-color: #4b5563; }
      .os-dialog-btn--ghost {
        background: transparent;
        color: var(--muted);
        border-color: transparent;
      }
      .os-dialog-btn--ghost:hover { color: var(--fg); background: var(--surface-hover); }
      .os-dialog-btn--danger {
        background: #dc2626;
        border-color: #dc2626;
        color: #fff;
      }
      .os-dialog-btn--danger:hover { background: #b91c1c; border-color: #b91c1c; }

      @media (max-width: 767px) {
        #os-dialog-backdrop.open.os-dialog-keyboard .ios-sheet {
          max-height: calc(100dvh - var(--os-dialog-keyboard-inset, 0px) - 0.5rem);
        }
        #os-dialog-backdrop.open.os-dialog-keyboard .os-dialog-body {
          overflow-y: auto;
          -webkit-overflow-scrolling: touch;
          overscroll-behavior: contain;
          min-height: 0;
          flex: 1 1 auto;
        }
      }

      /* Reave share sheet */
      #reave-share-backdrop {
        z-index: 5500;
      }
      #reave-share-backdrop .ios-sheet {
        --ios-sheet-bg: var(--panel);
        --ios-sheet-fg: var(--fg);
        --ios-sheet-border: var(--panel-border);
        --ios-sheet-muted: var(--muted);
        --ios-sheet-grabber: color-mix(in srgb, var(--muted) 55%, transparent);
        --ios-sheet-close-bg: var(--surface-hover);
        --ios-sheet-close-hover: var(--surface-hover-strong);
        max-width: 420px;
