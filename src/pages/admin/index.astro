      .wk-billable-hint {
        margin: 0.5rem 0 0;
        font-size: 0.75rem;
        color: var(--muted);
        line-height: 1.4;
      }
      .re-textarea {
        width: 100%;
        min-height: 4.5rem;
        font: inherit;
        font-size: max(16px, 0.84rem);
        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: var(--radius-input);
        padding: 0.45rem 0.55rem;
        resize: vertical;
        outline: none;
      }
      .re-textarea:focus { border-color: #3b82f6; }
      .wk-status {
        font-size: 0.62rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.08rem 0.35rem;
