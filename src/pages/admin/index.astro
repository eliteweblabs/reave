        cursor: pointer;
        transition: background 0.12s, border-color 0.12s;
      }
      .wk-client-profile-link:hover:not(:disabled) {
        background: var(--surface-hover);
        border-color: color-mix(in srgb, var(--accent) 45%, var(--panel-border));
