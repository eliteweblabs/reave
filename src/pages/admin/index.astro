      .os-dialog-title {
        margin: 0;
        padding: 1rem 1.15rem 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
      }
      .os-dialog-body {
        padding: 0 1.15rem 1rem;
        font-size: 0.84rem;
        line-height: 1.55;
        color: var(--muted);
      }
      .os-dialog-body p { margin: 0 0 0.65rem; }
      .os-dialog-body p:last-child { margin-bottom: 0; }
      .os-dialog-warn { color: #fbbf24; }
      .os-dialog-note { color: #93c5fd; font-size: 0.8rem; }
      .os-dialog-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        padding: 0.75rem 1rem 1rem;
        border-top: 1px solid var(--panel-border);
        background: rgba(0, 0, 0, 0.15);
      }
      .os-dialog-btn {
        font: inherit;
        font-size: 0.84rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 0.5rem 0.9rem;
        cursor: pointer;
        border: 1px solid var(--panel-border);
        background: #1b2230;
        color: var(--fg);
      }
      .os-dialog-btn:hover { border-color: #4b5563; }
      .os-dialog-btn--ghost {
        background: transparent;
        color: var(--muted);
        border-color: transparent;
      }
      .os-dialog-btn--ghost:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .os-dialog-btn--danger {
        background: #3f1515;
        border-color: #7f1d1d;
        color: #fca5a5;
      }
      .os-dialog-btn--danger:hover { background: #521818; border-color: #991b1b; }
    </style>
  </head>
  <body data-user-id={userId ?? ""}>
    <div id="topbar">
      <a href="/" class="brand" aria-label={company.name}>
        <img class="brand-img" src={company.logoPath} alt={company.name} />
      </a>
      <div id="tabs-scroll"><div id="tabs"></div></div>
      <div class="topbar-end">
        <select id="model-select" style="display:none" aria-label="Agent model">
          <option value="claude-sonnet-4-6">Sonnet 4.6</option>
        </select>
        <span id="health-checked" class="tb-icon" data-tooltip="">🕐</span>
        <button type="button" id="push-enable-btn" class="tb-icon push-btn tt-left" data-tooltip="Enable phone notifications" aria-label="Enable push notifications">🔔</button>
        <span id="topbar-stale-warn" class="tb-icon tt-left" data-tooltip="Keep current — edit public/admin/os-map-data.js when the system changes.">⚠️</span>
        <button type="button" id="topbar-inbox-btn" class="topbar-icon-btn topbar-inbox-btn tb-mobile-only" aria-label="Inbox notifications">
          <span class="topbar-inbox-icon" aria-hidden="true">🔔</span>
          <span id="topbar-inbox-badge" class="topbar-badge" hidden>0</span>
        </button>
        <div class="topbar-menu topbar-tools-menu tb-mobile-only">
          <button type="button" id="topbar-tools-toggle" class="topbar-icon-btn topbar-tools-btn" aria-label="Admin sections" aria-expanded="false" aria-haspopup="true">🔧</button>
          <div id="topbar-tools-menu" class="topbar-dropdown" role="menu" aria-label="Admin sections"></div>
        </div>
        <div class="topbar-menu topbar-profile-menu">
          <button type="button" id="topbar-profile-toggle" class="topbar-profile-btn" aria-label="Account menu" aria-expanded="false" aria-haspopup="true">
            {avatarUrl ? (
              <img src={avatarUrl} alt="" class="topbar-profile-avatar" />
            ) : (
              <span class="topbar-profile-initials">{userInitials || "?"}</span>
            )}
          </button>
          <div id="topbar-profile-menu" class="topbar-dropdown" role="menu">
            <a href="/admin/profile" class="topbar-dropdown-item" role="menuitem">Profile</a>
            <div class="topbar-dropdown-divider"></div>
            <button type="button" id="topbar-sign-out" class="topbar-dropdown-item topbar-dropdown-item--danger" role="menuitem">Sign out</button>
          </div>
        </div>
      </div>
    </div>

    <div id="tools">
      <button data-act="in" title="Zoom in">+</button>
      <button data-act="out" title="Zoom out">−</button>
      <button data-act="fit" title="Fit to screen">⤢</button>
      <button id="reset" title="Reset layout">↺</button>
    </div>

    <div id="legend"></div>

    <div id="wrap">
      <div id="world">
        <svg id="edges" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <!-- Documents tab panel (hidden unless documents tab is active) -->
    <div id="doc-editor" style="display:none"></div>

    <!-- Chats tab panel (hidden unless chats tab is active) -->
    <div id="chat-panel" style="display:none"></div>

    <!-- Email tab panel (hidden unless email tab is active) -->
    <div id="email-panel" style="display:none"></div>

    <!-- Knowledge tab panel (hidden unless knowledge tab is active) -->
    <div id="knowledge-editor" style="display:none"></div>

    <!-- Work tab panel (hidden unless work tab is active) -->
    <div id="work-editor" style="display:none"></div>

    <!-- Clients tab panel (hidden unless clients tab is active) -->
    <div id="clients-editor" style="display:none"></div>

    <div id="rule-editor" style="display:none"></div>

    <div id="os-dialog-backdrop" role="presentation" aria-hidden="true">
      <div class="os-dialog" role="dialog" aria-modal="true" aria-labelledby="os-dialog-title">
        <h2 class="os-dialog-title" id="os-dialog-title"></h2>
        <div class="os-dialog-body" id="os-dialog-body"></div>
        <div class="os-dialog-actions" id="os-dialog-actions"></div>
      </div>
    </div>

    <script is:inline type="module" src="/admin/os-map-loader.js?v=20250628g"></script>
    <script is:inline type="module" src="/admin/push-client.js"></script>
  </body>
</html>
