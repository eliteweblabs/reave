        display: none;
      }
      .panel-list-search-field.control-field {
        margin: 0;
      }
      /* Inline + FAB: mobile sidebar only (footer nav handles create on wider viewports). */
      @media (max-width: 639px) {
        .panel-list-subheader .de-new-btn.ch-new-btn {
          box-shadow: 0 2px 10px rgba(192, 38, 211, 0.45);
        }
        .panel-list-subheader .de-new-btn.ch-new-btn:hover {
