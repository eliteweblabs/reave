        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }
      .sliding-pill-select {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        min-width: 0;
      }
      .sliding-pill {
        position: relative;
        display: flex;
        align-items: stretch;
        width: 100%;
        padding: 0.15rem;
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-input);
        background: var(--surface-subtle);
        overflow: hidden;
      }
      .sliding-pill-indicator {
        position: absolute;
