      /* iOS-style swipe actions on email list rows */
      .swipe-row {
        position: relative;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow: hidden;
        border-radius: 8px;
        margin-bottom: 0.15rem;
        touch-action: pan-y;
