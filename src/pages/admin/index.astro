        border-radius: 6px;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: color 0.12s, background 0.12s;
      }
      .ch-msg-action svg {
        width: 0.875rem;
        height: 0.875rem;
      }
      .ch-msg-action:hover {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.08);
      }
      .ch-msg-user .ch-msg-action:hover {
        background: rgba(255, 255, 255, 0.12);
      }
      @media (hover: none) {
