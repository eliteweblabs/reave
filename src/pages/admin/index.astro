        line-height: 1.45;
      }
      .em-cat-junk { --em-item-accent: #f87171; color: #f87171; background: rgba(248,113,113,0.12); }
      .em-cat-client { --em-item-accent: #34d399; color: #34d399; background: rgba(52,211,153,0.12); }
      .em-project-reply {
        color: #fecaca;
        background: rgba(239, 68, 68, 0.22);
        font-weight: 700;
      }
      .em-list-item-urgent {
        --em-item-accent: #ef4444;
        border-left: 3px solid #ef4444;
        background: rgba(239, 68, 68, 0.06);
      }
      .em-cat-alert { --em-item-accent: #60a5fa; color: #60a5fa; background: rgba(96,165,250,0.12); }
      .em-cat-internal { --em-item-accent: #a78bfa; color: #a78bfa; background: rgba(167,139,250,0.12); }
      .em-cat-review { --em-item-accent: #fbbf24; color: #fbbf24; background: rgba(251,191,36,0.12); }
      .em-cat-receipt { --em-item-accent: #34d399; color: #34d399; background: rgba(52,211,153,0.14); }
      .em-money-hint { color: #6ee7b7; background: rgba(52,211,153,0.1); font-variant-numeric: tabular-nums; }
      .em-book-pending { color: #2dd4bf; background: rgba(45,212,191,0.14); }
      .em-book-scheduled { color: #34d399; background: rgba(52,211,153,0.14); }
      .em-book-card {
        margin: 0.75rem 0 1rem;
        padding: 0.85rem 1rem;
        border-radius: 10px;
        border: 1px solid rgba(45,212,191,0.35);
