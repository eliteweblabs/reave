        background: rgba(220, 38, 38, 0.88);
        color: #fff;
      }
      .admin-setup-alert-btn--danger:hover {
        background: rgba(185, 28, 28, 0.95);
        border-color: rgba(185, 28, 28, 0.95);
      }
      .admin-setup-alert-dismiss {
