      }
      .de-input.de-field-invalid,
      .de-textarea.de-field-invalid,
      .de-input.form-field--invalid,
      .de-textarea.form-field--invalid {
        border-color: #ef4444;
      }
      .de-input.de-field-invalid:focus,
