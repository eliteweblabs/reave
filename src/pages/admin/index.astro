        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .ch-attachment {
        position: relative;
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--card-border);
        background: var(--card);
      }
      .ch-attachment img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .ch-attachment-remove {
        position: absolute;
        top: 0.2rem;
        right: 0.2rem;
        width: 1.25rem;
        height: 1.25rem;
        padding: 0;
        border: none;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.65);
        color: #fff;
        font-size: 0.85rem;
        line-height: 1;
        cursor: pointer;
      }
      .ch-msg-images {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.45rem;
      }
      .ch-msg-img {
        max-width: min(240px, 100%);
        max-height: 180px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .ch-input {
        flex: 1;
        width: 100%;
        resize: none;
        min-height: 2.6rem;
        max-height: 8rem;
        padding: 0.55rem 0.75rem;
        font: inherit;
        font-size: max(16px, 0.84rem);
        line-height: 1.45;
        color: var(--fg);
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 9px;
        outline: none;
        overflow-x: hidden;
      }
      .ch-input::placeholder {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .ch-input:focus { border-color: #3b82f6; }
      .ch-compose-actions {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-self: flex-end;
      }
      .ch-send,
      .ch-stop {
        flex-shrink: 0;
        box-sizing: border-box;
        min-height: 2.6rem;
        height: 2.6rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font: inherit;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 9px;
        padding: 0 0.95rem;
        cursor: pointer;
        white-space: nowrap;
      }
      .ch-send {
        color: #fff;
        background: #2563eb;
        border: 1px solid #3b82f6;
      }
      .ch-send:disabled { opacity: 0.45; cursor: default; }
      .ch-send:not(:disabled):hover { background: #1d4ed8; }
      .ch-stop {
        color: #fff;
        background: #dc2626;
        border: 1px solid #ef4444;
      }
      .ch-stop:hover { background: #b91c1c; }
      .ch-stop[hidden] { display: none !important; }
      .ch-send[hidden] { display: none !important; }
      .ch-thinking {
        align-self: flex-start;
        color: var(--muted);
        font-size: 0.8rem;
        font-style: italic;
        padding: 0.25rem 0;
      }
      .ch-scroll-anchor {
        height: 0;
        width: 100%;
        flex-shrink: 0;
        overflow: hidden;
      }
      .ch-model-badge {
        margin-left: auto;
        font-size: 0.68rem;
        color: var(--muted);
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        padding: 0.12rem 0.5rem;
        white-space: nowrap;
      }
      .ch-delete-btn {
        margin-left: 0.45rem;
        padding: 0.35rem 0.65rem;
        border-radius: 8px;
        border: 1px solid rgba(239, 68, 68, 0.35);
        background: rgba(239, 68, 68, 0.08);
        color: #f87171;
        font: inherit;
        font-size: 0.75rem;
        cursor: pointer;
      }
      .ch-delete-btn:hover { background: rgba(239, 68, 68, 0.16); }
      .ch-copy-chat-btn,
      .ch-share-chat-btn {
        margin-left: 0.15rem;
      }
      .ch-toast {
        position: fixed;
        bottom: 1.25rem;
        left: 50%;
        transform: translateX(-50%) translateY(0.5rem);
        z-index: 9999;
        padding: 0.45rem 0.85rem;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--fg);
        background: #1a2332;
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.18s, transform 0.18s;
      }
      .ch-toast.ch-toast-visible {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      .ch-context-menu {
        position: fixed;
        z-index: 10000;
        min-width: 9rem;
        padding: 0.25rem;
        background: #1a2332;
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
      }
      .ch-context-item {
        display: block;
        width: 100%;
        padding: 0.45rem 0.65rem;
        font: inherit;
        font-size: 0.8rem;
        text-align: left;
        color: var(--fg);
        background: transparent;
        border: none;
        border-radius: 6px;
        cursor: pointer;
      }
      .ch-context-item:hover {
        background: rgba(255, 255, 255, 0.08);
      }

      /* ── Email tab ── */
      #email-panel {
        position: fixed;
        inset: 0;
        height: 100dvh;
        padding-top: var(--topbar-h);
        padding-bottom: var(--footer-nav-h);
        display: flex;
        flex-direction: row;
        background: var(--bg);
        z-index: 10;
      }
      .em-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 0.55rem 0.65rem;
        border-bottom: 1px solid var(--panel-border);
      }
      .em-refresh {
        font: inherit;
        font-size: 0.75rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid var(--panel-border);
        border-radius: 6px;
        padding: 0.25rem 0.55rem;
        cursor: pointer;
      }
      .em-refresh:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .em-list-item {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.2rem;
        padding: 0.55rem 0.65rem;
        font: inherit;
        font-size: 0.8rem;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        margin-bottom: 0.15rem;
      }
      .em-list-item:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .em-list-item.active { color: var(--fg); background: #11253d; border-color: #2d5a94; }

      /* iOS-style swipe actions on email list rows */
      .swipe-row {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
        margin-bottom: 0.15rem;
        touch-action: pan-y;
        background: var(--swipe-row-bg, var(--panel));
        --swipe-row-bg: var(--panel);
      }
      .ch-list .swipe-row:nth-child(odd) { --swipe-row-bg: #121722; }
      .ch-list .swipe-row:nth-child(even) { --swipe-row-bg: #171d2a; }
      .swipe-actions {
        position: absolute;
        inset: 0 0 0 auto;
        display: flex;
        align-items: stretch;
        z-index: 0;
        /* Hidden until swipe-open or active drag — stops action colors bleeding at corners */
        clip-path: inset(0 100% 0 0);
        pointer-events: none;
      }
      .swipe-row.swipe-open .swipe-actions,
      .swipe-row.swipe-dragging .swipe-actions {
        clip-path: none;
        pointer-events: auto;
      }
      .swipe-act {
        flex: none;
        width: 4.5rem;
        border: none;
        font: inherit;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: #fff;
        cursor: pointer;
        padding: 0 0.35rem;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        line-height: 1.2;
      }
      .swipe-act-agent { background: #007aff; }
      .swipe-act-junk { background: #ff9500; }
      .swipe-act-archive { background: #8e8e93; }
      .swipe-act-delete { background: #ff3b30; }
      .swipe-act:active { filter: brightness(0.92); }
      .swipe-content {
        position: relative;
        z-index: 1;
        will-change: transform;
        background: var(--swipe-row-bg, var(--panel));
        border-radius: 8px;
        overflow: hidden;
        isolation: isolate;
      }
      .swipe-content .em-list-item,
      .swipe-content .ch-list-item {
        margin-bottom: 0;
        border-radius: 8px;
        background: var(--swipe-row-bg, var(--panel));
      }
      .swipe-row:nth-child(odd) .em-list-item:hover,
      .swipe-row:nth-child(odd) .ch-list-item:hover {
        background: #161c28;
      }
      .swipe-row:nth-child(even) .em-list-item:hover,
      .swipe-row:nth-child(even) .ch-list-item:hover {
        background: #1b2230;
      }
      .swipe-content .em-list-item.active,
      .swipe-content .ch-list-item.active {
        background: #11253d;
      }
      .em-item-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        width: 100%;
        min-width: 0;
      }
      .em-item-header {
        gap: 0.35rem;
      }
      .em-item-subject {
        flex: 1;
        min-width: 0;
        font-weight: 600;
        font-size: 0.82rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .em-item-from {
        flex: 1;
        min-width: 0;
        font-size: 0.68rem;
        color: var(--fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .em-item-date {
        flex: 0 0 auto;
        font-size: 0.68rem;
        color: var(--muted);
        white-space: nowrap;
      }
      .em-status {
        flex: 0 0 auto;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        padding: 0.12rem 0.35rem;
        border-radius: 4px;
        border: 1px solid transparent;
      }
      .em-status-default { color: #94a3b8; background: rgba(148,163,184,0.12); }
      .em-status-unmatched { color: #fbbf24; background: rgba(251,191,36,0.12); }
      .em-status-needs_check { color: #fb923c; background: rgba(251,146,60,0.12); }
      .em-status-rejected { color: #f87171; background: rgba(248,113,113,0.12); }
      .em-status-delete { color: #f87171; background: rgba(248,113,113,0.12); }
      .em-status-auto_archived { color: #a78bfa; background: rgba(167,139,250,0.12); }
      .em-status-down { color: #60a5fa; background: rgba(96,165,250,0.12); }
      .em-detail {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1.2rem;
      }
      .em-detail-subject {
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0.65rem 0 0.85rem;
        line-height: 1.35;
      }
      .em-detail-meta {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 1rem;
      }
      .em-detail-meta strong { color: var(--fg); font-weight: 600; margin-right: 0.35rem; }
      .em-detail-body {
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 0.84rem;
        line-height: 1.55;
        padding: 0.75rem 0.85rem;
        background: var(--card);
        border: 1px solid var(--card-border);
        border-radius: 8px;
      }
      .em-digest {
        font-size: 0.72rem;
        color: var(--muted);
        padding: 0.45rem 0.65rem;
        border-bottom: 1px solid var(--panel-border);
        line-height: 1.4;
      }
      .em-item-summary {
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.35;
        width: 100%;
        text-align: left;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .em-detail-summary {
        font-size: 1rem;
        line-height: 1.45;
        margin: 0.5rem 0 0.75rem;
        color: var(--fg);
      }
      .em-hint {
        font-size: 0.75rem;
        color: var(--muted);
        font-weight: 400;
        line-height: 1.45;
      }
      .em-cat-junk { color: #f87171; background: rgba(248,113,113,0.12); }
      .em-cat-client { color: #34d399; background: rgba(52,211,153,0.12); }
      .em-cat-alert { color: #60a5fa; background: rgba(96,165,250,0.12); }
      .em-cat-internal { color: #a78bfa; background: rgba(167,139,250,0.12); }
      .em-cat-review { color: #fbbf24; background: rgba(251,191,36,0.12); }

      @media (max-width: 639px) {
        #chat-panel { flex-direction: column; }
        #email-panel { flex-direction: column; }
        .ch-sidebar {
          width: 100%;
          flex: 1 1 auto;
          border-right: none;
          border-bottom: 1px solid var(--panel-border);
        }
        .ch-pane { display: none; }
        #chat-panel.ch-pane-active .ch-sidebar { display: none; }
        #chat-panel.ch-pane-active .ch-pane { display: flex; flex: 1 1 auto; }
        #email-panel.em-pane-active .ch-sidebar { display: none; }
        #email-panel.em-pane-active .ch-pane { display: flex; flex: 1 1 auto; }
        .ch-messages { padding: 0.75rem 0.85rem; }
        .ch-compose {
          gap: 0.4rem;
          padding: 0.65rem 0.75rem;
        }
      }

      /* App dialog (replaces system alert/confirm on mobile) */
      #os-dialog-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 5000;
        background: rgba(0, 0, 0, 0.72);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        align-items: center;
        justify-content: center;
        padding: max(16px, env(safe-area-inset-top)) 16px max(16px, env(safe-area-inset-bottom));
      }
      #os-dialog-backdrop.open { display: flex; }
      .os-dialog {
        width: 100%;
        max-width: 400px;
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 14px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.55);
        overflow: hidden;
      }
      .os-dialog-title {
        margin: 0;
        padding: 1rem 1.15rem 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
      }
      .os-dialog-body {
        padding: 0 1.15rem 1rem;
        font-size: 0.84rem;
        line-height: 1.55;
        color: var(--muted);
      }
      .os-dialog-body p { margin: 0 0 0.65rem; }
      .os-dialog-body p:last-child { margin-bottom: 0; }
      .os-dialog-warn { color: #fbbf24; }
      .os-dialog-note { color: #93c5fd; font-size: 0.8rem; }
      .os-dialog-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        padding: 0.75rem 1rem 1rem;
        border-top: 1px solid var(--panel-border);
        background: rgba(0, 0, 0, 0.15);
      }
      .os-dialog-btn {
        font: inherit;
        font-size: 0.84rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 0.5rem 0.9rem;
        cursor: pointer;
        border: 1px solid var(--panel-border);
        background: #1b2230;
        color: var(--fg);
      }
      .os-dialog-btn:hover { border-color: #4b5563; }
      .os-dialog-btn--ghost {
        background: transparent;
        color: var(--muted);
        border-color: transparent;
      }
      .os-dialog-btn--ghost:hover { color: var(--fg); background: rgba(255,255,255,0.04); }
      .os-dialog-btn--danger {
        background: #3f1515;
        border-color: #7f1d1d;
        color: #fca5a5;
      }
      .os-dialog-btn--danger:hover { background: #521818; border-color: #991b1b; }

      /* ── Home dashboard ── */
      #home-dashboard {
        position: fixed;
        inset: 0;
        height: 100dvh;
        padding-top: var(--topbar-h);
        padding-bottom: var(--footer-nav-h);
        display: none;
        flex-direction: column;
        background: var(--bg);
        z-index: 10;
        overflow: hidden;
      }
      .home-dashboard-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1rem 1.25rem;
      }
      .home-dashboard-title {
        margin: 0 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .home-dashboard-sub {
        margin: 0 0 1.25rem;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .dash-header {
        margin-bottom: 1.25rem;
      }
      .dash-date {
        margin: 0.2rem 0 0;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .dash-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.65rem;
        margin-bottom: 1.35rem;
      }
      @media (min-width: 640px) {
        .dash-stats {
          grid-template-columns: repeat(4, minmax(0, 1fr));
        }
      }

      .dash-stat {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.15rem;
        padding: 0.9rem 0.85rem;
        border-radius: 14px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        transition: border-color 0.15s, background 0.15s, transform 0.12s;
        min-height: 5.5rem;
      }
      .dash-stat:hover {
        border-color: rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.06);
      }
      .dash-stat:active {
        transform: scale(0.98);
      }
      .dash-stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        font-variant-numeric: tabular-nums;
      }
      .dash-stat-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.88);
      }
      .dash-stat-hint {
        font-size: 0.68rem;
        color: var(--muted);
        line-height: 1.3;
      }
      .dash-stat--muted {
        cursor: default;
      }
      .dash-stat--muted:hover {
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--panel-border);
        transform: none;
      }
      .dash-stat--live .dash-stat-value { color: #4ade80; }
      .dash-stat--stale .dash-stat-value { color: #fbbf24; }
      .dash-stat--failed .dash-stat-value { color: #f87171; }

      .dash-panel {
        margin-bottom: 1.35rem;
        padding: 0.85rem 0.9rem;
        border-radius: 14px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.02);
      }
      .dash-panel-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.65rem;
      }
      .dash-panel-title {
        margin: 0;
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }
      .dash-panel-note {
        font-size: 0.65rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .dash-events {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }
      .dash-event {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 0.55rem 0.5rem;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
      }
      .dash-event-time {
        flex: 0 0 auto;
        min-width: 4.2rem;
        font-size: 0.72rem;
        font-weight: 600;
        color: #79c0ff;
        font-variant-numeric: tabular-nums;
      }
      .dash-event-body {
        min-width: 0;
      }
      .dash-event-title {
        font-size: 0.82rem;
        font-weight: 500;
        line-height: 1.35;
      }
      .dash-event-type {
        font-size: 0.65rem;
        color: var(--muted);
        margin-top: 0.1rem;
        text-transform: capitalize;
      }

      .dash-inbox-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .dash-inbox-item {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        width: 100%;
        padding: 0.55rem 0.5rem;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: inherit;
        cursor: pointer;
        text-align: left;
        font: inherit;
      }
      .dash-inbox-item:hover {
        background: rgba(255, 255, 255, 0.05);
      }
      .dash-inbox-subject {
        font-size: 0.82rem;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .dash-inbox-meta {
        font-size: 0.68rem;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .dash-empty {
        margin: 0;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .dash-loading {
        padding: 2rem 0;
        text-align: center;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .dash-quick-title {
        margin: 0 0 0.75rem;
        font-size: 0.88rem;
        font-weight: 700;
      }

      .home-dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(9.5rem, 1fr));
        gap: 0.65rem;
      }
      .home-dashboard-tile {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.55rem;
        padding: 0.85rem 0.8rem;
        border-radius: 12px;
        border: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.03);
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        transition: border-color 0.15s, background 0.15s;
      }
      .home-dashboard-tile:hover {
        border-color: rgba(255, 255, 255, 0.18);
        background: rgba(255, 255, 255, 0.06);
      }
      .home-dashboard-tile-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        color: rgba(255, 255, 255, 0.88);
      }
      .home-dashboard-tile-icon svg {
        width: 1.25rem;
        height: 1.25rem;
        display: block;
      }
      .home-dashboard-tile-label {
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.25;
      }

      /* ── Profile panel ── */
      #profile-panel {
        position: fixed;
        inset: 0;
        height: 100dvh;
        padding-top: var(--topbar-h);
        padding-bottom: var(--footer-nav-h);
        display: none;
        flex-direction: column;
        background: var(--bg);
        z-index: 10;
        overflow: hidden;
      }
      .profile-panel-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .prof-card {
        width: 100%;
        max-width: 560px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--panel-border);
        border-radius: 12px;
        padding: 1.5rem 1.35rem;
      }
      .prof-title {
        margin: 0 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .prof-title--section {
        font-size: 1.1rem;
      }
      .prof-subtitle {
        margin: 0 0 1.25rem;
        font-size: 0.82rem;
        color: var(--muted);
      }
      .prof-alert {
        padding: 0.65rem 0.85rem;
        border-radius: 8px;
        font-size: 0.82rem;
        margin-bottom: 1rem;
      }
      .prof-alert--success {
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #4ade80;
      }
      .prof-alert--error {
        background: rgba(239, 68, 68, 0.12);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
      }
      .prof-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .prof-field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.85rem;
      }
      @media (max-width: 639px) {
        .prof-field-row {
          grid-template-columns: 1fr;
        }
      }
      .prof-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .prof-field label {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prof-field input,
      .prof-field select {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--panel-border);
        border-radius: 8px;
        padding: 0.6rem 0.75rem;
        font: inherit;
        font-size: max(16px, 0.88rem);
        color: var(--fg);
        outline: none;
      }
      .prof-field input:focus,
      .prof-field select:focus {
        border-color: rgba(255, 255, 255, 0.22);
      }
      .prof-field input:disabled {
        opacity: 0.55;
        cursor: not-allowed;
      }
      .prof-hint {
        font-size: 0.72rem;
        color: var(--muted);
        line-height: 1.4;
      }
      .prof-hint--block {
        display: block;
        margin-top: -0.35rem;
      }
      .prof-hint code {
        font-size: 0.68rem;
      }
      .prof-actions {
        padding-top: 0.25rem;
      }
      .prof-btn-primary {
        font: inherit;
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        background: #2563eb;
        border: 1px solid #3b82f6;
        border-radius: 8px;
        padding: 0.55rem 1rem;
        cursor: pointer;
      }
      .prof-btn-primary:hover {
        background: #1d4ed8;
      }
      .prof-btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      /* ── Search overlay ── */
      #search-overlay {
        position: fixed;
        inset: 0;
        height: 100dvh;
        display: none;
        flex-direction: column;
        background: rgba(10, 13, 20, 0.96);
        z-index: 15;
        padding:
          calc(var(--topbar-h) + 0.75rem)
          1rem
          calc(1rem + var(--footer-nav-h));
      }
      #search-overlay.open {
        display: flex;
      }
      .search-overlay-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
      }
      .search-overlay-input {
        flex: 1;
        padding: 0.65rem 0.75rem;
        border-radius: 10px;
        border: 1px solid var(--panel-border);
        background: var(--panel);
        color: var(--fg);
        font: inherit;
        font-size: 1rem;
      }
      .search-overlay-input:focus {
        outline: none;
        border-color: rgba(255, 255, 255, 0.25);
      }
      .search-overlay-close {
        flex: 0 0 auto;
        width: 2.5rem;
        height: 2.5rem;
        border: 1px solid var(--panel-border);
        border-radius: 999px;
        background: transparent;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        display: grid;
        place-items: center;
      }
      .search-overlay-close:hover { color: #fff; border-color: rgba(255, 255, 255, 0.2); }
      .search-overlay-results {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .search-result-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        padding: 0.65rem 0.75rem;
        border: 1px solid transparent;
        border-radius: 10px;
        background: transparent;
        color: var(--fg);
        cursor: pointer;
        text-align: left;
        font: inherit;
        text-decoration: none;
      }
      .search-result-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--panel-border);
      }
      .search-result-icon {
        flex: 0 0 auto;
        width: 1.25rem;
        height: 1.25rem;
        color: rgba(255, 255, 255, 0.75);
      }
      .search-result-icon svg { width: 100%; height: 100%; display: block; }
      .search-result-body { min-width: 0; }
      .search-result-title {
        font-size: 0.84rem;
        font-weight: 600;
      }
      .search-result-sub {
        font-size: 0.72rem;
        color: var(--muted);
        margin-top: 0.1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .search-result-empty {
        padding: 2rem 0.5rem;
        text-align: center;
        color: var(--muted);
        font-size: 0.84rem;
      }
    </style>
  </head>
  <body data-user-id={userId ?? ""}>
    <Header adminShell />

    <div id="topbar-utilities" hidden aria-hidden="true">
      <div id="tabs-scroll"><div id="tabs"></div></div>
      <select id="model-select" style="display:none" aria-label="Agent model">
        <option value="claude-sonnet-4-6">Sonnet 4.6</option>
      </select>
      <span id="health-checked" class="tb-icon" data-tooltip="">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </span>
      <span id="topbar-stale-warn" class="tb-icon tt-left" data-tooltip="Keep current — edit public/admin/os-map-data.js when the system changes.">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      </span>
    </div>

    <div id="tools">
      <button data-act="in" title="Zoom in">+</button>
      <button data-act="out" title="Zoom out">−</button>
      <button data-act="fit" title="Fit to screen">⤢</button>
      <button id="reset" title="Reset layout">↺</button>
    </div>

    <div id="legend"></div>

    <div id="wrap">
      <div id="world">
        <svg id="edges" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <div id="home-dashboard" style="display:none" aria-label="Dashboard"></div>

    <div id="profile-panel" style="display:none" aria-label="Profile"></div>

    <div id="search-overlay" aria-hidden="true">
      <div class="search-overlay-bar">
        <input
          id="search-overlay-input"
          class="search-overlay-input"
          type="search"
          placeholder="Search sections and clients…"
          autocomplete="off"
          aria-label="Search"
        />
        <button type="button" id="search-overlay-close" class="search-overlay-close" aria-label="Close search">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div id="search-overlay-results" class="search-overlay-results"></div>
    </div>

    <!-- Documents tab panel (hidden unless documents tab is active) -->
    <div id="doc-editor" style="display:none"></div>

    <!-- Chats tab panel (hidden unless chats tab is active) -->
    <div id="chat-panel" style="display:none"></div>

    <!-- Email tab panel (hidden unless email tab is active) -->
    <div id="email-panel" style="display:none"></div>

    <!-- Knowledge tab panel (hidden unless knowledge tab is active) -->
    <div id="knowledge-editor" style="display:none"></div>

    <!-- Work tab panel (hidden unless work tab is active) -->
    <div id="work-editor" style="display:none"></div>

    <!-- Clients tab panel (hidden unless clients tab is active) -->
    <div id="clients-editor" style="display:none"></div>

    <div id="rule-editor" style="display:none"></div>

    <div id="os-dialog-backdrop" role="presentation" aria-hidden="true">
      <div class="os-dialog" role="dialog" aria-modal="true" aria-labelledby="os-dialog-title">
        <h2 class="os-dialog-title" id="os-dialog-title"></h2>
        <div class="os-dialog-body" id="os-dialog-body"></div>
        <div class="os-dialog-actions" id="os-dialog-actions"></div>
      </div>
    </div>

    <AdminFooterNav />

    <script is:inline type="module" src="/admin/os-map-loader.js?v=20250629e"></script>
    <script is:inline type="module" src="/admin/push-client.js?v=20250629e"></script>
  </body>
</html>
