        min-width: 0;
        font-size: 0.68rem;
        color: var(--muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .wk-client-picker { position: relative; margin-bottom: 0.5rem; }
      .wk-client-selected {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.55rem;
        border: 1px solid var(--panel-border);
        border-radius: 7px;
        background: var(--card);
      }
      .wk-client-selected span { flex: 1; font-size: max(16px, 0.875rem); }
      .wk-client-selected button {
        font-size: 0.72rem;
        padding: 0.2rem 0.45rem;
      }
      .wk-client-profile-link {
        width: 100%;
        box-sizing: border-box;
