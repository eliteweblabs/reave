        gap: 0.75rem 1rem;
      }
      @media (min-width: 980px) {
        #work-editor .re-form-scroll.wk-form-scroll .de-fields {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }
      #work-editor .re-form-scroll.wk-form-scroll .de-fields > .wk-client-picker {
