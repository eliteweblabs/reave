---
/**
 * /admin/contacts — visualization of the master contact database (contact-api),
 * with a Crater sync tab that surfaces customers missing from the master DB.
 *
 * SENSITIVE: lists every client (PII + links through to portal credentials), so
 * it is gated behind DASHBOARD_KEY. Provide the key once via ?key=… (stored in
 * an httpOnly cookie) or it stays locked. noindex; never prerendered.
 */
import Favicon from "../../components/Favicon.astro";

export const prerender = false;

import { listContacts, clientPortalUrl, type ContactRecord } from '../../lib/contactApi';
import {
  buildBillingCountsByCustomerName,
  craterBillingHintForContact,
  craterListEstimates,
  craterListInvoices,
  craterSearchCustomers,
  isCraterConfigured,
  matchCraterCustomer,
  type CraterBillingHint,
  type CraterCustomer,
} from '../../lib/craterClient';
import { serverEnv } from '../../lib/serverEnv';
import Header from '../../components/Header.astro';

const COOKIE = 'admin_contacts_key';
const expectedKey = serverEnv('DASHBOARD_KEY')?.trim() || '';

const queryKey = Astro.url.searchParams.get('key')?.trim() || '';
const cookieKey = Astro.cookies.get(COOKIE)?.value || '';

let authorized = false;
let lockReason = '';

if (!expectedKey) {
  lockReason = 'DASHBOARD_KEY is not set on the server. Set it to enable this dashboard.';
} else if (queryKey && queryKey === expectedKey) {
  Astro.cookies.set(COOKIE, queryKey, {
    httpOnly: true,
    sameSite: 'lax',
    secure: Astro.url.protocol === 'https:',
    path: '/admin',
    maxAge: 60 * 60 * 24 * 30,
  });
  authorized = true;
} else if (cookieKey && cookieKey === expectedKey) {
  authorized = true;
} else if (queryKey) {
  lockReason = 'Incorrect key.';
}

// ── Master DB ──────────────────────────────────────────────────────────────────
let contacts: ContactRecord[] = [];
let total = 0;
let loadError = '';

if (authorized) {
  const res = await listContacts({ limit: 200 });
  if (res.ok) {
    contacts = res.data.contacts;
    total = res.data.total;
  } else {
    loadError = res.error;
  }
}

// ── Crater sync ────────────────────────────────────────────────────────────────
let craterCustomers: CraterCustomer[] = [];
let craterError = '';
const craterConfigured = isCraterConfigured();
const craterHints = new Map<string, CraterBillingHint>();

if (authorized && craterConfigured) {
  const [custRes, invRes, estRes] = await Promise.all([
    craterSearchCustomers(''),
    craterListInvoices(),
    craterListEstimates(),
  ]);
  if (custRes.ok) {
    craterCustomers = custRes.data.customers ?? [];
  } else {
    craterError = custRes.error;
  }
  if (!craterError && !invRes.ok) {
    craterError = invRes.error;
  }
  if (!craterError && !estRes.ok) {
    craterError = estRes.error;
  }

  const billingCounts = invRes.ok && estRes.ok
    ? buildBillingCountsByCustomerName(invRes.data.invoices ?? [], estRes.data.estimates ?? [])
    : invRes.ok
      ? buildBillingCountsByCustomerName(invRes.data.invoices ?? [], [])
      : new Map();

  for (const c of contacts) {
    craterHints.set(c.uid, craterBillingHintForContact(c, craterCustomers, billingCounts));
  }
}

type SyncStatus = 'matched' | 'unmatched';
type CraterSyncEntry = { customer: CraterCustomer; status: SyncStatus; matchedUid?: string };

const syncEntries: CraterSyncEntry[] = craterCustomers.map((c) => {
  const email = (c.email ?? '').trim().toLowerCase();
  const cName = c.name.trim().toLowerCase();
  const cnName = (c.contact_name ?? '').trim().toLowerCase();

  let matchedUid: string | undefined;
  if (email) {
    const m = contacts.find((ct) => (ct.email ?? '').trim().toLowerCase() === email);
    if (m) matchedUid = m.uid;
  }
  if (!matchedUid) {
    const m2 = contacts.find((ct) => ct.name.trim().toLowerCase() === cName);
    if (m2) matchedUid = m2.uid;
  }
  if (!matchedUid && cnName) {
    const m3 = contacts.find((ct) => ct.name.trim().toLowerCase() === cnName);
    if (m3) matchedUid = m3.uid;
  }

  return {
    customer: c,
    status: matchedUid ? 'matched' : 'unmatched',
    matchedUid,
  } satisfies CraterSyncEntry;
});

const syncStats = {
  total: syncEntries.length,
  matched: syncEntries.filter((e) => e.status === 'matched').length,
  unmatched: syncEntries.filter((e) => e.status === 'unmatched').length,
};

// Contacts in master DB that have no Crater customer (orphaned / deleted from Crater)
const orphanedContacts = contacts.filter((c) => {
  if (c.archived) return false;
  return !matchCraterCustomer(c, craterCustomers);
});

// ── helpers ────────────────────────────────────────────────────────────────────
if (!authorized) Astro.response.status = 401;

const stats = {
  shown: contacts.length,
  withEmail: contacts.filter((c) => c.email?.trim()).length,
  withPhone: contacts.filter((c) => c.phone?.trim()).length,
  withCompany: contacts.filter((c) => c.company?.trim()).length,
};
const fmtDate = (s?: string | null) => {
  if (!s) return '';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? '' : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
const fmtMoney = (n: number) =>
  n === 0 ? '' : `$${n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    {authorized && <meta name="dashboard-key" content={expectedKey} />}
    <title>Master contacts</title>
    <Favicon />
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: #0a0d14; color: #e9eef6; min-height: 100vh;
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      }
      button,
      select {
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
      }
      input,
      textarea {
        -webkit-user-select: text;
        user-select: text;
      }
      a { color: #93c5fd; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: calc(64px + 24px) 20px 80px; }
      .head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
      h1 { font-size: 22px; margin: 0; }
      .sub { color: #8b97a8; font-size: 13px; }

      .gate { max-width: 380px; margin: 14vh auto 0; text-align: center; }
      .gate h1 { margin-bottom: 8px; }
      .gate p { color: #8b97a8; font-size: 14px; line-height: 1.6; }
      .gate form { margin-top: 18px; display: flex; gap: 8px; }
      .gate input {
        flex: 1; padding: 12px 14px; border-radius: 10px; border: 1px solid #283142;
        background: #11151d; color: #fff; font: inherit;
      }
      .gate button {
        padding: 12px 18px; border-radius: 10px; border: none; cursor: pointer;
        background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff; font: inherit; font-weight: 600;
      }
      .err { color: #fca5a5; font-size: 13px; margin-top: 10px; }

      /* ── tabs ───────────────────────────────────────────────────────────── */
      .tabs { display: flex; gap: 4px; margin: 20px 0 0; border-bottom: 1px solid #232c3a; }
      .tab-btn {
        padding: 9px 18px; border: none; background: none; color: #8b97a8;
        font: inherit; font-size: 14px; cursor: pointer; border-bottom: 2px solid transparent;
        margin-bottom: -1px; border-radius: 6px 6px 0 0; transition: color 0.15s;
      }
      .tab-btn:hover { color: #e9eef6; }
      .tab-btn.active { color: #e9eef6; border-bottom-color: #6366f1; font-weight: 600; }
      .tab-badge {
        display: inline-block; background: #1e2535; color: #8b97a8;
        font-size: 11px; padding: 1px 6px; border-radius: 10px; margin-left: 5px;
      }
      .tab-badge.warn { background: #2a1f0e; color: #f59e0b; }
      .tab-panel { display: none; padding-top: 20px; }
      .tab-panel.active { display: block; }

      /* ── stats ──────────────────────────────────────────────────────────── */
      .stats { display: flex; flex-wrap: wrap; gap: 10px; margin: 0 0 18px; }
      .stat {
        background: #11151d; border: 1px solid #232c3a; border-radius: 12px;
        padding: 10px 16px; min-width: 110px;
      }
      .stat .n { font-size: 22px; font-weight: 700; }
      .stat .l { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #8b97a8; }
      .stat.warn { border-color: #3d2800; }
      .stat.warn .n { color: #f59e0b; }

      .search {
        width: 100%; padding: 12px 14px; margin-bottom: 16px; border-radius: 10px;
        border: 1px solid #283142; background: #11151d; color: #fff; font: inherit;
      }

      /* ── contact cards ──────────────────────────────────────────────────── */
      .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      .card {
        background: #11151d; border: 1px solid #232c3a; border-radius: 14px; padding: 14px 16px;
        display: flex; flex-direction: column; gap: 6px; min-width: 0;
      }
      .card .name {
        font-size: 16px; font-weight: 600;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .card .company {
        font-size: 13px; color: #8b97a8;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .card .meta {
        font-size: 13px; color: #c7d0dc;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .card .meta a { text-decoration: none; }
      @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
      .card .when { font-size: 11px; color: #6e7681; margin-top: 2px; }
      .crater-hint {
        font-size: 12px;
        font-weight: 600;
        line-height: 1.35;
        margin-top: 2px;
      }
      .crater-hint--none { color: #6e7681; }
      .crater-hint--neutral { color: #93c5fd; }
      .crater-hint--paid { color: #4ade80; }
      .crater-hint--due { color: #fbbf24; }
      .card .links { display: flex; gap: 8px; flex-wrap: wrap; }
      .card .links a {
        font-size: 12px; text-decoration: none; padding: 5px 10px; border-radius: 8px;
        border: 1px solid #283142; background: #161b25; color: #cbd5e1;
      }
      .card .links a:hover { border-color: #4b5563; color: #fff; }
      .empty-note { color: #8b97a8; margin-top: 20px; }
      .no-match { color: #8b97a8; display: none; margin-top: 20px; }

      /* ── sync cards ─────────────────────────────────────────────────────── */
      .sync-filter {
        display: flex; gap: 8px; align-items: center; margin-bottom: 14px; flex-wrap: wrap;
      }
      .sync-filter label { font-size: 13px; color: #8b97a8; white-space: nowrap; }
      .sync-filter select {
        padding: 7px 12px; border-radius: 8px; border: 1px solid #283142;
        background: #11151d; color: #e9eef6; font: inherit; font-size: 13px; cursor: pointer;
      }
      .sync-filter .search { margin: 0; flex: 1; min-width: 160px; }
      .card.synced { border-color: #1a3a2a; }
      .card.unsynced { border-color: #3d2800; }
      .sync-badge {
        display: inline-flex; align-items: center; gap: 4px; flex-shrink: 0;
        font-size: 11px; padding: 2px 8px; border-radius: 10px; width: fit-content;
      }
      .sync-badge.ok { background: #0f2c1e; color: #4ade80; }
      .sync-badge.missing { background: #2a1000; color: #fb923c; }
      .card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
      .card-header .name { flex: 1; min-width: 0; }
      .btn-import {
        margin-top: 4px; padding: 7px 14px; border-radius: 9px; border: none; cursor: pointer;
        background: linear-gradient(135deg, #f59e0b, #ea580c); color: #0a0d14;
        font: inherit; font-size: 13px; font-weight: 700; align-self: flex-start;
        transition: opacity 0.15s;
      }
      .btn-import:hover { opacity: 0.88; }
      .btn-import:disabled { opacity: 0.45; cursor: default; }
      .btn-import.done { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; }
      .btn-delete {
        margin-top: 4px; padding: 7px 14px; border-radius: 9px; border: 1px solid #4b1c1c; cursor: pointer;
        background: #1c0a0a; color: #f87171;
        font: inherit; font-size: 13px; font-weight: 600; align-self: flex-start;
        transition: background 0.15s, border-color 0.15s;
      }
      .btn-delete:hover { background: #2d1010; border-color: #7f1d1d; }
      .btn-delete:disabled { opacity: 0.45; cursor: default; }
      .import-msg { font-size: 12px; margin-top: 4px; }
      .import-msg.ok { color: #4ade80; }
      .import-msg.err { color: #fca5a5; }

      /* ── add button + modal ─────────────────────────────────────────────── */
      .btn-add {
        padding: 9px 16px; border-radius: 10px; border: none; cursor: pointer;
        background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff;
        font: inherit; font-size: 14px; font-weight: 600;
      }
      .btn-add:hover { opacity: 0.88; }

      .modal-backdrop {
        display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.65);
        z-index: 100; align-items: center; justify-content: center;
      }
      .modal-backdrop.open { display: flex; }
      .modal {
        background: #11151d; border: 1px solid #283142; border-radius: 16px;
        padding: 28px 28px 24px; width: 100%; max-width: 420px; margin: 0 16px;
      }
      .modal h2 { margin: 0 0 18px; font-size: 17px; }
      .modal label { display: block; font-size: 13px; color: #8b97a8; margin-bottom: 4px; margin-top: 12px; }
      .modal label:first-of-type { margin-top: 0; }
      .modal input, .modal textarea {
        width: 100%; padding: 10px 12px; border-radius: 9px; border: 1px solid #283142;
        background: #0a0d14; color: #fff; font: inherit; font-size: 14px;
      }
      .modal textarea { resize: vertical; min-height: 64px; }
      .modal-actions { display: flex; gap: 10px; margin-top: 18px; justify-content: flex-end; }
      .btn-cancel {
        padding: 9px 16px; border-radius: 10px; border: 1px solid #283142;
        background: none; color: #8b97a8; font: inherit; font-size: 14px; cursor: pointer;
      }
      .btn-save {
        padding: 9px 18px; border-radius: 10px; border: none; cursor: pointer;
        background: linear-gradient(135deg, #6366f1, #a855f7); color: #fff;
        font: inherit; font-size: 14px; font-weight: 600;
      }
      .btn-save:disabled { opacity: 0.5; cursor: default; }
      .modal-err { color: #fca5a5; font-size: 13px; margin-top: 10px; display: none; }
      .modal-ok { color: #86efac; font-size: 13px; margin-top: 10px; display: none; }

      /* confirm / alert dialog (replaces system confirm/alert) */
      .confirm-backdrop {
        display: none; position: fixed; inset: 0; z-index: 200;
        background: rgba(0,0,0,0.72); backdrop-filter: blur(6px);
        align-items: center; justify-content: center; padding: 16px;
      }
      .confirm-backdrop.open { display: flex; }
      .confirm-dialog {
        width: 100%; max-width: 400px; background: #11151d;
        border: 1px solid #283142; border-radius: 14px; overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.55);
      }
      .confirm-dialog h2 {
        margin: 0; padding: 1rem 1.15rem 0.5rem; font-size: 1rem; font-weight: 600;
      }
      .confirm-body {
        padding: 0 1.15rem 1rem; font-size: 0.84rem; line-height: 1.55; color: #8b97a8;
      }
      .confirm-body p { margin: 0 0 0.65rem; }
      .confirm-body p:last-child { margin-bottom: 0; }
      .confirm-warn { color: #fbbf24; }
      .confirm-note { color: #93c5fd; font-size: 0.8rem; }
      .confirm-actions {
        display: flex; gap: 0.5rem; justify-content: flex-end;
        padding: 0.75rem 1rem 1rem; border-top: 1px solid #283142;
        background: rgba(0,0,0,0.15);
      }
      .btn-confirm-danger {
        padding: 9px 16px; border-radius: 10px; border: 1px solid #7f1d1d;
        background: #3f1515; color: #fca5a5; font: inherit; font-size: 14px;
        font-weight: 600; cursor: pointer;
      }
      .btn-confirm-danger:hover { background: #521818; }
    </style>
  </head>
  <body>
    <Header />
    {
      !authorized ? (
        <main class="wrap">
          <div class="gate">
            <h1>Master contacts</h1>
            <p>{lockReason || 'Enter the dashboard key to continue.'}</p>
            {expectedKey && (
              <form method="get" action="/admin/contacts">
                <input type="password" name="key" placeholder="Dashboard key" autocomplete="off" autofocus />
                <button type="submit">Unlock</button>
              </form>
            )}
            {lockReason === 'Incorrect key.' && <div class="err">That key didn't work.</div>}
          </div>
        </main>
      ) : (
        <main class="wrap">
          <div class="head">
            <div>
              <h1>Master contacts</h1>
              <div class="sub">contact-api · contact-postgres</div>
            </div>
            <div style="display:flex;gap:10px;align-items:center;">
              <button class="btn-add" id="openAdd">+ Add contact</button>
              <a href="/admin/">← OS map</a>
            </div>
          </div>

          {/* ── tab bar ───────────────────────────────────────────────────── */}
          <div class="tabs">
            <button class="tab-btn active" data-tab="master">
              Master DB
              <span class="tab-badge">{total}</span>
            </button>
            {craterConfigured && (
              <button class="tab-btn" data-tab="sync">
                Crater sync
                {syncStats.unmatched > 0
                  ? <span class="tab-badge warn">{syncStats.unmatched} missing</span>
                  : <span class="tab-badge">{syncStats.total}</span>
                }
              </button>
            )}
          </div>

          {/* ── Master DB tab ─────────────────────────────────────────────── */}
          <div class="tab-panel active" id="panel-master">
            {loadError ? (
              <p class="empty-note">Couldn't load contacts: {loadError}</p>
            ) : (
              <>
                <div class="stats">
                  <div class="stat"><div class="n">{total}</div><div class="l">Total</div></div>
                  <div class="stat"><div class="n">{stats.withCompany}</div><div class="l">Company</div></div>
                  <div class="stat"><div class="n">{stats.withEmail}</div><div class="l">Email</div></div>
                  <div class="stat"><div class="n">{stats.withPhone}</div><div class="l">Phone</div></div>
                  {total > stats.shown && (
                    <div class="stat"><div class="n">{stats.shown}</div><div class="l">Shown</div></div>
                  )}
                </div>

                <input id="search" class="search" type="search" placeholder="Search name, company, email, phone…" autocomplete="off" />

                <div class="grid" id="grid">
                  {contacts.map((c) => {
                    const portal = clientPortalUrl(c.uid);
                    const searchVal = [c.name, c.company, c.email, c.phone].filter(Boolean).join(' ').toLowerCase();
                    const craterHint = craterHints.get(c.uid);
                    return (
                      <div class="card" data-search={searchVal}>
                        <div class="name">{c.name}</div>
                        {c.company && <div class="company">{c.company}</div>}
                        {craterConfigured && craterHint && (
                          <div class={`crater-hint crater-hint--${craterHint.tone}`}>
                            🧾 {craterHint.label}
                          </div>
                        )}
                        {c.email && <div class="meta"><a href={`mailto:${c.email}`}>{c.email}</a></div>}
                        {c.phone && <div class="meta"><a href={`tel:${c.phone.replace(/[^\d+]/g, '')}`}>{c.phone}</a></div>}
                        {c.updatedAt && <div class="when">Updated {fmtDate(c.updatedAt)}</div>}
                        <div class="links">
                          <a href={portal} target="_blank" rel="noopener noreferrer">Portal</a>
                          <a href={`/c/${encodeURIComponent(c.uid)}.vcf`}>vCard</a>
                          <a href={`/c/${encodeURIComponent(c.uid)}/note.txt`} target="_blank" rel="noopener noreferrer">Notes</a>
                        </div>
                      </div>
                    );
                  })}
                </div>
                <p class="no-match" id="noMatch">No contacts match your search.</p>
                {contacts.length === 0 && <p class="empty-note">No contacts yet.</p>}
              </>
            )}
          </div>

          {/* ── Crater Sync tab ───────────────────────────────────────────── */}
          {craterConfigured && (
            <div class="tab-panel" id="panel-sync">
              {craterError ? (
                <p class="empty-note" style="color:#fca5a5">Couldn't load Crater customers: {craterError}</p>
              ) : (
                <>
                  <div class="stats">
                    <div class="stat">
                      <div class="n">{syncStats.total}</div>
                      <div class="l">Crater customers</div>
                    </div>
                    <div class="stat">
                      <div class="n" style="color:#4ade80">{syncStats.matched}</div>
                      <div class="l">Matched</div>
                    </div>
                    <div class={`stat${syncStats.unmatched > 0 ? ' warn' : ''}`}>
                      <div class="n">{syncStats.unmatched}</div>
                      <div class="l">Missing from master</div>
                    </div>
                    <div class={`stat${orphanedContacts.length > 0 ? ' warn' : ''}`}>
                      <div class="n">{orphanedContacts.length}</div>
                      <div class="l">Not in Crater</div>
                    </div>
                  </div>

                  <div class="sync-filter">
                    <label for="syncFilter">Show:</label>
                    <select id="syncFilter">
                      <option value="unmatched" selected={syncStats.unmatched > 0 && orphanedContacts.length === 0}>
                        Missing from master DB ({syncStats.unmatched})
                      </option>
                      <option value="orphaned" selected={orphanedContacts.length > 0}>
                        Not in Crater — master DB only ({orphanedContacts.length})
                      </option>
                      <option value="all">All Crater customers ({syncStats.total})</option>
                      <option value="matched">Matched ({syncStats.matched})</option>
                    </select>
                    <input id="syncSearch" class="search" type="search" placeholder="Filter by name or email…" autocomplete="off" />
                  </div>

                  {/* Crater customers grid (unmatched / matched / all) */}
                  <div class="grid" id="syncGrid">
                    {syncEntries.map((e) => {
                      const c = e.customer;
                      const displayName = c.contact_name || c.name;
                      const isCompany = Boolean(c.contact_name);
                      const sv = [c.name, c.contact_name, c.email, c.phone].filter(Boolean).join(' ').toLowerCase();
                      const portalUrl = e.matchedUid ? clientPortalUrl(e.matchedUid) : null;
                      const due = c.invoice_summary?.total_due ?? 0;
                      return (
                        <div
                          class={`card ${e.status === 'matched' ? 'synced' : 'unsynced'}`}
                          data-view="crater"
                          data-sync={e.status}
                          data-search={sv}
                        >
                          <div class="card-header">
                            <div class="name">{displayName}</div>
                            {e.status === 'matched'
                              ? <span class="sync-badge ok">✓ synced</span>
                              : <span class="sync-badge missing">⚠ missing</span>
                            }
                          </div>
                          {isCompany && <div class="company">{c.name}</div>}
                          {c.email && <div class="meta"><a href={`mailto:${c.email}`}>{c.email}</a></div>}
                          {c.phone && <div class="meta"><a href={`tel:${c.phone.replace(/[^\d+]/g,'')}`}>{c.phone}</a></div>}
                          {c.invoice_summary && (
                            <div class="when">
                              {c.invoice_summary.count} invoice{c.invoice_summary.count !== 1 ? 's' : ''}
                              {due > 0 && ` · ${fmtMoney(due)} due`}
                            </div>
                          )}
                          {c.estimate_summary && c.estimate_summary.count > 0 && (
                            <div class="when">
                              {c.estimate_summary.open > 0 && `${c.estimate_summary.open} estimate${c.estimate_summary.open !== 1 ? 's' : ''} open`}
                              {c.estimate_summary.open > 0 && c.estimate_summary.accepted > 0 && ' · '}
                              {c.estimate_summary.accepted > 0 && `${c.estimate_summary.accepted} accepted`}
                              {c.estimate_summary.open === 0 && c.estimate_summary.accepted === 0 &&
                                `${c.estimate_summary.count} estimate${c.estimate_summary.count !== 1 ? 's' : ''}`}
                            </div>
                          )}
                          {portalUrl && (
                            <div class="links">
                              <a href={portalUrl} target="_blank" rel="noopener noreferrer">Portal</a>
                            </div>
                          )}
                          {e.status === 'unmatched' && (
                            <>
                              <button
                                class="btn-import"
                                data-name={displayName}
                                data-company={isCompany ? c.name : ''}
                                data-email={c.email ?? ''}
                                data-phone={c.phone ?? ''}
                                data-notes={`Imported from Crater customer #${c.id}`}
                              >
                                Import to master DB
                              </button>
                              <div class="import-msg" style="display:none"></div>
                            </>
                          )}
                        </div>
                      );
                    })}
                  </div>

                  {/* Master-DB-only (orphaned) grid */}
                  <div class="grid" id="orphanGrid">
                    {orphanedContacts.map((c) => {
                      const portal = clientPortalUrl(c.uid);
                      const sv = [c.name, c.company, c.email, c.phone].filter(Boolean).join(' ').toLowerCase();
                      return (
                        <div class="card unsynced" data-view="orphaned" data-search={sv}>
                          <div class="card-header">
                            <div class="name">{c.name}</div>
                            <span class="sync-badge missing">not in Crater</span>
                          </div>
                          {c.company && <div class="company">{c.company}</div>}
                          {c.email && <div class="meta"><a href={`mailto:${c.email}`}>{c.email}</a></div>}
                          {c.phone && <div class="meta"><a href={`tel:${c.phone.replace(/[^\d+]/g,'')}`}>{c.phone}</a></div>}
                          {c.updatedAt && <div class="when">Added {fmtDate(c.updatedAt)}</div>}
                          <div class="links">
                            <a href={portal} target="_blank" rel="noopener noreferrer">Portal</a>
                          </div>
                          <button class="btn-delete" data-uid={c.uid} data-name={c.name}>
                            Delete from master DB
                          </button>
                          <div class="import-msg" style="display:none"></div>
                        </div>
                      );
                    })}
                  </div>

                  {syncEntries.length === 0 && orphanedContacts.length === 0 && (
                    <p class="empty-note">No contacts or Crater customers found.</p>
                  )}
                  <p class="no-match" id="syncNoMatch">No contacts match your filter.</p>
                </>
              )}
            </div>
          )}

          {/* ── Add-contact modal ─────────────────────────────────────────── */}
          <div class="modal-backdrop" id="modalBackdrop">
            <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
              <h2 id="modalTitle">Add contact</h2>
              <label for="f-name">Name *</label>
              <input id="f-name" type="text" placeholder="Jason Kahan" autocomplete="off" />
              <label for="f-company">Company</label>
              <input id="f-company" type="text" placeholder="CAPCO Design Group" autocomplete="off" />
              <label for="f-email">Email</label>
              <input id="f-email" type="email" placeholder="jason@example.com" autocomplete="off" />
              <label for="f-phone">Phone</label>
              <input id="f-phone" type="tel" placeholder="+1 (617) 000-0000" autocomplete="off" />
              <label for="f-notes">Notes</label>
              <textarea id="f-notes" placeholder="Internal notes (never shown to client)"></textarea>
              <div class="modal-err" id="modalErr"></div>
              <div class="modal-ok" id="modalOk"></div>
              <div class="modal-actions">
                <button class="btn-cancel" id="closeModal">Cancel</button>
                <button class="btn-save" id="saveContact">Save</button>
              </div>
            </div>
          </div>

          <div class="confirm-backdrop" id="confirmBackdrop" aria-hidden="true">
            <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="confirmTitle">
              <h2 id="confirmTitle"></h2>
              <div class="confirm-body" id="confirmBody"></div>
              <div class="confirm-actions" id="confirmActions"></div>
            </div>
          </div>
        </main>
      )
    }

    <script>
      // ── tab switching ──────────────────────────────────────────────────────
      const tabBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab-btn'));
      const tabPanels = Array.from(document.querySelectorAll<HTMLElement>('.tab-panel'));
      tabBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.tab;
          tabBtns.forEach((b) => b.classList.toggle('active', b === btn));
          tabPanels.forEach((p) => p.classList.toggle('active', p.id === `panel-${target}`));
        });
      });

      // ── master DB search filter ────────────────────────────────────────────
      const search = document.getElementById('search') as HTMLInputElement | null;
      const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid .card'));
      const noMatch = document.getElementById('noMatch');
      search?.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        let visible = 0;
        for (const card of cards) {
          const hay = card.getAttribute('data-search') || '';
          const show = !q || hay.includes(q);
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (noMatch) noMatch.style.display = visible === 0 && cards.length > 0 ? 'block' : 'none';
      });

      // ── Crater sync filter + search ────────────────────────────────────────
      const syncFilter = document.getElementById('syncFilter') as HTMLSelectElement | null;
      const syncSearch = document.getElementById('syncSearch') as HTMLInputElement | null;
      const craterCards = Array.from(document.querySelectorAll<HTMLElement>('#syncGrid .card'));
      const orphanCards = Array.from(document.querySelectorAll<HTMLElement>('#orphanGrid .card'));
      const syncNoMatch = document.getElementById('syncNoMatch');

      function applySyncFilter() {
        const filterVal = syncFilter?.value ?? 'orphaned';
        const q = syncSearch?.value.trim().toLowerCase() ?? '';
        let visible = 0;

        // Crater cards: shown for 'all', 'matched', 'unmatched'
        for (const card of craterCards) {
          const syncStatus = card.getAttribute('data-sync') || '';
          const hay = card.getAttribute('data-search') || '';
          const matchFilter = filterVal === 'all' || filterVal === syncStatus;
          const matchSearch = !q || hay.includes(q);
          const show = matchFilter && matchSearch;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }

        // Orphan cards: shown only for 'orphaned'
        for (const card of orphanCards) {
          const hay = card.getAttribute('data-search') || '';
          const matchSearch = !q || hay.includes(q);
          const show = filterVal === 'orphaned' && matchSearch;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        }

        const totalCards = craterCards.length + orphanCards.length;
        if (syncNoMatch) {
          syncNoMatch.style.display = visible === 0 && totalCards > 0 ? 'block' : 'none';
        }
      }

      syncFilter?.addEventListener('change', applySyncFilter);
      syncSearch?.addEventListener('input', applySyncFilter);
      applySyncFilter();

      // ── Import-to-master buttons ───────────────────────────────────────────
      const dashKey = (document.querySelector('meta[name="dashboard-key"]') as HTMLMetaElement | null)?.content || '';

      document.querySelectorAll<HTMLButtonElement>('.btn-import').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const card = btn.closest('.card') as HTMLElement | null;
          const msgEl = card?.querySelector<HTMLElement>('.import-msg');

          btn.disabled = true;
          if (msgEl) { msgEl.textContent = 'Importing…'; msgEl.className = 'import-msg'; msgEl.style.display = 'block'; }

          const payload = {
            name: btn.dataset.name || '',
            company: btn.dataset.company || undefined,
            email: btn.dataset.email || undefined,
            phone: btn.dataset.phone || undefined,
            notes: btn.dataset.notes || undefined,
          };

          try {
            const res = await fetch('/api/contacts', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'x-dashboard-key': dashKey },
              body: JSON.stringify(payload),
            });
            const data = await res.json() as { ok: boolean; error?: string; contact?: { name?: string } };
            if (data.ok) {
              btn.textContent = '✓ Imported';
              btn.classList.add('done');
              if (card) card.classList.replace('unsynced', 'synced');
              const badge = card?.querySelector('.sync-badge');
              if (badge) { badge.textContent = '✓ synced'; badge.className = 'sync-badge ok'; }
              if (msgEl) { msgEl.textContent = 'Added to master DB.'; msgEl.className = 'import-msg ok'; }
            } else {
              btn.disabled = false;
              if (msgEl) { msgEl.textContent = data.error || 'Import failed.'; msgEl.className = 'import-msg err'; }
            }
          } catch (e) {
            btn.disabled = false;
            if (msgEl) { msgEl.textContent = `Error: ${e instanceof Error ? e.message : String(e)}`; msgEl.className = 'import-msg err'; }
          }
        });
      });

      // ── Delete-from-master buttons ─────────────────────────────────────────
      const confirmBackdrop = document.getElementById('confirmBackdrop');
      const confirmTitle = document.getElementById('confirmTitle');
      const confirmBody = document.getElementById('confirmBody');
      const confirmActions = document.getElementById('confirmActions');

      function esc(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function appDialog(opts: {
        title: string;
        bodyHtml: string;
        confirmLabel?: string;
        cancelLabel?: string;
        danger?: boolean;
        showCancel?: boolean;
      }): Promise<boolean> {
        if (!confirmBackdrop || !confirmTitle || !confirmBody || !confirmActions) {
          return Promise.resolve(false);
        }
        return new Promise((resolve) => {
          let settled = false;
          const finish = (value: boolean) => {
            if (settled) return;
            settled = true;
            confirmBackdrop.classList.remove('open');
            confirmBackdrop.setAttribute('aria-hidden', 'true');
            document.removeEventListener('keydown', onKey);
            resolve(value);
          };
          const onKey = (ev: KeyboardEvent) => {
            if (ev.key === 'Escape' && opts.showCancel) finish(false);
          };
          confirmTitle.textContent = opts.title;
          confirmBody.innerHTML = opts.bodyHtml;
          confirmActions.innerHTML = '';
          const mkBtn = (label: string, cls: string, value: boolean) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = cls;
            btn.textContent = label;
            btn.addEventListener('click', () => finish(value));
            confirmActions.appendChild(btn);
            return btn;
          };
          if (opts.showCancel) {
            mkBtn(opts.cancelLabel || 'Cancel', 'btn-cancel', false);
          }
          const primary = mkBtn(
            opts.confirmLabel || 'OK',
            opts.danger ? 'btn-confirm-danger' : 'btn-save',
            true,
          );
          confirmBackdrop.classList.add('open');
          confirmBackdrop.setAttribute('aria-hidden', 'false');
          document.addEventListener('keydown', onKey);
          primary.focus();
        });
      }

      function appConfirm(opts: Parameters<typeof appDialog>[0]): Promise<boolean> {
        return appDialog({ ...opts, showCancel: true });
      }

      function appAlert(opts: Omit<Parameters<typeof appDialog>[0], 'showCancel'>): Promise<boolean> {
        return appDialog({ ...opts, showCancel: false, confirmLabel: opts.confirmLabel || 'OK' });
      }

      document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const uid = btn.dataset.uid || '';
          const name = btn.dataset.name || 'this contact';
          const card = btn.closest('.card') as HTMLElement | null;
          const msgEl = card?.querySelector<HTMLElement>('.import-msg');

          async function fetchDeletePreview(): Promise<Record<string, unknown>> {
            const res = await fetch(`/api/contacts/${encodeURIComponent(uid)}?preview=delete`, {
              headers: { 'x-dashboard-key': dashKey },
            });
            const data = (await res.json()) as Record<string, unknown> & { ok?: boolean; error?: string };
            if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
            return data;
          }

          function buildDeleteConfirmHtml(preview: Record<string, unknown>): string {
            const parts: string[] = [];
            const projectCount = Number(preview.project_count ?? preview.job_count ?? 0);
            if (projectCount > 0) {
              const projects = (preview.projects as Array<{ title?: string }> | undefined) ?? [];
              const titles = projects.map((p) => esc(p.title || '')).filter(Boolean).slice(0, 8);
              const extra = projectCount > titles.length ? ` (+${projectCount - titles.length} more)` : '';
              parts.push(
                `<p><strong>${esc(name)}</strong> has ${projectCount} attached project${projectCount === 1 ? '' : 's'}${titles.length ? `: ${titles.join(', ')}${extra}` : '.'}</p>`,
              );
              parts.push('<p class="confirm-warn">Deleting this client will permanently delete all attached projects.</p>');
            } else {
              parts.push(`<p>Delete <strong>${esc(name)}</strong> from the master DB? This cannot be undone.</p>`);
            }
            const invoiceCount = Number(preview.invoice_count ?? 0);
            const estimateCount = Number(preview.estimate_count ?? 0);
            if (invoiceCount > 0) {
              parts.push(
                `<p class="confirm-note">${invoiceCount} linked Crater invoice${invoiceCount === 1 ? '' : 's'} — the client will be removed; invoice records stay in billing.</p>`,
              );
            }
            if (estimateCount > 0) {
              parts.push(
                `<p class="confirm-note">${estimateCount} linked Crater estimate${estimateCount === 1 ? '' : 's'} — the client will be removed; estimate records stay in billing.</p>`,
              );
            }
            return parts.join('');
          }

          async function performDelete(force: boolean) {
            const qs = force ? '?force=true' : '';
            return fetch(`/api/contacts/${encodeURIComponent(uid)}${qs}`, {
              method: 'DELETE',
              headers: { 'x-dashboard-key': dashKey },
            });
          }

          let preview: Record<string, unknown>;
          try {
            preview = await fetchDeletePreview();
          } catch (e) {
            await appAlert({
              title: 'Could not verify',
              bodyHtml: `<p>${esc(e instanceof Error ? e.message : String(e))}</p>`,
            });
            return;
          }

          const projectCount = Number(preview.project_count ?? preview.job_count ?? 0);
          const confirmed = await appConfirm({
            title: projectCount > 0 ? 'Delete client and projects?' : 'Delete client?',
            bodyHtml: buildDeleteConfirmHtml(preview),
            confirmLabel: 'Delete',
            cancelLabel: 'Cancel',
            danger: true,
          });
          if (!confirmed) return;

          btn.disabled = true;
          if (msgEl) { msgEl.textContent = 'Deleting…'; msgEl.className = 'import-msg'; msgEl.style.display = 'block'; }

          try {
            let res = await performDelete(true);
            let data = (await res.json()) as { ok: boolean; error?: string; warning?: string };

            if (res.status === 409) {
              const retry = await appConfirm({
                title: 'Confirm delete',
                bodyHtml: `<p>${esc(data.error || data.warning || 'This client has linked records.')}</p>`,
                confirmLabel: 'Delete anyway',
                cancelLabel: 'Cancel',
                danger: true,
              });
              if (!retry) {
                btn.disabled = false;
                if (msgEl) msgEl.style.display = 'none';
                return;
              }
              res = await performDelete(true);
              data = (await res.json()) as { ok: boolean; error?: string; warning?: string };
            }

            if (data.ok) {
              if (card) {
                card.style.opacity = '0.4';
                card.style.pointerEvents = 'none';
              }
              if (msgEl) { msgEl.textContent = 'Deleted.'; msgEl.className = 'import-msg ok'; }
              return;
            }

            btn.disabled = false;
            await appAlert({
              title: 'Delete failed',
              bodyHtml: `<p>${esc(data.error || data.warning || 'Delete failed.')}</p>`,
            });
            if (msgEl) msgEl.style.display = 'none';
          } catch (e) {
            btn.disabled = false;
            await appAlert({
              title: 'Delete failed',
              bodyHtml: `<p>${esc(e instanceof Error ? e.message : String(e))}</p>`,
            });
            if (msgEl) msgEl.style.display = 'none';
          }
        });
      });

      // ── add-contact modal ──────────────────────────────────────────────────
      const backdrop  = document.getElementById('modalBackdrop');
      const openBtn   = document.getElementById('openAdd');
      const closeBtn  = document.getElementById('closeModal');
      const saveBtn   = document.getElementById('saveContact') as HTMLButtonElement | null;
      const errEl     = document.getElementById('modalErr');
      const okEl      = document.getElementById('modalOk');

      function openModal() {
        backdrop?.classList.add('open');
        (document.getElementById('f-name') as HTMLInputElement)?.focus();
      }
      function closeModal() {
        backdrop?.classList.remove('open');
        if (errEl) { errEl.textContent = ''; errEl.style.display = 'none'; }
        if (okEl)  { okEl.textContent  = ''; okEl.style.display  = 'none'; }
      }

      openBtn?.addEventListener('click', openModal);
      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', (e) => { if (e.target === backdrop) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

      saveBtn?.addEventListener('click', async () => {
        const name    = (document.getElementById('f-name')    as HTMLInputElement).value.trim();
        const company = (document.getElementById('f-company') as HTMLInputElement).value.trim();
        const email   = (document.getElementById('f-email')   as HTMLInputElement).value.trim();
        const phone   = (document.getElementById('f-phone')   as HTMLInputElement).value.trim();
        const notes   = (document.getElementById('f-notes')   as HTMLTextAreaElement).value.trim();

        if (errEl) { errEl.style.display = 'none'; }
        if (okEl)  { okEl.style.display  = 'none'; }

        if (!name) {
          if (errEl) { errEl.textContent = 'Name is required.'; errEl.style.display = 'block'; }
          return;
        }

        if (saveBtn) saveBtn.disabled = true;

        const key = (document.querySelector('meta[name="dashboard-key"]') as HTMLMetaElement | null)?.content || '';

        try {
          const res = await fetch('/api/contacts', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'x-dashboard-key': key },
            body: JSON.stringify({ name, company: company || undefined, email: email || undefined, phone: phone || undefined, notes: notes || undefined }),
          });
          const data = await res.json() as { ok: boolean; error?: string; contact?: { uid?: string; name?: string } };
          if (data.ok && data.contact) {
            if (okEl) { okEl.textContent = `Added ${data.contact.name}.`; okEl.style.display = 'block'; }
            (['f-name','f-company','f-email','f-phone','f-notes'] as const).forEach(id => {
              const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | null;
              if (el) el.value = '';
            });
            setTimeout(() => { window.location.reload(); }, 900);
          } else {
            if (errEl) { errEl.textContent = data.error || 'Unknown error.'; errEl.style.display = 'block'; }
          }
        } catch (e) {
          if (errEl) { errEl.textContent = `Network error: ${e instanceof Error ? e.message : String(e)}`; errEl.style.display = 'block'; }
        } finally {
          if (saveBtn) saveBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
