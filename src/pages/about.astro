---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import ClientLogos from "../components/ClientLogos.astro";
import { getCompanyConfig } from "../lib/companyConfig";

const company = await getCompanyConfig(Astro.request);
---

<MarketingLayout
  title="Automation Expertise"
  description="Over 20 years designing logos & graphics to building websites, developing plugins & web apps. Rooted in real world experience."
  label="Who We Are"
  active="about"
  backgroundImage="/images/about-office.jpg"
>
  <section>
    <h2>Design + Code All of the Things</h2>
    <p>
      Over 20 years I went from designing logos &amp; graphics to building websites and — aided by
      extensive one-on-one training from Toptal — developing plugins &amp; web apps. I'm rooted in
      real world experience; I've done more debugging than exterminators.
    </p>
    <p>
      From rebuilding the spaghetti code of janky websites to working within the rigid design
      guidelines of Fortune 500 companies, I can design + code all of the things.
    </p>
    <p>
      For the last 10 years I worked full time in the New York art world. I'm currently available
      for freelance remote long or short term projects and onsite consulting &amp; development.
    </p>
    <p>
      My biggest asset is that I can <strong>save you time &amp; money</strong> by reviewing your
      operations and providing tools to automate tasks. If you have a small to medium size business,
      a startup idea, or a critical problem — don't hesitate to reach out.
    </p>
  </section>

  <section class="section--full-bleed">
    <ClientLogos />
  </section>

  <section>
    <h2>Testimonials</h2>
    <div class="card-grid">
      <article class="card">
        <blockquote>
          "I am extremely pleased with the result of our website. Incredibly professional and tuned
          in to the needs of his clients. High quality work with a quick turn. He delivered on every
          level."
        </blockquote>
        <p><strong>Torey Champagne</strong>, 13x Emmy Winner — ESPN / Comcast</p>
      </article>
      <article class="card">
        <blockquote>
          "His assistance was critical in the smooth launch of Worcester Polytechnic Institute's new
          website. His abilities with CSS, Photoshop and Dreamweaver were crucial in maintaining our
          strict timeline."
        </blockquote>
        <p><strong>L. Salsich</strong>, Web Project Manager — Worcester Polytechnic Institute</p>
      </article>
      <article class="card">
        <blockquote>
          "He did a fantastic job building our website from scratch. His creativity and cutting edge
          web designing skills were exactly what we needed to establish a current, fresh and modern
          presence."
        </blockquote>
        <p><strong>Kathy Singh</strong>, Director — Stem &amp; Regenerative Medicine Int.</p>
      </article>
      <article class="card">
        <blockquote>
          "Being able to trust one company for my marketing needs is a huge asset. Cost effective
          pricing, prompt service and quality work."
        </blockquote>
        <p><strong>Nick Chacharone</strong>, President — Aster Group</p>
      </article>
    </div>
  </section>
</MarketingLayout>
