# Server
PORT=8080
HOST=0.0.0.0
APP_NAME=fleet-api

# Postgres — vehicle registry + location history
DATABASE_URL=

# Optional API key — Reave sends X-API-Key when set
API_KEY=

# CORS — comma-separated origins, or * for any
ALLOWED_ORIGINS=*

# Drop stale vehicle positions after this many minutes (status → offline)
STALE_MINUTES=15

# Max location history rows retained per vehicle (older rows pruned on insert)
HISTORY_LIMIT=500
