# Server
PORT=8080
APP_NAME=materials-api

# Optional API key — consumers send X-API-Key when set
API_KEY=

# CORS — comma-separated origins, or * for any
ALLOWED_ORIGINS=*

# Default store ZIP for location-specific pricing (Home Depot, Lowe's, etc.)
DEFAULT_STORE_ZIP=02108

# Enable mock provider (always on unless explicitly disabled)
MOCK_PROVIDER=1

# ── Home Depot (Unwrangle) ───────────────────────────────────────────────────
# https://docs.unwrangle.com/homedepot-product-data-api/
# UNWRANGLE_API_KEY=

# ── Home Depot (BigBox API / Traject Data) ───────────────────────────────────
# https://trajectdata.com/ecommerce/big-box-api/
# BIGBOX_API_KEY=

# ── Home Depot (SerpApi) ─────────────────────────────────────────────────────
# https://serpapi.com/home-depot-product-api
# SERPAPI_API_KEY=

# Provider priority for homedepot lookups (comma-separated): unwrangle, bigbox, serpapi, mock
# HOMEDEPOT_PROVIDER_ORDER=unwrangle,bigbox,serpapi,mock

# In-memory cache TTL for product lookups (seconds). 0 = disabled.
# CACHE_TTL_SECONDS=300
